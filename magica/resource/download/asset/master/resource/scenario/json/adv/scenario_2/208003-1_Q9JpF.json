{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21503.jpg","bgm":"bgm03_story10","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":303600,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":303600}],"nameCenter":"Maria","textCenter":"If you're not going to be good children,@I'll have to get strict with you...!","turnChangeOut":"fadeOut"},{"chara":[{"id":303600,"motion":400}],"nameCenter":"Maria","textCenter":"[flashEffect:flashWhite2][bgEffect:shakeSmall][surround:3036A01]Ei―!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":303600}],"textClear":1},{"autoTurnLast":0.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800400,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800200,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800700,"motion":0,"pos":1}],"textClear":1},{"autoTurnLast":1.0,"bgEffect":"shakeLarge","chara":[{"effect":"shake","id":800400},{"effect":"shake","id":800200},{"effect":"shake","id":800700}],"flashEffect":"flashRed2","surround":"3036A02","textClear":1},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800400},{"effect":"fadeout","id":800200},{"effect":"fadeout","id":800700}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":304200,"motion":400,"pos":2},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":303600,"motion":200,"pos":0}],"nameRight":"Meguru","textBg":"shout","textRight":"And another conneeects―!"},{"chara":[{"id":304200}],"nameRight":"Meguru","textRight":"Her magic rope from outta nowhere wraps@the rushers up like a gentle mother,"},{"chara":[{"eyeClose":1,"id":304200}],"nameRight":"Meguru","textRight":"and like a mother, she'll never let 'em go!"},{"chara":[{"id":304200,"motion":100}],"nameRight":"Meguru","textRight":"Ahhh! And like teary-eyed children,"},{"chara":[{"id":304200}],"nameRight":"Meguru","textRight":"they all quiet down, down, down~!"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":303600,"motion":300,"mouthOpen":1}],"nameLeft":"Maria","textLeft":"Haa...haa..."},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":304200,"motion":400}],"nameRight":"Meguru","textRight":"Woah― You okay?!"},{"chara":[{"cheek":0,"id":303600,"mouthOpen":0,"pos":0}],"nameLeft":"Maria","textLeft":"It's just, using it repeatedly has tired me out a little..."},{"chara":[{"id":303600,"motion":100}],"nameLeft":"Maria","textLeft":"While you guys hold them down,@I'll quickly tie them all up...!"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":304200,"motion":200,"pos":2}],"nameRight":"Meguru","textRight":"Got it. Meguru's on the scene to give support!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":304200},{"effect":"fadeout","id":303600}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":303900,"motion":400,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":305600,"motion":0,"pos":0}],"nameRight":"Seira","textRight":"Ah― That's right, Rui!"},{"chara":[{"id":303900}],"nameRight":"Seira","textRight":"Let's find out what those tied-up@people had in their bags!"},{"chara":[{"id":305600,"motion":300}],"nameLeft":"Rui","textLeft":"R-right...! What's in their heavy bags..."},{"chara":[{"id":305600}],"nameLeft":"Rui","textLeft":"Forgive me for borrowing these...!"},{"nameNarration":"","narration":"*Rustle*","narrationBg":"","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":305600,"lipSynch":0,"motion":400}],"nameLeft":"Rui","narrationEffect":"out","textLeft":"[chara:305600:effect_emotion_surprise_0][se:7226_shock]...?!"},{"chara":[{"id":303900,"motion":200}],"nameRight":"Seira","textRight":"What's wrong?!"},{"bgm":"stop","chara":[{"id":305600}],"nameLeft":"Rui","textLeft":"Lots of...hammers, and wrenches, and dumbbells..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101300,"motion":300,"pos":2}],"nameRight":"Asuka","textRight":"Another's was full of concrete blocks,"},{"chara":[{"id":101300}],"nameRight":"Asuka","textRight":"and lots of soil for gardening."},{"bgm":"bgm03_story12","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":305600,"lipSynch":0}],"nameLeft":"Rui","textLeft":"...[wait:1.0][chara:305600:lipSynch_1]All very heavy things..."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":305600,"lipSynch":0,"motion":1}],"nameLeft":"Rui","textLeft":"(And hard enough to be used as weapons...!)","turnEffect":"thinking"},{"chara":[{"id":305600,"lipSynch":0}],"nameLeft":"Rui","textLeft":"(Blocks and soil aren't exactly weapons, though...)"},{"chara":[{"id":305600,"lipSynch":0}],"nameLeft":"Rui","textLeft":"(Even ignoring that for the moment...)"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":305600,"lipSynch":0}],"nameLeft":"Rui","textLeft":"(In any case, all of them have something@to use as a weapon...!)"},{"chara":[{"id":305600,"motion":300}],"nameLeft":"Rui","textLeft":"I knew it...that's right...","turnEffect":"stop"},{"chara":[{"cheek":1,"eyeClose":0,"id":305600,"pos":0}],"nameLeft":"Rui","textLeft":"I didn't want to believe it,@so I tried not to think about it, but..."},{"autoTurnLast":0.2,"chara":[{"id":305600,"pos":2}],"textClear":1},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp3.json","id":305600,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800700,"motion":0,"pos":0}],"nameRight":"Rui","textRight":"As I suspected, all of you crossed the river carrying@so many weapons,"},{"chara":[{"id":305600,"motion":200,"tear":1}],"nameRight":"Rui","textRight":"all for your plan to destroy Daito Ward!!"},{"chara":[{"id":305600,"motion":300}],"nameRight":"Rui","textBg":"shout","textRight":"HOW COULD YOU―!!"},{"chara":[{"id":305600}],"nameRight":"Rui","textRight":"Why, of all things, did THOSE feelings"},{"chara":[{"id":305600}],"nameRight":"Rui","textRight":"have to be amplified from a Witch's kiss!"},{"chara":[{"id":305600,"motion":100}],"nameRight":"Rui","textBg":"shout","textRight":"WHY DO YOU PEOPLE OF THE WEST@HATE THE EAST SO MUCH!!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":305600},{"effect":"fadeout","id":800700}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":303900,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"Seira","textCenter":"(Rui...)"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":303900}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800700,"motion":0,"pos":0},{"cheek":1,"face":"mtn_ex_020.exp3.json","id":305600,"motion":0,"pos":2,"tear":1}],"nameLeft":"","textLeft":"Must stop...this...destruction..."},{"bgm":"stop","chara":[{"id":800700}],"nameLeft":"","surround":"7003_wind","textLeft":"I didn't want...this...@Destruction...I...just..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":305600,"lipSynch":0,"motion":400,"tear":0}],"nameRight":"Rui","textRight":"[chara:305600:effect_emotion_surprise_0][se:7226_shock](I was wrong!)"},{"chara":[{"id":305600}],"nameRight":"Rui","textRight":"Huh? Whu? W-what do you mean..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":305600,"motion":1,"pos":2}],"nameRight":"Rui","textRight":"Then maybe...this one...?"},{"chara":[{"eyeClose":1,"id":305600,"lipSynch":0}],"nameRight":"Rui","textRight":"...[wait:1.0][chara:305600:eyeClose_0][chara:305600:cheek_0][chara:305600:face_mtn_ex_020.exp3.json][chara:305600:lipSynch_1]Grant me sight, Heaven's Gate Eye...!"},{"autoTurnLast":2.0,"flashEffect":"flashWhiteSlow2","textClear":1},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800700},{"effect":"fadeout","id":305600}],"textClear":1},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp3.json","id":300600,"motion":1,"pos":1}],"nameCenter":"Emiri","textCenter":"Eh― What was that...\"Grant me sight...\"@That's...kinda sick, isn't it...?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":300600}],"textClear":1},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":305600,"motion":1,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":305600,"lipSynch":0,"motion":400}],"nameRight":"Rui","textRight":"[chara:305600:effect_emotion_surprise_0][se:7226_shock]...?!"},{"bgm":"bgm03_story13","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":305600,"pos":2}],"nameRight":"Rui","surround":"stop","textRight":"Everyone who has been kissed have incredibly@dark shadows of death..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":303900,"motion":0,"pos":2}],"nameRight":"Seira","textRight":"Meaning..."},{"chara":[{"cheek":0,"effect":"shake","face":"mtn_ex_020.exp3.json","id":800700,"pos":0}],"nameLeft":"","textLeft":"Ugh...let me go..."},{"chara":[{"id":800700}],"nameLeft":"","textLeft":"I'm worthless... I must sacrifice myself..."},{"chara":[{"id":800700}],"nameLeft":"","textLeft":"To...the river..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800400,"motion":0,"pos":0}],"nameLeft":"","textLeft":"Me too..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800200,"motion":0,"pos":0}],"nameLeft":"","textLeft":"Me too..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":303900},{"effect":"fadeout","id":800200}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":305600,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":303300,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":303600,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"Everyone","textCenter":"...?!"},{"chara":[{"id":305600}],"nameLeft":"Rui","textLeft":"Everyone here must be..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":303300,"motion":300,"pos":2}],"nameRight":"Sayuki","textRight":"T-then...it can't be. All of their heavy bags were..."},{"chara":[{"id":303300}],"nameRight":"Sayuki","textRight":"To stop them from floating after jumping into the@river..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":303600},{"effect":"fadeout","id":305600},{"effect":"fadeout","id":303300}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800400,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800200,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":800700,"motion":0,"pos":1}],"nameCenter":"","textCenter":"We're all...laughingstocks..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800700,"pos":1}],"nameCenter":"","textCenter":"You guys don't care either."},{"chara":[{"id":800700}],"nameCenter":"","textCenter":"Come on, toss us and have a laugh..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800400},{"effect":"fadeout","id":800200}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"id":800700,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":101300,"motion":300,"pos":2}],"nameRight":"Asuka","textRight":"I-I cannot..."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":303600,"motion":0,"pos":2}],"nameRight":"Maria","textRight":"...Now that you've said that,@there is no way I'm letting you go."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":304200,"motion":300,"pos":2}],"nameRight":"Meguru","textRight":"Why would we laugh at you to begin with?"},{"chara":[{"id":800700}],"nameLeft":"","textLeft":"The people of the East will be happy..."},{"chara":[{"id":800700}],"nameLeft":"","textLeft":"This is a ritual...to accomplish that..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":300400,"motion":100,"pos":2}],"nameRight":"Sasara","textRight":"Why now of all times...?"},{"chara":[{"id":800700}],"nameLeft":"","textLeft":"I had a guilty conscience...@It was my fault for not changing..."},{"chara":[{"id":800700}],"nameLeft":"","textLeft":"I don't have courage like Yachiyo Nanami."},{"chara":[{"id":800700}],"nameLeft":"","textLeft":"This is the only way..."},{"chara":[{"id":300400,"motion":0}],"nameRight":"Sasara","textRight":"You mean..."},{"autoTurnLast":0.01,"bg":"black","item":[{"path":"resource/scenario/img/part2_chapter10/103102_yachiyo_appearance.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"nameNarration":"Sasara","narration":"\"After watching that broadcast,@you were going to commit suicide@from your sense of guilt for@the people of the East...?\"","narrationBg":"","narrationEffect":"in","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bg":"bg_adv_21503.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":303600,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":303600}],"nameRight":"Maria","textRight":"You felt partially guilty toward the East from@the beginning...","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":303900,"motion":0,"pos":2}],"nameRight":"Seira","textRight":"Anxiety from the unusual state Kamihama's been@put in..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":101300,"motion":300,"pos":2}],"nameRight":"Asuka","textRight":"Then Yachiyo's broadcast aired."},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":300400,"motion":300,"pos":2}],"nameRight":"Sasara","textRight":"And after all of that, a Witch's kiss@to kick them while they're down..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":303300,"motion":0,"pos":2}],"nameRight":"Sayuki","textRight":"As a result...you've become hopeless...despairing@over your own selves..."},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

rame.ExportJson","zOrder":"messageBack"}],"autoTurnLast":0.2,"bg":"bg_adv_46602.jpg","chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_031.exp3.json","id":200910,"motion":0,"pos":1}],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/calender_day17.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"textAvClear":1,"turnChangeIn":"fadeIn"},{"chara":[{"id":200910,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-8"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]So now...","textAvColor":"textMabayu","turnChangeOut":"fadeOut"},{"chara":[{"cheek":1,"face":"mtn_ex_060.exp3.json","id":200910,"motion":100,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-9"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]There's no other path left for me!!!"},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":200910}],"textAvClear":1},{"autoTurnLast":0.2,"chara":[{"cheek":1,"face":"mtn_ex_020.exp3.json","id":200900,"motion":0,"pos":1}]},{"autoTurnLast":1.5,"chara":[{"id":200900,"motion":400,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-10"}],"flashEffect":"flashWhite2","nameAvCenter":"Mabayu","surround":"2009A03","textAvCenter":"[fontSize:20]Aaaghhh!!!","textAvColor":"textMabayu"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":200900}],"textAvClear":1},{"autoTurnLast":0.2,"chara":[{"id":660200,"pos":1}]},{"autoTurnLast":0.8,"bgEffect":"shakeSmall","chara":[{"effect":"7003_damage02","id":660200}],"surround":"2009A05"},{"autoTurnLast":0.2,"bgEffect":"shakeLarge","flashEffect":"flashWhite1"},{"autoTurnLast":0.2,"flashEffect":"flashWhite1"},{"autoTurnLast":0.2,"flashEffect":"flashWhite1"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":660200}]},{"autoTurnFirst":0.8,"chara":[{"cheek":1,"face":"mtn_ex_060.exp3.json","id":200900,"motion":300,"pos":1,"voiceFull":"fullvoice/section_104214/vo_full_913117-080-11"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20][flashEffect:flashRed1][se:3001_chara_damage][chara:200900:effect_shake][bgEffect:shakeSmall]Gah!","textAvColor":"textMabayu"},{"bgEffect":"shakeLarge","chara":[{"effect":"shake","id":200900}],"flashEffect":"flashRed2","se":"3001_chara_damage"},{"autoTurnLast":0.01,"voiceFullStop":"fullvoice/section_104214/vo_full_913117-080-11"},{"autoTurnLast":0.5,"bg":"bg_adv_23013.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200902,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200201,"motion":0,"pos":2}],"deleteArmatureList":[1],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/calender_day17.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"textAvClear":1,"turnChangeIn":"fadeIn"},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-13"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Did you ask Miss Tomoe directly,@after I died?","turnChangeOut":"fadeOut"},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-14"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]About how she used to work together@with me..."},{"chara":[{"id":200902,"motion":300,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-15"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]And how I didn't have any recollection@of that time anymore..."},{"chara":[{"id":200201,"motion":200,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-16"}],"nameAvRight":"Homura","textAvColor":"textHomura","textAvRight":"[fontSize:20]...It was all a guess."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-17"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]I only recognized your entanglement@in my timeline..."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-18"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]...from what would be considered@the second loop from my side."},{"chara":[{"eyeClose":1,"id":200902,"motion":1,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-19"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]That's right...@The first loop is a complete blank for me."},{"chara":[{"eyeClose":0,"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-20"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]I knew something was off about that."},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-21"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]The current me only has memories@starting from Miss Akemi's second loop."},{"chara":[{"id":200201,"motion":300,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-22"}],"nameAvRight":"Homura","textAvColor":"textHomura","textAvRight":"[fontSize:20]If one were to make a rational deduction@from that fact..."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-23"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]You two discovered the truth about Witches@within the events of the first loop."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-24"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]That was an unbearable memory@for the both of you."},{"chara":[{"id":200201,"motion":0,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-25"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]Fortunately, Mami Tomoe's memories@will reset with each loop."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-26"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]But because you and I share@the same timeline via magic..."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-27"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]The memories of learning about the@true nature of Witches remain with you."},{"chara":[{"id":200902,"motion":100,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-28"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]So, the me from the first loop@made a cut in my memory..."},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-29"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]...editing out the memories of Miss Tomoe,@along with all memories of being a Magical Girl."},{"chara":[{"id":200902,"motion":0,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-30"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]The reason why you tried to keep@me and Miss Tomoe apart..."},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-31"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]...is because if I learned about all of this,@I'd need to erase my memories again."},{"chara":[{"id":200902,"motion":200,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-32"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Right?"},{"chara":[{"eyeClose":1,"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-33"}],"nameAvRight":"Homura","textAvColor":"textHomura","textAvRight":"[fontSize:20]That's correct."},{"chara":[{"eyeClose":0,"id":200201,"motion":101,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-34"},{"id":200902,"motion":0}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]If you were to discover your past actions..."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-35"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]You would blame yourself,@and your Soul Gem would cloud over."},{"chara":[{"eyeClose":1,"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-36"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]That's what I feared."},{"chara":[{"cheek":-1,"eyeClose":1,"id":200902,"motion":100,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-37"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Heh heh heh..."},{"chara":[{"eyeClose":1,"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-38"},{"eyeClose":0,"id":200201,"motion":0}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Looks like my suspicions were true."},{"chara":[{"eyeClose":0,"id":200902,"motion":0,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-39"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]I always thought I was just an observer."},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-40"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Hiding in the shadows, peering into the@future, and dishing out irresponsible advice..."},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-41"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]But...that was all just my selfish desire."},{"chara":[{"id":200902,"motion":200,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-42"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]I was already directly involved with@all of this, from a long time ago."},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-43"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Because I pushed for it, so many girls ended@up making contracts, and turned into Witches..."},{"chara":[{"cheek":-1,"face":"mtn_ex_031.exp3.json","id":200902,"motion":400,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-44"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]But...none of that can be changed!@Not anymore!"},{"chara":[{"id":200902,"motion":300,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-45"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]So, I need to become a Witch too..."},{"chara":[{"eyeClose":1,"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-46"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]...and be punished."},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":200201,"motion":200,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-47"}],"nameAvRight":"Homura","textAvColor":"textHomura","textAvRight":"[fontSize:20]No."},{"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":200902,"motion":0,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-48"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]What...?"},{"bgm":"bgm01_anime11","chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-49"}],"nameAvRight":"Homura","textAvColor":"textHomura","textAvRight":"[fontSize:20]There's no need for any punishment."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-50"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]If your Soul Gem is clouding over,@I'll collect Grief Seeds for you."},{"chara":[{"id":200201,"motion":0,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-51"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]You'll never become a Witch."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-52"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]I'll make sure of it."},{"chara":[{"id":200902,"motion":100,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-53"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]You can't, Miss Akemi."},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-54"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Those Grief Seeds are all for@Miss Kaname."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200201,"motion":101,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-55"}],"nameAvRight":"Homura","textAvColor":"textHomura","textAvRight":"[fontSize:20]Mabayu, listen."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-56"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]None of it is your fault."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-57"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]The real culprit is Kyubey,@who tricked you all..."},{"chara":[{"cheek":0,"face":"mtn_ex_031.exp3.json","id":200201,"motion":300,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-58"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]You and Mami Tomoe are both victims, too!"},{"chara":[{"eyeClose":1,"id":200902,"lipSynch":0,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-59"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]......"},{"chara":[{"eyeClose":1,"id":200201,"lipSynch":0,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-60"}],"nameAvRight":"Homura","textAvColor":"textHomura","textAvRight":"[fontSize:20]......"},{"chara":[{"cheek":-1,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":200902,"lipSynch":1,"motion":0,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-61"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":200201,"motion":0}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Miss Akemi."},{"chara":[{"eyeClose":0,"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-62"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]I'm really happy that you care about@someone like me."},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-63"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Without any memories of the time@I spent with Miss Tomoe..."},{"chara":[{"id":200902,"motion":200,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-64"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]You've been my one and only friend."},{"chara":[{"cheek":-1,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":200902,"motion":0,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-65"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]I'd really like to stay by your side..."},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-66"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]...if fate allows it."},{"chara":[{"id":200201,"lipSynch":1,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-67"}],"nameAvRight":"Homura","textAvColor":"textHomura","textAvRight":"[fontSize:20]Mabayu...?"},{"autoTurnLast":0.01,"textAvClear":1},{"autoTurnLast":0.5,"chara":[{"cheek":-1,"effect":"ef_adv_05","face":"mtn_ex_020.exp3.json","id":200900,"motion":0,"pos":0}],"se":"7205_magic_girl"},{"chara":[{"id":200900,"voiceFullAuto":"fullvoice/section_104214/vo_full_913117-080-68"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Excuse me."},{"autoTurnLast":0.2,"bg":"white","bgm":"stop","item":[{"anchor":"skip","path":"resource/scenario/img/scene0/calender_day17.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"},{"path":"resource/scenario/img/scene0/film13_homura_sad.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"charaFront"}],"textAvClear":1,"turnChangeIn":"fadeIn"},{"autoTurnLast":1.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bg":"white","item":[{"anchor":"skip","path":"resource/scenario/img/scene0/calender_day17.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"turnChangeIn":"whiteIn"},{"autoTurnLast":0.01,"turnChangeOut":"whiteOut","turnChangeOutTime":0.1},{"autoTurnLast":0.01,"surround":"8005_heartbeat"},{"armatureList":[{"animation":["action"],"armatureId":1,"filePath":"resource/image_native/effect/story/general/1509_prophecy_active.ExportJson","zOrder":"messageBack"}],"autoTurnLast":0.01},{"autoTurnLast":0.5,"bg":"bg_adv_23013.jpg","chara":[{"cheek":-1,"face":"mtn_ex_020.exp3.json","id":200900,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200201,"motion":0,"pos":2}],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/calender_day17.png","posX":-4,"posY":-50,"visible":"appear","zOrder":
{"story":{"group_1":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":305500,"motion":0,"pos":1,"voice":"vo_char_3055_00_01","textHome":"I want to protect this world@and all its people."}]},{"autoTurnFirst":3.2,"chara":[{"id":305500,"motion":100}]},{"autoTurnFirst":9.8,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":305500,"motion":1,"textHome":"...My public face is that of a perfect, rich@girl who understands the feelings of the@common people and says platitudes like that."}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305500,"motion":200,"textHome":"But in reality,@I'm a poor girl striving hard,@wearing a mask to climb up in society."}]},{"autoTurnFirst":4.3,"chara":[{"id":305500,"motion":0}]},{"autoTurnFirst":3.3,"chara":[{"id":305500,"motion":300,"textHome":"I had to do this much to protect@that overly kind family of mine."}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":305500}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":305500,"motion":300,"pos":1,"voice":"vo_char_3055_00_17","textHome":"Mystery shopping, factory work..."}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":305500,"textHome":"There aren't many jobs you can pick from@if you're concerned with being seen."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":305500,"motion":0,"textHome":"On that note, if there's one thing@I appreciate about my Magical Girl powers,"}]},{"autoTurnFirst":4.0,"chara":[{"id":305500,"motion":200,"textHome":"it's how it makes manual labor easy@for a high school girl like me."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":305500,"motion":1,"pos":1,"voice":"vo_char_3055_00_18","textHome":"I need to get at least@five more qualifications@before graduating high school."}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305500,"motion":300,"textHome":"And to do that, I need money, so I'll@have to take on more part-time jobs..."}]},{"autoTurnFirst":0.9,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":305500,"motion":0,"textHome":"...I should be able to do delivery@even with a granny bike."}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":5.0,"chara":[{"id":305500,"motion":100}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":305500,"motion":0,"pos":1,"voice":"vo_char_3055_00_19","textHome":"You want to know@what's behind my mask, huh?"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":100,"textHome":"It's not particularly interesting."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500,"textHome":"Tee-hee."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":305500,"motion":300,"pos":1,"voice":"vo_char_3055_00_20","textHome":"I know you mean well,@but I don't think a lifetime of@unmanned labor is worth a wish."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":305500,"motion":200}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":305500,"motion":0,"pos":1,"voice":"vo_char_3055_00_21","textHome":"I don't envy winners."}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":7.6,"chara":[{"id":305500,"motion":1,"textHome":"If I have the time to envy them,@I'll work hard to earn more@connections and move forward."}]},{"autoTurnFirst":6.0,"chara":[{"id":305500,"motion":200,"textHome":"I won't become a sore loser who@curses others without making any effort."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":5.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":305500,"motion":300,"pos":1,"voice":"vo_char_3055_00_22","textHome":"My kind parents and siblings@are drawn into poverty..."}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":305500,"textHome":"This is such an unreasonable world."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":305500,"motion":0,"textHome":"That's why, to make such a family happy,@I'll wear the mask of a winner@and climb to the top."}]},{"autoTurnFirst":5.4,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":305500,"motion":100}]},{"autoTurnFirst":6.0,"chara":[{"id":305500,"motion":200,"textHome":"If I turn lies into truth,@they're no longer falsehoods."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp.json","id":305500,"motion":100,"pos":1,"voice":"vo_char_3055_00_23","textHome":"There are plenty of winners who never face@any struggles from the moment they're born."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305500,"motion":300,"textHome":"Every time I'm reminded of that,@I almost look down..."}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":305500,"motion":1,"textHome":"But when I see the smiling faces@of my parents and siblings,@I feel glad that I was born here."}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":5.0,"chara":[{"id":305500,"motion":0,"textHome":"It makes me want to do my best again."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_17":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":305500,"motion":1,"pos":1,"voice":"vo_char_3055_00_24","textHome":"I'm not poor."}]},{"autoTurnFirst":3.1,"chara":[{"eyeClose":1,"id":305500,"textHome":"I'm pretending to be an exemplary student@from a respectable family."}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":305500,"motion":100,"textHome":"Yeah. I'm fine."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":305500,"motion":400,"textHome":"Huh?! Oh? Ah!@You're here!"}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305500}]},{"autoTurnFirst":2.5,"chara":[{"id":305500,"motion":0,"textHome":"Uh, it's nothing."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500,"textHome":"Let's do our best today too!"}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":1,"pos":1,"voice":"vo_char_3055_00_25","textHome":"Oh, good morning."}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500,"textHome":"It's early in the morning, huh?"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":300,"textHome":"I'm doing some review for class."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":305500,"motion":0,"textHome":"Have you finished today's homework?"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500,"motion":100,"textHome":"If you haven't,@want to do it together?"}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":1,"pos":1,"voice":"vo_char_3055_00_26","textHome":"They say meals build your body, right?"}]},{"autoTurnFirst":6.5,"chara":[{"id":305500,"motion":200,"textHome":"That's why I make nutritious@bento boxes for my family every day."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500,"motion":300,"textHome":"I want them to stay healthy forever."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":0,"pos":1,"voice":"vo_char_3055_00_02","textHome":"Nice to meet you,@I'm Sae Kirino."}]},{"autoTurnFirst":5.0,"chara":[{"id":305500,"motion":300,"textHome":"When I help people,@I put on this mask."}]},{"autoTurnFirst":2.5,"chara":[{"id":305500,"motion":100,"textHome":"It's something I do because I like it,@so I don't need anything in return."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":305500,"motion":0,"pos":1,"voice":"vo_char_3055_00_27","textHome":"Did you see me at the sale corner?"}]},{"autoTurnFirst":1.2,"chara":[{"eyeClose":1,"id":305500,"motion":0,"textHome":"Yeah...@I figured I should learn@to shop like this too."}]},{"autoTurnLast":0.2,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500,"motion":1,"textHome":"I don't want to become an@irresponsible adult when@it comes to money, you know?"}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":305500,"motion":1,"pos":1,"voice":"vo_char_3055_00_28","textHome":"You need to sleep soon, or you@won't be able to wake up tomorrow."}]},{"autoTurnFirst":1.6,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":305500,"motion":0,"textHome":"Oops, I kind of treated you like@my little brothers by saying that."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":305500,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500,"motion":100,"textHome":"If you can't sleep,@want some warm milk?"}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":305500,"motion":0,"pos":1,"voice":"vo_char_3055_00_29","textHome":"I do have a part-time job."}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":300,"textHome":"My parents said I didn't have to, but@it's a good way to learn about society."}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"id":305500,"motion":100}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":305500,"motion":1,"textHome":"It makes me realize that the world@revolves around the power of many people."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":305500}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":305500,"motion":400,"pos":1,"voice":"vo_char_3055_00_30","textHome":"A Witch at a time like this..."}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":305500,"motion":300,"textHome":"If I'm late for work, I won't have@enough money for this month's expenses..."}]},{"autoTurnFirst":0.9,"chara":[{"eyeClose":1,"id":305500,"textHome":"But I'll feel worse for leaving@the problem in front of me..."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":4.3,"chara":[{"id":305500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":305500,"motion":200,"textHome":"I have to make it in time!"}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":6.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":305500,"motion":300,"pos":1,"voice":"vo_char_3055_00_31","textHome":"If my Endless Mirrors copies@had my same memories..."}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"id":305500,"motion":1,"textHome":"Would that mean that they could reveal@I was running around at the bargain sale@and fighting over products?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":305500,"motion":400,"textHome":"I have to defeat them quickly!"}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":305500,"motion":0,"pos":1,"voice":"vo_char_3055_00_32","textHome":"Magical Girls are fighting?"}]},{"autoTurnFirst":4.1,"chara":[{"id":305500,"motion":200,"textHome":"Wait, what's the point of that?"}]},{"autoTurnFirst":1.2,"chara":[{"eyeClose":1,"id":305500,"motion":1,"textHome":"I'd rather go to work early@than get hurt."}]},{"autoTurnLast":3.5,"chara":[{"eyeClose":0,"id":305500}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_26":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":1,"pos":1,"voice":"vo_char_3055_00_33","textHome":"You'd be surprised how many things@students can learn from business books."}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500,"motion":100,"textHome":"If you're interested, why don't we@look for them at the library together?"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305500,"textHome":"I want to hear your recommendations too."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":305500,"motion":0,"pos":1,"voice":"vo_char_3055_00_34","textHome":"Huh? Your outfit..."}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305500,"textHome":"Looks like a button might come off."}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500,"motion":200,"textHome":"I have sewing tools,@so should I fix it?"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":1,"textHome":"Hey, come over here for a second."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":305500,"motion":300,"pos":1,"voice":"vo_char_3055_00_35","textHome":"Are you...okay?"}]},{"autoTurnFirst":2.1,"chara":[{"eyeClose":1,"id":305500,"textHome":"It's not good to push yourself too hard."}]},{"autoTurnLast":0.2,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":1,"textHome":"Make sure to eat properly,@get enough sleep, and do@something you like once in a while."}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":100,"textHome":"I'm here to listen@anytime you want to talk."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":305500,"motion":400,"pos":1,"voice":"vo_char_3055_00_36","textHome":"I'm proud of having a strong body."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":0,"textHome":"I owe it to my parents, though."}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":305500,"motion":100,"textHome":"Your body is your asset."}]},{"autoTurnLast":3.6,"chara":[{"eyeClose":0,"id":305500,"textHome":"I never skip my daily training."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500,"textHome":"Heheh.@Was that unexpected?"}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":305500,"motion":100,"pos":1,"voice":"vo_char_3055_00_03"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":305500}]}],"group_30":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":305500,"motion":0,"pos":1,"voice":"vo_char_3055_00_37","textHome":"I'm not anything special."}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":305500,"motion":300,"textHome":"Even now, somewhere,@someone is probably crying,@and I can't do anything about it."}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":5.0,"chara":[{"id":305500,"motion":100,"textHome":"I'm not working hard at all,@how pathetic."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":305500,"motion":1,"pos":1,"voice":"vo_char_3055_00_38","textHome":"I don't hate Konoha and her friends,@even if they have a grounded way of thinking."}]},{"autoTurnLast":2.2,"chara":[{"eyeClose":1,"id":305500}]},{"autoTurnLast":0.3,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":6.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":305500,"motion":300,"textHome":"Maybe I could have been friends@with them even as my true self."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":305500,"textHome":"Just a thought."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":305500,"motion":200,"pos":1,"voice":"vo_char_3055_00_39","textHome":"Before asking me anything,@do some research first."}]},{"autoTurnFirst":5.1,"chara":[{"eyeClose":1,"id":305500,"motion":1,"textHome":"Just because I act like a model student@doesn't mean you have to do everything..."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":4.2,"chara":[{"id":305500,"motion":0,"textHome":"Well...I'll do my best to teach you@because I want to improve@my standing with everyone."}]},{"autoTurnFirst":5.0,"chara":[{"id":305500,"motion":100}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":305500,"motion":1,"pos":1,"voice":"vo_char_3055_00_40","textHome":"My classmates are living@without any inconvenience."}]},{"autoTurnFirst":4.6,"chara":[{"eyeClose":1,"id":305500,"textHome":"My anger towards them is just jealousy."}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":305500,"motion":0,"textHome":"Even though I know that, I want@to cover my ears whenever@I hear their half-hearted words."}]},{"autoTurnFirst":2.3,"chara":[{"id":305500,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":305500}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":2.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_001.exp.json","id":305500,"motion":0,"pos":1,"voice":"vo_char_3055_00_41","textHome":"Oh, no...@They're so cute..."}]},{"autoTurnFirst":2.7,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":305500}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":305500,"motion":400,"textHome":"Oh!@When did you start listening?"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":300,"textHome":"This is a video of my little siblings."}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500,"textHome":"Hehehe.@I don't think I really deserve@such cute siblings."}]},{"autoTurnFirst":3.9,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":305500,"motion":1}]},{"autoTurnLast":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":305500}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":305500,"motion":200,"pos":1,"voice":"vo_char_3055_00_42","textHome":"If you're going to be a hindrance,@I won't hold back."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":305500,"motion":100,"pos":1,"voice":"vo_char_3055_00_43","textHome":"This is a victory I won for everybody."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":305500,"motion":300,"pos":1,"voice":"vo_char_3055_00_44","textHome":"Did it end without suffering?"}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":305500,"motion":100,"pos":1,"voice":"vo_char_3055_00_45","textHome":"Are you alright?@You're not hurt, right?"}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":305500,"motion":200,"pos":1,"voice":"vo_char_3055_00_46","textHome":"Sorry, but it's for everyone's sake."}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":4.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":305500,"motion":0,"pos":1,"voice":"vo_char_3055_00_04"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":305500,"motion":300}]}],"group_5":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":305500,"motion":0,"pos":1,"voice":"vo_char_3055_00_05"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":0,"id":305500}]}],"group_6":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":0,"pos":1,"voice":"vo_char_3055_00_13","textHome":"With this power,@I can protect even more people!"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500,"motion":100}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":1,"pos":1,"voice":"vo_char_3055_00_14","textHome":"Becoming stronger doesn't mean@I can let my guard down."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":305500,"motion":200,"textHome":"I'll keep getting@stronger and stronger!"}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":305500,"motion":300,"pos":1,"voice":"vo_char_3055_00_15","textHome":"I'd rather hear about you@than talk about me.@If that's okay, though."}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":1,"id":305500}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":3.0,"chara":[{"id":305500,"motion":0}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":305500,"motion":300,"pos":1,"voice":"vo_char_3055_00_16","textHome":"I absolutely can't let it be known@that I'm actually poor."}]},{"autoTurnFirst":3.4,"chara":[{"eyeClose":1,"id":305500}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_001.exp.json","id":305500,"motion":100,"textHome":"That's why I wear a mask."}]},{"autoTurnFirst":1.7,"chara":[{"eyeClose":1,"id":305500,"textHome":"To get closer to the idealized version@of myself that I've dreamed of becoming."}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":305500}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":305500,"motion":200}]},{"chara":[{"id":305500,"textHomeStatus":"Clear"}]}]},"version":3}

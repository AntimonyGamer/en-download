a":[{"id":200401,"motion":201,"pos":0}],"nameAvLeft":"Sayaka","textAvLeft":"[fontSize:20]It's Sayaka-senpai from now on, got it?"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp3.json","id":200101,"motion":300,"pos":2}],"nameAvRight":"Madoka","textAvColor":"textMadoka","textAvRight":"[fontSize:20]Um, okay...@If you really want..."},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp3.json","id":200101,"pos":2}],"nameAvRight":"Madoka","textAvRight":"[fontSize:20]Oh―"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":200401,"motion":0}],"nameAvLeft":"Sayaka","textAvColor":"textSayaka","textAvLeft":"[fontSize:20]What is it?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":200401},{"effect":"fadeout","id":200101}],"textAvClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_21132.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810600,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810500,"motion":0,"pos":0}],"nameAvRight":"Hitomi","textAvColorRGB":"255255255","textAvRight":"[fontSize:20]......"},{"chara":[{"id":810500,"motion":100}],"nameAvLeft":"Kyosuke","textAvColorRGB":"255255255","textAvLeft":"[fontSize:20]......"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":810500},{"effect":"fadeout","id":810600}],"textAvClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_21132.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp3.json","id":200101,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_031.exp3.json","id":200401,"motion":0,"pos":0}],"nameAvRight":"Madoka","textAvColor":"textMadoka","textAvRight":"[fontSize:20]Is that Hitomi?@And...Kyosuke?"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp3.json","id":200401,"motion":100,"pos":0}],"nameAvLeft":"Sayaka","textAvColor":"textSayaka","textAvLeft":"[fontSize:20]Ooh! On a date, huh?@The confession must've gone well."},{"chara":[{"id":200401,"pos":0}],"nameAvLeft":"Sayaka","textAvLeft":"[fontSize:20]Aww, they're practically glowing!@Cute."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200101,"motion":300,"pos":2}],"nameAvRight":"Madoka","textAvColor":"textMadoka","textAvRight":"[fontSize:20]Sayaka."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200401,"motion":0,"pos":0}],"nameAvLeft":"Sayaka","textAvColor":"textSayaka","textAvLeft":"[fontSize:20]Hm? What's up?"},{"chara":[{"id":200101,"motion":0,"pos":2}],"nameAvRight":"Madoka","textAvColor":"textMadoka","textAvRight":"[fontSize:20]Are you sure you're okay?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200401,"pos":0}],"nameAvLeft":"Sayaka","textAvColor":"textSayaka","textAvLeft":"[fontSize:20]About what?"},{"chara":[{"id":200401,"motion":400,"pos":0}],"nameAvLeft":"Sayaka","textAvLeft":"[fontSize:20][chara:200401:effect_emotion_surprise_0][se:7226_shock]Oh wait, you mean Kyosuke?"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp3.json","id":200401,"motion":1,"pos":0}],"nameAvLeft":"Sayaka","textAvLeft":"[fontSize:20]Ew, as if!"},{"chara":[{"id":200401,"pos":0}],"nameAvLeft":"Sayaka","textAvLeft":"[fontSize:20]We're just old buddies.@Totally platonic, hundred percent."},{"chara":[{"id":200401,"pos":0}],"nameAvLeft":"Sayaka","textAvLeft":"[fontSize:20]And hey, Hitomi's sweet.@She's a good match for him."},{"chara":[{"id":200401,"motion":100,"pos":0}],"nameAvLeft":"Sayaka","textAvLeft":"[fontSize:20]So if those two end up together...@Honestly, it's kind of a relief!"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

{"story":{"group_1":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1109_00_01","textHome":"I'm Rena Minami,@Kamiha☆Magica's blue ambassador."}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110900,"motion":100}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":400,"textHome":"...Wait, I'm an idol?!"}]},{"autoTurnFirst":5.3,"chara":[{"cheek":1,"face":"mtn_ex_052.exp.json","id":110900,"motion":1,"textHome":"Sharing the stage@with the beauty bearing blades@from both history and tales,"}]},{"autoTurnFirst":3.0,"chara":[{"id":110900,"textHome":"the very-cute, natural-born,@kawaii, of-the-millennium Sayu-Sayu?!"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":110900,"motion":300,"textHome":"N-nonononono!"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":110900,"motion":100,"textHome":"There's no way I'm gonna reach@that level of cuteness."}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1109_00_17","textHome":"*Gasp*!@Sayu-Sayu's Memoria is so cute!"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":100}]},{"autoTurnFirst":4.6,"chara":[{"id":110900,"motion":1,"textHome":"And Kaede's pretty photogenic@in this Memoria too..."}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":0,"textHome":"Wh-what are you looking at?!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":110900,"motion":200}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1109_00_18","textHome":"Be sure to think hard@about which Memoria to use."}]},{"autoTurnFirst":3.6,"chara":[{"id":110900,"motion":1,"textHome":"Don't just pick the strongest you have, ok?"}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":1,"id":110900,"textHome":"Think about their synergy and find@the best way to maximize their effects!"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":110900}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1109_00_19","textHome":"With this power, I'll give you@the best concert you'll ever see!"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110900,"motion":101}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":2.1,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110900,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1109_00_20","textHome":"My power still isn't enough@to survive the idol industry..."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":110900,"motion":100}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":2.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1109_00_21","textHome":"Don't look down on idols!"}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":1,"id":110900,"motion":1,"textHome":"They're goddesses born from a combination@of natural talent and tons of hard work!"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":110900}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":100}]},{"autoTurnLast":3.5,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110900,"textHome":"That's what being an idol truly means."}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1109_00_22","textHome":"I can feel it!"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":200,"textHome":"I'm really close to achieving@the optimal idol body!"}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":110900,"motion":100,"textHome":"Worthy of standing side-by-side with@the embodied goddess, Sayu-Sayu...!!"}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110900,"textHome":"Me...being close to...Sayu-Sayu...?!"}]},{"autoTurnFirst":0.7,"chara":[{"cheek":1,"face":"mtn_ex_052.exp.json","id":110900,"motion":0,"textHome":"Hngh!@I'm gonna vomit..."}]},{"autoTurnFirst":4.1,"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":110900}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_033.exp.json","id":110900,"motion":301,"textHome":"Bleghhh!"}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1109_00_23"}]},{"autoTurnFirst":4.1,"chara":[{"cheek":1,"face":"mtn_ex_052.exp.json","id":110900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":110900,"motion":200}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":0}]},{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":1}]},{"autoTurnFirst":1.2,"chara":[{"eyeClose":1,"id":110900,"motion":100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":110900}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":110900}]}],"group_17":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110900,"motion":101,"pos":1,"tear":0,"voice":"vo_char_1109_00_24","textHome":"Hello! I'm Rena Minami~!"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900,"textHome":"Fans who bought a handshake ticket,@come over here!"}]},{"autoTurnFirst":5.0,"chara":[{"id":110900,"motion":100,"textHome":"If you don't have one, you can get one@by buying 10 CDs over there!"}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110900,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1109_00_25"}]},{"autoTurnFirst":4.8,"chara":[{"eyeClose":1,"id":110900,"textHome":"Glow stick swords...on sale...?"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":110900}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":400,"textHome":"*Gasp*!"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":110900,"motion":300,"textHome":"Oh, it was just a dream..."}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":0,"textHome":"I was so happy, too..."}]},{"autoTurnFirst":2.6,"chara":[{"id":110900,"motion":100,"textHome":"It sucks when that happens..."}]},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110900,"textHome":"Oh well,@I should get ready for school."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":1}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":6.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_031.exp.json","id":110900,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1109_00_26","textHome":"So hungryyyy...@I'm gonna get something to eat..."}]},{"autoTurnFirst":6.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":1,"textHome":"Wanna come with?@I know a place around here where@we can eat lots of delicious fruits..."}]},{"autoTurnFirst":3.0,"chara":[{"id":110900,"motion":200,"textHome":"Kaede's place."}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1109_00_02","textHome":"60% water with a salty disposition to match:"}]},{"autoTurnFirst":2.0,"chara":[{"id":110900,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110900,"motion":101,"textHome":"mineral supplying Rena Minami here!"}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110900,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1109_00_27","textHome":"I spend my time after school both hunting@for Witches and attending idol lessons..."}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":110900,"textHome":"*Sigh*..."}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":110900,"motion":0,"textHome":"Can I really become a legit idol@if I'm splitting my time like this?"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":110900,"motion":100,"textHome":"Unless I devote my whole life to lessons,@there's no way I could...!"}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":4.1,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1109_00_28","textHome":"Wait, I'll go to sleep after this!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":110900,"motion":100,"textHome":"Kyaaa! Sayu-Sayu!!@Slice me up!"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":110900,"motion":200}]},{"autoTurnFirst":0.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":0,"textHome":"Let's go!@One sword, two hearts!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110900,"motion":101}]},{"autoTurnFirst":1.1,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":110900,"motion":100,"textHome":"...Phewww!@Yep, she's the best!"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":110900}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1109_00_29","textHome":"I have some time to spare...@Time for a guerilla concert!"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":100}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":1,"id":110900,"motion":1,"textHome":"I'll make sure that every citizen of@Kamihama knows the name Kamiha☆Magica."}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":0,"id":110900}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":110900,"motion":0,"textHome":"I'm so tired of only our friends and@family showing up to our concerts!"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":110900,"motion":400,"tear":1}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1109_00_30","textHome":"Hunting down Witches?"}]},{"autoTurnFirst":4.0,"chara":[{"id":110900,"motion":200,"textHome":"Should an idol really be doing@something like that?"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":0,"textHome":"*Gasp!*@Oh, it might be good for publicity,@actually...!"}]},{"autoTurnFirst":4.5,"chara":[{"id":110900,"motion":300}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900}]},{"autoTurnFirst":1.1,"chara":[{"eyeClose":1,"id":110900,"motion":0,"textHome":"Okay~@Leave it to me!"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":110900}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110900,"motion":101}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1109_00_31","textHome":"Hey, how come nobody in Mirrors is@carrying their paper sumo wrestlers..?"}]},{"autoTurnFirst":4.6,"chara":[{"cheek":1,"face":"mtn_ex_052.exp.json","id":110900,"motion":400,"textHome":"Is that not the kind of battling@you do inside there?!"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":110900,"motion":300,"tear":1,"textHome":"Ughhh, Kaede tricked me!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_052.exp.json","id":110900,"tear":0,"textHome":"I knew there was something off@about what she said."}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1109_00_32"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":110900,"motion":100}]}],"group_26":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110900,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1109_00_33","textHome":"Important lesson: it doesn't matter@what kind of problem you have,@it's always because of the Magius."}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900}]},{"autoTurnFirst":2.1,"chara":[{"eyeClose":1,"id":110900,"motion":200,"textHome":"Repeat after me:"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":110900}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":110900,"motion":100,"textHome":"It's the Magius's fault!"}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1109_00_34","textHome":"I tried the new Banbanzai menu item@the other day but..."}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":110900,"textHome":"Actually, it wasn't that bad..."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":110900}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":200,"textHome":"At least it was edible.@I'll give it 50 points."}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1109_00_35","textHome":"*Gasp*!@That was a close one!"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_052.exp.json","id":110900}]},{"autoTurnFirst":5.1,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":110900,"motion":0,"textHome":"I had Sayu-Sayu's ultimate angelic soprano@voice stuck in my head for too long,"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":110900,"motion":300,"textHome":"I almost got taken into heaven."}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":2.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_031.exp.json","id":110900,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1109_00_36","textHome":"Ouch, don't touch me!"}]},{"autoTurnFirst":6.4,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":110900,"motion":300,"textHome":"I had too many dance lessons lately,@so my body really hurts..."}]},{"autoTurnFirst":3.5,"chara":[{"id":110900,"motion":0,"textHome":"But I'll never be able to become@an idol if I can't endure this pain."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_052.exp.json","id":110900,"motion":100}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1109_00_03"}]},{"autoTurnFirst":4.0,"chara":[{"id":110900,"motion":400}]}],"group_30":[{"autoTurnFirst":0.1,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1109_00_37","textHome":"Neither our producer nor any@of the Kamiha☆Magica members@know anything about idols!"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":110900}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":110900}]},{"autoTurnFirst":3.9,"chara":[{"id":110900,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"id":110900,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"id":110900,"textHome":"I've got no choice but to teach them@all about the holy world of idols!"}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1109_00_38","textHome":"Oh, Sayu-Sayu...@My Goddess Sayu-Sayu~...@Ahh, Sayu-Sayu~..."}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":110900}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":110900}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":110900}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110900,"textHome":"W-what do I do?"}]},{"autoTurnFirst":6.5,"chara":[{"id":110900,"motion":400,"textHome":"By reciting Sayu-Sayu's magnificence,@I accidentally created a poetic masterpiece@that's sure to go down in history!"}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110900,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1109_00_39","textHome":"I never realized how hard@it would be to always put a smile@on my face no matter what...!"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":1,"face":"mtn_ex_031.exp.json","id":110900,"tear":1}]},{"autoTurnFirst":4.1,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":110900,"motion":0,"tear":0,"textHome":"Unlike me, some girls are well loved@because they can do it so naturally..."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":110900,"motion":100}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1109_00_40","textHome":"Kamiha☆Magica's not so bad@of an idol group."}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110900}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_031.exp.json","id":110900,"motion":300,"textHome":"I might not be able to@become an amazing idol alone,"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":110900,"motion":100,"textHome":"but if we all try together...!"}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1109_00_41","textHome":"I'm Rena Minami, the blue one of@Kamihama's idol unit, Kamiha☆Magica!"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110900,"motion":101}]},{"autoTurnFirst":5.0,"chara":[{"id":110900,"motion":400,"textHome":"Everyone~!@Are you fired up?!"}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1109_00_42","textHome":"You gotta come see my performance!"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110900,"motion":101}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":110900,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1109_00_43","textHome":"*Pant*... *Wheeze..."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":110900,"motion":200,"textHome":"That result...was only natural."}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110900,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1109_00_44","textHome":"This outfit...hurts my chest..."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":110900,"motion":300}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1109_00_45","textHome":"Well?@Did you take a good look@at my performance?!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110900,"motion":101}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1109_00_46"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":110900}]}],"group_4":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_052.exp.json","id":110900,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1109_00_04"}]}],"group_5":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":110900,"motion":101,"pos":1,"tear":0,"voice":"vo_char_1109_00_05"}]}],"group_6":[{"autoTurnFirst":1.6,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1109_00_13","textHome":"Yeah!@More lessons, more lessons!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":110900,"motion":1}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":110900,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1109_00_14","textHome":"I've still got a long way to go@to reach the pinnacle of idol-hood...!"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":0,"textHome":"Wait, wouldn't that be like@some other kinda game?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":200,"textHome":"You got a screw loose or something?"}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1109_00_15","textHome":"You wanna know more about@the reason why I became an idol?"}]},{"autoTurnFirst":0.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":110900,"motion":1,"textHome":"O-okay...if you insist..."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":110900}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":110900,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1109_00_16","textHome":"Memoria?@That trading card looking thing?"}]},{"autoTurnFirst":5.2,"chara":[{"eyeClose":1,"id":110900,"motion":1,"textHome":"I don't need it,@I'm strong enough without them."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":110900,"motion":200,"textHome":"Well, since you brought it up,@I wouldn't mind trying it out."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":110900}]},{"autoTurnFirst":2.3,"chara":[{"id":110900}]},{"chara":[{"id":110900,"textHomeStatus":"Clear"}]}]},"version":3}

{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21503.jpg","bgm":"bgm03_story12","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":305600,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":303900,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":303900,"motion":400}],"nameRight":"Seira","textRight":"Ahh, damn!@What is this!","turnChangeOut":"fadeOut"},{"chara":[{"id":303900}],"nameRight":"Seira","textRight":"I'm not from Kamihama so@I don't know about any of this,"},{"chara":[{"id":303900,"motion":100}],"nameRight":"Seira","textRight":"but why's everyone gotta be so selfish?!@I just don't get it!"},{"chara":[{"id":305600,"motion":200}],"nameLeft":"Rui","textLeft":"Seira...!"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800400,"motion":0,"pos":0}],"nameLeft":"","textLeft":"It sure is nice to not know...@So happy not knowing..."},{"chara":[{"id":800400}],"nameLeft":"","textLeft":"When I didn't know I was so happy."},{"chara":[{"id":303900,"motion":200}],"nameRight":"Seira","textRight":"Haah?"},{"chara":[{"id":800400}],"nameLeft":"","textLeft":"Wish I hadn't known about those Daito folks..."},{"chara":[{"id":800400},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":303900,"motion":0}],"nameLeft":"","textLeft":"I shouldn't have...talked to them at the game..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800400,"pos":0}],"nameLeft":"","textLeft":"They're nothing like what my parents told me..."},{"chara":[{"id":800400}],"nameLeft":"","textLeft":"They were all so kind-hearted,@we coulda been rivals..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800400,"pos":0}],"nameLeft":"","textLeft":"Then I had to go talk shit about them...@And assume the worst in them..."},{"chara":[{"id":800400}],"nameLeft":"","textLeft":"Ahh...how idiotic of me...it's absurd..."},{"chara":[{"id":800400}],"nameLeft":"","textLeft":"Now that I'm aware of myself...@I'm ready...to just disappear..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800400},{"effect":"fadeout","id":303900}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":303600,"lipSynch":0,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":303300,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":304200,"motion":0,"pos":1}],"nameLeft":"Maria","textLeft":"..."},{"chara":[{"id":304200,"lipSynch":0}],"nameCenter":"Meguru","textCenter":"...[wait:1.0][chara:304200:lipSynch_1]Maybe, that's..."},{"autoTurnLast":0.5,"bg":"bg_adv_18023.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":304201,"motion":1,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":304201}],"nameCenter":"Meguru","textCenter":"On the contrary...why can I...@No, why can all of us Magical Girls,","turnChangeOut":"fadeOut"},{"chara":[{"id":304201}],"nameCenter":"Meguru","textCenter":"whether East or West,"},{"chara":[{"id":304201}],"nameCenter":"Meguru","textCenter":"treat each other so normally without division?"},{"autoTurnLast":0.5,"bg":"bg_adv_21503.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":303600,"lipSynch":0,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":303300,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":304200,"motion":0,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":304200}],"nameCenter":"Meguru","textCenter":"Is this the answer to that question...?","turnChangeOut":"fadeOut"},{"chara":[{"id":303600,"motion":200}],"nameLeft":"Maria","textLeft":"All of us Magical Girls are part of a big community."},{"chara":[{"id":303600}],"nameLeft":"Maria","textLeft":"Without even realizing it, we connected with our@peers in the East and got to know each other."},{"chara":[{"eyeClose":1,"id":303600}],"nameLeft":"Maria","textLeft":"If we hadn't become Magical Girls...we too..."},{"chara":[{"eyeClose":1,"id":303300,"motion":300}],"nameRight":"Sayuki","textRight":"May have been the same, right..."},{"chara":[{"id":304200,"lipSynch":0},{"eyeClose":0,"id":303600,"motion":0}],"nameCenter":"Everyone","textCenter":"..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":303300},{"effect":"fadeout","id":304200},{"effect":"fadeout","id":303600}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":305600,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":303900,"motion":0,"pos":2}],"nameLeft":"Rui","textLeft":"If that's true...@No, because it's true..."},{"chara":[{"id":305600,"lipSynch":0}],"nameLeft":"Rui","textLeft":"(I really don't want to say it, but...)"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":305600,"motion":200,"pos":0}],"nameLeft":"Rui","textLeft":"There is still hope...!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":303900,"lipSynch":0,"pos":2}],"nameRight":"Seira","textRight":"...!"},{"bgm":"bgm03_story07","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":101300,"motion":0,"pos":2}],"nameRight":"Asuka","textRight":"You're right!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":305600}],"textClear":1},{"chara":[{"id":101300,"motion":200},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800700,"motion":0,"pos":0}],"nameRight":"Asuka","textRight":"Between us, there is fundamentally zero difference!"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":303300,"motion":100,"pos":2}],"nameRight":"Sayuki","textRight":"Taking time to reflect on it,"},{"chara":[{"id":303300}],"nameRight":"Sayuki","textRight":"it may not be an issue of one's personal character."},{"chara":[{"cheek":0,"face":"mtn_ex_042.exp3.json","id":300400,"motion":100,"pos":2}],"nameRight":"Sasara","textRight":"If there were any difference between us..."},{"chara":[{"eyeClose":1,"id":300400}],"nameRight":"Sasara","textRight":"It would be \"luck\"."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":303600,"motion":1,"pos":2}],"nameRight":"Maria","textRight":"If we had bad luck, we could have ended up the@same as you."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":300600,"motion":200,"pos":2}],"nameRight":"Emiri","textRight":"It's not like you guys have bad character!"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":304200,"motion":200,"pos":2}],"nameRight":"Meguru","textRight":"It's all just because of the environment that fate@gave you!"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":305600,"motion":0,"pos":2}],"nameRight":"Rui","textRight":"So don't think that you must despair over@yourselves...!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":305600}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"id":800700,"pos":1}],"textClear":1},{"autoTurnLast":0.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800400,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800200,"motion":0,"pos":2}]},{"nameNarration":"Everyone","narration":"\"...\"","narrationBg":"","narrationEffect":"in"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

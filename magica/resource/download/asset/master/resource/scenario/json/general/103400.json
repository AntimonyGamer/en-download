{"story":{"group_1":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103400,"motion":0,"pos":1,"voice":"vo_char_1034_00_01","textHome":"Whoops...@Terribly sorry for startling you."}]},{"autoTurnFirst":6.8,"chara":[{"id":103400,"motion":300,"textHome":"I had intended to just say hello,@but I snuck up on you out of habit."}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103400,"motion":1,"textHome":"I'm Asahi Miura.@I know this isn't@a sufficient apology,"}]},{"autoTurnFirst":4.3,"chara":[{"id":103400,"motion":100,"textHome":"but I hope you will forgive me@and accept this dried meat."}]},{"autoTurnFirst":2.0,"chara":[{"id":103400,"motion":0,"textHome":"I prepared it myself, but I can@assure you that it is delicious."}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103400,"motion":200}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103400,"motion":100,"pos":1,"voice":"vo_char_1034_00_17","textHome":"It is a strict rule to hold your fire@upon hearing rustling in the bushes."}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":0,"textHome":"There was one time when@I was deep in the mountains,@and I mistook Lady Chika for a bear."}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":103400,"motion":300,"textHome":"That chilled me to my core."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103400,"motion":0,"pos":1,"voice":"vo_char_1034_00_18","textHome":"We live by taking the lives@of other living beings."}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":103400}]},{"autoTurnFirst":2.9,"chara":[{"id":103400,"motion":1,"textHome":"In order to cherish and savor the lives@we have received, my grandmother@taught me a lot about cooking game."}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103400,"motion":100}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103400,"motion":100,"pos":1,"voice":"vo_char_1034_00_19","textHome":"The bayonet is the most powerful weapon@of all. Not only can it fire shots,@it can also cut things to ribbons."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103400,"motion":200}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103400,"motion":0,"pos":1,"voice":"vo_char_1034_00_20","textHome":"The stronger one becomes,@the more things one can protect."}]},{"autoTurnFirst":5.0,"chara":[{"id":103400,"motion":100}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":0,"pos":1,"voice":"vo_char_1034_00_21","textHome":"A Diviner is a Magical Girl@like no other..."}]},{"autoTurnFirst":4.7,"chara":[{"id":103400,"motion":300,"textHome":"There was once a time where@I harbored hope in such pure,@beautiful dignity; however..."}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_023.exp3.json","id":103400,"motion":1,"textHome":"We are destined@to resign to the truth."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"id":103400,"textHome":"Naught but emptiness..."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":1,"pos":1,"voice":"vo_char_1034_00_22","textHome":"\"Hope\" and \"salvation\"@are meaningless to us."}]},{"autoTurnFirst":4.8,"chara":[{"id":103400,"motion":100,"textHome":"Rather than keep my expectations up@only to be disappointed,"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103400,"textHome":"I will simply surrender to the@resignation that fills my heart..."}]},{"autoTurnFirst":4.9,"chara":[{"id":103400,"motion":200,"textHome":"...and accept the emptiness@that surrounds us."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_023.exp3.json","id":103400,"motion":0,"pos":1,"voice":"vo_char_1034_00_23"}]},{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103400,"motion":200}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103400}]}],"group_17":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103400,"motion":0,"pos":1,"voice":"vo_char_1034_00_24","textHome":"Right when I thought@I would go for a walk,"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103400,"textHome":"I happened to bump into you."}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103400,"motion":100,"textHome":"Another of God's little tricks.@Since you're here,@why don't we go together?"}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103400,"motion":300,"pos":1,"voice":"vo_char_1034_00_25","textHome":"Ahh...!"}]},{"autoTurnFirst":5.3,"chara":[{"eyeClose":0,"id":103400,"textHome":"Nothing wakes me up quite@like the morning sunshine."}]},{"autoTurnFirst":4.0,"chara":[{"id":103400,"motion":0,"textHome":"Let that clean air@fill your lungs, and..."}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":1,"id":103400,"textHome":"Hm!"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":103400}]},{"autoTurnFirst":5.0,"chara":[{"id":103400,"motion":200,"textHome":"...Alright!@Let's go out hunting."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":0,"pos":1,"voice":"vo_char_1034_00_26","textHome":"I've been camped out in the@mountains since this morning..."}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_050.exp3.json","id":103400,"motion":300,"textHome":"Ugh...@I am unbelievably tired..."}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":103400}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":0,"textHome":"It's warm and comfortable here..."}]},{"autoTurnFirst":4.7,"chara":[{"eyeClose":1,"id":103400,"textHome":"I'm going to catch up on@a little sleep..."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103400,"textHome":"Mm..."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103400,"motion":1,"pos":1,"voice":"vo_char_1034_00_02","textHome":"It's a pleasure to make@your acquaintance.@My name is Asahi Miura."}]},{"autoTurnFirst":6.4,"chara":[{"id":103400,"motion":100,"textHome":"My family is in the hunting business,@so you can ask me anything@you'd like to know about hunting."}]},{"autoTurnFirst":2.8,"chara":[{"eyeClose":1,"id":103400,"motion":0,"textHome":"I look forward to hearing from you."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":6.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103400,"motion":100,"pos":1,"voice":"vo_char_1034_00_27","textHome":"I once carried some dried meat@in my pocket in case I got hungry@in the evening, but..."}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103400,"textHome":"The scent wafted through the air and@landed me in a great deal of trouble,"}]},{"autoTurnFirst":2.9,"chara":[{"id":103400,"motion":300,"textHome":"so I will never do that again."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103400,"motion":0,"pos":1,"voice":"vo_char_1034_00_28","textHome":"Drat. My prey escaped."}]},{"autoTurnFirst":6.6,"chara":[{"id":103400,"motion":100,"textHome":"Hold your breath—@you must not let the other@party know your whereabouts."}]},{"autoTurnFirst":5.0,"chara":[{"id":103400,"motion":200,"textHome":"As it is dangerous,@and I possess good night vision,@do not stray from me."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":3.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103400,"motion":400,"pos":1,"voice":"vo_char_1034_00_29","textHome":"Do I smell that bad?!"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":103400,"motion":100,"textHome":"My apologies; I was in the process of@gutting an animal until recently..."}]},{"autoTurnFirst":5.0,"chara":[{"id":103400,"motion":300,"textHome":"I-I will go shower on the double!"}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103400,"motion":1,"pos":1,"voice":"vo_char_1034_00_30","textHome":"That's a Witch's signature, isn't it?"}]},{"autoTurnFirst":3.0,"chara":[{"id":103400,"motion":100,"textHome":"They used to be@Magical Girls just like us."}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_023.exp3.json","id":103400,"textHome":"All we can do for them@is ensure that they will be able@to pass away without suffering."}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":103400}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103400,"motion":200}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":7.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103400,"motion":100,"pos":1,"voice":"vo_char_1034_00_31","textHome":"For someone like me, who specializes@in long-range attacks, Endless Mirrors@proves to be a challenge."}]},{"autoTurnFirst":5.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":300,"textHome":"It is difficult to distinguish between@\"real\" and \"fake\" from a distance."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":7.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103400,"motion":0,"pos":1,"voice":"vo_char_1034_00_32"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":103400}]},{"autoTurnFirst":7.2,"chara":[{"id":103400,"motion":1}]}],"group_26":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":0,"pos":1,"voice":"vo_char_1034_00_33","textHome":"Whenever I go anywhere,"}]},{"autoTurnFirst":4.7,"chara":[{"id":103400,"motion":300,"textHome":"I must prepare for the unexpected,@so I have to pack emergency rations@and a GPS and whatnot..."}]},{"autoTurnFirst":5.2,"chara":[{"id":103400,"motion":100,"textHome":"I always find myself carrying around@a great deal of luggage."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":3.6,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103400,"motion":300,"pos":1,"voice":"vo_char_1034_00_34","textHome":"A steampunk-style clock..."}]},{"autoTurnFirst":2.6,"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":103400,"textHome":"How cool is that...?"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":1,"face":"mtn_ex_050.exp3.json","id":103400,"motion":400,"textHome":"Ah, n-no matter!@It's not as though I'm interested@in this sort of thing..."}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp3.json","id":103400,"motion":200,"textHome":"Functionality—@I am purely speaking@about functionality...!"}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":4.6,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103400,"motion":200,"pos":1,"voice":"vo_char_1034_00_35","textHome":"*Gasp!*@Entering my room without@permission, are we?"}]},{"autoTurnFirst":6.4,"chara":[{"id":103400,"motion":100,"textHome":"Didn't I tell you not@to go in there carelessly,@as it is full of dangerous items?"}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103400,"motion":0,"pos":1,"voice":"vo_char_1034_00_36","textHome":"Heh. I was well aware@that you were there."}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":103400}]},{"autoTurnFirst":3.4,"chara":[{"id":103400,"motion":1,"textHome":"It amuses me that you would attempt@to sneak up on a hunter like myself."}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103400,"motion":100}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103400,"motion":300,"pos":1,"voice":"vo_char_1034_00_03"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103400}]}],"group_30":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103400,"motion":400,"pos":1,"voice":"vo_char_1034_00_37","textHome":"Urgh...@I cannot believe I've been@bested by mere mosquitoes!"}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":300,"textHome":"I hadn't expected to go so deep@into the mountains picking@wild vegetables with Lady Ryouko...!"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103400,"motion":200,"textHome":"Despite being a Magical Girl,@an itch is still an itch!"}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":3.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":103400,"motion":1,"pos":1,"voice":"vo_char_1034_00_38","textHome":"Eheheh... Ahaha!"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":103400,"motion":300,"textHome":"I've been watching a comedy show@that Lady Chiharu recommended to me,"}]},{"autoTurnFirst":4.4,"chara":[{"cheek":1,"face":"mtn_ex_011.exp3.json","id":103400,"textHome":"and it certainly hits the spot."}]},{"autoTurnFirst":3.0,"chara":[{"id":103400,"motion":400,"textHome":"Haha!"}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":300,"pos":1,"voice":"vo_char_1034_00_39","textHome":"Lady Shizuka is very upstanding,"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_023.exp3.json","id":103400,"textHome":"which is why@I worry about her at times."}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":0,"textHome":"I fear that her sincerity@may turn out to be a detriment..."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103400}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":300,"pos":1,"voice":"vo_char_1034_00_40","textHome":"In nature, I am the one who takes,"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_023.exp3.json","id":103400,"textHome":"but in my hometown..."}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103400,"motion":200,"textHome":"Although the saying goes \"the weak are@meat, and the strong do eat\", strength@does not necessarily equate to power."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":0,"textHome":"That's what I'd like@to believe, at least."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103400,"motion":1,"pos":1,"voice":"vo_char_1034_00_41","textHome":"Rabi, Sasha, and Urara have all@taken their respective places@and begun to change."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":300,"textHome":"The same goes for myself."}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":1,"id":103400,"textHome":"I've seen some hope,@even if only a little bit."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103400,"motion":100,"pos":1,"voice":"vo_char_1034_00_42","textHome":"I cannot let my quarry escape."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103400,"motion":1,"pos":1,"voice":"vo_char_1034_00_43","textHome":"These ordinary days@are all the same in the end."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103400,"motion":100,"pos":1,"voice":"vo_char_1034_00_44","textHome":"I hope that I was able to@send you off without suffering."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103400,"motion":200,"pos":1,"voice":"vo_char_1034_00_45","textHome":"Do not underestimate@my hunting skills."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103400,"motion":300,"pos":1,"voice":"vo_char_1034_00_46","textHome":"I had something I wanted@to save as well, you see."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103400,"motion":0,"pos":1,"voice":"vo_char_1034_00_04"}]}],"group_5":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":0,"pos":1,"voice":"vo_char_1034_00_05"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_023.exp3.json","id":103400}]}],"group_6":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103400,"motion":200,"pos":1,"voice":"vo_char_1034_00_13","textHome":"Mm...!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103400,"textHome":"It would appear that@my range has increased!"}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103400,"motion":100,"pos":1,"voice":"vo_char_1034_00_14","textHome":"With this, I will be able@to secure any prey I desire."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":300,"pos":1,"voice":"vo_char_1034_00_15","textHome":"Well now, I must say@I'm surprised they treated me@like some sort of youkai."}]},{"autoTurnFirst":2.5,"chara":[{"id":103400,"motion":1}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103400,"motion":100,"pos":1,"voice":"vo_char_1034_00_16","textHome":"My father is the kind of careless person@who often forgets to release the safety@on his firearm and lets the game slip away."}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103400,"motion":0,"textHome":"He also often mismatches his socks."}]},{"autoTurnFirst":3.0,"chara":[{"id":103400,"motion":300,"textHome":"Please refrain from laughing."}]},{"chara":[{"id":103400,"textHomeStatus":"Clear"}]}]},"version":3}

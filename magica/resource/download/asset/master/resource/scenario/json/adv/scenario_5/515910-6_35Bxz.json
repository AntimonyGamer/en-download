ome","textLeft":"Someone defeated them...?"},{"bgm":"bgm03_story09","nameCenter":"???'s Voice","textCenter":"We've been searching for you."},{"chara":[{"id":102001,"motion":400}],"nameLeft":"Kagome","textLeft":"Torte, look up!"},{"autoTurnLast":0.4,"bg":"black","deleteArmatureList":[2],"item":[{"path":"resource/scenario/img/51158_tower_tart2/memoria_1736.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"nameNarration":"Perenelle","narration":"―Perenelle―@I thought you were playing around the neighborhood,@but I never expected this...","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":10.0,"narrationLineSpace":20.0,"turnChangeOut":"fadeOut"},{"nameNarration":"Nicolas","narration":"―Nicolas―@Apparently Qube wasn't with you either."},{"narration":"―Nicolas―@We were worried about you!"},{"autoTurnLast":0.4,"bg":"bg_adv_20071.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":2,"soulGem":0}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":831303}],"nameRight":"Torte","textRight":"...Father, Mother.","turnChangeOut":"fadeOut"},{"chara":[{"id":102001,"motion":400}],"nameLeft":"Kagome","textLeft":"Who...are these people...?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831700,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":0,"pos":0}],"nameRight":"Nicolas","textRight":"Nice to meet you!"},{"chara":[{"id":831700}],"nameRight":"Nicolas","textRight":"I am Nicolas Flamel, an alchemist."},{"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_010.exp3.json","id":402901,"motion":0,"pos":0}],"nameLeft":"Perenelle","se":"7205_magic_girl","textLeft":"And I am Perenelle Flamel, also an alchemist and a@Magical Girl."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":200,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"Ah...I'm Kagome Satori."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402901,"motion":100,"pos":2}],"nameRight":"Perenelle","textRight":"Our daughter, Torte...no, Jeanne, seems to have@caused you trouble."},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"I sincerely apologize."},{"chara":[{"id":402901,"motion":300}],"nameRight":"Perenelle","textRight":"I've been trying my best to keep an eye on her,"},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"but she's quite uncontrollable..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831303,"motion":0,"pos":0,"soulGem":0}],"nameLeft":"Torte","textLeft":"I'm sorry...Father...Mother."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":402901}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":1,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831700,"motion":0,"pos":2}],"nameLeft":"Kagome","textLeft":"Wha...what...? F-Father...?"},{"chara":[{"id":102001,"lipSynch":0}],"nameLeft":"Kagome","textLeft":"(He seems to be about the same age as me...?)"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402901,"motion":100,"pos":2}],"nameRight":"Perenelle","textRight":"Oh, please don't mind Nicolas' appearance."},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"He has a certain condition where he doesn't age..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"lipSynch":0,"motion":400}],"nameLeft":"Kagome","textLeft":"[chara:102001:effect_emotion_surprise_0][se:7226_shock](He has that kind of condition...?)"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":200,"pos":0,"soulGem":0}],"nameLeft":"Torte","textLeft":"Listen, listen!"},{"chara":[{"id":831303}],"nameLeft":"Torte","textLeft":"Kagome came from the future!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831700,"motion":0,"pos":2}],"nameRight":"Nicolas","textRight":"From the future...?"},{"chara":[{"cheek":0,"id":810000,"motion":0,"pos":2,"posX":50}],"nameRight":"Qube","textRight":"That's interesting."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":400,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"K-Kyubey?!"},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"Looks like you can see me after all."},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"I never thought I would encounter a child with@potential to become a Magical Girl"},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"in a place like this."},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_040.exp3.json","id":102001,"lipSynch":0,"motion":300,"pos":0}],"nameLeft":"Kagome","textLeft":"...@..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":1,"pos":2}],"nameRight":"Torte","textRight":"What's wrong, Kagome?"},{"chara":[{"eyeClose":0,"id":102001}],"nameLeft":"Kagome","textLeft":"I'm getting overwhelmed with all the information@coming in..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831700,"pos":2}],"nameRight":"Nicolas","textRight":"Hmm, I see. Well, for now..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831700,"pos":2}],"nameRight":"Nicolas","textRight":"Shall we talk about what we're doing here?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402901,"motion":0,"pos":2}],"nameRight":"Perenelle","textRight":"Yes."},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

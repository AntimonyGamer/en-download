{"story":{"group_1":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":100,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_01","textHome":"Nice to meet you~!@It's me."}]},{"autoTurnFirst":5.0,"chara":[{"id":390100,"motion":1,"textHome":"I'm getting rid of bad guys now!@Once I'm done,"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":390100,"motion":200,"textHome":"those who are troubled by dreams involving@bad guys won't be troubled anymore!"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":0,"textHome":"So, I have to keep getting rid@of more and more bad guys."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100,"textHome":"I have to go find my next target!"}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":200,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_17","textHome":"Ghosts only come from the past."}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100,"textHome":"They don't come from the future."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":0,"textHome":"So why...can I only go to tomorrow?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":400,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_18","textHome":"I was a bad guy, so I became@a Magical Girl who does good."}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":390100}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":1,"textHome":"I was empty,@but Shii filled me up."}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_014.exp3.json","id":390100}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":4.0,"chara":[{"id":390100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":0,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_19","textHome":"Now that I can do more,@I'll try to do more!"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_014.exp3.json","id":390100,"motion":300,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_20","textHome":"Wow~...!@I really like this feeling...!"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":4.5,"chara":[{"id":390100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":1,"textHome":"I want more of it."}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":200,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_21","textHome":"Witches and bad guys@are all the same."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":390100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390100,"motion":300,"textHome":"Once you become one,@there's no turning back."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":100,"textHome":"So I have to get rid of them."}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":400,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_22","textHome":"There's no point hiding!"}]},{"autoTurnFirst":2.2,"chara":[{"id":390100,"motion":1,"textHome":"I'll find you,@and doors and walls won't protect you."}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390100,"textHome":"So just stay there."}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":200,"textHome":"If you accidentally tear yourself apart,@you'll get into trouble and it'll hurt...?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":1,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_23","textHome":"Where do those left behind go@when their story is over?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":200,"textHome":"Everything important has melted away."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"id":390100}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":400,"textHome":"There are only fakes left."}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_17":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":0,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_24","textHome":"We're together today too~."}]},{"autoTurnFirst":1.4,"chara":[{"cheek":1,"face":"mtn_ex_050.exp3.json","id":390100,"motion":200,"textHome":"Was it the same as yesterday?@Will it be the same tomorrow?!"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":390100,"motion":1,"textHome":"Maybe the day before yesterday too?"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390100,"textHome":"Maybe after tomorrow as well..."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":400,"textHome":"Wait, so even today too?!"}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":100,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_25","textHome":"Did you just say good morning~?"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":1,"textHome":"Oh, is it morning now?@I see."}]},{"autoTurnLast":0.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100,"textHome":"Wait...did I sleep?"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390100,"textHome":"What a pain."}]},{"autoTurnFirst":1.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":200,"textHome":"No, it isn't!@Aha! Morning!"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":390100,"motion":300,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_26","textHome":"I'm getting hungry..."}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":400,"textHome":"Wait?! Maybe I'm full?!@Which was it?"}]},{"autoTurnLast":1.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":0,"textHome":"It sucks not to know what's@inside of your tummy, doesn't it?"}]},{"autoTurnFirst":2.6,"chara":[{"eyeClose":1,"id":390100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":1,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_02","textHome":"Hey, I'm looking for bad guys.@Do you know where they are?"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390100}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":0,"textHome":"I have to get rid of them."}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":200}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":100,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_27","textHome":"Darkness is seeping in more and more."}]},{"autoTurnFirst":2.3,"chara":[{"id":390100,"motion":1,"textHome":"When I'm alone, it feels like@I'm melting away. You know?"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390100,"motion":300,"textHome":"So I'm getting rid of bad guys."}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":400,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_28","textHome":"Did you just say good evening...?"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100,"textHome":"Isn't good evening a signal@of the end of the day?!"}]},{"autoTurnFirst":3.8,"chara":[{"eyeClose":1,"id":390100,"motion":1,"textHome":"If we keep saying good evening,@can we stop tomorrow from coming...?"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":390100,"motion":200,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_29","textHome":"Sorry! I..."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":390100,"textHome":"What was I thinking about?"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":0,"textHome":"Do you know?@Can you tell me?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100,"textHome":"What a pain, what a pain."}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":400,"textHome":"Oh?@What was bothering me?"}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":0,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_30","textHome":"Do I really need magic@to get rid of Witches?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":300,"textHome":"I can just stab them."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":1,"textHome":"Let's do it together!"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100,"textHome":"It'll be okay, probably."}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":400,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_31","textHome":"If I go to the Endless Mirrors,@will I be able to meet myself?"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":200,"textHome":"I am not me!@I can meet me!@Where...am I?"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":100,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_32","textHome":"Wow!@So many nice smells!"}]},{"autoTurnFirst":0.9,"chara":[{"id":390100,"motion":1,"textHome":"They're coming from here and there!"}]},{"autoTurnFirst":1.4,"chara":[{"eyeClose":1,"id":390100}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":1.7,"chara":[{"id":390100}]},{"autoTurnFirst":3.3,"chara":[{"id":390100,"motion":400,"textHome":"I want to take them all for myself!"}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_26":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":300,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_33","textHome":"When I see a lovely neck,@I get all shivery and tingly..."}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":1,"id":390100}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100,"textHome":"It reminds me that I am Yuu."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390100,"motion":0,"textHome":"But I can't go anywhere as Yuu."}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":1,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_34","textHome":"There's a smell I like.@I can't remember it,@but I'm sure it's my favorite smell..."}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":390100,"motion":100,"textHome":"I love it.@I want to have it all for myself."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":390100,"motion":200,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_35","textHome":"Magical Girls have to@get rid of bad things, right?"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":1,"textHome":"And since I get rid of the bad guys@on my list, I'm a Magical Girl!"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":0,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_36","textHome":"Legs, arms...@Why not just rip them off@if they get worn out?"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":390100,"textHome":"New ones will grow back,@so it's okay!"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_014.exp3.json","id":390100,"motion":100,"textHome":"Want me to help?"}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":390100,"motion":300,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_03"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":3.4,"chara":[{"id":390100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":400}]}],"group_30":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":300,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_37","textHome":"Nagisa helps with my job."}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":390100,"textHome":"She's really kind..."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":5.0,"chara":[{"id":390100,"motion":100,"textHome":"I want to help her too..."}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":200,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_38","textHome":"Once the bad guys are gone,@Shii will feel relieved."}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":1,"textHome":"So I have to get rid of bad guys."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100,"textHome":"Hehe!@I'll keep doing it more and more."}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":400,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_39","textHome":"I got this from Shii."}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390100,"textHome":"It's my list!"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100,"textHome":"It has a meaning."}]},{"autoTurnFirst":3.0,"chara":[{"id":390100,"motion":0,"textHome":"That's why I decided to follow it."}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":100,"textHome":"I want to give her what she wants."}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":1,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_40","textHome":"No matter how many times time rewinds,@I'll do the same things!"}]},{"autoTurnFirst":2.2,"chara":[{"eyeClose":1,"id":390100,"textHome":"I don't want to pretend that@any failure or sadness was a lie!"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":200}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":390100,"motion":0,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_41","textHome":"No matter how many times I'm reborn,"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390100,"textHome":"once I meet you,@my life...ends..."}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":390100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":0,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_42","textHome":"What a pain...@Violence is no good!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":200}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":400,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_43","textHome":"I can't go back anymore,@'cause there's nothing left."}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":1,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_44","textHome":"If you're in a pinch,@why don't I lend you a hand?"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":100,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_45","textHome":"Alright, I've gotta get to the next one."}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp3.json","id":390100,"motion":0,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_46","textHome":"The end of the dream,@the end is here."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":1,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_04"}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390100,"motion":100}]}],"group_5":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":200,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_05"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390100}]}],"group_6":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":300,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_13","textHome":"Did something change in me?@Did everything change?"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":0,"textHome":"Did I become someone else...?"}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":100,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_14","textHome":"Did I change?"}]},{"autoTurnLast":3.4,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100,"motion":200,"textHome":"Am I not me anymore...?"}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":1,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_15","textHome":"If it's something I don't know,@I want to know it."}]},{"autoTurnLast":1.3,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390100,"textHome":"But maybe I don't want to know."}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":390100,"motion":0,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_00_16","textHome":"Nagisa loves cheese,@I love someone,@and that someone is me."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390100}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":400}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390100,"motion":1,"textHome":"Don't forget about cheese and@someone even when tomorrow comes."}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390100}]},{"chara":[{"id":390100,"textHomeStatus":"Clear"}]}]},"version":3}

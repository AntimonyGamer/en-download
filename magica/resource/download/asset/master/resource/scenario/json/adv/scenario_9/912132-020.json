_full_912132-020-24"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]I...was supporting Miss Akemi?"},{"chara":[{"id":810000,"voiceFullAuto":"fullvoice/section_104211/vo_full_912132-020-25"}],"nameAvRight":"Kyubey","textAvColorRGB":"255255255","textAvRight":"[fontSize:20]If that was planned by a previous@iteration of me, then it was a success."},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200900,"motion":0,"voiceFullAuto":"fullvoice/section_104211/vo_full_912132-020-26"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Wait, what are you...?"},{"chara":[{"id":810000,"voiceFullAuto":"fullvoice/section_104211/vo_full_912132-020-27"}],"nameAvRight":"Kyubey","textAvColorRGB":"255255255","textAvRight":"[fontSize:20]I think you have it in you."},{"chara":[{"id":810000,"voiceFullAuto":"fullvoice/section_104211/vo_full_912132-020-28"}],"nameAvRight":"Kyubey","textAvRight":"[fontSize:20]You could be the one to replace@Madoka Kaname."},{"chara":[{"id":200900,"voiceFullAuto":"fullvoice/section_104211/vo_full_912132-020-29"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Huh...?"},{"autoTurnLast":0.01,"bg":"black","item":[{"anchor":"skip","path":"resource/scenario/img/scene0/calender_day32.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"},{"path":"resource/scenario/img/scene0/film05_scene09_01.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"charaFront"}],"textAvClear":1,"turnChangeIn":"fadeIn"},{"autoTurnLast":1.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":1.0,"flashEffect":"flashWhiteSlow1","item":[{"path":"resource/scenario/img/scene0/film05_scene09_02.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"messageBack"}],"surround":"7017_homura_backtime"},{"autoTurnLast":0.01,"bg":"white","turnChangeIn":"whiteIn","turnChangeInTime":1.5},{"autoTurnLast":0.01,"turnChangeOut":"whiteOut"},{"autoTurnLast":0.01,"bg":"black","turnChangeIn":"fadeIn","t
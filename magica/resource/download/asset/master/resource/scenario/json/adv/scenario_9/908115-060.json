{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_23183.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":200904,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":240202,"motion":0,"pos":2,"soulGem":0}],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/calender_day15.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"turnChangeIn":"fadeIn"},{"bgm":"bgm01_anime02","chara":[{"id":200904,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-1"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Hey, Miss Miki?","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":240202,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-2"}],"nameAvRight":"Sayaka","textAvColor":"textSayaka","textAvRight":"[fontSize:20]Um, yeah?"},{"chara":[{"id":200904,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-3"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Weren't you at the hospital today?"},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp3.json","id":240202,"motion":100,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-4"}],"nameAvRight":"Sayaka","textAvColor":"textSayaka","textAvRight":"[fontSize:20]Oh... You saw me?"},{"chara":[{"id":200904,"motion":200,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-5"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]I was out on a cake delivery,@and I happened to see you there..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200904,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-6"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Were you there to visit that@childhood friend of yours?"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":240202,"motion":300,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-7"}],"nameAvRight":"Sayaka","textAvColor":"textSayaka","textAvRight":"[fontSize:20]Yep. But he was in the middle of@physical therapy, so I couldn't see him."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200904,"motion":100,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-8"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Oh.@Then, who was it that I saw...?"},{"autoTurnFirst":1.2,"autoTurnNoDelay":1,"bgmFadeOut":3000,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":240202,"lipSynch":0,"motion":1,"voiceFull":"fullvoice/section_104207/vo_full_908115-060-9"}],"nameAvRight":"Sayaka","textAvColor":"textSayaka","textAvRight":"[fontSize:20]Hm? You mean, Madoka?"},{"chara":[{"id":240202,"lipSynch":1}]},{"chara":[{"id":200904,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-10"},{"id":240202,"voiceFullStop":"fullvoice/section_104207/vo_full_908115-060-9"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]No, not her. Your other friend."},{"bgm":"bgm02_anime07","chara":[{"id":240202,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-11"}],"nameAvRight":"Sayaka","textAvColor":"textSayaka","textAvRight":"[fontSize:20]One of my other friends...?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200904,"motion":1,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-12"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Right. Don't you have another friend@besides Miss Kaname?"},{"chara":[{"id":200904,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-13"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]I've seen her sometimes at the hospital,@chatting away happily."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200904,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-14"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Oh wait!@That might not have been yesterday."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":240202,"motion":100,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-15"}],"nameAvRight":"Sayaka","textAvColor":"textSayaka","textAvRight":"[fontSize:20]Do you mean...Hitomi?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200904,"motion":0,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-16"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]W-wait?"},{"chara":[{"id":200904,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-17"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Did I...say something I shouldn't have?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":240202,"motion":0,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-18"}],"nameAvRight":"Sayaka","textAvColor":"textSayaka","textAvRight":"[fontSize:20]No.@...It's fine."},{"chara":[{"id":240202,"lipSynch":0,"motion":300,"voiceFullAuto":"fullvoice/section_104207/vo_full_908115-060-19"}],"nameAvRight":"Sayaka","textAvRight":"[fontSize:20]......"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

{"story":{"group_1":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":0,"pos":1,"voice":"vo_char_2103_00_01","textHome":"I, Ultimate Madoka-senpai,@have awakened my ultimate powers@and powered up."}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":200}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"textHome":"A lot of features were added,"}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":100,"textHome":"but most importantly,@my chances of winning in a match of@paper sumo are considerably higher now."}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":400,"textHome":"Look forward to the unbeatable@Ultimate Madoka-senpai!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":101,"textHome":"When I lose, I become a stuffed bear!"}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210300,"motion":1,"pos":1,"voice":"vo_char_2103_00_17","textHome":"Now to reveal secret number 2!"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":101,"textHome":"This one's about the equipment I'm wearing."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":210300,"motion":400,"textHome":"These may look like@run-of-the-mill jet shoes,"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":200,"textHome":"but if I'm feeling up to it,@I can break the sound barrier@and even exit the atmosphere."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210300,"motion":1,"pos":1,"voice":"vo_char_2103_00_18","textHome":"You know the drill, it's secret number 3!"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":400,"textHome":"Our final installment covers the@combat fireworks: my beam weapon."}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":0,"textHome":"Believe it or not, this beam can deliver@the kind of massage that heals@all your combat-related fatigue!"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":200}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":0,"pos":1,"voice":"vo_char_2103_00_19","textHome":"Huh?@Did my wings just grow bigger?"}]},{"autoTurnFirst":5.0,"chara":[{"id":210300,"motion":101}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":100,"pos":1,"voice":"vo_char_2103_00_20","textHome":"Since you've been helping me grow stronger,@I'm gonna tell you a secret every now and then."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":0,"pos":1,"voice":"vo_char_2103_00_21","textHome":"Why do I feel that I've been@wearing this since forever...@Actually..."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210300,"motion":300,"textHome":"I don't know how to take this off..."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_054.exp.json","id":210300,"motion":200,"textHome":"What should I do?@Am I gonna be like this@for the rest of my life?"}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":100,"pos":1,"voice":"vo_char_2103_00_22","textHome":"As thanks for upgrading me this far,@I'll let you in on an extra-secret..."}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":400,"textHome":"See..."}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":101,"textHome":"I actually float a little bit!@Pretty cool, huh?"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210300,"motion":0,"textHome":"And just to be clear, I mean@I physically float, not like@stick out from my friends group."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":6.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":1,"pos":1,"voice":"vo_char_2103_00_23","textHome":"Well, Ultimate Madoka makes@five implementations of me@in the MagiReco-verse."}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":100,"textHome":"They gave me my own background art,@and I've got plenty of power@thanks to all of my level ups."}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":200}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300,"textHome":"Think we should take over@the MagiReco-verse while we're at it?"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":400,"textHome":"Now now, that'll be our little secret!"}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_17":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":101,"pos":1,"voice":"vo_char_2103_00_24","textHome":"'Sup! Ultimate Madoka-senpai here!@Which feature should I show you today?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":0,"textHome":"Giantification...?@I don't have that one."}]},{"autoTurnFirst":5.0,"chara":[{"id":210300,"motion":300,"textHome":"Want me to call Iroha-chan over here?"}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":0,"pos":1,"voice":"vo_char_2103_00_25","textHome":"Good morning!@Despite having lots of features,"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210300,"motion":300,"textHome":"the ultimate dress@doesn't have an alarm clock."}]},{"autoTurnFirst":5.0,"chara":[{"id":210300,"motion":100,"textHome":"I think I'll ask for one to be added."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":0,"pos":1,"voice":"vo_char_2103_00_26","textHome":"Curry udon for lunch, huh..."}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":100,"textHome":"No need to worry.@On the off chance that I end up@making a huge mess,"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":200,"textHome":"my ultimate power@will take care of the cleaning."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":200,"pos":1,"voice":"vo_char_2103_00_02","textHome":"I'm Madoka-senpai,@bearer of the Ultimate Power!"}]},{"autoTurnFirst":0.9,"chara":[{"cheek":0,"face":"mtn_ex_054.exp.json","id":210300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":0,"textHome":"What does it mean to be ultimate?"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":400,"textHome":"It means that my time on-screen@is higher than before!"}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":300,"pos":1,"voice":"vo_char_2103_00_27","textHome":"Eureka...@The ultimate ramen!"}]},{"autoTurnFirst":2.4,"chara":[{"id":210300,"motion":400}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":101,"textHome":"It comes in two flavors:@ultimate shoyu flavor@and ultimate miso flavor."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300,"textHome":"That way you can alternate between them@each day and won't get tired of the taste."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210300,"motion":200,"pos":1,"voice":"vo_char_2103_00_28","textHome":"Feel safe on the streets at night@with these ultimate eye lights!"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210300,"motion":0,"textHome":"...Is what I would say@if I had them equipped,"}]},{"autoTurnFirst":5.0,"chara":[{"id":210300,"motion":300,"textHome":"but I sealed them away since@I couldn't see anything in front of me@with them shining from my eyes."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":101,"pos":1,"voice":"vo_char_2103_00_29","textHome":"Bored~?@How 'bout we play the ultimate game?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":100,"textHome":"Hit Felicia-chan and cover;@Rock, Paper, Scissors!"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":0,"textHome":"If you lose, you'll lose your memory."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":400,"pos":1,"voice":"vo_char_2103_00_30","textHome":"Finally, all five of me are here."}]},{"autoTurnFirst":5.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":1,"textHome":"Mado-cancer, Mado-cannon,@Producer, Aloha,"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":210300,"motion":200,"textHome":"and last but not least, my ultimate self."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":210300,"textHome":"...Huh?@That's too many?"}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":0,"pos":1,"voice":"vo_char_2103_00_31","textHome":"You don't know which copy is the real one?"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":1,"textHome":"Just touch the bottom of my dress...@There's no way that this@ultimate texture can be copied."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":100}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":210300,"motion":0,"pos":1,"voice":"vo_char_2103_00_32","textHome":"So we gotta fight a bunch@of Magical Girls, huh."}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":200,"textHome":"Iroha-chan, mind if you go@giant mode for me for a bit?"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":101,"textHome":"I'll turn you back@with the whole shebang afterward."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_26":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":300,"pos":1,"voice":"vo_char_2103_00_33","textHome":"Do I look more mature?"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"textHome":"That's because I'm a teenager!"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":0,"textHome":"My hair grew longer@compared to my normal self?"}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":200,"textHome":"That's also because I'm a teenager!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210300,"textHome":"That's what being a teenager@is all about, yeah?"}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":101,"pos":1,"voice":"vo_char_2103_00_34","textHome":"Do you think my enhanced armor@looks very robotic?"}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_054.exp.json","id":210300,"motion":400,"textHome":"\"ME MADOKA.@FIGHT, ENEMY, DESTROY.\""}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":100,"textHome":"I wonder if I should speak like that."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":200,"pos":1,"voice":"vo_char_2103_00_35","textHome":"Because I've obtained the ultimate power,@I got a new paper sumo wrestler."}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":0,"textHome":"What does it look like?"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":400,"textHome":"You'll have to play my@Magical Girl Story to find out!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":100,"textHome":"Shameless plug~♪"}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":101,"pos":1,"voice":"vo_char_2103_00_36","textHome":"Iroha-chan said that back at her place,@they hit anything that's broken to fix them."}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":1,"textHome":"When I told her that my family@just sends things to repair services,@she looked really shocked."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210300,"motion":0}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":0,"pos":1,"voice":"vo_char_2103_00_03","textHome":"Honor?@Iroha-chan, even with honor...@You'll never get what you want."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210300,"motion":300}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_30":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":101,"pos":1,"voice":"vo_char_2103_00_37","textHome":"Where did she get all that honor?"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":100,"textHome":"Did she take it as payment for adjustments?"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_053.exp.json","id":210300,"motion":0,"textHome":"I say that as a joke,@but maybe it IS that."}]},{"autoTurnFirst":5.0,"chara":[{"id":210300,"motion":200}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":300,"pos":1,"voice":"vo_char_2103_00_38","textHome":"It's nice how Ui-chan can look@so well-behaved and also be so bold."}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":100,"textHome":"I asked her about what she uses@the Big Sister Discipline Stick for..."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_053.exp.json","id":210300,"motion":0,"textHome":"But I can't really talk about it here."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":101,"pos":1,"voice":"vo_char_2103_00_39","textHome":"Don't worry, Homura-chan.@It doesn't matter what kind of powers@I have, I will always be myself."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":400,"textHome":"Now, let's go eat some of the usual ramen."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210300,"motion":200,"pos":1,"voice":"vo_char_2103_00_40","textHome":"I want to save everyone...@Everyone that lives in despair@because of the gacha...!"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210300,"motion":0,"textHome":"But, honestly?@Iroha-chan seems like the only one@who's beyond saving..."}]},{"autoTurnFirst":5.0,"chara":[{"id":210300,"motion":300,"textHome":"Sorry."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":300,"pos":1,"voice":"vo_char_2103_00_41","textHome":"If I give this feather to Tatsuya,@he might transform into@\"Ultimate Tatsuya\"..."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":210300,"motion":400,"textHome":"He'll probably be even stronger than me."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":400,"pos":1,"voice":"vo_char_2103_00_42","textHome":"My ultimate self@is going to be your opponent!"}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210300,"motion":100,"pos":1,"voice":"vo_char_2103_00_43","textHome":"Let's head back before@the ultimate ramen gets cold."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":0,"pos":1,"voice":"vo_char_2103_00_44","textHome":"The material you were looking for...@didn't drop."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":210300}]},{"autoTurnFirst":3.0,"chara":[{"id":210300,"motion":300,"textHome":"What a cruel world..."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210300,"motion":0,"pos":1,"voice":"vo_char_2103_00_45","textHome":"Ultimaaaate!@And, strike a pose!"}]},{"autoTurnFirst":1.1,"chara":[{"id":210300,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210300,"motion":0,"pos":1,"voice":"vo_char_2103_00_46","textHome":"The ultimate dress...@I can't imagine fighting@without this anymore."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_053.exp.json","id":210300,"motion":200}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210300,"motion":200,"pos":1,"voice":"vo_char_2103_00_04","textHome":"I'm gonna win by any means necessary.@Don't blame me, Sayaka-chan."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":100}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_5":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":0,"pos":1,"voice":"vo_char_2103_00_05","textHome":"I hope to have your vote@in the next leader election!"}]},{"autoTurnFirst":5.0,"chara":[{"id":210300,"motion":200}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_6":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":0,"pos":1,"voice":"vo_char_2103_00_13","textHome":"I've... Or uh, actually..."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":101,"textHome":"The ultimate dress's features@have been enhanced, looks like."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":210300,"motion":300,"pos":1,"voice":"vo_char_2103_00_14","textHome":"Is there anything after \"ultimate\"?"}]},{"autoTurnFirst":5.0,"chara":[{"id":210300,"motion":400,"textHome":"I already have the ultimate power."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_054.exp.json","id":210300,"motion":300,"pos":1,"voice":"vo_char_2103_00_15","textHome":"Did you know?@I've only shown up in Magia Report@in this form for one panel..."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":210300,"motion":0,"textHome":"Not much else to say about it."}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":210300,"motion":1,"pos":1,"voice":"vo_char_2103_00_16","textHome":"Here's Ultimate Madoka-senpai's@secret number 1!"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_013.exp.json","id":210300,"motion":100,"textHome":"This ultimate dress is actually@a scientific suit of armor@that runs on magic power."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":210300,"motion":200,"textHome":"It can make passers-by do a triple-take!"}]},{"chara":[{"id":210300,"textHomeStatus":"Clear"}]}]},"version":3}

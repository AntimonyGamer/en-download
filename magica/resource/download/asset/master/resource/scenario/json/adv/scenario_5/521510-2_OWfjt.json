{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_20021.jpg","turnChangeIn":"fadeIn"},{"autoTurnLast":2.5,"turnChangeOut":"fadeOut"},{"autoTurnLast":2.5,"bg":"bg_adv_20023.jpg","bgChangeEffect":"fade"},{"autoTurnLast":2.5,"bg":"bg_adv_20021.jpg","bgChangeEffect":"fade"},{"autoTurnLast":2.5,"bg":"bg_adv_20023.jpg","bgChangeEffect":"fade"},{"autoTurnLast":0.5,"bg":"bg_adv_21593.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104300,"motion":1,"pos":1}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story06","chara":[{"eyeClose":1,"id":104300}],"nameCenter":"Kuroe","textCenter":"Phew...","turnChangeOut":"fadeOut"},{"chara":[{"id":104300,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(No sign of any Witches in this area, either...)"},{"chara":[{"eyeClose":0,"id":104300,"lipSynch":0,"motion":100}],"nameCenter":"Kuroe","textCenter":"(Which is a good thing, but...)"},{"chara":[{"id":104300,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(It also means I can't help people like Tamaki-san@did...)"},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":104300}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_21593.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":770602,"motion":300,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":770700,"motion":1,"pos":2}],"nameLeft":"","textLeft":"Psst, hey, that's her, isn't it? Lookie there, do you@see her?"},{"chara":[{"id":770700}],"nameRight":"","textRight":"The girl who's rumored to be poaching Witches@in other people's territory?"},{"chara":[{"id":770602,"motion":200}],"nameLeft":"","textLeft":"Yeah, yeah, that's the one."},{"chara":[{"id":770700}],"nameRight":"","textRight":"How curious. I must say, this is the first time@I've spotted her around here..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":770602},{"effect":"fadeout","id":770700}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104300,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"Kuroe","textCenter":"..."},{"chara":[{"id":104300,"lipSynch":0,"motion":300}],"nameCenter":"Kuroe","textCenter":"(I guess I stood out too much after all, huh...)"},{"chara":[{"id":104300,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(Not like there's anything I can do about it,@though.)"},{"chara":[{"id":104300,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(It's a Magical Girl's duty to help people...)"},{"chara":[{"eyeClose":1,"id":104300,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(...so we can't get hung up on territory...)"},{"autoTurnLast":0.2,"chara":[{"eyeClose":0,"id":104300,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":770602,"motion":0,"pos":2}],"nameRight":"","textRight":"Hey, you."},{"chara":[{"id":770602}],"nameRight":"","textRight":"I don't think you're in charge of this area,@are you?"},{"chara":[{"id":104300,"lipSynch":1,"motion":100}],"nameLeft":"Kuroe","textLeft":"...There aren't any Witches on my side of town,@so..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":770700,"motion":400,"pos":2}],"nameRight":"","textRight":"Ooh, goodness gracious!"},{"chara":[{"id":770700}],"nameRight":"","textRight":"Don't tell me you don't even know the rules@around territory?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":770602,"motion":1,"pos":2}],"nameRight":"","textRight":"Or are you looking to hog all the Grief Seeds for@yourself?"},{"chara":[{"id":104300,"motion":200}],"nameLeft":"Kuroe","textLeft":"That's not it..."},{"chara":[{"id":104300}],"nameLeft":"Kuroe","textLeft":"I just wanted to defeat Witches..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":770700,"motion":0,"pos":2}],"nameRight":"","textRight":"...My, my, what's this? Er, are you going to be@alright?"},{"chara":[{"id":104300,"motion":0}],"nameLeft":"Kuroe","textLeft":"Eh...?"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":770602,"motion":0,"pos":2}],"nameRight":"","textRight":"Your Soul Gem, it's kind of cloudy? Or it looks@that way..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":770700,"motion":300,"pos":2}],"nameRight":"","textRight":"Are you having trouble getting enough@Grief Seeds, perhaps?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":770602,"motion":1,"pos":2}],"nameRight":"","textRight":"Wanna talk about it?"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":104300,"motion":1,"pos":0}],"nameLeft":"Kuroe","textLeft":"I've got Grief Seeds, but... The Automatic@Purification System is up, too."},{"chara":[{"id":104300}],"nameLeft":"Kuroe","textLeft":"I'll be fine."},{"chara":[{"eyeClose":1,"id":104300,"lipSynch":0,"motion":300}],"nameLeft":"Kuroe","textLeft":"(That's the hope that Tamaki-san created for@Magical Girls like us...)"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":104300,"lipSynch":0}],"nameLeft":"Kuroe","textLeft":"(We don't even need Grief Seeds at all anymore,@truthfully...)"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":770602,"motion":300,"pos":2}],"nameRight":"","textRight":"Then...why are you so fixated on beating@Witches?"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":104300,"lipSynch":1,"motion":0}],"nameLeft":"Kuroe","textLeft":"I'm just trying to save as many people as I can..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104300,"motion":200,"pos":0}],"nameLeft":"Kuroe","textLeft":"Um, I'm really sorry about all of this. I'll get@going now."},{"chara":[{"id":104300,"motion":0}],"nameLeft":"Kuroe","textLeft":"Well, see y..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":770602,"motion":0,"pos":2}],"nameRight":"","textRight":"Ah, wait, wait."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":770700,"motion":1,"pos":2}],"nameRight":"","textRight":"We ran into this other girl who said she was was@scouring the city for..."},{"chara":[{"id":770700}],"nameRight":"","textRight":"...\"a Magical Girl in a black hood who does@her best to help others\"."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":770602,"motion":300,"pos":2}],"nameRight":"","textRight":"Any chance that's you...?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104300,"lipSynch":0}],"nameLeft":"Kuroe","textLeft":"...? [wait:1.0][chara:104300:cheek_0][chara:104300:face_mtn_ex_000.exp3.json][chara:104300:lipSynch_1]I think you've got the wrong person?"},{"chara":[{"id":104300,"motion":100}],"nameLeft":"Kuroe","textLeft":"I'm not that kind of Magical Girl..."},{"autoTurnLast":0.8,"chara":[{"effect":"fadeout","id":104300}],"textClear":1},{"autoTurnLast":3.0,"bg":"bg_adv_21723.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104301,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":104301,"lipSynch":0}],"nameCenter":"Kuroe","surround":"7009_night_townbuzz","textCenter":"...","turnChangeOut":"fadeOut"},{"chara":[{"id":104301,"lipSynch":1,"motion":300}],"nameCenter":"Kuroe","textCenter":"...*Sigh* What a headache..."},{"chara":[{"id":104301,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(All I want to do is defeat Witches...)"},{"chara":[{"id":104301,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(...but I don't know if my current method is going@to cut it...)"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":104301,"lipSynch":0,"motion":1}],"nameCenter":"Kuroe","textCenter":"(This might be a reach, but...)"},{"chara":[{"eyeClose":1,"id":104301,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(Maybe I should keep an eye out for places where@Witches are likely to spawn...?)"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":104301,"lipSynch":1}],"nameCenter":"Kuroe","textCenter":"But how am I going to..."},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":104301}],"textClear":1},{"bgm":"bgm05_event07","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":800101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":800203,"motion":0,"pos":2}],"nameLeft":"","surround":"stop","textLeft":"Woah, breaking news. Says there's been another@robbery."},{"chara":[{"id":800203}],"nameRight":"","textRight":"Here in Takarazaki? Hasn't that been happening@a lot these days?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800101}],"nameLeft":"","textLeft":"This city's security has been taking a nosedive,@huh?"},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":800101},{"effect":"fadeout","id":800203}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":104301,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"Kuroe","textCenter":"..."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":104301,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(Fraud and robbery cases are on the rise in@Takarazaki...)"},{"chara":[{"id":104301,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(Magical Girls can't exactly help with that,@though.)"},{"chara":[{"id":104301,"lipSynch":0,"motion":100}],"nameCenter":"Kuroe","textCenter":"(Then again, the rates have been skyrocketing...)"},{"chara":[{"id":104301,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(What if a Witch is behind all of this?)"},{"chara":[{"eyeClose":1,"id":104301,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(I completely glossed over that possibility until@just now.)"},{"chara":[{"eyeClose":1,"id":104301,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(Maybe the culprit is a Witch that's really good@at hiding her magic signature...?)"},{"chara":[{"eyeClose":0,"id":104301,"lipSynch":0,"motion":0}],"nameCenter":"Kuroe","textCenter":"(Might be worth looking into...right?)"},{"autoTurnLast":2.0,"bgm":"stop","turnChangeIn":"fadeIn"}]},"version":3}

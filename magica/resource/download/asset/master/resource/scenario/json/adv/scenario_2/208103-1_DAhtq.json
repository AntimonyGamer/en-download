{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"white","bgm":"bgm20_song10","chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":0,"pos":1,"soulGem":0}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":102001}],"nameCenter":"Kagome","textCenter":"The interview with Shizuka...or rather,@the Tokime Clan, was tough...","turnChangeOut":"fadeOut"},{"chara":[{"id":102001,"motion":300}],"nameCenter":"Kagome","textCenter":"However, there are some things that can only be@understood through conversations like that..."},{"chara":[{"id":102001}],"nameCenter":"Kagome","textCenter":"...Yeah... At least, I think so, probably..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102001,"motion":1}],"nameCenter":"Kagome","textCenter":"Still, it was fulfilling to experience their pure hearts..."},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":102001,"motion":0,"pos":1}],"nameCenter":"Kagome","textCenter":"...So, the next group I heard from was..."},{"bg":"black","bgm":"stop","nameNarration":"","narration":"<Puella Care>","narrationBg":"black","narrationEffect":"in"},{"autoTurnLast":1.0,"bg":"bg_adv_14113.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104100,"motion":0,"pos":1}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm23_puella01","chara":[{"id":104100,"motion":300}],"nameCenter":"Livia","textCenter":"...*Sigh*@I'm exhausted...","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"id":104100,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":102001,"motion":0,"pos":2,"soulGem":0}],"nameRight":"Kagome","textRight":"Miss Livia."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104100,"motion":400,"pos":0}],"nameLeft":"Livia","textLeft":"Ah, sorry for making you wait."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102001,"motion":100,"pos":2}],"nameRight":"Kagome","textRight":"The Puella Care trailer has been a huge success."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104100,"motion":1,"pos":0}],"nameLeft":"Livia","textLeft":"Seriously, I can't handle it~..."},{"chara":[{"id":104100}],"nameLeft":"Livia","textLeft":"What with Mitama gone an' all,@there simply aren't enough Coordinators in town."},{"chara":[{"id":104100,"motion":300}],"nameLeft":"Livia","textLeft":"After what happened..."},{"autoTurnLast":1.0,"bg":"bg_adv_11061.jpg","chara":[{"cheek":-1,"eyeClose":1,"face":"mtn_ex_060.exp3.json","id":100401,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104100,"motion":0,"pos":0}],"item":[{"path":"resource/scenario/img/51030_fishing_homura/51030_homura_dairy.jpg","visible":"hide"}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":100401}],"nameRight":"Sana","textRight":"Um...","turnChangeOut":"fadeOut"},{"chara":[{"id":104100,"motion":300}],"nameLeft":"Livia","textLeft":"This ain't good. Wounds that deep are gonna@burn through a ton of magic..."},{"chara":[{"id":104100}],"nameLeft":"Livia","textLeft":"She'll run out before she can heal up..."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":104000,"motion":100,"pos":2}],"nameRight":"Yozuru","textRight":"Does she require a Grief Seed?"},{"chara":[{"id":104100,"motion":1}],"nameLeft":"Livia","textLeft":"I guess we gotta purify her before anythin' else..."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103900,"lipSynch":0,"motion":100,"pos":2}],"nameRight":"Sudachi","textRight":"Fumu, fumunmu fumu!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104100}],"nameLeft":"Livia","textLeft":"Thanks, Sudachi."},{"chara":[{"cheek":-1,"face":"mtn_ex_031.exp3.json","id":100401,"motion":0,"pos":2}],"nameRight":"Sana","textRight":"I'll...pay you back...later..."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":104000,"motion":1,"pos":0}],"nameLeft":"Yozuru","textLeft":"If you wish to return to the front lines as soon@as possible, stay quiet and let us treat you."},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":102501,"motion":100,"pos":2}],"nameRight":"Shizuka","textRight":"I'll give you one of my Devil's Souls."},{"chara":[{"eyeClose":1,"id":104000}],"nameLeft":"Yozuru","textLeft":"Much obliged."},{"autoTurnLast":0.01,"bg":"bg_adv_14113.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104100,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_001.exp3.json","id":102001,"motion":0,"pos":2,"soulGem":0}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":104100,"motion":300}],"nameLeft":"Livia","textLeft":"Apparently our actions back then have become the@talk of the town.","turnChangeOut":"fadeOut"},{"chara":[{"id":104100}],"nameLeft":"Livia","textLeft":"That's probably what all the fuss is about."},{"chara":[{"id":102001,"motion":300}],"nameRight":"Kagome","textRight":"I see..."},{"chara":[{"id":104100,"motion":100}],"nameLeft":"Livia","textLeft":"Supposedly some...\"influencers\"? Spread the word@around."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":400,"pos":2}],"nameRight":"Kagome","textRight":"Influencers?!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104100,"pos":0}],"nameLeft":"Livia","textLeft":"...You got all flustered, what's wrong?"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":1,"pos":2}],"nameRight":"Kagome","textRight":"Ah, no, no, it's nothing...!"},{"chara":[{"id":104100,"motion":200}],"nameLeft":"Livia","textLeft":"...Hmm..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104100,"pos":0}],"nameLeft":"Livia","textLeft":"Well, anyways, we've been super busy all day and@night."},{"chara":[{"id":102001,"motion":200}],"nameRight":"Kagome","textRight":"I'm sorry, I didn't mean to interrupt you at a time@like this..."},{"chara":[{"id":104100,"motion":1}],"nameLeft":"Livia","textLeft":"Nah, it's okay. This'll give me a break as well."},{"chara":[{"id":104100}],"nameLeft":"Livia","textLeft":"...So, where should we start?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":104100},{"effect":"fadeout","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103900,"lipSynch":0,"motion":400,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":104000,"motion":0,"pos":0}],"nameRight":"Sudachi","textRight":"Fumumumumu!"},{"chara":[{"id":104000,"motion":100}],"nameLeft":"Yozuru","textLeft":"Excuse us for interrupting..."},{"chara":[{"id":104000}],"nameLeft":"Yozuru","textLeft":"\"Coming through!\" That's what she said."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":103900},{"effect":"fadeout","id":104000}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104100,"motion":200,"pos":0},{"cheek":0,"face":"mtn_ex_001.exp3.json","id":102001,"lipSynch":0,"motion":0,"pos":2,"soulGem":0}],"nameLeft":"Livia","textLeft":"Ah, Sudachi, Yozuru."},{"chara":[{"id":104100}],"nameLeft":"Livia","textLeft":"I have to talk to Kagome, so please@take care of things over there."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":104100},{"effect":"fadeout","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":103900,"lipSynch":0,"motion":300,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":104000,"motion":0,"pos":0}],"nameRight":"Sudachi","textRight":"...Fumumu..."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":104000,"motion":300}],"nameLeft":"Yozuru","textLeft":"...Yes..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":103900},{"effect":"fadeout","id":104000}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"lipSynch":0,"motion":0,"pos":2,"soulGem":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104100,"motion":0,"pos":0}],"nameRight":"Kagome","textRight":"(...Huh...?)"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104100,"motion":100,"pos":0}],"nameLeft":"Livia","textLeft":"...Did you notice?"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":200,"pos":2}],"nameRight":"Kagome","textRight":"Ah, no..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104100,"motion":200,"pos":0}],"nameLeft":"Livia","textLeft":"It's so obvious, isn't it?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104100,"pos":0},{"id":102001,"motion":0}],"nameLeft":"Livia","textLeft":"After that last incident, how busy we are ain't@the only thing that's changed..."},{"chara":[{"id":104100,"motion":300}],"nameLeft":"Livia","textLeft":"The atmosphere between us has changed too..."},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

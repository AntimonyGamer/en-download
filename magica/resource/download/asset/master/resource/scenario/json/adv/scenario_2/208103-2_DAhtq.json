{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_14113.jpg","bgm":"bgm23_puella04","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104100,"motion":200,"pos":0},{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":0,"pos":2,"soulGem":0}],"turnChangeIn":"fadeIn"},{"chara":[{"id":104100}],"nameLeft":"Livia","textLeft":"After that last incident, how busy we are ain't@the only thing that's changed...","turnChangeOut":"fadeOut"},{"chara":[{"id":104100,"motion":300}],"nameLeft":"Livia","textLeft":"The atmosphere between us has changed too..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":100,"pos":2}],"nameRight":"Kagome","textRight":"Why is that...?"},{"chara":[{"id":104100,"motion":100}],"nameLeft":"Livia","textLeft":"Hmmm...well..."},{"autoTurnLast":1.0,"bg":"bg_adv_14121.jpg","chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":104000,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_041.exp3.json","id":104101,"motion":0,"pos":0}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":104000,"motion":300}],"nameRight":"Yozuru","textRight":"Besides, adjusting you made Sudachi@and I feel worse.","turnChangeOut":"fadeOut"},{"chara":[{"id":104000}],"nameRight":"Yozuru","textRight":"Neither of us was in the right mental state@to do anything."},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103900,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104101}],"textClear":1},{"autoTurnLast":2.5,"chara":[{"eyeClose":1,"id":103900}],"flashEffect":"flashWhiteSlow2"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103900,"lipSynch":0,"motion":400}],"nameRight":"Sudachi","textRight":"Fumu?!"},{"chara":[{"cheek":0,"face":"mtn_ex_060.exp3.json","id":103900,"lipSynch":0,"motion":300}],"nameRight":"Sudachi","textRight":"*Whimper*...!"},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":103900}],"se":"3002_chara_dead","textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104101,"motion":300,"pos":0}],"nameLeft":"Livia","textLeft":"If the sight a' my past makes you drop like a stone,@you don't gotta help, ya know...?"},{"chara":[{"id":104101}],"nameLeft":"Livia","textLeft":"Back when I wished to \"become evil itself\"..."},{"chara":[{"eyeClose":1,"id":104101}],"nameLeft":"Livia","textLeft":"Seein' that's gotta make ya feel bad..."},{"autoTurnLast":1.0,"bg":"bg_adv_14113.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":2,"soulGem":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104100,"motion":1,"pos":0}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm23_puella02","chara":[{"id":102001,"motion":400}],"nameRight":"Kagome","textRight":"Miss Livia's past...","turnChangeOut":"fadeOut"},{"chara":[{"id":104100,"motion":300}],"nameLeft":"Livia","textLeft":"I only briefly touched on it, but..."},{"chara":[{"id":104100}],"nameLeft":"Livia","textLeft":"Those two know that I've been lying to them both."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104100,"motion":400,"pos":0}],"nameLeft":"Livia","textLeft":"...Ah, but I wasn't lying because I was trying to@deceive them! "},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104100,"pos":0}],"nameLeft":"Livia","textLeft":"It's more like the lie was a consequence of@necessary means..."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":200,"pos":2}],"nameRight":"Kagome","textRight":"Yet, they're still friendly with you..."},{"chara":[{"id":104100,"motion":300}],"nameLeft":"Livia","textLeft":"How should I put this...@It looks like you're feeling confused."},{"chara":[{"id":102001}],"nameRight":"Kagome","textRight":"Perhaps they have some lingering resentment..."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":104100,"motion":100,"pos":0}],"nameLeft":"Livia","textLeft":"Yeah, that's it."},{"chara":[{"id":104100}],"nameLeft":"Livia","textLeft":"My past ain't exactly something I'm upfront about@very often."},{"chara":[{"id":104100}],"nameLeft":"Livia","textLeft":"So, as far as I'm concerned,@I did what was necessary."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104100,"motion":200,"pos":0}],"nameLeft":"Livia","textLeft":"Even so, they're both still sticking with me."},{"chara":[{"id":104100}],"nameLeft":"Livia","textLeft":"Thank heavens for that."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":102001,"lipSynch":0,"motion":0}],"nameRight":"Kagome","textRight":"..."},{"chara":[{"id":102001}],"nameRight":"Kagome","textRight":"...Um..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104100,"motion":400,"pos":0}],"nameLeft":"Livia","textLeft":"Wait, wait, remember what I just said?"},{"chara":[{"id":104100}],"nameLeft":"Livia","textLeft":"Even for me, it's not something I can talk about so@casually. "},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104100,"pos":0}],"nameLeft":"Livia","textLeft":"My past is just..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102001,"motion":400,"pos":2}],"nameRight":"Kagome","textRight":"Y...Yes... I'm sorry!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104100,"motion":1,"pos":0}],"nameLeft":"Livia","textLeft":"Ah, it's okay. I'm sorry too."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":104100,"motion":100,"pos":0}],"nameLeft":"Livia","textLeft":"It probably feels like I'm just hinting and hinting@at it, but not saying anything."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104100,"pos":0}],"nameLeft":"Livia","textLeft":"Eventually, the right time will come."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104100,"motion":300}],"nameLeft":"Livia","textLeft":"When that time comes, I'll have to tell Sudachi@and Yozuru properly."},{"chara":[{"eyeClose":1,"id":104100}],"nameLeft":"Livia","textLeft":"It sounds formal to say I have a responsibility@to do so, but..."},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":104100,"motion":0}],"nameLeft":"Livia","textLeft":"I have to draw the line somewhere, don't I?"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":102001,"lipSynch":0,"motion":1}],"nameRight":"Kagome","textRight":"..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104100,"motion":200,"pos":0}],"nameLeft":"Livia","textLeft":"...Oh yeah!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104100,"pos":0}],"nameLeft":"Livia","textLeft":"I'd like to ask a few questions, too."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":300,"pos":2}],"nameRight":"Kagome","textRight":"Huh? To who?"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":104100,"motion":100,"pos":0}],"nameLeft":"Livia","textLeft":"Hehehe..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104100,"pos":0}],"nameLeft":"Livia","textLeft":"To you."},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

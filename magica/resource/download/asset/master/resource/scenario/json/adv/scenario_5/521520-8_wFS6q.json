Close":1,"id":104300,"lipSynch":1,"motion":400,"mouthOpen":1}],"nameCenter":"Kuroe","textBg":"shout","textCenter":"[flashEffect:flashWhite2][chara:104300:effect_shake]...ngh, aaaAAAAAaaAH!!","turnEffect":"blackPromist"},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":104300}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_21932.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390100,"motion":400,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390201,"motion":0,"pos":0}],"nameRight":"Yuu","textRight":"That's probably a huge threat, huh?! Shii!@Let's run away for now!"},{"chara":[{"id":390201,"motion":400}],"nameLeft":"Shii","textLeft":"Ah...wait for me...!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":390201},{"effect":"fadeout","id":390100}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_21932.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp3.json","id":200700,"motion":400,"pos":1}],"nameCenter":"Nagisa","textCenter":"Th-th-this is REALLY bad news!"},{"chara":[{"id":200700}],"nameCenter":"Nagisa","textCenter":"I blew it big time!"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":200700,"motion":100,"pos":1}],"nameCenter":"Nagisa","textCenter":"And how long are YOU gonna sleep for?!"},{"autoTurnLast":0.2,"chara":[{"id":200700,"motion":0,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104700,"motion":0,"pos":2}],"nameRight":"","textRight":"Ooh...ungh..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104700,"mouthOpen":1}],"nameRight":"","textRight":"...W-wait, what the—?!"},{"chara":[{"id":200700,"motion":200},{"id":104700,"mouthOpen":0}],"nameLeft":"Nagisa","textLeft":"Kuroe's about to get swallowed up by her own@Doppel!"},{"chara":[{"id":104700,"lipSynch":0}],"nameRight":"","textRight":"...!"},{"autoTurnLast":0.5,"chara":[{"effect":"slideOutLeftFast","id":104700},{"cheek":0,"face":"mtn_ex_051.exp3.json","id":200700}],"t
{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_46124.jpg","item":[{"path":"resource/scenario/img/51215_tower_iroha_kuroe/51215_Ichizo.png","posX":0,"posY":-30,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"autoTurnLast":0.1,"bgm":"bgm01_anime15","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bgEffect":"shakeLarge","flashEffect":"flashRed2","surround":"1801A04"},{"autoTurnLast":0.5,"item":[{"action":{"sequence":[{"moveTo":{"duration":0.05,"posX":-30,"posY":-60}},{"moveTo":{"duration":0.05,"posX":30,"posY":30}},{"moveTo":{"duration":0.05,"posX":-30,"posY":-60}},{"moveTo":{"duration":0.05,"posX":30,"posY":30}},{"moveTo":{"duration":0.05,"posX":-30,"posY":-60}},{"moveTo":{"duration":0.05,"posX":0,"posY":-30}}]},"path":"resource/scenario/img/51215_tower_iroha_kuroe/51215_Ichizo.png"}]},{"autoTurnLast":0.01,"bgEffect":"shakeLarge","flashEffect":"flashRed2","surround":"1801A04"},{"autoTurnLast":0.5,"item":[{"action":{"sequence":[{"moveTo":{"duration":0.05,"posX":-30,"posY":-60}},{"moveTo":{"duration":0.05,"posX":30,"posY":30}},{"moveTo":{"duration":0.05,"posX":-30,"posY":-60}},{"moveTo":{"duration":0.05,"posX":30,"posY":30}},{"moveTo":{"duration":0.05,"posX":-30,"posY":-60}},{"moveTo":{"duration":0.05,"posX":0,"posY":-30}}]},"path":"resource/scenario/img/51215_tower_iroha_kuroe/51215_Ichizo.png"}]},{"autoTurnLast":0.5,"item":[{"path":"resource/scenario/img/51215_tower_iroha_kuroe/51215_Ichizo.png","visible":"hide"}]},{"chara":[{"cheek":0,"face":"mtn_ex_021.exp3.json","id":100106,"motion":401,"pos":2},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":104300,"motion":0,"pos":0}],"nameRight":"Iroha","textRight":"Kuroe-san! Take my hand!"},{"chara":[{"id":104300,"motion":200}],"nameLeft":"Kuroe","textLeft":"Alright...!"},{"chara":[{"eyeClose":1,"id":104300},{"id":100106,"motion":0}],"nameLeft":"Kuroe","textLeft":"I...don't care if I'm not qualified to be@a Magical Girl...!"},{"chara":[{"eyeClose":1,"id":104300}],"nameLeft":"Kuroe","textLeft":"I'll stay as myself, and...!"},{"chara":[{"eyeClose":0,"id":104300,"motion":400,"mouthOpen":1},{"id":100106,"motion":400,"mouthOpen":1}],"nameCenter":"Kuroe & Iroha","textBg":"shout","textCenter":"Move forward to tomorrow!"},{"autoTurnLast":0.8,"chara":[{"id":104300,"mouthOpen":0},{"id":100106,"mouthOpen":0}],"flashEffect":"explosion","surround":"1801A08","textClear":1},{"autoTurnLast":2.0,"bg":"white","bgm":"stop","turnChangeIn":"whiteIn","turnChangeInTime":0.2},{"autoTurnLast":0.2,"flashEffect":"flashRed2","surround":"1801A13","turnChangeOut":"whiteOut"},{"autoTurnLast":1.0,"flashEffect":"flashRed2","surround":"1801A13"},{"autoTurnLast":2.0,"se":"7209_gate_close"},{"autoTurnLast":2.0,"bg":"bg_adv_21251.jpg","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":104300,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_021.exp3.json","id":100106,"motion":0,"pos":2}],"turnChangeIn":"whiteIn","turnChangeInTime":0.2},{"chara":[{"id":104300,"lipSynch":0}],"nameLeft":"Kuroe","textLeft":"...[wait:1.0][chara:104300:cheek_0][chara:104300:face_mtn_ex_030.exp3.json][chara:104300:lipSynch_1:eyeClose_1]*Sigh*...","turnChangeOut":"whiteOut","turnChangeOutTime":1.5},{"bgm":"bgm05_event05","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":100106,"motion":200,"pos":2}],"nameRight":"Iroha","textRight":"Looks like your impurities have been cleansed,@huh?"},{"chara":[{"eyeClose":0,"id":104300,"motion":0}],"nameLeft":"Kuroe","textLeft":"Thanks...Tamaki-san..."},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp3.json","id":100106}],"nameRight":"Iroha","textRight":"All I did was huddle up to you."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":100106,"motion":301,"pos":2}],"nameRight":"Iroha","textRight":"If I hadn't been able to borrow that girl's body..."},{"chara":[{"id":100106}],"nameRight":"Iroha","textRight":"...I wouldn't have been able to do anything."},{"chara":[{"cheek":0,"face":"mtn_ex_041.exp3.json","id":100106,"motion":0,"pos":2}],"nameRight":"Iroha","textRight":"So the two of you saved yourselves..."},{"chara":[{"id":104300,"lipSynch":0}],"nameLeft":"Kuroe","textLeft":"..."},{"chara":[{"id":104300,"lipSynch":0}],"nameLeft":"Kuroe","textLeft":"...[wait:1.0][chara:104300:cheek_0][chara:104300:motion_100][chara:104300:lipSynch_1]This is probably goodbye for real, huh...?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":100106}],"nameRight":"Iroha","textRight":"...Yeah."},{"chara":[{"id":104300}],"nameLeft":"Kuroe","textLeft":"...Um, I..."},{"chara":[{"id":104300,"motion":200}],"nameLeft":"Kuroe","textLeft":"I...I don't want to leave you behind, after all...!"},{"chara":[{"id":104300}],"nameLeft":"Kuroe","textLeft":"I'm scared that I'm going to forget these feelings@one day!"},{"chara":[{"id":104300,"motion":300}],"nameLeft":"Kuroe","textLeft":"And yet...you keep slipping further away into@the past!"},{"chara":[{"id":104300}],"nameLeft":"Kuroe","textLeft":"Even if I could live forever..."},{"chara":[{"id":104300}],"nameLeft":"Kuroe","textLeft":"...I'd never be able to forgive my future self@for thinking of you..."},{"chara":[{"eyeClose":1,"id":104300}],"nameLeft":"Kuroe","textLeft":"...as \"just a fond memory\"..."},{"chara":[{"eyeClose":0,"id":104300,"motion":1}],"nameLeft":"Kuroe","textLeft":"Do I have to accept that this will all be over@one day?"},{"chara":[{"id":104300}],"nameLeft":"Kuroe","textLeft":"Is the past really a curse, and the future filled@with hope?"},{"chara":[{"eyeClose":1,"id":104300}],"nameLeft":"Kuroe","textLeft":"You only exist in the past, so...!"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":100106,"motion":301}],"nameRight":"Iroha","textRight":"I don't want to force you to forget how sad@you are."},{"chara":[{"eyeClose":0,"id":104300,"motion":100}],"nameLeft":"Kuroe","textLeft":"Really...?"},{"chara":[{"id":104300}],"nameLeft":"Kuroe","textLeft":"Are you sure I can live on without forgetting?"},{"chara":[{"eyeClose":0,"id":100106,"motion":200}],"nameRight":"Iroha","textRight":"Even if you can't let go, and you can't patch up@your loneliness..."},{"chara":[{"id":100106}],"nameRight":"Iroha","textRight":"...you can still build new memories on top of@everything, slowly but surely."},{"chara":[{"eyeClose":0,"id":100106},{"id":104300,"motion":0}],"nameRight":"Iroha","textRight":"The sour taste of a pickled plum."},{"chara":[{"id":100106}],"nameRight":"Iroha","textRight":"Catching the smell of a cat on the breeze."},{"chara":[{"id":100106,"motion":1}],"nameRight":"Iroha","textRight":"Excitedly waiting for your old favorite candy@to get restocked at the store."},{"chara":[{"eyeClose":1,"id":100106}],"nameRight":"Iroha","textRight":"It's the warmth of little events like that."},{"chara":[{"eyeClose":1,"id":100106}],"nameRight":"Iroha","textRight":"You might be sad..."},{"chara":[{"eyeClose":1,"id":100106}],"nameRight":"Iroha","textRight":"...but as you plod along, searching for reasons@to stay alive..."},{"chara":[{"eyeClose":1,"id":100106,"motion":301}],"nameRight":"Iroha","textRight":"...both people you cherished and the scars left@behind will start to fade..."},{"chara":[{"cheek":1,"id":104300,"motion":400}],"nameLeft":"Kuroe","textLeft":"I don't want that! I really don't...!"},{"chara":[{"id":104300}],"nameLeft":"Kuroe","textLeft":"Are you just saying that because I'm weak...?!"},{"chara":[{"id":104300,"motion":200}],"nameLeft":"Kuroe","textLeft":"I want to remember you, Tamaki-san...!"},{"chara":[{"id":104300}],"nameLeft":"Kuroe","textLeft":"You told me I didn't have to forget!"},{"chara":[{"eyeClose":0,"id":100106,"motion":0}],"nameRight":"Iroha","textRight":"You don't have to accept it now. You've got time@on your side."},{"autoTurnLast":1.5,"flashEffect":"flashWhiteSlow2","textClear":1},{"chara":[{"cheek":1,"face":"mtn_ex_050.exp3.json","id":104300,"lipSynch":0,"motion":0}],"nameLeft":"Kuroe","textLeft":"—?!"},{"chara":[{"id":104300,"lipSynch":1}],"nameLeft":"Kuroe","textLeft":"Tamaki-san...?!"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":100106,"motion":100,"pos":2}],"nameRight":"Iroha","textRight":"Please promise me that you'll stay kind,@Kuroe-san."},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":104300,"motion":400,"tear":1}],"nameLeft":"Kuroe","textLeft":"Ta...maki-san...!","turnEffect":"promist"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":100106,"motion":200,"pos":2}],"nameRight":"Iroha","textRight":"Someday, when all that's left are memories..."},{"chara":[{"id":100106}],"nameRight":"Iroha","textRight":"...I want you to think about me one more time."},{"autoTurnLast":0.1,"bgm":"stop","textClear":1},{"autoTurnLast":2.0,"bg":"bg_adv_21933.jpg","chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":104301,"motion":0,"pos":1,"tear":1}],"turnChangeIn":"whiteIn","turnChangeInTime":1.5,"turnEffect":"stop"},{"autoTurnLast":1.5,"turnChangeOut":"whiteOut","turnChangeOutTime":1.5},{"chara":[{"eyeClose":0,"id":104301,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"..."},{"chara":[{"cheek":1,"eyeClose":1,"id":104301,"lipSynch":1,"tear":0}],"nameCenter":"Kuroe","textCenter":"Tamaki-san..."},{"autoTurnLast":0.2,"chara":[{"cheek":0,"id":104301,"pos":0}],"textClear":1},{"bgm":"bgm01_anime02","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104701,"motion":0,"pos":2},{"eyeClose":0,"id":104301}],"nameRight":"","textRight":"...Kuroe-san?! You woke up!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104701}],"nameRight":"","textRight":"Whew~... Thank goodness..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104301,"lipSynch":0}],"nameLeft":"Kuroe","textLeft":"..."},{"autoTurnLast":0.2,"bg":"black","item":[{"path":"resource/scenario/img/51215_tower_iroha_kuroe/memoria_2040_kuro.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"nameNarration":"Kuroe","narration":"―Kuroe―@Why...are you...?","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":35.0,"narrationLineSpace":20.0,"turnChangeOut":"fadeOut"},{"nameNarration":"","narration":"Because we're two peas in a pod!@We don't know anything,@so we desperately wanna be kind!"},{"autoTurnLast":0.2,"bg":"bg_adv_21933.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104301,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104701,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"eyeClose":1,"id":104301,"lipSynch":0}],"nameLeft":"Kuroe","textLeft":"...","turnChangeOut":"fadeOut"},{"chara":[{"eyeClose":0,"id":104301,"lipSynch":1,"motion":100}],"nameLeft":"Kuroe","textLeft":"Hey, um... Are you feeling alright?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104701}],"nameRight":"","textRight":"Heh? Me?"},{"chara":[{"id":104701}],"nameRight":"","textRight":"I was all in a tizzy, so I don't remember much,@but..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104701,"motion":300}],"nameRight":"","textRight":"I'm so glad you're safe!"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":104301,"motion":0,"pos":0}],"nameLeft":"Kuroe","textLeft":"...Yeah."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104701,"motion":0,"pos":2}],"nameRight":"","textRight":"I'm sorry, Kuroe-san."},{"chara":[{"id":104701}],"nameRight":"","textRight":"I wanted to save you, but I was totally useless..."},{"chara":[{"id":104301,"motion":200}],"nameLeft":"Kuroe","textLeft":"That's not true."},{"chara":[{"id":104301}],"nameLeft":"Kuroe","textLeft":"It's thanks to you that I was able to come back@here."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104701,"lipSynch":0}],"nameRight":"","textRight":"[chara:104701:effect_emotion_surprise_0][se:7226_shock]...!"},{"chara":[{"id":104701,"lipSynch":1,"motion":300}],"nameRight":"","textRight":"[chara:104701:effect_shake]Whuh? Fweheheh... [chara:104701:lipSynch_0][wait:1.0][chara:104701:cheek_0][chara:104701:face_mtn_ex_010.exp3.json][chara:104701:lipSynch_1]Y-you're gonna make me@blush!"},{"chara":[{"id":104301,"motion":0}],"nameLeft":"Kuroe","textLeft":"...Thank you."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104701,"lipSynch":0,"motion":0}],"nameRight":"","textRight":"...!"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104301,"motion":100,"pos":0}],"nameLeft":"Kuroe","textLeft":"I'm sorry I doubted the things you knew@about me."},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":104301,"pos":0}],"nameLeft":"Kuroe","textLeft":"But I'm good now, I think."},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":104301,"motion":1}],"nameLeft":"Kuroe","textLeft":"Since you helped me see what you saw in me..."},{"chara":[{"eyeClose":1,"id":104301}],"nameLeft":"Kuroe","textLeft":"...then even if the day comes that I can't do@the right thing..."},{"chara":[{"eyeClose":1,"id":104301}],"nameLeft":"Kuroe","textLeft":"I feel like I'll be able to live as a phony@Magical Girl."},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":104301,"motion":0}],"nameLeft":"Kuroe","textLeft":"So...thanks again."},{"chara":[{"id":104701,"lipSynch":0}],"nameRight":"","textRight":"..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":104701,"lipSynch":1}],"nameRight":"","textRight":"...You're very welcome!"},{"autoTurnLast":2.0,"bgm":"stop","turnChangeIn":"fadeIn"}]},"version":3}

{"story":{"group_1":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":0,"pos":1,"voice":"vo_char_1031_00_01"}]},{"autoTurnFirst":5.3,"chara":[{"id":103100,"motion":200}]},{"autoTurnFirst":8.8,"chara":[{"id":103100,"motion":1}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":103100,"motion":0}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103100}]}],"group_10":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_17"}]},{"autoTurnFirst":2.0,"chara":[{"id":103100,"motion":301}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100}]}],"group_11":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103100,"motion":300,"pos":1,"voice":"vo_char_1031_00_18"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":103100}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":7.0,"chara":[{"id":103100,"motion":0}]}],"group_12":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":200,"pos":1,"voice":"vo_char_1031_00_19"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103100}]}],"group_13":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_20"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":103100}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp3.json","id":103100,"motion":200}]}],"group_14":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":100,"pos":1,"voice":"vo_char_1031_00_21"}]},{"autoTurnFirst":5.6,"chara":[{"eyeClose":1,"id":103100}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":6.0,"chara":[{"id":103100,"motion":1}]}],"group_15":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":0,"pos":1,"voice":"vo_char_1031_00_22"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":301}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_021.exp3.json","id":103100}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":1}]}],"group_16":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":103100,"motion":300,"pos":1,"voice":"vo_char_1031_00_23"}]},{"autoTurnFirst":5.7,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103100,"motion":0}]},{"autoTurnFirst":3.4,"chara":[{"id":103100,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":103100}]}],"group_17":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103150,"motion":1,"pos":1,"voice":"vo_char_1031_50_24","textHome":"What's the matter?@You look surprised."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":103150,"motion":100,"textHome":"It's a beach day today—@why wouldn't I put on@a bathing suit?"}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":103150}]},{"autoTurnFirst":2.6,"chara":[{"id":103150,"motion":200,"textHome":"Come on, time is limited."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103150,"textHome":"Let's get going."}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103150,"motion":100,"pos":1,"voice":"vo_char_1031_50_25","textHome":"When I was little,@I used to do my homework@in the cool of the morning."}]},{"autoTurnFirst":2.6,"chara":[{"id":103150,"motion":1,"textHome":"It was easier for me@to concentrate that way,"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103150,"textHome":"and I enjoyed being able@to play outside after doing@what I needed to do."}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_050.exp3.json","id":103150,"motion":300,"pos":1,"voice":"vo_char_1031_50_26","textHome":"Whew..."}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103150,"textHome":"The best way to beat the heat@is to eat something piping hot@and work up a sweat."}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":103150}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103150,"motion":1,"textHome":"Curry, ramen, udon..."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103150,"textHome":"Choose whatever you like,@I'll treat you to it."}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":200,"pos":1,"voice":"vo_char_1031_00_02"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103100,"motion":1}]}],"group_20":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103150,"motion":0,"pos":1,"voice":"vo_char_1031_50_27","textHome":"It's about time we start the campfire."}]},{"autoTurnFirst":2.2,"chara":[{"id":103150,"motion":400,"textHome":"Let's head to the venue."}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":103150,"motion":0,"textHome":"Ah, but before we go..."}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103150,"motion":100,"textHome":"You must bring something to wrap@yourself in. The flaming sparks@can be dangerous, you know."}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103150,"motion":300,"pos":1,"voice":"vo_char_1031_50_28","textHome":"*Sigh*... I was wondering who@was calling me at this hour,"}]},{"autoTurnFirst":2.6,"chara":[{"eyeClose":1,"id":103150,"textHome":"but it was the guys from@the Youth Association again."}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":103150}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_042.exp3.json","id":103150,"motion":0,"textHome":"What's more, they were drunk..."}]},{"autoTurnFirst":5.5,"chara":[{"id":103150,"motion":200,"textHome":"They've been using the@Community Center in the summer@to drink there every night..."}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103150,"motion":1,"pos":1,"voice":"vo_char_1031_50_29","textHome":"Have you seen the Princess and Sasha?"}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103150,"motion":301,"textHome":"First they asked me to do@their shopping, then they@vanished into thin air."}]},{"autoTurnFirst":2.4,"chara":[{"eyeClose":1,"id":103150,"motion":100,"textHome":"*Sigh*...@Something curious must've@caught their eyes, I suppose."}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":103150}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103150,"motion":200,"pos":1,"voice":"vo_char_1031_50_30","textHome":"We could have a showdown if you like."}]},{"autoTurnFirst":5.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103150,"motion":1,"textHome":"Since we're at the ocean,@how about a game of Beach Flags?@As the Instructor of Neo-Magius,"}]},{"autoTurnFirst":2.5,"chara":[{"id":103150,"motion":400,"textHome":"I don't plan on losing."}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103150,"motion":0,"pos":1,"voice":"vo_char_1031_50_31","textHome":"The myth that if you look@in the mirror at 4:44,@you'll be dragged inside..."}]},{"autoTurnFirst":2.8,"chara":[{"id":103150,"motion":100,"textHome":"...might be surprisingly true."}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":103150,"textHome":"Places like the@Endless Mirrors exist, after all."}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":0.9,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp3.json","id":103150,"motion":1,"pos":1,"voice":"vo_char_1031_50_32"}]},{"autoTurnFirst":4.4,"chara":[{"eyeClose":0,"id":103150}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103150,"motion":400}]}],"group_26":[{"autoTurnFirst":4.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103150,"motion":100,"pos":1,"voice":"vo_char_1031_50_33","textHome":"Every summer,@the Youth Association@hosts a barbecue event."}]},{"autoTurnFirst":4.1,"chara":[{"id":103150,"motion":0,"textHome":"We also have bingo and other@activities that people from@outside the town can enjoy,"}]},{"autoTurnFirst":3.0,"chara":[{"id":103150,"motion":200,"textHome":"so why don't you@come visit us next time?"}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103150,"motion":0,"pos":1,"voice":"vo_char_1031_50_34","textHome":"I wonder if Miyabi and Azumi@will go to the beach."}]},{"autoTurnFirst":6.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103150,"motion":300,"textHome":"I feel like Miyabi might get snagged@by the waves, and Azumi might get@herself tangled up with creeps."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103150,"textHome":"How worrisome..."}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103150,"motion":1,"pos":1,"voice":"vo_char_1031_50_35","textHome":"There's a festival@tomorrow in Sankyo Ward;@would you like to come along?"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103150,"motion":100,"textHome":"It's an old, venerable festival@that's been going on for centuries,"}]},{"autoTurnFirst":5.5,"chara":[{"eyeClose":0,"id":103150,"textHome":"and I wish to see it@in the interest of reviving@the Hikarizuka Fire Festival."}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":5.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_021.exp3.json","id":103150,"motion":400,"pos":1,"voice":"vo_char_1031_50_36","textHome":"Urghh!@Why are sparklers so frustrating?!"}]},{"autoTurnFirst":5.0,"chara":[{"id":103150,"motion":200,"textHome":"When I light them, I want them to@blaze up to their maximum power@and disperse at once...!"}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":300,"pos":1,"voice":"vo_char_1031_00_03"}]}],"group_30":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103150,"motion":301,"pos":1,"voice":"vo_char_1031_50_37","textHome":"I used to be so spineless that I would cry@during family vacations about how I didn't@want to go because the ocean scares me."}]},{"autoTurnFirst":6.1,"chara":[{"eyeClose":1,"id":103150}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":103150}]},{"autoTurnFirst":6.0,"chara":[{"id":103150,"motion":1,"textHome":"Needless to say, that's quite hard@to imagine from how I am now."}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":4.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103150,"motion":100,"pos":1,"voice":"vo_char_1031_50_38","textHome":"This time, all of us at Neo-Magius@are going to hold a study camp."}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_042.exp3.json","id":103150,"motion":1,"textHome":"Too many girls neglect@their summer homework,"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103150,"motion":400,"textHome":"so I plan on whipping their@pampered spirits back into shape."}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103150,"motion":301,"pos":1,"voice":"vo_char_1031_50_39","textHome":"What a hassle...@When I wear a swimsuit,@Miyu faints, as expected."}]},{"autoTurnFirst":2.1,"chara":[{"id":103150,"motion":200,"textHome":"I tried to cover my legs,"}]},{"autoTurnFirst":2.1,"chara":[{"eyeClose":1,"id":103150,"textHome":"but she said it was nice@to see a glimpse of them,"}]},{"autoTurnFirst":0.4,"chara":[{"eyeClose":0,"id":103150}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_042.exp3.json","id":103150,"motion":0,"textHome":"and instead got excited..."}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103150,"motion":1,"pos":1,"voice":"vo_char_1031_50_40","textHome":"Can you stop staring at me@like that? I'm wearing my hair down@because it makes it easier to swim."}]},{"autoTurnFirst":3.4,"chara":[{"id":103150,"motion":301,"textHome":"The swimsuit was picked out@for me by the Princess..."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"id":103150,"motion":100,"textHome":"It's not that weird, is it?"}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103150,"motion":400,"pos":1,"voice":"vo_char_1031_50_41","textHome":"*Gasp*?!@W-what was that noise?!"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103150,"motion":1,"textHome":"...Huh, it's just the wind?"}]},{"autoTurnFirst":5.8,"chara":[{"eyeClose":1,"id":103150,"textHome":"...Ghost stories—or rather, things@I can't root out the truth of—@aren't something I'm good with."}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":103150}]},{"autoTurnFirst":8.0,"chara":[{"cheek":1,"id":103150,"motion":301,"textHome":"They're uncanny,@and I hate feeling@so frightened and pathetic..."}]},{"chara":[{"id":103150,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_42"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":200,"pos":1,"voice":"vo_char_1031_00_43"}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp3.json","id":103100,"motion":0,"pos":1,"voice":"vo_char_1031_00_44"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_45"}]}],"group_39":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":100,"pos":1,"voice":"vo_char_1031_00_46"}]}],"group_4":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_04"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":103100}]}],"group_5":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp3.json","id":103100,"motion":0,"pos":1,"voice":"vo_char_1031_00_05"}]},{"autoTurnFirst":4.0,"chara":[{"id":103100,"motion":200}]}],"group_6":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_13"}]}],"group_7":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":100,"pos":1,"voice":"vo_char_1031_00_14"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103100}]}],"group_8":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_15"}]}],"group_9":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":301,"pos":1,"voice":"vo_char_1031_00_16"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103100}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100}]}]},"version":3}

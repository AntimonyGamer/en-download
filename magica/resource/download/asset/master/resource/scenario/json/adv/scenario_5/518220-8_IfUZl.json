{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_20091.jpg","bgm":"bgm05_event05","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":402301,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402601,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":402301}],"nameLeft":"Melissa","textLeft":"To think that we could meet and talk with Tart@and Liz once again...","turnChangeOut":"fadeOut"},{"chara":[{"id":402301}],"nameLeft":"Melissa","textLeft":"It's like a dream."},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":402601,"motion":300,"pos":2}],"nameRight":"Elisa","textRight":"It was quite a challenge to keep it under wraps."},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":402301,"motion":300}],"nameLeft":"Melissa","textLeft":"We had only just met you at that time, after all."},{"chara":[{"id":402301}],"nameLeft":"Melissa","textLeft":"It's been over ten years since then."},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":402601,"pos":2}],"nameRight":"Elisa","textRight":"And to think that if I were to run into my past self..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":400,"pos":0,"soulGem":0}],"nameLeft":"Torte","textLeft":"Huh? So you were nearby by back then?"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402601,"motion":1,"pos":2}],"nameRight":"Elisa","textRight":"Of course. Back then, I was the one who invited@Prince Louis to the castle."},{"chara":[{"id":402601}],"nameRight":"Elisa","textRight":"It was me and Grandpa Vole."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831700,"motion":0,"pos":2},{"id":831303,"motion":0}],"nameRight":"Nicolas","textRight":"Thanks to that, Lord Charles resolved to march on@to Reims..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831700}],"nameRight":"Nicolas","textRight":"And fulfilled his long-cherished coronation."},{"chara":[{"id":831700}],"nameRight":"Nicolas","textRight":"He was officially recognized as the true King of@France by all."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":831700}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402301,"motion":1,"pos":0},{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":402601,"lipSynch":0,"motion":0,"pos":2}],"nameLeft":"Melissa","textLeft":"Yes... However, the fate that awaits beyond..."},{"chara":[{"id":402301}],"nameLeft":"Melissa","textLeft":"Tart and Liz still don't know..."},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":402601,"lipSynch":0,"pos":2}],"nameRight":"Elisa","textRight":"...@..."},{"autoTurnLast":1.0,"bg":"bg_adv_20091.jpg","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402901,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50}],"turnChangeIn":"fadeIn"},{"chara":[{"id":402901}],"nameLeft":"Perenelle","textLeft":"Well, there's still work left for us to do.","turnChangeOut":"fadeOut"},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"That's right. Once Kagome finishes recording the@final entry,"},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"we'll need to stop the erosion of the world@without Tart."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":102001,"motion":1,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"And when we reach the Endless Mirrors Terminal,"},{"chara":[{"id":102001}],"nameLeft":"Kagome","textLeft":"we'll destroy the mirror..."},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"If your information is accurate,"},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"doing so will destroy the timeline where Tart@wasn't born..."},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"In other words, the world of the red moon should@disappear without a trace."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831700,"motion":0,"pos":2}],"nameRight":"Nicolas","textRight":"Let's hope it goes as planned..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":200,"pos":2,"soulGem":0}],"nameRight":"Torte","textRight":"It'll be okay!"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":831303,"lipSynch":0}],"nameRight":"Torte","textRight":"(If it fails, then I'll...)"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"...Is something wrong, Torte?"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":400,"pos":2}],"nameRight":"Torte","textRight":"Oh... N-no, it's nothing!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402601,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402301,"motion":0,"pos":0}],"nameRight":"Elisa","textRight":"Well then...@We entrust the rest to you."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402601},{"effect":"fadeout","id":402301}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402901,"motion":100,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"item":[{"path":"resource/scenario/img/51158_tower_tart2/51158_kagome_magical_pencil.png","posX":0,"posY":0,"visible":"appear","zOrder":"charaBack"}],"nameRight":"Perenelle","textRight":"Kagome, please record it."},{"chara":[{"id":102001,"motion":400}],"nameLeft":"Kagome","textLeft":"Yes...!"},{"autoTurnLast":2.0,"bg":"black","bgm":"stop","item":[{"iPhoneXScale":1.0,"path":"resource/scenario/img/51030_fishing_homura/51030_homura_dairy.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"bgm":"bgm20_song10","nameNarration":"Kagome","narrationCoverOpacity":0.0,"narrationEffect":"in","narrationHAlignment":"left","narrationPosX":150.0,"progressNarration":"[textBlack:I believe the record of this incredible@journey will probably end here.]","turnChangeOut":"fadeOut"},{"progressNarration":"[textBlack:Once I finish recording this, the sixth@entry in my journal...Dauphin Louis will@carry back the cherished memories of@La Pucelle from the world within his mind.@The crisis facing France in the 15th@century, happening in the real world,@should be heading towards its resolution...]"},{"progressNarration":"[textBlack:It's a relief to have been able@to assist in the reunion between@La Pucelle and her comrades...@I felt a sense of comfort.]"},{"progressNarration":"[textBlack:But, considering that this experience@was caused by an offshoot Mirrors,@if we break the Terminal Mirror and@resolve the time paradox, it will become@as if it \"never happened\", right?]"},{"progressNarration":"[textBlack:Realizing that my memories might@also fade away if that happens...@I'm feeling a bit lonely.]"},{"autoTurnLast":2.0,"bg":"bg_adv_20091.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102001,"motion":0,"pos":1,"soulGem":0}],"item":[{"path":"resource/scenario/img/51030_fishing_homura/51030_homura_dairy.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":102001}],"nameCenter":"Kagome","textCenter":"...I've finished writing.","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402301,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402601,"motion":1,"pos":2}],"nameCenter":"Melissa & Elisa","textCenter":"..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402301},{"effect":"fadeout","id":402601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402901,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831700,"motion":0,"pos":2}],"nameCenter":"Perenelle & Nicolas","textCenter":"..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402901},{"effect":"fadeout","id":831700}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":1,"pos":0,"soulGem":0}],"nameRight":"Qube","textRight":"It seems as though nothing has happened."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":1,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"I thought our plan was to restore the original world,"},{"chara":[{"id":102001}],"nameLeft":"Kagome","textLeft":"so we could go back to the Ark as before,"},{"chara":[{"id":102001,"motion":300}],"nameLeft":"Kagome","textLeft":"or go to the Endless Mirrors...but.."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402601,"motion":400,"pos":2}],"nameRight":"Elisa","textRight":"[chara:402601:effect_emotion_surprise_0][se:7226_shock]It's a problem if we can't return anywhere, right?!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50}],"nameRight":"Qube","textRight":"This is the last book, so the conditions to restore@the world are in place."},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"But there's something missing...some parts are@incomplete."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402901,"motion":300,"pos":2}],"nameRight":"Perenelle","textRight":"If there are still unsolved mysteries,@could that be the cause?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":0}],"nameLeft":"Kagome","textLeft":"Unresolved mysteries..."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":300,"pos":0}],"item":[{"path":"resource/scenario/img/51158_tower_tart2/51158_kagome_magical_pencil.png","posX":0,"posY":0,"visible":"appear","zOrder":"charaBack"}],"nameLeft":"Kagome","textLeft":"You mean like why I was chosen as the Record-keeper...?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402301,"motion":1,"pos":2}],"nameRight":"Melissa","textRight":"Indeed, why does Kagome possess@that magic pen?"},{"chara":[{"id":402301}],"nameRight":"Melissa","textRight":"We still don't know, do we?"},{"chara":[{"id":102001,"motion":0}],"nameLeft":"Kagome","textLeft":"No..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402601,"motion":1,"pos":2}],"item":[{"path":"resource/scenario/img/51158_tower_tart2/51158_kagome_magical_pencil.png","visible":"hide"}],"nameRight":"Elisa","textRight":"It's strange how people's memories returned when@they saw Torte."},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402901,"motion":400,"pos":2}],"nameRight":"Perenelle","textRight":"It's almost as if there's a strong causal connection"},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"between Kagome, Torte, and La Pucelle's memories..."},{"bgm":"bgm05_event10","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":0,"pos":0,"soulGem":0}],"nameLeft":"Torte","textLeft":"I already know the reason for that."},{"autoTurnLast":0.2,"chara":[{"id":831303,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"Huh...?"},{"chara":[{"eyeClose":1,"id":831303}],"nameRight":"Torte","textRight":"My meeting with you, Kagome,"},{"chara":[{"id":831303}],"nameRight":"Torte","textRight":"and our receiving special powers..."},{"chara":[{"cheek":0,"eyeClose":0,"id":831303,"motion":200,"pos":2}],"nameRight":"Torte","textRight":"It's all the miraculous result of what@I'm [textRed:just about] to ask Qube for."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831700,"motion":0,"pos":2}],"nameRight":"Nicolas","textRight":"Huh...?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102001},{"effect":"fadeout","id":831700}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402901,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":1,"pos":0,"soulGem":0}],"nameRight":"Perenelle","textRight":"...Torte, what are you thinking?"},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"By asking Qube for a miracle..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831303,"motion":0,"pos":0}],"nameLeft":"Torte","textLeft":"Yes, I know. I'm sorry, Mother."},{"chara":[{"id":831303}],"nameLeft":"Torte","textLeft":"I've been thinking about it all by myself."},{"chara":[{"id":831303,"motion":300}],"nameLeft":"Torte","textLeft":"You mentioned it too, didn't you?"},{"chara":[{"id":831303}],"nameLeft":"Torte","textLeft":"You wanted me to think about what I can do for@the late La Pucelle."},{"chara":[{"id":402901,"motion":100}],"nameRight":"Perenelle","textRight":"I didn't help you for that reason..."},{"chara":[{"id":831303,"motion":0}],"nameLeft":"Torte","textLeft":"No, this is... By looking at the memories@of everyone who was left behind,"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":831303,"pos":0}],"nameLeft":"Torte","textLeft":"I learned La Pucelle's...no, everyone's feelings."},{"chara":[{"id":831303,"motion":100}],"nameLeft":"Torte","textLeft":"This is a decision I made on my own.@So, I won't have any regrets."},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp3.json","id":402901,"motion":400,"pos":2}],"nameRight":"Perenelle","textRight":"...Is that alright with you?"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":831303,"motion":0}],"nameLeft":"Torte","textLeft":"Yes."},{"autoTurnLast":0.2,"chara":[{"id":402901,"motion":0,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402901,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831700,"motion":0,"pos":2}],"nameCenter":"Perenelle & Nicolas","textCenter":"..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402901},{"effect":"fadeout","id":831700}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":1,"soulGem":0}],"nameCenter":"Kagome","textCenter":"Torte...!"},{"chara":[{"id":102001,"lipSynch":0,"motion":1}],"nameCenter":"Kagome","textCenter":"(Back when we jumped into the last journal...)"},{"chara":[{"id":102001,"lipSynch":0}],"nameCenter":"Kagome","textCenter":"(Torte had already made up her mind...)"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"lipSynch":0,"pos":1}],"nameCenter":"Kagome","textCenter":"(Could I...make a decision like this...?)"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":831303,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50}],"nameLeft":"Torte","textLeft":"Listen, Qube! My wish is..."},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":831303,"motion":100}],"nameNarration":"Torte","narration":"\"That the feelings of La Pucelle are never lost...@and are rightfully passed down in this world.\"","narrationBg":"","narrationCoverOpacity":110.0,"narrationEffect":"in"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":810000},{"effect":"fadeout","id":831303}],"narrationEffect":"out","textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402301,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402601,"motion":0,"pos":2}],"nameCenter":"Melissa & Elisa","textCenter":"..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402601},{"effect":"fadeout","id":402301}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402901,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831700,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":0,"pos":1,"soulGem":0}],"nameCenter":"Torte","textCenter":"I'm sorry, Kagome.@It seems we're saying goodbye here."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831700},{"effect":"fadeout","id":402901}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"id":831303,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102001,"motion":400,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"No way..."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":831303,"motion":200}],"nameRight":"Torte","textRight":"Take care, Kagome!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"lipSynch":0,"motion":0}],"nameLeft":"Kagome","textLeft":"..."},{"autoTurnLast":0.2,"textClear":1},{"autoTurnLast":0.01,"turnChangeIn":"whiteIn","turnChangeInTime":2.0},{"autoTurnLast":1.0,"se":"7205_magic_girl"},{"autoTurnLast":2.0}]},"version":3}

{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_20312.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":104301,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200301,"motion":0,"pos":2}],"item":[{"iPhoneXScale":1.0,"path":"resource/scenario/img/51030_fishing_homura/51030_window.png","posX":0,"posY":0,"visible":"appear","zOrder":"bgFront"}],"turnChangeIn":"fadeIn","turnEffect":"ef_adv_10"},{"bgm":"bgm03_story12","chara":[{"id":104301}],"nameLeft":"Kuroe","textLeft":"I used to have a cat forever ago...","turnChangeOut":"fadeOut"},{"chara":[{"id":104301}],"nameLeft":"Kuroe","textLeft":"But I haven't owned any others since then."},{"chara":[{"eyeClose":1,"id":104301}],"nameLeft":"Kuroe","textLeft":"I just can't bring myself to move on."},{"chara":[{"id":200301}],"nameRight":"Homura","textRight":"That makes sense, but..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200301,"motion":100},{"eyeClose":0,"id":104301}],"nameRight":"Homura","textRight":"Your old cat can't be by your side anymore,@no matter how much you care about it."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104301,"lipSynch":0}],"nameLeft":"Kuroe","textLeft":"..."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200301,"motion":1,"pos":2}],"nameRight":"Homura","textRight":"Ah, I can't believe it's that time already...@I have to get off at the next stop..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104301,"motion":400,"pos":0}],"nameLeft":"Kuroe","textLeft":"Huh...? You're getting off here?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200301}],"nameRight":"Homura","textRight":"Yeah."},{"chara":[{"id":200301}],"nameRight":"Homura","textRight":"Together with my friends in Mitakihara, I decided@I was going to move the clock forward."},{"chara":[{"id":200301,"motion":300},{"id":104301,"motion":0}],"nameRight":"Homura","textRight":"Thanks to them..."},{"chara":[{"id":200301}],"nameRight":"Homura","textRight":"...I started to think that, maybe..."},{"chara":[{"eyeClose":1,"id":200301}],"nameRight":"Homura","textRight":"...I could live on as a Magical Girl."},{"chara":[{"id":104301,"lipSynch":0}],"nameLeft":"Kuroe","textLeft":"..."},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp3.json","id":200301,"motion":0}],"nameRight":"Homura","textRight":"You're not getting off yet, Kuroe-san?"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":104301,"lipSynch":1,"motion":100}],"nameLeft":"Kuroe","textLeft":"It's just... [chara:104301:lipSynch_0][wait:1.0][chara:104301:cheek_0][chara:104301:face_mtn_ex_030.exp3.json][chara:104301:lipSynch_1]If I do, then..."},{"chara":[{"id":200301}],"nameRight":"Homura","textRight":"This train keeps going straight on forever..."},{"chara":[{"eyeClose":1,"id":200301}],"nameRight":"Homura","textRight":"And ever, and ever..."},{"chara":[{"eyeClose":0,"id":200301,"motion":200}],"nameRight":"Homura","textRight":"But we'll never reach \"tomorrow\" unless we get@off here."},{"chara":[{"id":104301,"motion":300}],"nameLeft":"Kuroe","textLeft":"...I'd rather stay in the past forever,@dreaming of yesterday..."},{"chara":[{"id":104301}],"nameLeft":"Kuroe","textLeft":"...than have to come to grips with what I've lost."},{"chara":[{"id":104301}],"nameLeft":"Kuroe","textLeft":"Is that wrong of me?"},{"chara":[{"eyeClose":1,"id":200301,"lipSynch":0,"motion":0}],"nameRight":"Homura","textRight":"..."},{"chara":[{"eyeClose":0,"id":200301,"lipSynch":1,"motion":100}],"nameRight":"Homura","textRight":"The only person who can bring your memories@into the future..."},{"chara":[{"id":200301}],"nameRight":"Homura","textRight":"...is yourself, you know?"},{"chara":[{"eyeClose":1,"id":104301,"lipSynch":0}],"nameLeft":"Kuroe","textLeft":"..."},{"chara":[{"id":200301,"motion":0},{"eyeClose":0,"id":104301,"motion":0}],"nameRight":"Homura","textRight":"If you happen to meet that girl who smells like@night jasmine, could you apologize for me?"},{"chara":[{"eyeClose":1,"id":200301,"motion":300}],"nameRight":"Homura","textRight":"I feel she might've seen me as cold and@insensitive..."},{"autoTurnLast":1.5,"flashEffect":"flashWhiteSlow1","textClear":1,"turnEffect":"promist"},{"chara":[{"eyeClose":0,"id":200301,"motion":0}],"nameRight":"Homura","textRight":"Well, I've got to get going. I'll see you tomorrow."},{"autoTurnLast":0.5,"bgm":"stop","textClear":1},{"autoTurnLast":2.0,"turnChangeIn":"whiteIn","turnChangeInTime":1.5,"turnEffect":"stop"}]},"version":3}

{"story":{"group_1":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3036_00_01","textHome":"Hello, my name is Maria Yuki."}]},{"autoTurnFirst":7.6,"chara":[{"id":303600,"motion":1,"textHome":"Aside from fighting as a Magical Girl@after school, I also work part-time at@a children's supplementary care service."}]},{"autoTurnFirst":1.7,"chara":[{"id":303600,"motion":200,"textHome":"It can be quite difficult sometimes,@but the kids are just too lovely,@so I really enjoy this job."}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":0,"textHome":"Would you like to try helping out as well?"}]},{"autoTurnFirst":0.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303600,"motion":400,"textHome":"Ah, of course,@only as part-time work."}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303600}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303600,"motion":300,"pos":1,"tear":0,"voice":"vo_char_3036_00_17","textHome":"I can't confidently say that@my family wasn't an influence@on my dream of being a nursery teacher."}]},{"autoTurnFirst":3.0,"chara":[{"id":303600,"motion":1,"textHome":"After all, my parents were@remarkable people, but I never really...@got that much affection from them..."}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":1,"id":303600}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303600,"motion":300,"pos":1,"tear":0,"voice":"vo_char_3036_00_18","textHome":"Maybe, aside from my own household,"}]},{"autoTurnFirst":4.7,"chara":[{"eyeClose":1,"id":303600,"textHome":"there are certainly families that,@because of many circumstances, are not@able to give their kids the love they need."}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":303600}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":0,"textHome":"I believe that perhaps@I can be of assistance to them."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303600,"motion":100,"pos":1,"tear":0,"voice":"vo_char_3036_00_19","textHome":"No~w then, the super fun puppet theater@is about to begin~!"}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303600,"motion":400,"pos":1,"tear":0,"voice":"vo_char_3036_00_20","textHome":"So this is what it means to be@\"overflowing with power\", isn't it."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303600,"motion":300,"pos":1,"tear":0,"voice":"vo_char_3036_00_21","textHome":"I didn't have that much interest@in being strong before,"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303600,"motion":0,"textHome":"but now,@I want to become stronger and stronger,@so that I can protect the children."}]},{"autoTurnFirst":2.7,"chara":[{"id":303600,"motion":200}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303600,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3036_00_22","textHome":"The truth about Magical Girls@did frighten me,"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303600,"textHome":"but even so, I still want to fight on@so that everyone can live in peace."}]},{"autoTurnFirst":4.5,"chara":[{"id":303600,"motion":200,"textHome":"If that means Witches were@to completely disappear,@then that's fine by me..."}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303600,"motion":0,"textHome":"I guess thinking like that would@get me being called delusional."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":303600,"motion":300,"pos":1,"tear":0,"voice":"vo_char_3036_00_23"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":303600}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303600}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_17":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303600,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3036_00_24","textHome":"My, you came, I was waiting for you."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303600}]},{"autoTurnFirst":1.5,"chara":[{"id":303600,"motion":200,"textHome":"Seeing all your lively faces@makes me so happy!"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600}]},{"autoTurnFirst":4.2,"chara":[{"id":303600,"motion":1,"textHome":"Alright, I'll call your names now,@so give me a big reply, okay?"}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303600,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3036_00_25","textHome":"Are you still sleepy?"}]},{"autoTurnFirst":0.8,"chara":[{"eyeClose":1,"id":303600,"textHome":"Hmm..."}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":303600}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303600,"motion":400,"textHome":"I know!@I'll cheer you on!"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600}]},{"autoTurnFirst":3.5,"chara":[{"id":303600,"motion":200,"textHome":"Do your best, do your best!@You can do it, you can do it!@Fight, fight!"}]},{"autoTurnFirst":2.7,"chara":[{"id":303600,"motion":400}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":0,"textHome":"There, good job!"}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303600,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3036_00_26","textHome":"Join your hands together please."}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303600,"motion":400,"textHome":"Oh, I'm not at work now, am I?"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":200,"textHome":"Still, it's better to be polite when@expressing gratitude, so shall we continue?"}]},{"autoTurnFirst":1.2,"chara":[{"id":303600,"motion":0,"textHome":"One, two...@\"thank you for the meal\". "}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3036_00_02","textHome":"Nice to meet you,@my name is Maria Yuki."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303600,"motion":300,"textHome":"People often tell me I come across@as a widow or an apartment housewife,"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303600,"motion":200,"textHome":"but I'm merely a high schooler,@you know."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303600,"textHome":"What does an \"apartment housewife\"@even mean...?"}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":5.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303600,"motion":400,"pos":1,"tear":0,"voice":"vo_char_3036_00_27","textHome":"Ah, this scent...@Someone around here is making curry!"}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":303600,"motion":200,"textHome":"An excited kid might come back home covered@in dirt, and ask for lots of helpings..."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600,"motion":100,"textHome":"Ehehe, seems delightful."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3036_00_28","textHome":"I've got to practice for the puppet theater@I'll be performing at the event next month."}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":303600,"motion":0,"textHome":"Ahem...!"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600,"motion":300,"textHome":"Oh dear, how truly magnificent@of a thing this is..."}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":303600}]},{"autoTurnFirst":4.2,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":303600,"motion":1,"textHome":"I wonder if I'm doing@a good old lady's voice...?"}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3036_00_29","textHome":"Over at the supplementary care service,@I help out with things like event duties@and checking homework."}]},{"autoTurnFirst":3.5,"chara":[{"id":303600,"motion":200,"textHome":"It's not easy sometimes,@but it's pure bliss,@since everyone is so adorable."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303600,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3036_00_30","textHome":"There is no need to panic."}]},{"autoTurnFirst":2.3,"chara":[{"id":303600,"motion":200,"textHome":"It's a very strong Witch's reaction@indeed, but I am here with you."}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303600}]},{"autoTurnFirst":2.0,"chara":[{"id":303600,"motion":0,"textHome":"Try taking a soft, deep breath,@and once you're feeling calmer,@let's go and quickly take it down."}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600,"motion":100}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303600,"motion":400,"pos":1,"tear":0,"voice":"vo_char_3036_00_31","textHome":"The Mirror Witch?!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303600,"motion":200,"textHome":"That is quite the depraved one, isn't it."}]},{"autoTurnFirst":5.0,"chara":[{"id":303600,"textHome":"Even if they're fakes,@fighting with another person still@bears a heavy burden on one's heart."}]},{"autoTurnFirst":4.0,"chara":[{"id":303600,"motion":0,"textHome":"But even so,@that's precisely why I can't run away!"}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303600,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3036_00_32"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":303600,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":100}]}],"group_26":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3036_00_33","textHome":"When playing together with the children,@there is one thing to be mindful of."}]},{"autoTurnFirst":2.8,"chara":[{"id":303600,"motion":300,"textHome":"That is: how to hold back."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":303600,"textHome":"Those kids are more keen than I thought;@if I carelessly hold back,@they will notice it right away."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600,"motion":100}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303600,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3036_00_34","textHome":"My classmates tell me@I'm like a widow and everything,"}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":303600,"textHome":"but honestly, not even losing a husband—@just never having a boyfriend to begin with... "}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":303600}]},{"autoTurnFirst":2.2,"chara":[{"id":303600,"motion":300,"textHome":"...feels a bit lonely already."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303600,"motion":400,"pos":1,"tear":0,"voice":"vo_char_3036_00_35","textHome":"Could it be that people think@I'm older because of my curly hair?"}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303600}]},{"autoTurnFirst":4.2,"chara":[{"id":303600,"motion":200,"textHome":"*Sigh*... I really do envy@those smooth and silky hairstyles@that have an angelic halo-like shine."}]},{"autoTurnFirst":3.3,"chara":[{"id":303600,"motion":300}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303600,"motion":200,"pos":1,"tear":0,"voice":"vo_char_3036_00_36","textHome":"Hey you!"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303600,"textHome":"Oh, have I startled you?"}]},{"autoTurnFirst":8.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":1,"textHome":"I was practicing getting angry just now.@I'm not good at it, but the teachers@I admire are all very good at being mad."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3036_00_03"}]},{"autoTurnFirst":1.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303600}]}],"group_30":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":300,"pos":1,"tear":0,"voice":"vo_char_3036_00_37","textHome":"The older primary school kids who@have left the supplementary care@service sometimes come back to play."}]},{"autoTurnFirst":3.8,"chara":[{"id":303600,"motion":1,"textHome":"When I see how big they've gotten@after not meeting for a while,"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":303600,"motion":400,"tear":1,"textHome":"I get a little emotional."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3036_00_38","textHome":"Moka is a bit of an airhead,@but she is a sweet girl@from the bottom of her heart."}]},{"autoTurnFirst":2.9,"chara":[{"id":303600,"motion":200}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":303600,"textHome":"I wish kids like her can eventually live@in this world without any impairments."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303600,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3036_00_39","textHome":"Hagumu is such a hard worker,@it's admirable."}]},{"autoTurnFirst":4.2,"chara":[{"id":303600,"motion":300,"textHome":"But in some respects, she is@negative and lacks self confidence..."}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":303600,"textHome":"Yeah, I just cannot neglect her."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":303600,"motion":300,"pos":1,"tear":0,"voice":"vo_char_3036_00_40","textHome":"I would probably be lying if@I said I don't have any regrets@over becoming a Magical Girl..."}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":200,"textHome":"But if I'm able to protect the children@from the dangers that threaten them,@even if just a little bit,"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600,"textHome":"then that is a good thing."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":1.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":303600,"motion":200,"pos":1,"tear":0,"voice":"vo_char_3036_00_41","textHome":"Oh~?!@Looks like you went@a little too far just now."}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":100,"textHome":"What should you do@when you've done something wrong?"}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600,"motion":0,"textHome":"There you go!@You apologized honestly, good, good!"}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303600,"motion":400,"pos":1,"tear":0,"voice":"vo_char_3036_00_42","textHome":"I guess this is something@I can't show the kids!"}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3036_00_43","textHome":"Now, let's get ready to go home."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303600,"motion":200,"pos":1,"tear":0,"voice":"vo_char_3036_00_44","textHome":"You can't do this, okay?"}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303600,"motion":100,"pos":1,"tear":0,"voice":"vo_char_3036_00_45","textHome":"Everyone~, you all did great!"}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":303600,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3036_00_46"}]}],"group_4":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":303600,"motion":200,"pos":1,"tear":0,"voice":"vo_char_3036_00_04"}]}],"group_5":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":303600,"motion":300,"pos":1,"tear":0,"voice":"vo_char_3036_00_05"}]}],"group_6":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3036_00_13","textHome":"The value of unwavering diligence..."}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":303600,"textHome":"I want to teach this@to the children as well."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":303600,"motion":100,"pos":1,"tear":0,"voice":"vo_char_3036_00_14","textHome":"Even I can still grow this much!"}]},{"autoTurnFirst":0.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":303600,"textHome":"This isn't a sign of age, right?"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":303600}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":200,"pos":1,"tear":0,"voice":"vo_char_3036_00_15","textHome":"When I'm with the children,@I can understand the worries@their parents have to go through."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":303600,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3036_00_16","textHome":"I want to become an actual@nursery teacher in the future."}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":1,"id":303600,"motion":300,"textHome":"In fact even now, apart from working@at the supplementary care service,"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":303600}]},{"autoTurnFirst":4.0,"chara":[{"id":303600,"motion":200,"textHome":"I'm also having a glimpse@at the nursery school life@working there as a volunteer."}]},{"chara":[{"id":303600,"textHomeStatus":"Clear"}]}]},"version":3}

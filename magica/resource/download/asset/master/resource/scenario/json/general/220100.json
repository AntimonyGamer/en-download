{"story":{"group_1":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_01","textHome":"Uhm, nice to meet you?"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":220100,"textHome":"If you make a contract with me,@I'll grant you any one wish."}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":220100}]},{"autoTurnFirst":5.4,"chara":[{"id":220100,"motion":100,"textHome":"I'll tell you in advance,@I have nothing to do with Kyubey."}]},{"autoTurnFirst":5.4,"chara":[{"id":220100,"motion":0,"textHome":"I'm a demon who's temporarily residing@in the body of Homura Akemi."}]},{"autoTurnFirst":8.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":200,"textHome":"So, what's your wish?@I'll grant you anything@in exchange for your body."}]},{"autoTurnFirst":7.5,"chara":[{"cheek":-1,"face":"mtn_ex_014.exp3.json","id":220100,"motion":300,"textHome":"Let's see...@How about 50 pizzas?"}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":7.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_17","textHome":"Apparently, there's a memory in@her head where she tried to@imitate Madoka by wearing twintails."}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"face":"mtn_ex_053.exp3.json","id":220100,"textHome":"But she didn't look as much like Madoka@as she thought she would."}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":220100,"motion":100,"textHome":"I guess Madoka's cuteness is unparalleled."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_053.exp3.json","id":220100,"motion":400,"pos":1,"voice":"vo_char_2201_00_18","textHome":"Oh, her mind is overflowing@with memories of Madoka."}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":220100,"textHome":"Hey, Homura Akemi, stop it!"}]},{"autoTurnFirst":3.9,"chara":[{"id":220100,"motion":200,"textHome":"Right now,@I'm the one in control of this body."}]},{"autoTurnFirst":2.1,"chara":[{"id":220100,"motion":300,"textHome":"*Pant* *Pant*...@Yes, privacy is important."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_053.exp3.json","id":220100}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":9.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_19","textHome":"As a demon, it's only natural that@I can defy the game's functions, right?"}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":5.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":220100,"motion":100,"pos":1,"voice":"vo_char_2201_00_20","textHome":"It is the pinnacle of all@human emotions, desires, and calories:"}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":220100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":200,"textHome":"Giga Cheese Italiana@and Mentaiko Mayo Shrimp."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":5.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_21","textHome":"I am now a being who disrupts providence@and acts as an agitator for this world."}]},{"autoTurnFirst":6.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":200,"textHome":"Even if it's a thick-cut steak, I can@burn off the calories with my demon power."}]},{"autoTurnFirst":7.0,"chara":[{"id":220100,"motion":400,"textHome":"Well, now it's essentially zero calories."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":8.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":100,"pos":1,"voice":"vo_char_2201_00_22","textHome":"*Chuckle* I'll show you too.@A sinful act allowed only for true demons."}]},{"autoTurnFirst":9.3,"chara":[{"id":220100,"motion":1,"textHome":"On a quiet night,@take Camembert cheese, wrap it in bacon,@and cook it until the cheese melts."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":-1,"face":"mtn_ex_014.exp3.json","id":220100,"motion":200,"textHome":"Truly a devilish deed."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":8.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":220100,"motion":100,"pos":1,"voice":"vo_char_2201_00_23","textHome":"Do you treasure this world?@Do you consider order and stability@more important than desire?"}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":220100,"textHome":"I see.@Then I suppose you are my enemy."}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":220100}]},{"autoTurnFirst":7.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":200,"textHome":"Perhaps you should indulge in the@simple pleasures of human desires."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":220100,"motion":400,"textHome":"Hurry up and order a large pizza!"}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_17":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_24","textHome":"Do you need something@from Homura Akemi?"}]},{"autoTurnFirst":6.9,"chara":[{"eyeClose":0,"id":220100,"textHome":"Unfortunately, I have been summoned,@and I am using her body."}]},{"autoTurnFirst":5.0,"chara":[{"id":220100,"motion":100,"textHome":"If you have a message, I'll hear you out."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":6.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":220100,"motion":200,"pos":1,"voice":"vo_char_2201_00_25","textHome":"The early bird gets the worm?@I don't seek such joy."}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":220100,"motion":0,"textHome":"I'll just sleep if I want to,@regardless of the precious morning hours."}]},{"autoTurnFirst":3.6,"chara":[{"eyeClose":0,"id":220100,"textHome":"Now THAT brings me joy."}]},{"autoTurnFirst":3.2,"chara":[{"id":220100,"motion":100,"textHome":"Well, I'm going to take a nap again,@so please don't wake me up."}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":220100,"textHome":"Zzz... Zzz..."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_26","textHome":"Good morning.@Oh, already noon, is it?"}]},{"autoTurnFirst":7.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":100,"textHome":"But that doesn't matter.@Morning is when I wake up.@That's how it is."}]},{"autoTurnFirst":8.0,"chara":[{"id":220100,"motion":200,"textHome":"Now, should I make some marshmallow toast@with plenty of honey for breakfast?"}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":5.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_02","textHome":"I am a demon who was summoned by@Homura Akemi and took over her body."}]},{"autoTurnFirst":6.6,"chara":[{"eyeClose":1,"id":220100,"textHome":"*Chuckle* I'm not even@a demon version of Homura-chan,@that is just slightly different."}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":220100}]},{"autoTurnFirst":8.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":200,"textHome":"Such a being could only be called@Devil Homura-chan, I suppose?"}]},{"autoTurnFirst":4.5,"chara":[{"id":220100,"motion":100,"textHome":"We should at least pretend to be@friendly in our day-to-day lives."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":220100,"motion":100,"pos":1,"voice":"vo_char_2201_00_27","textHome":"Actually, I didn't do anything@all day today..."}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":220100,"textHome":"Well, it's okay@to have days like that, right?"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":220100,"motion":200,"textHome":"I am a demon;@there's no one who can criticize me."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":220100,"textHome":"And if someone does, I won't forgive them!"}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":200,"pos":1,"voice":"vo_char_2201_00_28","textHome":"You're looking at me in disbelief,@aren't you? Coca-Cola and@fried potatoes at night are a sin?"}]},{"autoTurnFirst":1.2,"chara":[{"eyeClose":1,"id":220100,"motion":100,"textHome":"Well, yes, but I won't hesitate."}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":0,"id":220100}]},{"autoTurnFirst":5.0,"chara":[{"id":220100,"motion":400,"textHome":"After all, I'm a demon.@*Chuckle*"}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":5.1,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_29","textHome":"I'm an ally of level-headed people@and an enemy of fools@who engage in pointless fights."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":0,"id":220100,"textHome":"Which one are you?"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_053.exp3.json","id":220100,"motion":300,"textHome":"If you're trying to strip my futon@right now, I'll let it slide."}]},{"autoTurnFirst":4.7,"chara":[{"cheek":2,"face":"mtn_ex_050.exp3.json","id":220100,"motion":400,"textHome":"So let go of your hand grabbing that futon!"}]},{"autoTurnFirst":4.0,"chara":[{"id":220100,"motion":200,"textHome":"I'll never give up!"}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":220100,"motion":400,"pos":1,"voice":"vo_char_2201_00_30","textHome":"Fight Witches? Me?"}]},{"autoTurnFirst":6.4,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":220100,"motion":200,"textHome":"I'm just temporarily residing in@Homura Akemi's body after being summoned."}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":0,"textHome":"But it's a good opportunity@to test my power in this body."}]},{"autoTurnFirst":7.0,"chara":[{"id":220100,"motion":100,"textHome":"I'll annihilate them in an instant@with my demon power."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":220100,"motion":0,"pos":1,"voice":"vo_char_2201_00_31","textHome":"There's a copy of me in the Endless Mirrors?"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":1,"textHome":"Oh, right..."}]},{"autoTurnFirst":1.6,"chara":[{"eyeClose":1,"id":220100,"textHome":"Hmm...@I remembered I had something to do,@so I should go."}]},{"autoTurnFirst":4.8,"chara":[{"eyeClose":0,"id":220100}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_053.exp3.json","id":220100,"motion":300,"textHome":"It's not like I'm going to@defeat that copy or anything."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":5.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":100,"pos":1,"voice":"vo_char_2201_00_32","textHome":"It's pointless for Magical Girls@to fight each other."}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":220100,"motion":200,"textHome":"I'm a demon,@so I have no interest in conflicts."}]},{"autoTurnFirst":5.5,"chara":[{"eyeClose":0,"id":220100,"textHome":"Maybe I should just@stay home and order food."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_26":[{"autoTurnFirst":8.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":220100,"motion":400,"pos":1,"voice":"vo_char_2201_00_33","textHome":"Oh, ouch! I was practicing@a demon-like signature pose@and accidentally twisted my neck."}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_053.exp3.json","id":220100,"motion":0,"textHome":"I guess I need to do some warm-up exercises@to avoid getting hurt next time I try@dynamic back arches and dramatic turns."}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":220100,"motion":100}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":9.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_053.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_34","textHome":"There's a memory in Homura Akemi's mind@about attending a meeting of@eyeglass-wearing Magical Girls..."}]},{"autoTurnFirst":10.0,"chara":[{"id":220100,"motion":300,"textHome":"What kind of organization is that,@I wonder? Or rather, she's actually@a member of such an organization?"}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":8.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":220100,"motion":200,"pos":1,"voice":"vo_char_2201_00_35","textHome":"I thought about giving Homura Akemi@a makeover. I wanted her to take off@her glasses and let her hair down like me,"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":220100,"textHome":"but I stopped halfway.@There are adult reasons for that."}]},{"autoTurnFirst":4.0,"chara":[{"id":220100,"motion":100,"textHome":"It's a shame, though."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":5.1,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":220100,"motion":400,"pos":1,"voice":"vo_char_2201_00_36","textHome":"Tch!@A child on the street pointed at me@and said, \"You have chuunibyou!\""}]},{"autoTurnFirst":5.2,"chara":[{"cheek":2,"face":"mtn_ex_053.exp3.json","id":220100,"motion":1,"textHome":"Well, it's just a child's comment,@so I don't really care."}]},{"autoTurnFirst":5.5,"chara":[{"cheek":2,"face":"mtn_ex_050.exp3.json","id":220100,"motion":100,"textHome":"Huh?@Do you think my outfit...is strange?"}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":220100,"motion":400,"pos":1,"voice":"vo_char_2201_00_03"}]}],"group_30":[{"autoTurnFirst":9.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_37","textHome":"The other day, I ordered a pizza with@lots of cheese as per recommendation of@that girl who always talks about cheese."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":220100,"motion":200,"textHome":"She has some interesting qualities@that would make a good demon."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":8.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_38","textHome":"I thought about trying to break up@Madoka's friendship with Sayaka Miki."}]},{"autoTurnFirst":7.0,"chara":[{"id":220100,"motion":100,"textHome":"But the contract is to break up@her friendship with Iroha Tamaki,@so I'll prioritize that for now."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":9.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":220100,"motion":300,"pos":1,"voice":"vo_char_2201_00_39","textHome":"I had some business in Kazamino@and took a bus with Kyoko Sakura.@We never seemed to reach our destination."}]},{"autoTurnFirst":2.8,"chara":[{"id":220100,"motion":0,"textHome":"You see..."}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":220100,"textHome":"We were on the wrong bus!"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":-1,"face":"mtn_ex_050.exp3.json","id":220100,"motion":400,"textHome":"Why? Hey!@When did we go wrong?!"}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":5.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_40","textHome":"Mami Tomoe and Madoka used a technique@called \"Tiro Duet\" together."}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":100,"textHome":"So, I'm thinking of coming up with@a technique for Madoka and me@to perform together."}]},{"autoTurnFirst":4.0,"chara":[{"id":220100,"motion":300,"textHome":"What do you think would be a good name?@Devil..."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":220100,"motion":400,"pos":1,"voice":"vo_char_2201_00_41","textHome":"Ah-choo!"}]},{"autoTurnFirst":2.3,"chara":[{"eyeClose":0,"id":220100,"textHome":"Huh? Did I just..."}]},{"autoTurnFirst":0.7,"chara":[{"eyeClose":1,"id":220100,"motion":400,"textHome":"Ah-choo!"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":220100}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":220100,"textHome":"What?"}]},{"autoTurnFirst":4.3,"chara":[{"id":220100,"motion":0,"textHome":"Does she get freed if I sneeze? I've@been a demon for years, and I've never@known about this sneezing swap system!"}]},{"autoTurnFirst":5.0,"chara":[{"id":220100,"motion":200}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_42","textHome":"I'll be your enemy."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":100,"pos":1,"voice":"vo_char_2201_00_43","textHome":"I won't lose in a contest of endurance."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":200,"pos":1,"voice":"vo_char_2201_00_44","textHome":"I'm modifying the system@so you can never defy me again."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":300,"pos":1,"voice":"vo_char_2201_00_45","textHome":"I too want a personal assistant."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":100,"pos":1,"voice":"vo_char_2201_00_46","textHome":"It's always the devil who wins in the end."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_053.exp3.json","id":220100,"motion":100,"pos":1,"voice":"vo_char_2201_00_04"}]}],"group_5":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_05"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":220100}]}],"group_6":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":200,"pos":1,"voice":"vo_char_2201_00_13","textHome":"My demon power is overflowing."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":220100,"motion":100,"pos":1,"voice":"vo_char_2201_00_14","textHome":"You've gathered so many gems for me."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":7.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_053.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_15","textHome":"Maybe I've gotten too used to this body?@I feel like I'm gradually forgetting who I was@as a demon before taking over Homura Akemi."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":220100,"motion":400}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":7.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":220100,"motion":1,"pos":1,"voice":"vo_char_2201_00_16","textHome":"Being inside Homura Akemi's body, I can@feel her memories and emotions flowing."}]},{"autoTurnFirst":9.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":220100,"motion":200,"textHome":"Like, she wanted a duo unit with@Madoka to be released. Maybe she@should've wished for that instead."}]},{"chara":[{"id":220100,"textHomeStatus":"Clear"}]}]},"version":3}

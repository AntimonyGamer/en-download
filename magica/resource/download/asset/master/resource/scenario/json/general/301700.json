{"story":{"group_1":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3017_00_01","textHome":"I'm Yukika Nanase,@a first-year high school student@of Mizuna Girls' Academy."}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301700,"textHome":"My hobby is...going to arcades after school@in secret, I guess you could say?"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":100}]},{"autoTurnFirst":0.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301700,"motion":400,"textHome":"Oh, that was...@Please act like you didn't hear that."}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301700}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"id":301700,"motion":300,"textHome":"I keep it a secret@from my classmates, so..."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":4.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3017_00_17","textHome":"In truth, I've recently become@addicted to pinball, which before has@gathered dust in the corner of the arcade."}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301700,"motion":200}]},{"autoTurnFirst":1.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301700,"motion":400,"textHome":"Oh, please keep it a secret@from my friends...!"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":301700,"motion":300}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301700,"motion":100,"pos":1,"tear":0,"voice":"vo_char_3017_00_18","textHome":"The difference between Mizuna Girls' Academy@and Saint Liliana Academy, you ask...?"}]},{"autoTurnFirst":1.9,"chara":[{"eyeClose":1,"id":301700,"motion":0,"textHome":"Let's see..."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301700}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":200,"textHome":"Mizuna is a school with@venerable traditionalism,"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301700,"textHome":"while Lilianna is a school@for celebrity young ladies...@That's how I feel."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301700,"motion":400,"pos":1,"tear":0,"voice":"vo_char_3017_00_19","textHome":"I can see it!@The pattern of triumph!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301700}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":200,"pos":1,"tear":0,"voice":"vo_char_3017_00_20","textHome":"With the power I have now,@any trouble is welcomed with open arms!"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301700}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301700,"motion":0,"textHome":"J-Just kidding."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301700,"motion":300}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3017_00_21","textHome":"Magical Girls grow up little by little,@do they not?"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":301700,"motion":300,"textHome":"Though, the stronger you become,@the more trouble you can get@yourself into...doesn't it?"}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301700}]},{"autoTurnFirst":3.0,"chara":[{"id":301700,"motion":100}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3017_00_22"}]},{"autoTurnFirst":3.7,"chara":[{"eyeClose":1,"id":301700,"textHome":"I realized something after I became@a Magical Girl and got a little stronger."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301700}]},{"autoTurnFirst":4.0,"chara":[{"id":301700}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301700,"motion":300,"textHome":"Even when I'm cornered and prepared to die,@at that moment I still want to live,@so I'm certain that I'll continue to live on."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":301700}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301700}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":0}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":4.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":200,"pos":1,"tear":0,"voice":"vo_char_3017_00_23"}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301700,"motion":300}]},{"autoTurnFirst":2.8,"chara":[{"eyeClose":1,"id":301700}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301700}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301700,"motion":1}]}],"group_17":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301700,"motion":400,"pos":1,"tear":0,"voice":"vo_char_3017_00_24","textHome":"I'm so sorry!"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301700,"textHome":"Oh no, I've just apologized to you in advance@were there any troubles caused thereafter."}]},{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":1,"textHome":"I want to get through the day safely without@involving any peculiar incidents, you see."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3017_00_25","textHome":"You're quite the early bird,@aren't you?"}]},{"autoTurnFirst":5.4,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301700,"motion":300,"textHome":"If you stay asleep any longer, I would@think that you'll never wake up again..."}]},{"autoTurnFirst":3.0,"chara":[{"id":301700,"motion":200,"textHome":"...and end up informing my parents@to escort you to the hospital, so..."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301700,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3017_00_26","textHome":"Do you get nervous at lunchtime?"}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301700,"textHome":"Personally, I do."}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301700,"textHome":"I do enjoy having lunch with my friends,@but I worry that I might cause a scene..."}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301700,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":301700}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3017_00_02","textHome":"Apologies for the trouble@I cause every time."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301700,"motion":100,"textHome":"My name is Yukika Nanase."}]},{"autoTurnFirst":6.3,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301700,"motion":1,"textHome":"For undisclosed reasons, I'm prone to@getting into trouble, so I suggest@you stay away right this instant...!"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301700,"motion":200}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":3.4,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301700,"motion":200,"pos":1,"tear":0,"voice":"vo_char_3017_00_27","textHome":"A moment, please? I'm currently@in the middle of an important..."}]},{"autoTurnFirst":0.8,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":301700,"textHome":"What do you mean, \"what\"? I'm in@the middle of a medal game right now."}]},{"autoTurnFirst":2.9,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":301700,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":301700,"motion":400,"textHome":"This is the breaking point,@it's either win or lose!"}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":300,"pos":1,"tear":0,"voice":"vo_char_3017_00_28"}]},{"autoTurnFirst":2.6,"chara":[{"eyeClose":1,"id":301700,"textHome":"*Yaaawn*..."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301700}]},{"autoTurnFirst":3.6,"chara":[{"id":301700,"motion":100,"textHome":"I hope that I will be able@to sleep well today."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301700,"motion":1,"textHome":"Lately I've been getting into trouble,@even in my dreams..."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301700,"motion":400,"pos":1,"tear":0,"voice":"vo_char_3017_00_29","textHome":"Oh, \"trouble\", you say?"}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301700}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301700,"motion":0,"textHome":"No trouble is allowed within@a two-meter radius around me!"}]},{"autoTurnFirst":3.0,"chara":[{"id":301700,"motion":200}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":301700,"motion":300,"pos":1,"tear":0,"voice":"vo_char_3017_00_30"}]},{"autoTurnFirst":1.4,"chara":[{"eyeClose":1,"id":301700,"textHome":"Witch-hunting... It's certainly@nerve-wracking and really scary,@but I don't dislike it."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301700}]},{"autoTurnFirst":4.1,"chara":[{"id":301700}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":0}]},{"autoTurnFirst":7.0,"chara":[{"id":301700,"motion":100,"textHome":"I didn't know such a thing could happen in@our world before becoming a Magical Girl."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":301700,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3017_00_31","textHome":"A mansion with copies upon copies@of Magical Girls...?"}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301700,"motion":100,"textHome":"Then it's a place where troubles@will 100% occur."}]},{"autoTurnFirst":5.0,"chara":[{"id":301700,"motion":400,"textHome":"This is not somewhere@you should enter by yourself..."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301700,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3017_00_32"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301700,"motion":300}]},{"autoTurnFirst":4.0,"chara":[{"id":301700,"motion":100}]}],"group_26":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301700,"motion":400,"pos":1,"tear":0,"voice":"vo_char_3017_00_33","textHome":"Oh, I'm sorry I didn't notice you,@as I was studying."}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301700}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301700,"motion":1,"textHome":"Excuse me, could you not look at me@with a surprised face?"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301700,"textHome":"At school, I'm more of an honor student,@you know..."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3017_00_34","textHome":"I bought a smartphone rather recently,"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301700,"motion":100,"textHome":"so occasionally I play games in my pastime."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_040.exp.json","id":301700,"motion":300,"textHome":"M-Medal games, for instance."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":301700,"motion":200,"pos":1,"tear":0,"voice":"vo_char_3017_00_35","textHome":"I don't have any particular skills@to be called \"special\"."}]},{"autoTurnFirst":6.3,"chara":[{"id":301700,"motion":1,"textHome":"I did play the piano and violin@when I was little,@but neither did I do good nor bad,"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":301700,"motion":300,"textHome":"and my interest in them@faded away in the end."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":1.4,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301700,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3017_00_36","textHome":"Ah... Whoever looks at my Magical Girl@outfit will immediately come to the@conclusion that I like medal games~"}]},{"autoTurnFirst":4.2,"chara":[{"id":301700,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"id":301700,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":301700,"motion":200,"textHome":"It's supposed to be@a maiden's pastime secret..."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":301700,"motion":300,"pos":1,"tear":0,"voice":"vo_char_3017_00_03"}]}],"group_30":[{"autoTurnFirst":5.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3017_00_37","textHome":"I've had interactions with students@from Saint Liliana Academy."}]},{"autoTurnFirst":3.8,"chara":[{"id":301700,"motion":200,"textHome":"Some of them are super-wealthy@young ladies who have rows of@butlers and maids in their mansions."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301700}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":100,"pos":1,"tear":0,"voice":"vo_char_3017_00_38","textHome":"Hotori is such a good girl,@always trying her best."}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301700}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":1,"textHome":"I think I can understand why her sister@Rion wants to keep her for herself."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301700}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301700,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3017_00_39","textHome":"I'd say I'm quite confident@about my lack of presence."}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301700,"motion":300,"textHome":"I've bumped into Akatsuki-senpai@quite a number of times,"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":200,"textHome":"yet she didn't notice@that I was a Black Feather."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":301700,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3017_00_40","textHome":"What's good about being a Magical Girl,@you ask...?"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":301700,"textHome":"The moments when you get through the@hassle on the brink is very fulfilling."}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301700,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":301700,"motion":400,"textHome":"But in the end,@troubles are still troubles."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301700,"motion":400,"pos":1,"tear":0,"voice":"vo_char_3017_00_41","textHome":"Let us go all in!@How was that?"}]},{"autoTurnFirst":1.4,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":301700,"motion":200,"textHome":"Yes, yes, I've got it!@Medals obtained record streak:@broken!"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":301700}]},{"autoTurnFirst":0.8,"chara":[{"cheek":2,"face":"mtn_ex_050.exp.json","id":301700,"motion":0,"textHome":"Ah, eh, um..."}]},{"autoTurnFirst":1.2,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":301700,"motion":0,"tear":1}]},{"autoTurnFirst":5.0,"chara":[{"id":301700,"motion":100,"tear":1,"textHome":"S-since when have you been watching~?!"}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":100,"pos":1,"tear":0,"voice":"vo_char_3017_00_42","textHome":"Let the games begin!"}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301700,"motion":300,"pos":1,"tear":0,"voice":"vo_char_3017_00_43"}]},{"autoTurnFirst":0.8,"chara":[{"eyeClose":1,"id":301700,"textHome":"Phew...@Apologies for the disturbance..."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301700}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301700}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":200,"pos":1,"tear":0,"voice":"vo_char_3017_00_44","textHome":"It seems like you've run out of luck."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":301700,"motion":400,"pos":1,"tear":0,"voice":"vo_char_3017_00_45","textHome":"Winning this game takes guts!"}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":0.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":301700,"motion":200,"pos":1,"tear":0,"voice":"vo_char_3017_00_46","textHome":"We've barely made it, indeed!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301700}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":301700,"motion":0,"pos":1,"tear":0,"voice":"vo_char_3017_00_04"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":301700,"motion":300}]}],"group_5":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3017_00_05"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":301700}]}],"group_6":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":200,"pos":1,"tear":0,"voice":"vo_char_3017_00_13","textHome":"I can do it! I have a hunch@that we will hit the jackpot...!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301700}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":100,"pos":1,"tear":0,"voice":"vo_char_3017_00_14","textHome":"By now, I am certain@that I can win any big game!"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301700}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":301700,"motion":1,"pos":1,"tear":0,"voice":"vo_char_3017_00_15","textHome":"Thank you very much for always@putting up with someone like me."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":301700}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":301700,"motion":300,"pos":1,"tear":0,"voice":"vo_char_3017_00_16"}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":301700,"textHome":"I too do not want to get myself@into trouble at all..."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":301700}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_040.exp.json","id":301700,"motion":1,"textHome":"But somehow, I always come to@a pinch when I can't run away from."}]},{"chara":[{"id":301700,"textHomeStatus":"Clear"}]}]},"version":3}

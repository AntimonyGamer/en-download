xp3.json","id":800100}],"nameLeft":"","textLeft":"I think our opponents feel it too.@They might try for a safe score next…"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":801000}],"nameRight":"","textRight":"Yeah, but then…"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800100}],"narrationBg":"bg_adv_20251.jpg","narrationEffect":"in","textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":801000,"pos":1}],"nameNarration":"Kokoro","narration":"If they do, they give us the chance to score@a narrow victory. Unlike baseball, kickball only@has five innings, so they can only try so many@tactics before the game ends…@That was what the coach was aiming for."},{"chara":[{"id":801000}],"nameCenter":"","narrationEffect":"out","textCenter":"And that's why we can still pull ahead, even@against a much stronger team."},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":801000}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_20251.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp3.json","id":305251,"motion":200,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp3.json","id":303901,"motion":1,"pos":2}],"nameLeft":"Ashley","textLeft":"Ooh, things are REALLY getting exciting now!"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":801200,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":801300,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":801600,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"autoTurnLast":0.2,"narrationBg":"bg_adv_20251.jpg","narrationEffect":"in"},{"nameNarration":"Kokoro","narration":"We've managed to keep the match close,@but the skill gap was too much to overcome.@They managed to pull three comebacks on us,@putting the score at 1 to 2…@It was anyone's game at this point.","turnChangeOut":"fadeOut"},{"autoTurnLast":1.8,"narrationEffect":"out"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":801600},{"effect":"fadeout","id":801
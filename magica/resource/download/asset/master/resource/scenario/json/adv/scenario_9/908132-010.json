{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"black","bgm":"stop","item":[{"path":"resource/scenario/img/scene0/scene_bg.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"charaBack"},{"path":"resource/scenario/img/scene0/scene_16.png","posX":0,"posY":0,"visible":"appear","zOrder":"charaFront"}],"turnChangeIn":"fadeIn"},{"autoTurnLast":1.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":0.5,"item":[{"path":"resource/scenario/img/scene0/scene_16.png","visible":"hide"}]},{"autoTurnLast":1.5,"item":[{"path":"resource/scenario/img/scene0/scene_32.png","posX":0,"posY":0,"visible":"appear","zOrder":"charaFront"}]},{"armatureList":[{"animation":["action"],"armatureId":1,"filePath":"resource/image_native/effect/story/general/3003_act_stage.ExportJson","zOrder":"messageBack"}],"autoTurnLast":0.2,"bg":"bg_adv_20203.jpg","chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":200902,"motion":0,"pos":1}],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/calender_day32.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"turnChangeIn":"fadeIn","turnEffect":"blackPromist"},{"autoTurnLast":1.5,"surround":"8056_stoppingtime","turnChangeOut":"fadeOut"},{"chara":[{"eyeClose":0,"id":200902,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-1"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]Huh...?@Where am I...?","textAvColor":"textMabayu"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200902,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-2"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]Why...?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200902,"motion":100,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-3"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]There's...no one here."},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-4"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]Everything's frozen in time..."},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-5"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]And I'm...all alone..."},{"autoTurnLast":0.01,"textAvClear":1},{"nameNarration":"","narration":"That's right. You're all alone.","narrationBg":"bg_adv_narration.jpg","narrationEffect":"in","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-6"},{"chara":[{"id":200902,"motion":0}],"narration":"It's fine to want to save somebody.","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-7"},{"narration":"There's nothing wrong with hoping@someone can work a miracle.","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-8"},{"narration":"But...","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-9"},{"narration":"...you'll never be friends with anyone.","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-10"},{"narration":"You're going to fade away,@completely alone.","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-11"},{"autoTurnLast":0.2,"narrationEffect":"out"},{"chara":[{"id":200902,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-12"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]Fade away...forsaken...","textAvColor":"textMabayu"},{"autoTurnLast":0.01,"bg":"black","deleteArmatureList":[1],"surround":"stop","textAvClear":1,"turnChangeIn":"fadeIn","turnEffect":"stop"},{"nameNarration":"","narration":"[surround:8020_alarmclock]*Ding Ding Ding*","narrationEffect":"in","turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bg":"black","narrationEffect":"out","turnChangeIn":"fadeIn","turnChangeInTime":0.01},{"armatureList":[{"animation":["action"],"armatureId":2,"filePath":"resource/image_native/effect/story/general/1507_wake_up.ExportJson","zOrder":"messageBack"}],"autoTurnLast":0.1,"turnChangeOut":"fadeOut"},{"autoTurnLast":0.1,"bg":"bg_adv_23167.jpg","chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":200901,"motion":0,"pos":1}],"deleteArmatureList":[2],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/calender_day32.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"turnChangeIn":"fadeIn"},{"chara":[{"eyeClose":1,"id":200901,"motion":300,"tear":1,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-13"}],"nameAvCenter":"Mabayu","surround":"stop","textAvCenter":"[fontSize:20]*Yawn*","textAvColor":"textMabayu","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"eyeClose":0,"id":200901,"tear":0,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-14"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]So that was...all a dream..."},{"chara":[{"id":200901,"motion":0,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-15"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]Yup. A dream..."},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":200901,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-16"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]Back to bed..."},{"autoTurnLast":1.0,"chara":[{"effect":"fadeout","id":200901}],"surround":"8036_futon","textAvClear":1},{"chara":[{"id":200901,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-17"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]......"},{"nameNarration":"","narration":"[surround:8020_alarmclock]*Ding Ding Ding*","narrationEffect":"in","textAvClear":1},{"autoTurnLast":0.2,"narrationEffect":"out"},{"nameAvCenter":"Mabayu's Voice","textAvCenter":"[fontSize:20]...NOPE.@Not waking up.","textAvColor":"textMabayu","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-18"},{"nameAvCenter":"Mabayu's Voice","textAvCenter":"[fontSize:20]What's the point in getting up, anyway?@Nothing good ever comes of it...","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-19"},{"autoTurnLast":0.01,"surround":"8036_futon"},{"autoTurnLast":0.5,"bg":"black","item":[{"anchor":"skip","path":"resource/scenario/img/scene0/calender_day32.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"textAvClear":1,"turnChangeIn":"fadeIn"},{"nameAvCenter":"Mabayu's Voice","textAvCenter":"[fontSize:20]I'm just going to curl up and die, making@a tragic pact with my beloved kotatsu.","turnChangeOut":"fadeOut","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-20"},{"nameAvCenter":"Mabayu's Voice","textAvCenter":"[fontSize:20]I'll stay holed up here forever...and ever...","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-21"},{"nameAvCenter":"Mabayu","surround":"stop","textAvCenter":"[fontSize:20]......","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-22"},{"autoTurnLast":1.5,"textAvClear":1},{"nameAvRight":"Homura's Voice","textAvColor":"textHomura","textAvRight":"[fontSize:20]How long are you going to keep sleeping?","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-23"},{"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]......","textAvColor":"textMabayu","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-24"},{"nameAvCenter":"Mabayu's Voice","textAvCenter":"[fontSize:20]Forever.","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-25"},{"nameAvRight":"Homura's Voice","textAvColor":"textHomura","textAvRight":"[fontSize:20]There is no \"forever.\"@We're going to escape this loop.","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-26"},{"nameAvRight":"Homura's Voice","textAvRight":"[fontSize:20]Someday, for sure...","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-27"},{"nameAvCenter":"Mabayu's Voice","textAvCenter":"[fontSize:20]Good luck out there. I could never betray my@kotatsu's warm embrace, so go on without m―","textAvColor":"textMabayu","voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-28"},{"autoTurnLast":0.01,"surround":"8036_futon"},{"autoTurnLast":0.01,"bg":"bg_adv_23167.jpg","chara":[{"cheek":0,"face":"mtn_ex_060.exp3.json","id":200911,"motion":0,"pos":1}],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/calender_day32.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"textAvClear":1,"turnChangeIn":"whiteIn"},{"autoTurnFirst":2.3,"autoTurnNoDelay":1,"chara":[{"effect":"shake","id":200911,"motion":400,"voiceFull":"fullvoice/section_104207/vo_full_908132-010-29"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]Wagh, cold!@W-what are you doing...?!","textAvColor":"textMabayu","turnChangeOut":"whiteOut"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":200911,"motion":0}]},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":200911,"voiceFullStop":"fullvoice/section_104207/vo_full_908132-010-29"}],"textAvClear":1},{"bgm":"bgm02_anime06","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":200201,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-30"},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200901,"motion":0,"pos":0}],"nameAvRight":"Homura","textAvColor":"textHomura","textAvRight":"[fontSize:20]Sayaka Miki ended up making a contract@with Kyubey."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-31"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]But after that, she learned the@truth about what that does to you,@and began to mentally spiral..."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-32"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]To try and stop her from turning into@a Witch, Madoka became a Magical Girl too."},{"chara":[{"eyeClose":1,"id":200201,"motion":300,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-33"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]So...this world is already a lost cause."},{"chara":[{"cheek":0,"face":"mtn_ex_031.exp3.json","id":200901,"motion":300,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-34"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]...It's all my fault."},{"chara":[{"id":200901,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-35"},{"eyeClose":0,"id":200201,"motion":0}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]This is my punishment for thinking@I could be her friend."},{"chara":[{"id":200901,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-36"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]I used my knowledge to cheat,@and manipulated Miss Miki's feelings..."},{"chara":[{"cheek":1,"id":200901,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-37"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]And I still had the gall to act@as if I was her friend."},{"chara":[{"eyeClose":1,"id":200901,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-38"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]I'm the worst...@Just absolute trash..."},{"bgm":"stop","nameNarration":"","narration":"[flashEffect:flashWhite1][surround:8044_slap][chara:200201:cheek_1:motion_400][chara:200901:cheek_1:face_mtn_ex_060.exp3.json:effect_shake]*Slap*","narrationEffect":"in","textAvClear":1},{"autoTurnLast":0.2,"narrationEffect":"out"},{"chara":[{"id":200901,"lipSynch":0,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-39"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]...!"},{"bgm":"bgm01_anime11","chara":[{"id":200201,"motion":0,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-40"},{"cheek":1,"face":"mtn_ex_031.exp3.json","id":200901}],"nameAvRight":"Homura","textAvColor":"textHomura","textAvRight":"[fontSize:20]Snap out of it already."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-41"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]Even if you try to remain in this world,@you're just going to get pulled along@to the next one with me."},{"chara":[{"id":200201,"motion":200,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-42"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]You won't be able to see the Sayaka@of this world again."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-43"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]Are you okay with that?"},{"chara":[{"id":200201,"motion":0,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-44"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]If you want to apologize to her,@this is your last chance."},{"chara":[{"eyeClose":0,"id":200901,"motion":0,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-45"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]What's the point in apologizing...?"},{"chara":[{"id":200901,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-46"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]We're going to leave this world behind."},{"chara":[{"id":200901,"motion":100,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-47"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Apologizing isn't going to..."},{"chara":[{"cheek":1,"id":200201,"motion":400,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-48"},{"cheek":1,"face":"mtn_ex_050.exp3.json","id":200901}],"nameAvRight":"Homura","textAvColor":"textHomura","textAvRight":"[fontSize:20]I know that!"},{"chara":[{"id":200201,"motion":0,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-49"},{"id":200901,"motion":0}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]My actions are pointless."},{"autoTurnFirst":2.2,"autoTurnNoDelay":1,"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":200201,"voiceFull":"fullvoice/section_104207/vo_full_908132-010-50"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]We can't beat Walpurgisnacht.@I keep letting them die!"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp3.json","id":200201}]},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":200201,"motion":200,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-51","voiceFullStop":"fullvoice/section_104207/vo_full_908132-010-50"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]This is all just self-indulgence!"},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-52"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]All to process my feelings!"},{"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_031.exp3.json","id":200201,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-53"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]I keep restarting the world@over and over..."},{"chara":[{"eyeClose":0,"id":200201,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-54"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]...all in a selfish attempt@to earn forgiveness for my sins!"},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":200201,"motion":101,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-55"},{"cheek":1,"face":"mtn_ex_030.exp3.json","id":200901}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]But if I lose even that..."},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-56"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]I don't think...@I'll be able to stay sane any longer."},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp3.json","id":200201,"motion":0,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-57"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]YOU were the one that made me@realize that!"},{"chara":[{"id":200201,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-58"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]So if you lose hope before I do..."},{"chara":[{"id":200201,"motion":200,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-59"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]...and leave me here all alone...@I won't forgive you, Mabayu!!!"},{"chara":[{"id":200901,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-60"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Miss Akemi..."},{"autoTurnLast":2.0,"textAvClear":1},{"chara":[{"eyeClose":1,"id":200901,"motion":100,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-61"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]...thank you."},{"autoTurnLast":1.5,"textAvClear":1},{"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":200901,"voiceFullAuto":"fullvoice/section_104207/vo_full_908132-010-62"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]I think...I'll go..."},{"autoTurnFirst":1.8,"autoTurnNoDelay":1,"chara":[{"id":200901,"voiceFull":"fullvoice/section_104207/vo_full_908132-010-63"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]...apologize to Miss Miki, now!"},{"chara":[{"id":200901,"motion":400}]},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn","voiceFullStop":"fullvoice/section_104207/vo_full_908132-010-63"}]},"version":3}

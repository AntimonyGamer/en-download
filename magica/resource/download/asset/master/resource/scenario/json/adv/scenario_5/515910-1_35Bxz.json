pos":0}],"nameLeft":"Kagome","textLeft":"Ah... Then, I'll..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":101501,"motion":100,"pos":2}],"nameRight":"Ui","textRight":"We'll be back soon, so you can relax."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":101501}],"nameRight":"Ui","textRight":"Sakurako is here too!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":304301,"motion":0,"pos":2}],"nameRight":"Eternal Sakura","textRight":"| Kagome, you can stay here with me. |"},{"chara":[{"cheek":0,"id":102001,"lipSynch":0,"motion":0,"pos":0}],"nameLeft":"Kagome","textLeft":"..."},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_31094.jpg","bgm":"bgm03_story23","chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402301,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":830200,"motion":0,"pos":0}],"turnChangeIn":"fadeIn"},{"chara":[{"id":402301}],"nameRight":"Melissa","textRight":"Lord Richemont used to say it like a mantra:","turnChangeOut":"fadeOut"},{"chara":[{"id":402301}],"nameRight":"Melissa","textRight":"La Pucelle's will shall never be extinguished..."},{"chara":[{"id":402301,"motion":400}],"nameRight":"Melissa","textRight":"If we proceed while trusting in that person,"},{"chara":[{"id":402301}],"nameRight":"Melissa","textRight":"Lord Charles can reclaim France from England...!"},{"chara":[{"id":830200}],"nameLeft":"Charles VII","textLeft":"...That's true, but..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402601,"motion":1,"pos":2}],"nameRight":"Elisa","textRight":"Is there something troubling you?"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":830200,"pos":0}],"nameLeft":"Charles VII","textLeft":"Ah, yes. It's my son, Dauphin Louis."},{"chara":[{"id":830200}],"nameLeft":"Charles VII","textLeft":"Louis is consumed by ambition for the throne."},{"chara":[{"id":830200}],"nameLeft":"Charles VII","textLeft":"As if driven by something,@he's rebelling against me..."},{"chara":[{"id":830200}],"nameLeft":"Charles VII","textLeft":"At first I thought he was merely being@manipulated by discontented nobles..."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402601,"motion":0}],"nameRight":"Elisa","textRight":"And it's not like that...?"},{"chara":[{"id":830200}],"nameLeft":"Charles VII","textLeft":"Yes, it's different.@It isn't normal, he seems insane."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":830200}],"nameLeft":"Charles VII","textLeft":"Just like I was until a moment ago."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402601},{"effect":"fadeout","id":830200}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":2,"soulGem":0}],"nameCenter":"Kagome & Torte","textCenter":"...!"},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402901,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":831303,"motion":300}],"nameLeft":"Torte","textLeft":"Um...unless we can bring back Dauphin Louis to@his right mind...","turnChangeOut":"fadeOut"},{"chara":[{"id":831303}],"nameLeft":"Torte","textLeft":"There's no chance of victory against England...?"},{"chara":[{"id":402901,"motion":400}],"nameRight":"Perenelle","textRight":"That's right."},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"Dauphin Louis, supported by the nobles,@is leading a large-scale rebellion..."},{"chara":[{"id":402901,"motion":0}],"nameRight":"Perenelle","textRight":"If this crisis continues,"},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"Tarte's desired light will not shine upon France."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":1,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"If we stop Dauphin Louis,"},{"chara":[{"id":102001}],"nameLeft":"Kagome","textLeft":"will the eroded world return to its original state...?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50}],"nameRight":"Qube","textRight":"La Hire's change of heart caused a significant shift."},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"Isabeau is showing signs of unease due to this@change."},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"We are in a critical situation that will shape the@future, and if Prince Louis also redirects his efforts,"},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"it could become a catalyst for a major change in the@world."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":0,"soulGem":0}],"nameLeft":"Torte","textLeft":"The last book left in the Ark...[chara:831303:lipSynch_0][wait:1.0][chara:831303:motion_100][chara:831303:cheek_0][chara:831303:face_mtn_ex_010.exp3.json][chara:831303:lipSynch_1]@It might be Dauphin Louis's book!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831700,"motion":0,"pos":2}],"nameRight":"Nicolas","textRight":"Yes, let's hope so."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402901,"motion":0,"pos":0}],"nameLeft":"Perenelle","textLeft":"Indeed."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831700},{"effect":"fadeout","id":402901}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831303,"motion":400,"pos":2,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":830200,"motion":0,"pos":0}],"nameRight":"Torte","textRight":"Oh... I'm sorry, Lord Charles."},{"chara":[{"id":831303,"motion":0}],"nameRight":"Torte","textRight":"We've been talking about things you probably don't@understand..."},{"chara":[{"id":830200}],"nameLeft":"Charles VII","textLeft":"No, it doesn't matter..."},{"chara":[{"id":830200}],"nameLeft":"Charles VII","textLeft":"However, you really do resemble La Pucelle."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":100,"pos":2}],"nameRight":"Torte","textRight":"It seems so!"},{"chara":[{"id":831303},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"nameRight":"Torte","textRight":"...Then, Kagome!"},{"chara":[{"id":831303,"motion":200}],"nameRight":"Torte","textRight":"Let's investigate the contents of the last book and@restore the world!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":400,"pos":0}],"nameLeft":"Kagome","textLeft":"Oh, sure..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":102001}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_31094.jpg","bgChangeEffect":"cameraPan"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402301,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402601,"motion":300,"pos":2}],"nameCenter":"Melissa & Elisa","textCenter":"...@..."},{"autoTurnLast":0.2,"chara":[{"id":402301,"pos":2}],"textClear":1},{"bgm":"bgm05_event05","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":0,"soulGem":0}],"nameLeft":"Torte","textLeft":"Huh...? Is something bothering you?"},{"chara":[{"id":402301,"motion":300}],"nameRight":"Melissa","textRight":"Yes..."},{"chara":[{"id":402301}],"nameRight":"Melissa","textRight":"If the world returns to its original state,"},{"chara":[{"id":402301}],"nameRight":"Melissa","textRight":"won't it mean subjecting Tart to the same suffering@once again...?"},{"chara":[{"id":402301}],"nameRight":"Melissa","textRight":"That's what I've started thinking..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831303,"pos":0}],"nameLeft":"Torte","textLeft":"Ah..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"...That's right."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402901,"motion":1,"pos":2}],"nameRight":"Perenelle","textRight":"Elisa, do you feel the same as Melissa?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402601,"motion":0,"pos":0}],"nameLeft":"Elisa","textLeft":"Yes, but we can't simply leave things as they are..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102001,"motion":300,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"If the erosion of the world of the red moon@continues,"},{"chara":[{"id":102001}],"nameLeft":"Kagome","textLeft":"La Pucelle herself will cease to exist..."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":831303,"motion":200,"pos":2,"soulGem":0}],"nameRight":"Torte","textRight":"That's...too much! To say it would've been@better for her never to have been born!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50}],"nameRight":"Qube","textRight":"Moreover, what awaits beyond that is a future@without humanity."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402301,"motion":1,"pos":0}],"nameLeft":"Melissa","textLeft":"I understand that there's no other way..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402601,"motion":300,"pos":2}],"nameRight":"Elisa","textRight":"Yes...even if she was given the choice,"},{"chara":[{"id":402601}],"nameRight":"Elisa","textRight":"Tart would choose to live the same life once again."},{"chara":[{"eyeClose":1,"id":402301}],"nameLeft":"Melissa","textLeft":"But..."},{"chara":[{"cheek":0,"eyeClose":1,"id":402601,"lipSynch":0,"pos":2}],"nameRight":"Elisa","textRight":"..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402301},{"effect":"fadeout","id":402601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402901,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831700,"motion":0,"pos":2}],"nameCenter":"Perenelle & Nicolas","textCenter":"..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402901},{"effect":"fadeout","id":831700}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102001,"motion":1,"pos":0,"soulGem":0},{"cheek":0,"id":810000,"motion":0,"pos":2,"posX":50}],"nameCenter":"Kagome & Qube","textCenter":"...@..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831303,"motion":0,"pos":2}],"nameRight":"Torte","textRight":"I don't think the two of you can make this choice.@The memories are just too painful."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":831303,"pos":2}],"nameRight":"Torte","textRight":"...So, it's my responsibility."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":400,"pos":0}],"nameLeft":"Kagome","textLeft":"What...?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402301,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402601,"motion":0,"pos":2}],"nameCenter":"Melissa & Elisa","textCenter":"..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402301},{"effect":"fadeout","id":402601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831303,"motion":0,"pos":1,"soulGem":0}],"nameCenter":"Torte","textCenter":"Well, you see... Before coming here,@and even after I arrived,"},{"chara":[{"id":831303}],"nameCenter":"Torte","textCenter":"I had this desire to learn about La Pucelle, who@shared my name and looked so much like me."},{"chara":[{"id":831303}],"nameCenter":"Torte","textCenter":"I just followed that feeling and jumped headfirst@into it."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":831303,"pos":1}],"nameCenter":"Torte","textCenter":"...But now, it's different."},{"chara":[{"id":831303,"motion":200}],"nameCenter":"Torte","textCenter":"I feel like it's our turn to inherit the feelings of@La Pucelle,"},{"chara":[{"id":831303}],"nameCenter":"Torte","textCenter":"and make them a reality."},{"chara":[{"id":831303}],"nameCenter":"Torte","textCenter":"Because, you know, La Pucelle...Miss Tart..."},{"chara":[{"id":831303,"motion":100}],"nameCenter":"Torte","textCenter":"She opened a path because she wanted someone@to walk it."},{"autoTurnLast":0.2,"chara":[{"id":831303,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"Oh..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831303,"motion":300,"pos":2}],"nameRight":"Torte","textRight":"If no one walks the path she created with such@desperate determination,"},{"chara":[{"id":831303}],"nameRight":"Torte","textRight":"I think it would be a terribly lonely outcome."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402301,"lipSynch":0,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402601,"motion":0,"pos":2}],"nameLeft":"Melissa","textLeft":"..."},{"chara":[{"id":402601,"motion":1}],"nameRight":"Elisa","textRight":"...That's true."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402601},{"effect":"fadeout","id":402301}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":831303,"motion":1,"pos":1,"soulGem":0}],"nameCenter":"Torte","textCenter":"So, if you can't choose,"},{"chara":[{"id":831303}],"nameCenter":"Torte","textCenter":"it's okay for it to be my responsibility."},{"chara":[{"id":831303}],"nameCenter":"Torte","textCenter":"If we continue like this and it turns out this path@was wrong,"},{"chara":[{"id":831303,"motion":200}],"nameCenter":"Torte","textCenter":"I'll take the blame for everything."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"pos":1}],"nameCenter":"Torte","textCenter":"...What do you think about that?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402601,"motion":400,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402301,"motion":0,"pos":0}],"nameRight":"Elisa","textRight":"...You're quite audacious, aren't you?"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":402301,"motion":100,"pos":0}],"nameLeft":"Melissa","textLeft":"Tee-hee."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402601},{"effect":"fadeout","id":402301}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":102001,"motion":1,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":0,"pos":2,"soulGem":0}],"nameLeft":"Kagome","textLeft":"It's a heavy burden, isn't it..."},{"chara":[{"id":831303,"motion":1}],"nameRight":"Torte","textRight":"It's alright. It'll definitely work out!"},{"chara":[{"eyeClose":1,"id":831303,"lipSynch":0}],"nameRight":"Torte","textRight":"(Yes...absolutely.)"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"lipSynch":0}],"nameLeft":"Kagome","textLeft":"...?"},{"autoTurnLast":2.0,"bg":"black","bgm":"stop","item":[{"iPhoneXScale":1.0,"path":"resource/scenario/img/51030_fishing_homura/51030_homura_dairy.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"bgm":"bgm20_song10","nameNarration":"Kagome","narrationCoverOpacity":0.0,"narrationEffect":"in","narrationHAlignment":"left","narrationPosX":150.0,"progressNarration":"[textBlack:I, who wanted to interview Miss Jeanne,@and Torte, who came to@the Ark out of curiosity,@both started as observers of a sort...@feeling like mere guests, I think.]","turnChangeOut":"fadeOut"},{"progressNarration":"[textBlack:But somehow, Torte had changed.@She voiced her determination@to be more than an observer,@to become involved.]"},{"progressNarration":"[textBlack:And I, through the act of recording@with that magical pen, realized that@I had already become a participant...@And when I realized that, I became afraid.]"},{"progressNarration":"[textBlack:It's not because I was dragged into it,@or because I happened to be there...@It's not for such reasons.@I conduct interview and record this@information out of my own volition.@I record it all, as a person involved,@in order to make a difference.]"},{"progressNarration":"[textBlack:Someday, in the not-so-distant future,@when the time comes that I must do it...@Like Torte, I wonder if I'll have the@determination to become a participant...]"},{"autoTurnLast":1.0,"bg":"bg_adv_31094.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831700,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"item":[{"path":"resource/scenario/img/51030_fishing_homura/51030_homura_dairy.jpg","visible":"hide"},{"path":"resource/scenario/img/51158_tower_tart2/51158_kagome_magical_pencil.png","posX":0,"posY":0,"visible":"appear","zOrder":"charaFront"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":831700}],"nameRight":"Nicolas","textRight":"Did you finish your record-keeping?","turnChangeOut":"fadeOut"},{"chara":[{"id":102001}],"nameLeft":"Kagome","textLeft":"...Yes...!"},{"autoTurnLast":1.0,"bg":"black","bgm":"stop","item":[{"path":"resource/scenario/img/51158_tower_tart2/memoria_1733.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"autoTurnLast":1.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":2.0,"surround":"7023_camera"},{"autoTurnLast":0.2,"bg":"bg_adv_21184.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":1,"soulGem":0}],"se":"7208_wander_into","turnChangeIn":"fadeIn"},{"bgm":"bgm24_story03","chara":[{"cheek":0,"id":102001,"lipSynch":0,"motion":400,"pos":1}],"nameCenter":"Kagome","textCenter":"[chara:102001:effect_emotion_surprise_0][se:7226_shock]...?!","turnChangeOut":"fadeOut"},{"chara":[{"id":102001}],"nameCenter":"Kagome","textCenter":"This place...!"},{"autoTurnLast":2.0,"bg":"bg_adv_31031.jpg","bgChangeEffect":"enterWitchSpace","se":"7208_wander_into","textClear":1},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":400,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402601,"motion":0,"pos":2}],"nameLeft":"Torte","textLeft":"...Now it's that confusing space again!"},{"chara":[{"id":402601,"motion":400}],"nameRight":"Elisa","textRight":"What's happening here?!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":402601}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_31031.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831300,"live2dName":"live2d_0","motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831300,"live2dName":"live2d_1","motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":100,"pos":1}],"nameCenter":"Isabeau","textCenter":"We meet again."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831300,"live2dName":"live2d_0"},{"effect":"fadeout","id":831300,"live2dName":"live2d_1"},{"effect":"fadeout","id":412200}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"lipSynch":0,"motion":400,"pos":1,"soulGem":0}],"nameCenter":"Kagome","textCenter":"...!"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

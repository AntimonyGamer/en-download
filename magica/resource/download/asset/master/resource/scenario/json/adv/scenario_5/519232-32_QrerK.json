{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"black","bgm":"stop","item":[{"path":"resource/scenario/img/51170_storyselect_kuroe/51170_kokoro_title.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"autoTurnLast":2.4,"se":"3201_heal","turnChangeOut":"fadeOut"},{"autoTurnLast":1.8,"item":[{"path":"resource/scenario/img/51170_storyselect_kuroe/51170_kokoro_title.jpg","visible":"hide"}],"turnChangeIn":"fadeIn","turnChangeInTime":1.0},{"autoTurnLast":0.2,"bg":"white","nameNarration":"???","narrationBg":"","narrationCoverOpacity":0.0,"narrationEffect":"in"},{"bgm":"bgm03_story12","narration":"[textBlack:\"The match is over, huh.\"]","turnChangeOut":"fadeOut","turnChangeOutTime":1.4},{"narration":"[textBlack:...@...]"},{"narration":"[textBlack:\"Well… We did what we could…\"]"},{"autoTurnLast":0.2,"narrationEffect":"out"},{"autoTurnLast":0.2,"bg":"bg_adv_24012.jpg","turnChangeIn":"whiteIn","turnChangeInTime":1.3},{"autoTurnLast":3.0,"turnChangeOut":"whiteOut","turnChangeOutTime":1.4},{"autoTurnLast":1.5,"bg":"bg_adv_20331.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":301650,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302950,"motion":0,"pos":2}],"narrationBg":"bg_adv_20331.jpg","narrationEffect":"in","turnChangeIn":"fadeIn","turnChangeInTime":1.0},{"bgm":"bgm03_story19","nameNarration":"Kokoro","narration":"One day during our summer vacation,@Masara and I went down to the beach.","turnChangeOut":"fadeOut"},{"chara":[{"id":301650}],"nameLeft":"Kokoro","narrationEffect":"out","textLeft":"Ooh… Look at that bright sunshine!@You can really feel the summer energy."},{"chara":[{"id":302950,"motion":200}],"nameRight":"Masara","textRight":"Direct sunlight is at its most intense during@the summer solstice in June, not now."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":301650,"motion":100}],"nameLeft":"Kokoro","textLeft":"Heeheehee."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":302950,"motion":0,"pos":2}],"nameRight":"Masara","textRight":"…What?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":301650,"motion":0}],"nameLeft":"Kokoro","textLeft":"Oh, just thinking how you're the same old you."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301650}],"nameNarration":"","narration":"WooOOOooo...!","narrationBg":"bg_adv_20331.jpg","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301650,"motion":400}],"nameLeft":"Kokoro","narrationEffect":"out","textLeft":" Oh? Looks like something's going on over there."},{"autoTurnLast":2.0,"bg":"bg_adv_20251.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301650,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302950,"motion":0,"pos":2}],"narrationBg":"bg_adv_20251.jpg","narrationEffect":"in","turnChangeIn":"fadeIn"},{"nameNarration":"","narration":"\"And we're back for the Girls' Prelims!@Without further ado, let's introduce@today's competing teams!\"","turnChangeOut":"fadeOut"},{"chara":[{"id":301650}],"nameLeft":"Kokoro","narrationEffect":"out","textLeft":"A beach kickball tournament, apparently."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":301650,"motion":200}],"nameLeft":"Kokoro","textLeft":"Kickball was that sport that combines soccer@and baseball, I think?"},{"chara":[{"id":302950,"motion":300}],"nameRight":"Masara","textRight":"…Though the beach seems like a rather@dubious setting for it."},{"autoTurnLast":0.4,"nameCenter":"???'s Voice","textCenter":"…Oh no, we still haven't found any@replacements… What do we do…?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301650},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":302950}]},{"nameCenter":"???'s Voice","textCenter":"We can't just go in without a full team…"},{"chara":[{"id":302950,"lipSynch":0,"motion":0,"pos":2},{"id":301650,"motion":0}],"nameRight":"Masara","textRight":"...?"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":301650},{"effect":"fadeout","id":302950}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_20251.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800100,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":800300,"motion":0,"pos":2}],"nameRight":"","textRight":"Oh… Is that you, Kagami-senpai?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301650,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":302950,"motion":0,"pos":2}],"nameLeft":"Kokoro","textLeft":"Someone you know?"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302950,"motion":100}],"nameRight":"Masara","textRight":"Yes, she's a junior from the Swimming Club.@A middle-school second-year, as it happens."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800300,"motion":0,"pos":2}],"nameRight":"","textRight":"We're really glad we have her, by the way!"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":301650,"motion":100}],"nameLeft":"Kokoro","textLeft":"I'm Kokoro Awane, from the year above you."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800300}],"nameRight":"","textRight":"Ah… Awane-senpai, then. Nice to meet you!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":800300}],"nameRight":"","textRight":"Oh, er… Are you two here for the beach kickball tournament, too…?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":301650,"motion":0}],"nameLeft":"Kokoro","textLeft":"No, we just thought we'd have a look."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":302950,"motion":1,"pos":2}],"nameRight":"Masara","textRight":"Going by your words, I take it you're here@to compete?"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":301650},{"effect":"fadeout","id":302950}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":800100,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800300,"motion":0,"pos":2}],"nameRight":"","textRight":"Yup!"},{"chara":[{"id":800300}],"nameRight":"","textRight":" We practiced really hard to be here on@this big day."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":301650,"motion":200,"pos":0}],"nameLeft":"Kokoro","textLeft":"While still going to the Swimming Club?@You sure know how to put in the effort."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":800300}],"nameRight":"","textRight":"That we did!@[chara:800300:lipSynch_0][wait:1.2][chara:800300:lipSynch_1][chara:800300:cheek_0][chara:800300:face_mtn_ex_030.exp3.json]Although, well…"},{"chara":[{"id":800300}],"nameRight":"","textRight":"…You see, two of our teammates couldn't@make it."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301650,"motion":400}],"nameLeft":"Kokoro","textLeft":"Whaaa?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800100,"motion":0,"pos":0}],"nameLeft":"","textLeft":"They were away visiting their families, and@their plan was to be back two days ago,"},{"chara":[{"id":800100}],"nameLeft":"","textLeft":"but their flight was grounded by strong winds,@and now they won't make it in until tonight…"},{"chara":[{"id":800300}],"nameRight":"","textRight":"So, yeah. At this rate, our team's gonna have@to resign…"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":800100},{"effect":"fadeout","id":800300}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_20251.jpg","bgChangeEffect":"cameraPan"},{"autoTurnLast":1.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800102,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800200,"motion":0,"pos":2}]},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":800102},{"effect":"fadeout","id":800200}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_20251.jpg","bgChangeEffect":"cameraPan"},{"autoTurnLast":1.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800201,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800302,"motion":0,"pos":2}]},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":800201},{"effect":"fadeout","id":800302}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":301650,"motion":300,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800300,"motion":0,"pos":2}],"nameLeft":"Kokoro","textLeft":"All that hard work together, all down the drain…"},{"chara":[{"id":800300}],"nameRight":"","textRight":"Yeah…"},{"chara":[{"id":800300}],"nameRight":"","textRight":"…Um, I just had an idea."},{"chara":[{"id":800300}],"nameRight":"","textRight":"Would you two be willing to sub for us?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":302950,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301650,"motion":0}],"nameRight":"Masara","textRight":"…What…?"},{"chara":[{"effect":"fadeout","id":301650}],"nameNarration":"Kokoro","narration":"The sudden ask threw Masara off at first…","narrationBg":"bg_adv_20251.jpg","narrationEffect":"in","textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302950,"motion":0,"pos":1}],"narration":"…but once I decided that I couldn't just@leave these sad juniors alone, and asked@Masara to join me in helping them out…"},{"chara":[{"id":302950,"lipSynch":0}],"nameCenter":"Masara","narrationEffect":"out","textCenter":"…[chara:302950:lipSynch_0][wait:2][chara:302950:lipSynch_1][chara:302950:motion_200]If that's what you'd like, Kokoro,@then very well."},{"nameNarration":"Kokoro","narration":"And that was what kicked off@our \"fiery\" summer.","narrationBg":"bg_adv_20251.jpg","narrationEffect":"in"},{"autoTurnLast":2.0,"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":801000,"motion":0,"pos":1}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"bgm":"bgm01_anime03","chara":[{"id":801000}],"nameCenter":"","textCenter":"…and I'm here as the coach of this team.","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":801000,"motion":0}],"nameCenter":"","textCenter":"Good to be working with you, Miss Kagami,@and you, Miss Awane."},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":801000}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":301650,"motion":200,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":302950,"motion":0,"pos":2}],"nameLeft":"Kokoro","textLeft":"Thanks for having us!"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302950,"motion":100}],"nameRight":"Masara","textRight":"…Is this attire appropriate?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":801000,"motion":0,"pos":2}],"nameRight":"","textRight":"Yeah. There are no rules on clothing, and a lot@of the participants are in swimsuits anyway."},{"nameNarration":"Kokoro","narration":"After warming up and a bit of practice,@it was finally time for the match.","narrationBg":"bg_adv_20251.jpg","narrationEffect":"in"},{"narration":"I'd never even heard of playing kickball on@the beach until now. This tournament is a pretty@casual one with rules against sliding and such,@but apparently it still garners a ton@of excitement every year!"},{"autoTurnLast":1.3,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302950,"lipSynch":0,"motion":0,"pos":1}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnLast":0.2,"narrationBg":"bg_adv_20251.jpg","narrationEffect":"in"},{"nameNarration":"","narration":"[se:7108_arrivals]\"Safe!\"","turnChangeOut":"fadeOut"},{"chara":[{"id":302950,"lipSynch":0,"motion":100}],"nameCenter":"Masara","narrationEffect":"out","textCenter":"…"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":302950}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":301650,"motion":200,"pos":1}],"nameCenter":"Kokoro","textCenter":"[chara:301650:effect_emotion_joy_0][se:7222_happy]Yes!"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":301650}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_20251.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":800300,"motion":0,"pos":1}],"nameCenter":"","textCenter":"And Awane-senpai's RBI kick brings@Kagami-senpai safely home!"},{"chara":[{"id":800300}],"nameCenter":"","textBg":"shout","textCenter":"[chara:800300:effect_emotion_joy_0][se:7222_happy]We're in the lead!"},{"nameNarration":"Kokoro","narration":"It seems like all the exercise we usually get@—Masara from swimming, and me from hiking—@really paid off in the match, and…","narrationBg":"bg_adv_20251.jpg","narrationEffect":"in"},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":301650,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":302950,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":301650,"motion":200,"pos":0}],"nameLeft":"Kokoro","textLeft":"…Looks like we pulled that win off!","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":800100,"motion":0,"pos":2}],"nameRight":"","textRight":"With the winning point coming from@your guy's play, no less."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302950,"motion":200,"pos":0}],"nameLeft":"Masara","textLeft":"I only followed the coach's instructions. Without@them, I doubt I would've made it on base at all."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":301650,"motion":1,"pos":0}],"nameLeft":"Kokoro","textLeft":"Same here."},{"chara":[{"id":301650}],"nameLeft":"Kokoro","textLeft":"She told me to kick right since those fielders@were farther away, so that's what I did…"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":301650},{"effect":"fadeout","id":800100}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":801000,"motion":0,"pos":1}],"nameCenter":"","textCenter":"Good work, everyone.@We're safely through the prelims now."},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":801000}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":800100,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp3.json","id":800300,"motion":0,"pos":2}],"nameRight":"","textRight":"Yup, and the finals are only ten days away!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":301650,"motion":0,"pos":0}],"nameLeft":"Kokoro","textLeft":"The girls who couldn't come this time will be@here for that, right?"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":800300}],"nameRight":"","textRight":"Yeah. Thank you so much for today!@You really helped us out!"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":800300}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":301650,"motion":100,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":302950,"motion":0,"pos":2}],"nameLeft":"Kokoro","textLeft":"*Giggle* You're very welcome."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":301650},{"effect":"fadeout","id":302950}],"narrationBg":"bg_adv_20251.jpg","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800100,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800300,"motion":0,"pos":2}],"nameNarration":"Kokoro","narration":"Our roles in this should've ended right there…"},{"chara":[{"id":800300}],"nameRight":"","narrationEffect":"out","textRight":"Anyway, I'm gonna go scout out our rivals!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":302950,"motion":300,"pos":0}],"nameLeft":"Masara","textLeft":"What rivals?"},{"chara":[{"id":800300}],"nameRight":"","textRight":"There's a six-time returning champion team@in the brackets!"},{"chara":[{"id":800300}],"nameRight":"","textRight":"Want to come watch them with us, you two?"},{"nameNarration":"Kokoro","narration":"…But things weren't going to be so simple.","narrationBg":"bg_adv_20251.jpg","narrationEffect":"in"},{"autoTurnLast":1.8,"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301650,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":302950,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnLast":0.2,"narrationBg":"bg_adv_20251.jpg","narrationEffect":"in"},{"nameNarration":"","narration":"*Murmur* *Murmur...*","turnChangeOut":"fadeOut"},{"bgm":"bgm05_event07","narration":"\"10 to 0 already…?!@That was a second inning run-rule!\""},{"narration":"\"Geez, this team's on a whole different level.\""},{"chara":[{"id":301650,"motion":200}],"nameLeft":"Kokoro","narrationEffect":"out","textLeft":"Don't the tournament rules specify five innings@per game?"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302950,"motion":200}],"nameRight":"Masara","textRight":"The skill difference was so great, it ended in@only two, I suppose."},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":301650},{"effect":"fadeout","id":302901}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":800100,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":800300,"motion":0,"pos":2}],"nameLeft":"","textLeft":"And we're supposed to go up against THAT@in the finals…?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800300}],"nameRight":"","textRight":"Y-yeah…"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":800100},{"effect":"fadeout","id":800300}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":801000,"motion":0,"pos":1}],"nameCenter":"","textCenter":"There's no avoiding them if we want that win."},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":801000}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301650,"lipSynch":0,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302950,"lipSynch":0,"motion":0,"pos":2}],"nameCenter":"Kokoro & Masara","textCenter":"…"},{"autoTurnLast":0.2,"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":305251,"motion":1,"pos":1}],"turnChangeIn":"rollInFast"},{"chara":[{"id":305251}],"nameCenter":"Ashley","textCenter":"…Hmm?","turnChangeOut":"rollOutFast"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp3.json","id":305251,"motion":200}],"nameCenter":"Ashley","textCenter":"[chara:305251:effect_emotion_joy_0][se:7222_happy]Well, well, looks like some reeeal interesting@stuff's going on over there!","turnChangeOut":"rollOutFast"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

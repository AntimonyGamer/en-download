omura","textAvRight":"[fontSize:20]I won't turn back time for you."},{"chara":[{"id":200901,"motion":100,"voiceFullAuto":"fullvoice/section_104211/vo_full_912101-010-26"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Oh...okay."},{"chara":[{"eyeClose":1,"id":230101,"voiceFullAuto":"fullvoice/section_104211/vo_full_912101-010-27"}],"nameAvRight":"Homura","textAvColor":"textHomura","textAvRight":"[fontSize:20]So..."},{"chara":[{"eyeClose":0,"id":230101,"motion":200,"voiceFullAuto":"fullvoice/section_104211/vo_full_912101-010-28"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]Don't be too quick to sacrifice yourself."},{"autoTurnFirst":2.0,"autoTurnNoDelay":1,"chara":[{"id":230101,"voiceFull":"fullvoice/section_104211/vo_full_912101-010-29"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]The last thing I need is a future@where your death is on my conscience."},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":230101}]},{"chara":[{"eyeClose":1,"id":230101}]},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200901,"lipSynch":0,"motion":0,"voiceFullAuto":"fullvoice/section_104211/vo_full_912101-010-30","voiceFullStop":"fullvoice/section_104211/vo_full_912101-010-29"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]......"},{"chara":[{"cheek":2,"face":"mtn_ex_010.exp3.json","id":200901,"lipSynch":1,"motion":400,"voiceFullAuto":"fullvoice/section_104211/vo_full_912101-010-31"},{"eyeClose":0,"id":230101}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Okay! I'll do my best!"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":230101,"motion":1,"voiceFullAuto":"fullvoice/section_104211/vo_full_912101-010-32"}],"nameAvRight":"Homura","textAvColor":"textHomura","textAvRight":"[fontSize:20]Also..."},{"chara":[{"id":230101,"voiceFullAuto":"fullvoice/section_104211/vo_full_912101-010-33"}],"nameAvRight":"Homura","textAvRight":"[fontSize:20]How about cleaning your room?"},
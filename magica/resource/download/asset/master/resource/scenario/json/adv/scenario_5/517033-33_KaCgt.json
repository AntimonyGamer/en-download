{"story":{"group_1":[{"autoTurnLast":0.2,"bg":"bg_adv_21421.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":300201,"lipSynch":0,"motion":1,"pos":1}],"narrationBg":"bg_adv_21421.jpg","narrationEffect":"in","turnChangeIn":"fadeIn"},{"nameNarration":"Kokoro","narration":"The next day…","turnChangeOut":"fadeOut"},{"bgm":"bgm01_anime02","chara":[{"id":300201,"lipSynch":0}],"nameCenter":"Natsuki","narrationEffect":"out","textCenter":"…"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":300201}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_21421.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":302901,"motion":100,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301601,"motion":0,"pos":0}],"nameRight":"Masara","textRight":"…Natsuki?"},{"chara":[{"id":301601,"motion":100}],"nameLeft":"Kokoro","textLeft":"What're you doing over there?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":300201,"motion":0,"pos":0},{"id":302901,"motion":0}],"nameLeft":"Natsuki","textLeft":"Oh… Hey, Kokoro, Masara."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":300201,"motion":300}],"nameLeft":"Natsuki","textLeft":"I've just been admiring all the energy those girls@are training with. Like, look at them!"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":300201},{"effect":"fadeout","id":302901}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_21421.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800100,"motion":0,"pos":1}],"nameCenter":"","textBg":"shout","textCenter":"Next kick's going left!"},{"nameNarration":"","narration":"[se:3223_move_l]*Pomph*","narrationBg":"bg_adv_21421.jpg","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":800100,"pos":1}],"nameCenter":"","narrationEffect":"out","textCenter":"Good catch!"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":800100}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":302901,"motion":0,"pos":2}],"nameLeft":"Kokoro","textLeft":"Ah, it's the girls from yesterday!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":301601,"motion":100}],"nameLeft":"Kokoro","textLeft":"So this is where they've been doing their beach@kickball practice."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":300201,"motion":100,"pos":0}],"nameLeft":"Natsuki","textLeft":"Wait, you know them…?"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":300201},{"effect":"fadeout","id":302901}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800100,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800300,"motion":0,"pos":2}],"nameRight":"","textRight":"Ah, familiar faces!"},{"nameNarration":"Kokoro","narration":"By some huge coincidence, we met again.","narrationBg":"bg_adv_21421.jpg","narrationEffect":"in"},{"autoTurnLast":1.8,"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":300201,"motion":0,"pos":1}]},{"chara":[{"id":300201,"motion":200}],"nameCenter":"Natsuki","textCenter":"I see~! So that's how you all got to know@each other!","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":300201,"motion":0}],"nameCenter":"Natsuki","textCenter":"…Going by that, I'm guessing you're…"},{"chara":[{"id":300201}],"nameCenter":"Natsuki","textCenter":"…practicing in your own time for the@tournament finals, then!"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":300201}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302901,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800100,"motion":0,"pos":0}],"nameRight":"Masara","textRight":"Right after yesterday's match, though? If nothing@else, you should've at least taken today to rest."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800100}],"nameLeft":"","textLeft":"We don't have the luxury to!@Not after seeing a team like THAT…"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":800300,"motion":0,"pos":2}],"nameRight":"","textRight":"We want to win the tournament!"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":800100},{"effect":"fadeout","id":800300}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":300201,"motion":100,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302901,"motion":0,"pos":2}],"nameLeft":"Natsuki","textLeft":"Ooh, I like how enthusiastic you are!"},{"chara":[{"id":302901,"motion":300}],"nameRight":"Masara","textRight":"But…"},{"autoTurnLast":0.2,"bg":"bg_adv_20251.jpg","narrationBg":"","narrationCoverOpacity":180.0,"narrationEffect":"in","turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"nameNarration":"","narration":"\"10 to 0 already…?!@That was a second inning run-rule!\"","turnChangeOut":"fadeOut"},{"narration":"\"Geez, this team's on a whole different level.\""},{"autoTurnLast":0.2,"bg":"bg_adv_21421.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":301601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302901,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":301601,"motion":300}],"nameLeft":"Kokoro","textLeft":"…You'd have to go against that crazy-strong@team to do it.","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":302901,"motion":100}],"nameRight":"Masara","textRight":"Frankly, the difference is so severe, you'd be@applauded just for avoiding the run rule."},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":301601},{"effect":"fadeout","id":302901}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800300,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800100,"motion":0,"pos":0}],"nameRight":"","textRight":"Yeah… Exactly. Our team hasn't been around@for very long…"},{"chara":[{"id":800100}],"nameLeft":"","textLeft":"And compared to us, their core members are@from a school that dominates in soccer."},{"chara":[{"id":800100}],"nameLeft":"","textLeft":"To be honest with you, seeing their match@yesterday really shook us…"},{"autoTurnLast":0.2,"chara":[{"id":800300,"pos":0}],"narrationBg":"bg_adv_21421.jpg","narrationEffect":"in","textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301601,"motion":0,"pos":2}],"nameNarration":"Kokoro","narration":"So I figured there had to be some kind@of reason why they're still trying@to win against such impossible odds,@and when I asked…"},{"chara":[{"id":800300}],"nameLeft":"","narrationEffect":"out","textLeft":"Um, you see… We actually have a promise with@our coach."},{"chara":[{"id":800300}],"nameLeft":"","textLeft":"If we won, she'd listen to any one thing we say."},{"chara":[{"id":301601}],"nameRight":"Kokoro","textRight":"Okay?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800100,"motion":0,"pos":0}],"nameLeft":"","textLeft":"We haven't told her anything yet, "},{"chara":[{"id":800100}],"nameLeft":"","textLeft":"but we're going to ask her to unretire if we win."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":302901,"motion":200,"pos":2}],"nameRight":"Masara","textRight":"\"Unretire,\" you say…@From beach kickball?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":800300,"motion":0,"pos":0}],"nameLeft":"","textLeft":"Oh, not that. Actually..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800300}],"nameLeft":"","textLeft":"She used to play for Japan in the Women's@Baseball World Cup."},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":800300},{"effect":"fadeout","id":302901}],"textClear":1},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":300201,"motion":400,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301601,"motion":400,"pos":2}],"nameCenter":"Natsuki & Kokoro","textCenter":"EEEEH?!"},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":300201,"motion":0,"pos":1}],"narrationBg":"bg_adv_21421.jpg","narrationEffect":"in","turnChangeIn":"fadeIn"},{"nameNarration":"Kokoro","narration":"Our former baseball player Natsuki did a@double take when she heard the coach's name.","turnChangeOut":"fadeOut"},{"bgm":"bgm03_story02","chara":[{"id":300201,"motion":100}],"nameCenter":"Natsuki","narrationEffect":"out","textCenter":"…I know about her!@She was a regular in the team!"},{"chara":[{"id":300201}],"nameCenter":"Natsuki","textCenter":"Their shortstop and main batter, in fact!@[chara:300201:lipSynch_0][wait:1.5][chara:300201:lipSynch_1][chara:300201:cheek_0][chara:300201:face_mtn_ex_030.exp3.json][chara:300201:motion_0]…Oh, but she retired this year, didn't she?"},{"autoTurnLast":0.25,"chara":[{"id":300201,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301601,"motion":0,"pos":2}],"nameRight":"Kokoro","textRight":"Why? Did something happen to her?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":300201,"motion":300}],"nameLeft":"Natsuki","textLeft":"Well, according to a magazine interview@she did…"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302901,"motion":0,"pos":2},{"id":300201,"motion":0}],"nameNarration":"Kokoro","narration":"It turns out, the coach's late father was an@Olympic medalist, and her entire baseball career was@so she could dedicate a gold medal to his memory.","narrationBg":"bg_adv_21421.jpg","narrationEffect":"in"},{"narration":"But the IOC refused to add Women's Baseball@as a sport, so… When her club team decided@to disband, she took it as a sign to retire."},{"chara":[{"id":302901,"motion":300}],"nameRight":"Masara","narrationEffect":"out","textRight":"…I didn't expect Women's Baseball to not be@an Olympic sport."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":300201,"motion":200}],"nameLeft":"Natsuki","textLeft":"Right?! It's even got a world cup and@everything."},{"autoTurnLast":0.2},{"chara":[{"id":300201,"motion":301}],"nameLeft":"Natsuki","textLeft":"We baseball girls always get the short end@of the stick somehow…"},{"autoTurnLast":0.25,"chara":[{"id":300201,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800100,"motion":0,"pos":0}],"nameLeft":"","textLeft":"But in the end, we don't wanna just see her@leave baseball like that."},{"autoTurnLast":0.2,"chara":[{"eyeClose":0,"id":300201}]},{"chara":[{"id":300201,"motion":0}],"nameRight":"Natsuki","textRight":"Yeah… I get it. It's such a waste."},{"chara":[{"id":300201,"motion":0}],"nameNarration":"Kokoro","narration":"With a sad chuckle, Natsuki recounted her own@experience to us: she ended up diving into@cheerleading after quitting baseball, but…@a part of her still misses the ballpark even now.","narrationBg":"bg_adv_21421.jpg","narrationEffect":"in"},{"narration":"The coach has already found another job with@nothing to do with the sport, and it seems like@she's too busy to be with the team often, but…@How does she feel about this?"},{"chara":[{"id":300201}],"nameRight":"Natsuki","narrationEffect":"out","textRight":"She's put so much into baseball, but now…"},{"chara":[{"id":800100}],"nameLeft":"","textLeft":"Yeah… That's why we really want to see her@on the field again."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":800100}],"nameLeft":"","textLeft":"And we're going to ask her to do just that!"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":300201},{"effect":"fadeout","id":800100}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":301601,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800300,"motion":0,"pos":0}],"nameRight":"Kokoro","textRight":"So that's why this win is so important to you…"},{"chara":[{"id":800300}],"nameLeft":"","textLeft":"Yeah…"},{"autoTurnLast":0.2,"chara":[{"id":800300,"pos":1}],"narrationBg":"bg_adv_21421.jpg","narrationEffect":"in","textClear":1},{"chara":[{"effect":"fadeout","id":301601}],"nameNarration":"Kokoro","narration":"And it was only natural…"},{"chara":[{"id":800300}],"nameCenter":"","narrationEffect":"out","textCenter":"You know…"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":800300}],"nameCenter":"","textCenter":"If you don't mind, could we ask you two to play@for us in the finals as well?"},{"autoTurnLast":0.2,"narrationBg":"bg_adv_21421.jpg","narrationEffect":"in"},{"autoTurnLast":0.25,"chara":[{"id":800300,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":302901,"motion":0,"pos":2}],"nameNarration":"Kokoro","narration":"…that this was the direction the topic went…"},{"chara":[{"id":302901,"motion":100}],"nameRight":"Masara","narrationEffect":"out","textRight":"…Don't you already have your members?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800300}],"nameLeft":"","textLeft":"We do, but…"},{"chara":[{"id":800300}],"nameLeft":"","textLeft":"It was thanks to you two that we won@yesterday's match."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":800300}],"nameLeft":"","textLeft":"And it's not like we'd leave any of our existing@members out, either!"},{"autoTurnLast":0.2,"bgm":"stop","chara":[{"effect":"fadeout","id":302901},{"effect":"fadeout","id":800300}],"narrationBg":"bg_adv_21421.jpg","narrationEffect":"in","textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":300201,"motion":0,"pos":1}],"nameNarration":"Kokoro","narration":"…After hearing the girls pour out their feelings,@I started wanting to do something for them."},{"bgm":"bgm03_story09","chara":[{"id":300201}],"nameCenter":"Natsuki","narrationEffect":"out","textCenter":"Well, if you and Masara want to do this,@I can help out with the training."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":300201,"motion":300,"mouthOpen":1}],"nameCenter":"Natsuki","textCenter":"Though the finals overlap with a club camp I'm@doing, so I can't go see how it all works out.[chara:300201:mouthOpen_0]"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":300201}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":301601,"motion":100,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302901,"motion":0,"pos":2}],"nameLeft":"Kokoro","textLeft":"Hmm… Alright!@Let's lend them a hand, Masara."},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":302901,"motion":300}],"nameRight":"Masara","textRight":"…I thought you'd say so."},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":301601},{"effect":"fadeout","id":302901}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":300201,"motion":0,"pos":1}],"nameCenter":"Natsuki","textCenter":"Then that's that!"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":300201,"motion":200}],"nameCenter":"Natsuki","textCenter":"[chara:300201:effect_emotion_joy_0][se:7222_happy]Now, let the training hell begin!@Go! Fight! WIN!"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":300201}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301601,"motion":200,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":302901,"motion":0,"pos":2}],"nameLeft":"Kokoro","textLeft":"Wait… Did you say \"hell\"?"},{"autoTurnLast":0.2,"bg":"bg_adv_21171.jpg","turnChangeIn":"fadeIn"},{"autoTurnLast":1.8,"turnChangeOut":"fadeOut"},{"autoTurnLast":1.8,"bg":"bg_adv_21172.jpg","bgChangeEffect":"fade"},{"autoTurnLast":0.2,"bg":"bg_adv_21422.jpg","chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":300201,"motion":0,"pos":1}],"narrationBg":"bg_adv_21422.jpg","narrationEffect":"in","turnChangeIn":"fadeIn"},{"nameNarration":"Natsuki","narration":"\"C'mon! One more play!\"","turnChangeOut":"fadeOut"},{"autoTurnLast":0.1,"se":"3223_move_l"},{"chara":[{"id":300201,"motion":100}],"nameCenter":"Natsuki","narrationEffect":"out","textCenter":"…[chara:300201:effect_emotion_joy_0][se:7222_happy]Nice catch!@[chara:300201:cheek_0][chara:300201:face_mtn_ex_010.exp3.json]I guess we can stop here for today."},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":300201}],"textClear":1},{"chara":[{"cheek":2,"face":"mtn_ex_060.exp3.json","id":301601,"motion":100,"pos":0},{"cheek":1,"face":"mtn_ex_000.exp3.json","id":302901,"motion":0,"pos":2}],"nameLeft":"Kokoro","textLeft":"…*Pant*...*Pant*…@[chara:301601:lipSynch_0][wait:2.0][chara:301601:lipSynch_1][chara:302901:cheek_2][chara:302901:face_mtn_ex_030.exp3.json]I never thought Natsuki could be so harsh…"},{"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":302901,"motion":100,"pos":2}],"nameRight":"Masara","textRight":"…But our teamwork has improved noticeably,@hasn't it?"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":800300,"motion":0,"pos":0}],"nameLeft":"","textLeft":"The coach will be here for practice tomorrow,@by the way. We'll see you then!"},{"autoTurnLast":2.0,"bg":"bg_adv_14053.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302901,"lipSynch":0,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":301601,"motion":0,"pos":0}],"narrationBg":"bg_adv_14053.jpg","narrationEffect":"in","turnChangeIn":"fadeIn"},{"nameNarration":"Kokoro","narration":"On our way back home…","turnChangeOut":"fadeOut"},{"chara":[{"id":302901,"lipSynch":0}],"nameRight":"Masara","narrationEffect":"out","surround":"7007_evening_townbuzz","textRight":"…"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301601,"motion":1}],"nameLeft":"Kokoro","textLeft":"What's the matter, Masara?"},{"chara":[{"id":302901}],"nameRight":"Masara","textRight":"Look, across the street…"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":301601},{"effect":"fadeout","id":302901}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_14053.jpg","bgChangeEffect":"cameraPan"},{"autoTurnLast":2.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":801000,"motion":0,"pos":1}]},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":801000}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":301601,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":302901,"motion":0,"pos":2}],"nameLeft":"Kokoro","textLeft":"Oh, it's the coach…"},{"nameNarration":"Kokoro","narration":"But we couldn't bring ourselves to call out to her.@Not while she was gazing so intensely at the Japan@team uniform hung up in the sports store.","narrationBg":"bg_adv_14053.jpg","narrationEffect":"in","surround":"stop"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

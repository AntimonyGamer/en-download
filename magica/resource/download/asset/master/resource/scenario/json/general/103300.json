{"story":{"group_1":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_01","textHome":"If you want to spend time in nature,"}]},{"autoTurnFirst":5.7,"chara":[{"id":103300,"motion":100,"textHome":"come to the Cradle of the Earth,@run by my mother and grandfather@in Yukuni City."}]},{"autoTurnFirst":2.0,"chara":[{"id":103300,"motion":300,"textHome":"It's not a luxurious inn,"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103300,"textHome":"but the vegetables my grandfather@grows are delicious and healthy,@so some people come to recuperate."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":2.2,"chara":[{"id":103300}]},{"autoTurnFirst":3.7,"chara":[{"id":103300,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":0,"textHome":"Yukuni City itself is a tourist destination@with hot springs, and I am sure that visitors@will enjoy their stay for that purpose as well."}]},{"autoTurnFirst":4.0,"chara":[{"id":103300,"motion":400}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103300,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1033_00_17","textHome":"Gazing at the stars@brings back memories..."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":7.0,"chara":[{"id":103300,"motion":1,"textHome":"...of Shirogane, the person who@continually proved to me that I exist."}]},{"autoTurnFirst":6.5,"chara":[{"cheek":1,"face":"mtn_ex_031.exp3.json","id":103300,"motion":300,"textHome":"I wonder if she'll forgive me...@Me, who'd given up on ever being saved..."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103300}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1033_00_18","textHome":"Though I still hold onto resignation,"}]},{"autoTurnFirst":1.2,"chara":[{"eyeClose":1,"id":103300,"textHome":"sometimes I end up having that dream."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":300}]},{"autoTurnFirst":5.2,"chara":[{"eyeClose":1,"id":103300,"textHome":"In it, I see Mikage@and Nayuta as adults...@laughing...along with me..."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":4.0,"chara":[{"id":103300,"motion":0}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_032.exp3.json","id":103300,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1033_00_19","textHome":"We are surely far too small@to resist the will of the universe..."}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_031.exp3.json","id":103300}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_033.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_20","textHome":"The world is constantly changing,@as is my own self."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":4.0,"chara":[{"id":103300,"motion":200}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_032.exp3.json","id":103300,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_00_21","textHome":"We cannot be saved."}]},{"autoTurnFirst":5.3,"chara":[{"id":103300,"motion":300,"textHome":"That was decided from the moment@we became Magical Girls."}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":1,"textHome":"Even so, we watch over@these battles because we want@to believe in a glimmer of hope."}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":103300,"motion":400}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_033.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_22","textHome":"Recognizing one another's existence@under the stars..."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":5.0,"chara":[{"id":103300,"textHome":"Companions who share their sorrows@and embrace each other..."}]},{"autoTurnFirst":6.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":0,"textHome":"The rowdy days spent with Nayuta@and the others as a servant..."}]},{"autoTurnFirst":7.7,"chara":[{"cheek":0,"face":"mtn_ex_031.exp3.json","id":103300,"motion":300,"textHome":"This past is the one thing@that I pray never fades away."}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_00_23"}]},{"autoTurnFirst":4.2,"chara":[{"id":103300,"motion":200}]},{"autoTurnFirst":4.8,"chara":[{"eyeClose":1,"id":103300,"motion":1}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":103300,"motion":100}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_031.exp3.json","id":103300,"motion":300}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_033.exp3.json","id":103300,"motion":0}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":3.5,"chara":[{"id":103300}]}],"group_17":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1033_00_24","textHome":"My position is to observe carefully."}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":103300,"motion":1,"textHome":"While I cannot fight with you,@I can be someone to talk to."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":4.0,"chara":[{"id":103300}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":0,"textHome":"You can stay@if you're alright with that."}]},{"autoTurnFirst":3.0,"chara":[{"id":103300,"motion":100}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1033_00_25","textHome":"I apologize if I woke you up."}]},{"autoTurnFirst":1.8,"chara":[{"id":103300,"motion":1,"textHome":"My grandfather inspired me to start@a vegetable garden at Nayuta's house,"}]},{"autoTurnFirst":3.7,"chara":[{"eyeClose":1,"id":103300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":200,"textHome":"but I have to wake up early@to tend to it."}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1033_00_26","textHome":"After Nayuta forgot her bento@and came home hungry,"}]},{"autoTurnFirst":3.0,"chara":[{"id":103300}]},{"autoTurnFirst":3.1,"chara":[{"id":103300,"motion":1,"textHome":"I started putting a sign@on the front door saying,@\"Don't forget your bento\""}]},{"autoTurnFirst":1.7,"chara":[{"eyeClose":1,"id":103300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":3.5,"chara":[{"id":103300,"textHome":"so that she'll be aware@before she leaves."}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":300,"textHome":"Am I...spoiling her a little...?"}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_00_02","textHome":"Folklore of Zero, Rabi Himuro."}]},{"autoTurnFirst":3.1,"chara":[{"id":103300,"motion":100}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":300,"textHome":"All the others and I can do is@watch and see if the existence of@Magical Girls can be saved or not."}]},{"autoTurnFirst":4.3,"chara":[{"eyeClose":1,"id":103300}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1033_00_27","textHome":"If you're not busy, I'd like you@to come shopping with me."}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":300,"textHome":"The supermarket holds@flash sales at this time of day,"}]},{"autoTurnFirst":3.9,"chara":[{"eyeClose":1,"id":103300,"textHome":"and it would be best to have more@people around, given the limit to the@number of items one person can buy."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":3.3,"chara":[{"id":103300,"motion":100}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":4.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1033_00_28","textHome":"I was stargazing@since I couldn't sleep."}]},{"autoTurnFirst":5.3,"chara":[{"eyeClose":1,"id":103300,"motion":0,"tear":0,"textHome":"In the past, I kept my sense of self@by being recognized by the stars,"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":1.8,"chara":[{"id":103300,"textHome":"but now there are several voices@calling out to me."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":100,"textHome":"It's sort of a strange feeling."}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":6.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_033.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_29","textHome":"The river flows endlessly, yet it is@never the same water as it was before."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":4.5,"chara":[{"id":103300,"motion":0,"textHome":"We can't return@to the time we spend now."}]},{"autoTurnFirst":2.5,"chara":[{"id":103300,"motion":200,"textHome":"That's why we must cherish the present@and live to our fullest."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103300,"motion":100}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1033_00_30","textHome":"Becoming a Witch is an immutable truth."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103300}]},{"autoTurnFirst":0.8,"chara":[{"cheek":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":0,"textHome":"Because of that, I have to@come up with my own guidance."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnLast":4.0,"chara":[{"id":103300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103300,"motion":400,"textHome":"Ignorance may be bliss,@but it's nothing more than deception."}]},{"autoTurnFirst":3.0,"chara":[{"id":103300,"motion":200}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_31","textHome":"Aside from Nayuta,"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103300,"textHome":"if I came across a copy of Mikage@or something in Endless Mirrors,"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":5.0,"chara":[{"id":103300,"motion":300,"textHome":"I might not be able to defeat it..."}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_00_32"}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":1,"id":103300,"motion":0}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":4.5,"chara":[{"id":103300,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"id":103300,"motion":200}]}],"group_26":[{"autoTurnFirst":5.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1033_00_33","textHome":"Our characters are the result@of our previous actions."}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":300,"textHome":"Everything in our past@makes up our present."}]},{"autoTurnFirst":2.7,"chara":[{"id":103300,"motion":1,"textHome":"This conversation we're having@here and now may become@a component of our future."}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":103300}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1033_00_34","textHome":"I learned housekeeping from my mother,@who runs an inn."}]},{"autoTurnFirst":3.8,"chara":[{"eyeClose":1,"id":103300,"motion":1,"textHome":"I had hoped to be able@to help her with her work,"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":1.0,"chara":[{"id":103300,"motion":0,"textHome":"but I hadn't expected that@my skills would prove useful@in my job as Nayuta's servant."}]},{"autoTurnFirst":4.5,"chara":[{"id":103300,"motion":100}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":7.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1033_00_35","textHome":"Although I know it's a little late@for this, I hope I don't come across@as unsociable for not talking much."}]},{"autoTurnFirst":3.5,"chara":[{"id":103300,"motion":1,"textHome":"Because of my illness,@I've never had many friends,"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":103300,"motion":400,"textHome":"so sometimes I don't know@how to treat them."}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_36","textHome":"The Professor looks@much like my late father."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":3.0,"chara":[{"id":103300}]},{"autoTurnFirst":4.5,"chara":[{"id":103300,"motion":300,"textHome":"Both of them are kind and@a little out of the ordinary."}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103300,"motion":100,"textHome":"He's physically weak, yet also reckless...@which makes me worry about him."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":4.0,"chara":[{"id":103300}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103300,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_00_03"}]},{"autoTurnFirst":3.0,"chara":[{"id":103300,"motion":200}]}],"group_30":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_00_37","textHome":"No matter how much we believe@in resignation, we can't stay@in the dark forever."}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103300,"motion":1,"textHome":"That's why Urara's smile@is always comforting to us."}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":103300}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":7.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1033_00_38","textHome":"I once told Sasha I couldn't sleep,@and she offered to sing me a lullaby."}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":1,"textHome":"I said I didn't need it@because I was embarrassed,"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":103300,"motion":300,"textHome":"but the next thing I knew,@I was drifting off."}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":6.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_39","textHome":"Asahi seems to think she's being@sneaky about her military hobby."}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":200,"textHome":"She's not,"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103300,"motion":100,"textHome":"but she appears to be enjoying herself,@so I hope she stays that way."}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_052.exp3.json","id":103300,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1033_00_40","textHome":"Ugh..."}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":103300,"textHome":"It's gotten all over@the rest of the laundry."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":1,"face":"mtn_ex_020.exp3.json","id":103300,"motion":300,"textHome":"I've told Nayuta time and again@that before she puts clothes@in the washing machine,"}]},{"autoTurnFirst":3.2,"chara":[{"eyeClose":1,"id":103300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_023.exp3.json","id":103300,"motion":200,"textHome":"that she should make sure@there are no tissues in them...!"}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103300,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_00_41","textHome":"Done.@*Chuckle*"}]},{"autoTurnFirst":3.4,"chara":[{"eyeClose":1,"id":103300,"motion":300,"textHome":"I can see her delight already."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_051.exp3.json","id":103300,"motion":400,"textHome":"...Ah!"}]},{"autoTurnFirst":5.3,"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":103300,"motion":200,"textHome":"I simply baked these cookies thinking@that they would be a snack for myself."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp3.json","id":103300,"motion":1,"textHome":"Whether Nayuta is pleased or not@is entirely irrelevant."}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103300,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1033_00_42","textHome":"Resistance is futile;@I don't recommend it."}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103300,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1033_00_43","textHome":"It's okay.@We all end up in the same place."}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_44","textHome":"Even victory is meaningless@to Magical Girls."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103300}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1033_00_45","textHome":"At the very least,@I hope you didn't suffer."}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_033.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_46","textHome":"Either way, we are all the same;@none of us can be saved."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":2.5,"chara":[{"id":103300}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_04"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103300}]}],"group_5":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1033_00_05"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":103300}]}],"group_6":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_033.exp3.json","id":103300,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1033_00_13","textHome":"Even if we're destined for resignation,"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_032.exp3.json","id":103300,"textHome":"if I am weak,@I cannot protect what I need to."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_023.exp3.json","id":103300,"motion":200}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_14","textHome":"Humanity has advanced because@it goes beyond its limits."}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":103300,"motion":300,"textHome":"The same seems to be true for myself."}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1033_00_15","textHome":"It's not as though there wasn't@a period where I believed in hope."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_032.exp3.json","id":103300}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_00_16","textHome":"My father was frail@and always reading,"}]},{"autoTurnFirst":1.8,"chara":[{"eyeClose":1,"id":103300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":4.5,"chara":[{"id":103300,"motion":100,"textHome":"and it made him glad that@I was interested in books, too."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103300,"motion":200,"textHome":"So I read whatever I could."}]},{"autoTurnFirst":3.1,"chara":[{"id":103300,"motion":1,"textHome":"I wanted to see his@happy face and be praised."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103300}]},{"chara":[{"id":103300,"textHomeStatus":"Clear"}]}]},"version":3}

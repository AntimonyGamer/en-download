{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"black","bgm":"stop","turnChangeIn":"fadeIn"},{"nameNarration":"","narration":"Chapter 4@\"Revolt\"","narrationBg":"black","narrationEffect":"in","narrationFontSize":37.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":1.0,"bg":"bg_adv_31111.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402901,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831700,"motion":0,"pos":1}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402901,"motion":100,"pos":0}],"nameLeft":"Perenelle","textLeft":"Is everyone here?","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":810000},{"effect":"fadeout","id":831700},{"effect":"fadeout","id":402901}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":831303,"motion":200,"pos":2,"soulGem":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"nameRight":"Torte","textRight":"Yep!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402301,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402601,"motion":0,"pos":2}],"nameLeft":"Melissa","textLeft":"Yes!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402901,"motion":400,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831700,"motion":0,"pos":1}],"nameLeft":"Perenelle","textLeft":"Then let's proceed into the fourth book."},{"chara":[{"id":831700}],"nameCenter":"Nicolas","textCenter":"The fourth book out of six...@There might be some changes soon!"},{"autoTurnLast":2.0,"chara":[{"effect":"fadeout","id":402901},{"effect":"fadeout","id":810000},{"effect":"fadeout","id":831700}],"flashEffect":"explosion","se":"3205_charm","textClear":1},{"autoTurnLast":2.0,"bg":"bg_adv_24015.jpg","turnChangeIn":"fadeIn"},{"autoTurnLast":3.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":1.0,"bg":"bg_adv_20073.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831700,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":831303}],"nameLeft":"Torte","textLeft":"Another forest...?","turnChangeOut":"fadeOut"},{"chara":[{"id":831700}],"nameRight":"Nicolas","textRight":"But it's different from before...@I think it's somewhere in France."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831700}],"nameRight":"Nicolas","textRight":"There are well-trodden paths, and we seem to be@close to a village."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402601,"motion":400,"pos":0}],"nameLeft":"Elisa","textLeft":"Let's walk a bit!"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402901,"motion":0,"pos":2}],"turnChangeIn":"rollInFast"},{"chara":[{"id":831303}],"nameLeft":"Torte","textLeft":"At first, I was anxious and didn't know what to do...","turnChangeOut":"rollOutFast"},{"chara":[{"id":831303,"motion":100}],"nameLeft":"Torte","textLeft":"But now, I'm starting to understand what we@should do!"},{"chara":[{"id":402901,"motion":300}],"nameRight":"Perenelle","textRight":"Yes, but there are still unsolved mysteries."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":1,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"Like...?"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402901}],"nameRight":"Perenelle","textRight":"Who wants a world without La Pucelle?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":400,"pos":0}],"nameLeft":"Kagome","textLeft":"Ah... I see."},{"chara":[{"id":102001,"motion":300}],"nameLeft":"Kagome","textLeft":"We still don't know what caused the two worlds"},{"chara":[{"cheek":0,"id":102001,"pos":0}],"nameLeft":"Kagome","textLeft":"to diverge..."},{"autoTurnLast":1.0,"bg":"black","bgm":"stop","item":[{"path":"resource/scenario/img/51158_tower_tart2/memoria_1733.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"autoTurnLast":1.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":2.0,"surround":"7023_camera"},{"autoTurnLast":1.0,"bg":"bg_adv_20103.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":2,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":0}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story06","chara":[{"id":831303,"motion":101}],"nameRight":"Torte","textRight":"[se:7222_happy]Ah!","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":100,"pos":2}],"nameRight":"Torte","textRight":"They're here!"},{"chara":[{"id":831303}],"nameRight":"Torte","textRight":"This world is inside the mind of someone in this@campsite!"},{"chara":[{"id":102001,"motion":200}],"nameLeft":"Kagome","textLeft":"More soldiers again?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402301,"motion":300,"pos":2}],"nameRight":"Melissa","textRight":"I wonder who that person is...?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102001},{"effect":"fadeout","id":402301}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_20103.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":830000,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"La Hire","textCenter":"..."},{"autoTurnLast":0.2,"chara":[{"id":830000,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":200,"pos":2}],"nameRight":"Torte","textRight":"It's that person!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402301,"motion":400,"pos":2}],"nameRight":"Melissa","textRight":"Father?!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":402301}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":400,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":400,"pos":2,"soulGem":0}],"nameCenter":"Kagome & Torte","textCenter":"Huh?!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102001},{"effect":"fadeout","id":831303}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402301,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":830000,"motion":0,"pos":0}],"nameRight":"Melissa","textRight":"Father..."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":830000,"pos":0}],"nameLeft":"La Hire","textLeft":"Oh, Melissa! You're here too!"},{"chara":[{"id":830000}],"nameLeft":"La Hire","textLeft":"Will you help us...in the upcoming battle?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402301},{"effect":"fadeout","id":830000}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_20103.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":1,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402601,"motion":0,"pos":2}],"nameLeft":"Kagome","textLeft":"Battle...?"},{"chara":[{"id":402601}],"nameRight":"Elisa","textRight":"I see, I understand now. This army..."},{"chara":[{"id":402601,"motion":200}],"nameRight":"Elisa","textRight":"They are rebels against His Majesty King Charles VII@of France."},{"chara":[{"id":102001,"lipSynch":0,"motion":400}],"nameLeft":"Kagome","textLeft":"[chara:102001:effect_emotion_surprise_0][se:7226_shock]...?!"},{"autoTurnLast":2.0,"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":1,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402601,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story13","chara":[{"id":102001}],"nameLeft":"Kagome","textLeft":"Huh, is this okay...?","turnChangeOut":"fadeOut"},{"chara":[{"id":102001}],"nameLeft":"Kagome","textLeft":"I'd like to leave Miss Melissa and her father alone..."},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":402601,"motion":300}],"nameRight":"Elisa","textRight":"Let's let them talk."},{"chara":[{"id":402601}],"nameRight":"Elisa","textRight":"If we need them, we'll call them later."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":0,"soulGem":0}],"nameLeft":"Torte","textLeft":"By the way, what you just said...@about the rebel army...?"},{"chara":[{"id":831303,"motion":100}],"nameLeft":"Torte","textLeft":"Is this man, La Hire, the one who was a companion@of La Pucelle,"},{"chara":[{"id":831303}],"nameLeft":"Torte","textLeft":"and who played a role in crowning King Charles@more than ten years ago?"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402901,"motion":300,"pos":2},{"id":831303,"motion":0}],"nameRight":"Perenelle","textRight":"Many of the former companions"},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"have grievances against King Charles now, it seems."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402901}],"nameRight":"Perenelle","textRight":"La Hire's allies, Saintrailles, Alençon, Bâtard..."},{"chara":[{"id":402901,"motion":0}],"nameRight":"Perenelle","textRight":"The comrades who once admired La Pucelle and@fought alongside her"},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"are now supporting Prince Louis, King Charles' son,"},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"and leading the rebellion."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50}],"nameRight":"Qube","textRight":"It's becoming a larger-scale conflict than ever before."},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"If it keeps up like this, they'll never be@in a position to wage war with England."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":200,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"I've heard about former comrades fighting each@other before,"},{"chara":[{"id":102001}],"nameLeft":"Kagome","textLeft":"but I still don't fully understand why it happened...@I guess."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402601,"motion":1,"pos":2}],"nameRight":"Elisa","textRight":"There are various reasons."},{"chara":[{"id":402601}],"nameRight":"Elisa","textRight":"One of them is the presence of the King's confidant,@Marshal Richemont..."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402601,"motion":0}],"nameRight":"Elisa","textRight":"Richemont was also a comrade of Tart."},{"chara":[{"id":402601}],"nameRight":"Elisa","textRight":"He's a fearsomely capable man, both as a soldier@and a politician."},{"chara":[{"id":402601,"motion":300}],"nameRight":"Elisa","textRight":"He believes that in order to counter England's@organized army,"},{"chara":[{"id":402601}],"nameRight":"Elisa","textRight":"it is necessary to expand the King's personal@standing army,"},{"chara":[{"id":402601}],"nameRight":"Elisa","textRight":"not rely on noble private soldiers or mercenaries."},{"chara":[{"id":402601,"motion":200}],"nameRight":"Elisa","textRight":"He knows that the traditional way of fighting with@knights"},{"chara":[{"id":402601}],"nameRight":"Elisa","textRight":"won't be enough to drive out England."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402901,"motion":300,"pos":2}],"nameRight":"Perenelle","textRight":"...But if he goes ahead with that plan, the power of@the nobles will be diminished,"},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"and the mercenary bands that make a living@through highway robbery and looting"},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"won't be able to act as they please anymore..."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402601,"motion":0,"pos":0}],"nameLeft":"Elisa","textLeft":"That's why Richemont has many enemies as well."},{"chara":[{"id":402601,"motion":1}],"nameLeft":"Elisa","textLeft":"...In addition to that, there must be many generals@who hold grudges against King Charles."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831303,"motion":1,"pos":0,"soulGem":0}],"nameLeft":"Torte","textLeft":"Why...?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402601,"motion":300,"pos":2}],"nameRight":"Elisa","textRight":"When Tart was captured, King Charles could have@paid a ransom"},{"chara":[{"cheek":0,"eyeClose":1,"id":402601,"pos":2}],"nameRight":"Elisa","textRight":"to free her."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":200,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"Oh..."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402901,"motion":1,"pos":2}],"nameRight":"Perenelle","textRight":"But King Charles abandoned La Pucelle..."},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"Even if that was her final wish,"},{"chara":[{"id":402901,"motion":100}],"nameRight":"Perenelle","textRight":"those who admired La Pucelle don't see it that way."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102001,"motion":300,"pos":0}],"nameLeft":"Kagome","textLeft":"When Jeanne La Pucelle disappeared, everyone@was scattered..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831700,"motion":0,"pos":2}],"nameRight":"Nicolas","textRight":"If La Pucelle knew about this, she would be@quite saddened."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":0,"soulGem":0}],"nameLeft":"Torte","textLeft":"Huh?"},{"chara":[{"id":831303}],"nameLeft":"Torte","textLeft":"But everyone has forgotten about La Pucelle,@right?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402601,"motion":0,"pos":2}],"nameRight":"Elisa","textRight":"...Yes, that's why it's now difficult to understand"},{"chara":[{"id":402601}],"nameRight":"Elisa","textRight":"why the rebellion happened."},{"chara":[{"eyeClose":1,"id":402601,"motion":300}],"nameRight":"Elisa","textRight":"...Likely, even for La Hire."},{"autoTurnLast":0.2,"bg":"bg_adv_narration.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402301,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402601,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":402301,"motion":300}],"nameLeft":"Melissa","surround":"7202_telepathy","textLeft":"Elisa... Can you hear me?@Please come here with the others.","turnChangeOut":"fadeOut","turnEffect":"ef_adv_02"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402601,"motion":200,"pos":2}],"nameRight":"Elisa","textRight":"Understood. Guys, let's go!"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

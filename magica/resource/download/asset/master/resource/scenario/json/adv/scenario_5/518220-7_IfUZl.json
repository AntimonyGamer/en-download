{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_31094.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":801300,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"bgm":"bgm03_story23","chara":[{"id":801300}],"nameRight":"Prince Louis","textRight":"I must go...","turnChangeOut":"fadeOut"},{"chara":[{"id":801300}],"nameRight":"Prince Louis","textRight":"To that room, where La Pucelle is..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":801300},{"effect":"fadeout","id":831700}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":400,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":400,"pos":2,"soulGem":0}],"nameCenter":"Kagome & Torte","textCenter":"[chara:102001:effect_emotion_surprise_0][chara:831303:effect_emotion_surprise_0][se:7226_shock]...?!"},{"chara":[{"id":831303}],"nameRight":"Torte","textRight":"Is she here...?@Right in front of us...?"},{"chara":[{"id":831303,"motion":1}],"nameRight":"Torte","textRight":"Um...Jeanne La Pucelle..."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402901,"motion":1,"pos":2}],"nameRight":"Perenelle","textRight":"You two haven't met her yet, have you?"},{"chara":[{"id":102001,"motion":1}],"nameLeft":"Kagome","textLeft":"No..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831700,"motion":0,"pos":2}],"nameRight":"Nicolas","textRight":"Ah...do you hear something?"},{"chara":[{"id":831700}],"nameRight":"Nicolas","textRight":"From the direction of the grand hall..."},{"nameCenter":"Tart's Voice","textCenter":"...so we should head to Reims as soon as possible."},{"nameCenter":"Tart's Voice","textCenter":"I believe that's the best course of action."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50}],"nameRight":"Qube","textRight":"That's Tart's voice."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"lipSynch":0,"motion":400,"pos":0,"soulGem":0}],"nameLeft":"Torte","textLeft":"[chara:831303:effect_emotion_surprise_0][se:7226_shock]...?!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":801300,"motion":0,"pos":2}],"nameRight":"Prince Louis","textRight":"La Pucelle...!"},{"autoTurnLast":0.2,"chara":[{"effect":"slideOutRightFast","id":801300}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"Oh..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831700,"motion":0,"pos":2}],"nameRight":"Nicolas","textRight":"Let's follow him!"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402901,"motion":400,"pos":2}],"nameRight":"Perenelle","textRight":"...Yes, since he can't see us."},{"autoTurnLast":0.2,"textClear":1},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402201,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnChangeInTime":1.0},{"chara":[{"id":402101,"motion":400}],"nameLeft":"Tart","textLeft":"Dauphin Louis will be crowned as king in the@Cathedral of Reims.","turnChangeOut":"fadeOut","turnChangeOutTime":1.0},{"chara":[{"id":402101}],"nameLeft":"Tart","textLeft":"This is what's necessary for the people of France@at this time."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402101},{"effect":"fadeout","id":402201}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":830100,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":830200,"motion":0,"pos":0}],"nameRight":"Gilles de Rais","textRight":"Once he's consecrated as king,"},{"chara":[{"id":830100}],"nameRight":"Gilles de Rais","textRight":"The momentum supporting England will gradually@weaken."},{"chara":[{"id":830200}],"nameLeft":"Dauphin Charles","textLeft":"I see..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":830100},{"effect":"fadeout","id":830200}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_31094.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402901,"motion":100,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"nameRight":"Perenelle","textRight":"...I heard that the civil officials opposed the claims@of La Pucelle,"},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"and that Prince Charles, who was the Dauphin,"},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"was conflicted about marching on Reims until the@very end."},{"bgm":"stop","chara":[{"effect":"fadeout","id":102001},{"effect":"fadeout","id":402901},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":830200,"motion":0,"pos":1}],"nameNarration":"","narration":"[se:7107_arrivalone]*Crash*","narrationBg":"bg_adv_31094.jpg","narrationEffect":"in"},{"bgm":"bgm03_story07","chara":[{"id":830200,"lipSynch":0}],"nameCenter":"Dauphin Charles","narrationEffect":"out","textCenter":"..."},{"autoTurnLast":0.2,"chara":[{"id":830200,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":801300,"motion":0,"pos":2}],"nameRight":"Prince Louis","textRight":"Father."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":830200,"pos":0}],"nameLeft":"Dauphin Charles","textLeft":"Oh...Louis."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":801000,"motion":0,"pos":2}],"nameRight":"Dauphine","textRight":"Your Highness, I apologize!"},{"chara":[{"id":801000}],"nameRight":"Dauphine","textRight":"I tried to stop him, but..."},{"chara":[{"id":801000}],"nameRight":"Dauphine","textRight":"This child really wanted to meet La Pucelle..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":830200},{"effect":"fadeout","id":801000}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402101,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":801300,"motion":0,"pos":2}],"nameLeft":"Tart","textLeft":"Me?"},{"chara":[{"id":801300}],"nameRight":"Prince Louis","textRight":"La Pucelle..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":801300}],"nameRight":"Prince Louis","textRight":"Thank you for the victory in Orleans."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402101,"motion":0}],"nameLeft":"Tart","textLeft":"Such kind words are unnecessary, Lord Louis."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":801300}],"nameRight":"Prince Louis","textRight":"Please...I beg of you."},{"chara":[{"id":801300}],"nameRight":"Prince Louis","textRight":"Use your power to guide my father to become the@King of France."},{"bg":"bg_adv_31094.jpg","nameNarration":"","narration":"*Woosh*","narrationBg":"bg_adv_31094.jpg","narrationEffect":"in"},{"autoTurnLast":1.0,"bg":"black","item":[{"path":"resource/scenario/img/51158_tower_tart2/memoria_1738.jpg","posX":0,"posY":0,"visible":"appear"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"nameNarration":"Prince Louis","narration":"―Prince Louis―@...?","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":35.0,"narrationLineSpace":20.0,"turnChangeOut":"fadeOut"},{"nameNarration":"Tart","narration":"―Tart―@Yes...leave it to me."},{"narration":"―Tart―@For Lord Louis's sake,@I will definitely see him crowned as Dauphin."},{"narrationEffect":"out"},{"autoTurnLast":1.0,"bg":"bg_adv_31094.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":830200,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":830100,"motion":0,"pos":2}],"turnChangeIn":"whiteIn","turnChangeInTime":1.3},{"chara":[{"id":830100}],"nameRight":"Gilles de Rais","textRight":"Ohh...","turnChangeOut":"whiteOut","turnChangeOutTime":1.0},{"bg":"bg_adv_31094.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":830200,"pos":1},{"effect":"fadeout","id":830100}],"nameNarration":"","narration":"*Gasp*","narrationBg":"bg_adv_31094.jpg","narrationEffect":"in"},{"bgm":"bgm05_event03","chara":[{"id":830200}],"nameCenter":"Dauphin Charles","narrationEffect":"out","textCenter":"I...I've made up my mind."},{"chara":[{"id":830200}],"nameCenter":"Dauphin Charles","textBg":"shout","textCenter":"Our next goal is Reims!"},{"chara":[{"id":830200}],"nameCenter":"Dauphin Charles","textBg":"shout","textCenter":"Guided by La Pucelle, I will be crowned as king!"},{"chara":[{"id":830200}],"nameCenter":"Dauphin Charles","textBg":"shout","textCenter":"Let's bring peace to France!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":830200}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402101,"motion":0,"mouthOpen":1,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":801300,"motion":0,"mouthOpen":1,"pos":2}],"nameCenter":"Tart & Prince Louis","textCenter":"...!"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":1,"pos":1,"soulGem":0}],"turnChangeIn":"rollInFast"},{"chara":[{"id":831303}],"nameCenter":"Torte","textCenter":"At that moment, when Lord Louis met La Pucelle,","turnChangeOut":"rollOutFast"},{"chara":[{"id":831303}],"nameCenter":"Torte","textCenter":"Lord Charles solidified his decision to march to@Reims."},{"bg":"bg_adv_31094.jpg","chara":[{"effect":"fadeout","id":831303},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402301,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402601,"motion":1,"pos":2}],"nameNarration":"","narration":"[se:7107_arrivalone]*Thud*","narrationBg":"bg_adv_31094.jpg","narrationEffect":"in"},{"autoTurnLast":2.5,"narrationEffect":"out"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"Ah...you two also came here."},{"chara":[{"eyeClose":1,"id":402601,"motion":300}],"nameRight":"Elisa","textRight":"Yes..."},{"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402601,"tear":1}],"nameRight":"Elisa","textRight":"Tart..."},{"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":402301,"motion":0,"pos":0,"tear":1}],"nameLeft":"Melissa","textLeft":"Yes, she is right here..."},{"chara":[{"eyeClose":0,"id":402301}],"nameLeft":"Melissa","textLeft":"I thought I'd never see her again..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402301},{"effect":"fadeout","id":402601}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"lipSynch":0,"motion":0,"pos":1,"soulGem":0}],"nameCenter":"Kagome","textCenter":"(I see...for the two of them...)"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102001,"lipSynch":0,"motion":300,"pos":1}],"nameCenter":"Kagome","textCenter":"...@..."},{"autoTurnLast":2.0,"bg":"black","bgm":"stop","item":[{"iPhoneXScale":1.0,"path":"resource/scenario/img/51030_fishing_homura/51030_homura_dairy.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"bgm":"bgm20_song10","nameNarration":"Kagome","narrationCoverOpacity":0.0,"narrationEffect":"in","narrationHAlignment":"left","narrationPosX":150.0,"progressNarration":"[textBlack:Even after ten years, Dauphin Louis@didn't hide his gratitude to La Pucelle@whom he met that day.]","turnChangeOut":"fadeOut"},{"progressNarration":"[textBlack:\"If I had been king,@I could have saved La Pucelle...\"@It was Miss Perenelle's theory that,@after forgetting the existence of@La Pucelle due to the world's erosion,@the only thing that remained was his@rebellion against his father...]"},{"progressNarration":"[textBlack:If only he could regain the tender feelings@they shared at that time when he was wishing@for the peace of France alongside Miss Jeanne@and Dauphin Charles....]"},{"progressNarration":"[textBlack:He would remind us that now is not@the time for this. Surely, the@great rebellion will be quelled...@I couldn't help but hope that would happen.]"},{"autoTurnLast":1.0,"bg":"bg_adv_31094.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402101,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402201,"motion":1,"pos":2}],"item":[{"path":"resource/scenario/img/51030_fishing_homura/51030_homura_dairy.jpg","visible":"hide"}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"bgm":"bgm05_event05","chara":[{"id":402101}],"nameLeft":"Tart","textLeft":"Huh?","turnChangeOut":"fadeOut"},{"chara":[{"id":402101}],"nameLeft":"Tart","textLeft":"Melissa...and Elisa...?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402201},{"effect":"fadeout","id":402101}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402301,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402601,"motion":0,"pos":2}],"nameCenter":"Melissa & Elisa","textCenter":"...?!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402101,"motion":1,"pos":0}],"nameLeft":"Tart","textLeft":"Both of you seem different in some way..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402601},{"effect":"fadeout","id":402101}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_31094.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"lipSynch":0,"motion":400,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831700,"motion":0,"pos":2}],"nameLeft":"Kagome","textLeft":"(M-Miss Jeanne...?)"},{"chara":[{"id":831700}],"nameRight":"Nicolas","textRight":"Stay calm!"},{"chara":[{"id":831700}],"nameRight":"Nicolas","textRight":"Our forms are invisible to those who don't possess@magic stones."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102001},{"effect":"fadeout","id":831700}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402201,"motion":300,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402101,"motion":0,"pos":0}],"nameRight":"Liz","textRight":"...I feel strange somehow."},{"chara":[{"id":402201}],"nameRight":"Liz","textRight":"I thought I was asleep, but I'm here,@as if I'm dreaming..."},{"chara":[{"id":402101,"motion":1}],"nameLeft":"Tart","textLeft":"I feel the same..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402301,"motion":0,"pos":2}],"nameRight":"Melissa","textRight":"Tart...Liz..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402601,"motion":0,"pos":2}],"nameRight":"Elisa","textRight":"...Are they...real...?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402101,"pos":0}],"nameLeft":"Tart","textLeft":"...What do you mean?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402601},{"effect":"fadeout","id":402101}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_31094.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":100,"pos":2,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"nameRight":"Torte","textRight":"It might be the real them...they might have been@summoned by the dream!"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402901,"motion":0,"pos":2}],"nameRight":"Perenelle","textRight":"Just as Kagome came from the future...did they@come from the past?"},{"chara":[{"id":102001}],"nameLeft":"Kagome","textLeft":"Um, who is Miss Liz...?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402901,"motion":300,"pos":2}],"nameRight":"Perenelle","textRight":"Well...I could say she is like an older sister to@La Pucelle."},{"chara":[{"id":402901}],"nameRight":"Perenelle","textRight":"A Magical Girl who supported her and stayed by@her side until the very end."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":200,"pos":2}],"nameRight":"Torte","textRight":"Kagome! How about you interview the two of@them?"},{"chara":[{"id":102001,"motion":400,"pos":0}],"nameLeft":"Kagome","textLeft":"Huh?"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":831303,"motion":0,"pos":2}],"nameRight":"Torte","textRight":"Let's show ourselves!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102001},{"effect":"fadeout","id":831303}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402301,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402601,"motion":1,"pos":2}],"nameLeft":"Melissa","textLeft":"...Please convey their feelings to the future."},{"autoTurnLast":0.1,"textClear":1},{"autoTurnLast":2.0,"bg":"black","bgm":"stop","turnChangeIn":"fadeIn","turnChangeInTime":1.0},{"autoTurnLast":0.1,"turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bg":"white","turnChangeIn":"whiteIn"},{"nameNarration":"","narration":"[textBlack:―Interview Record―@Liz Hawkwood@Jeanne d'Arc (Tart)]","narrationCoverOpacity":0.0,"narrationEffect":"in","turnChangeOut":"whiteOut","turnChangeOutTime":0.2},{"autoTurnLast":0.01,"bg":"black","chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402201,"motion":1,"pos":2,"posX":30}],"item":[{"iPhoneXScale":1.0,"path":"resource/scenario/img/51030_fishing_homura/51030_homura_dairy.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"bgFront"}],"narrationEffect":"out","turnChangeIn":"whiteIn"},{"bgm":"bgm20_song10","nameNarration":"Liz","narrationCoverOpacity":0.0,"narrationEffect":"in","narrationHAlignment":"left","narrationPosX":80.0,"progressNarration":"[textBlack:  \"To give rise to a true@  hero with my own hands...@  That's all I've ever desired,@  and I've embarked on a long@  journey for that purpose.\"]","turnChangeOut":"whiteOut"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402201,"motion":300}],"progressNarration":"[textBlack:  \"Along the way, I experienced@  countless farewells and@  moments of despair.\"]"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402201,"motion":100}],"progressNarration":"[textBlack:  \"Tart is the light of my hope...@  The hope I finally encountered@  at the end of my long journey.\"]"},{"progressNarration":"[textBlack:  \"No matter what lies ahead,@  I will never let this@  light be extinguished.\"]"},{"autoTurnLast":0.01,"bg":"black","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":402101,"motion":0,"pos":2,"posX":30}],"item":[{"iPhoneXScale":1.0,"path":"resource/scenario/img/51030_fishing_homura/51030_homura_dairy.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"bgFront"}],"narrationEffect":"out","turnChangeIn":"whiteIn"},{"chara":[{"id":402101,"motion":300}],"nameNarration":"Tart","narrationCoverOpacity":0.0,"narrationEffect":"in","narrationHAlignment":"left","narrationPosX":80.0,"progressNarration":"[textBlack:  \"When I lost Catherine,@  my beloved sister,@  I made a vow before her grave.@  I swore to save this country@  and bring light to France.\"]","turnChangeOut":"whiteOut"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402101,"motion":201}],"progressNarration":"[textBlack:  \"That's why I, guided by the angels,@  will continue straight ahead,@  no matter what happens.\"]"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402101}],"progressNarration":"[textBlack:  \"Because beyond that,@  there is a world where@  everyone can live in peace...@  I believe there is hope.\"]"},{"chara":[{"id":402101,"motion":0}],"progressNarration":"[textBlack:\"I believe in that light...@And keep my gaze forward.\"]"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

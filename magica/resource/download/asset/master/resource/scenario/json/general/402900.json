{"story":{"group_1":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp3.json","id":402900,"motion":200,"pos":1,"voice":"vo_char_4029_00_01","textHome":"Separate the earth from the fire,@the subtle from the coarse,@gently and skillfully."}]},{"autoTurnFirst":4.0,"chara":[{"id":402900,"motion":0,"textHome":"It ascends from the earth to the heavens@and descends again to the earth,"}]},{"autoTurnFirst":6.4,"chara":[{"id":402900,"textHome":"thereby receiving the power@of the higher and the lower."}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":100,"textHome":"Oh, sorry, I didn't introduce myself.@My name is Perenelle Flamel,@and I am a Magical Girl and alchemist."}]},{"autoTurnFirst":4.8,"chara":[{"id":402900,"motion":400}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":402900,"motion":0,"pos":1,"voice":"vo_char_4029_00_17","textHome":"La Pucelle was aware of it."}]},{"autoTurnFirst":6.0,"chara":[{"id":402900,"motion":300,"textHome":"If she became a Witch, a second Dark Age,@different from what Isabeau and@Minou desired, would have arrived."}]},{"autoTurnFirst":4.0,"chara":[{"id":402900,"motion":1}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":5.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":100,"pos":1,"voice":"vo_char_4029_00_18","textHome":"La Pucelle's way of life@has changed my way of being."}]},{"autoTurnFirst":3.9,"chara":[{"id":402900,"motion":300,"textHome":"If I were to conceive a child..."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":402900,"motion":0,"textHome":"When that time comes,@I would name them after her."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":402900,"motion":400,"pos":1,"voice":"vo_char_4029_00_19","textHome":"Hehehe."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":200,"textHome":"Next time, I'll show you@a more improved sorcery."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":402900,"motion":0,"pos":1,"voice":"vo_char_4029_00_20","textHome":"I feel it.@I feel the presence@of my inseparable soul."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402900}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":1,"pos":1,"voice":"vo_char_4029_00_21","textHome":"When we first met,@Qube called me \"Child of Hermes\"."}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp3.json","id":402900,"motion":300,"textHome":"I wonder if I am really@worthy of that name."}]},{"autoTurnFirst":5.7,"chara":[{"id":402900}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":400,"pos":1,"voice":"vo_char_4029_00_22","textHome":"Having lived a little longer@than others, I have learned a lesson."}]},{"autoTurnFirst":6.5,"chara":[{"id":402900,"motion":100,"textHome":"I have learned to appreciate, to love,@and to be in awe of many things."}]},{"autoTurnFirst":4.0,"chara":[{"id":402900,"motion":200,"textHome":"The feelings I have for@all those important things..."}]},{"autoTurnFirst":3.5,"chara":[{"id":402900,"motion":0,"textHome":"I call them prayers."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":402900,"motion":1,"pos":1,"voice":"vo_char_4029_00_23","textHome":"Ah... the new wisdom I've gained here@will be the guiding ray@on the path we both walk."}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":300}]},{"autoTurnFirst":3.3,"chara":[{"id":402900,"motion":0,"textHome":"It's the path toward our great goal,@the creation of a true Philosopher's Stone."}]},{"autoTurnFirst":3.3,"chara":[{"id":402900,"motion":200}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_17":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":402900,"motion":400,"pos":1,"voice":"vo_char_4029_00_24","textHome":"Oh, I've arrived a little late.@Let's get started with today's experiment."}]},{"autoTurnFirst":3.7,"chara":[{"id":402900}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_041.exp3.json","id":402900,"motion":0,"textHome":"Of course, we'll start now."}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":402900,"motion":100,"textHome":"First of all, I need to put@the catalyst in this flask."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":1,"pos":1,"voice":"vo_char_4029_00_25","textHome":"Good morning."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp3.json","id":402900,"textHome":"The sun rises in the morning@and sets at night."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":300,"textHome":"It seems like nothing, but this@is also a mystery of the world@that we, alchemists, must unravel."}]},{"autoTurnFirst":4.0,"chara":[{"id":402900}]},{"autoTurnFirst":3.0,"chara":[{"id":402900,"motion":200}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":100,"pos":1,"voice":"vo_char_4029_00_26","textHome":"Eating habits vary from@place to place and time to time:"}]},{"autoTurnFirst":6.5,"chara":[{"id":402900,"motion":300,"textHome":"in some places, they have two meals a day,@in others three, and even more."}]},{"autoTurnFirst":5.3,"chara":[{"id":402900,"motion":1,"textHome":"I prefer to have a proper lunch."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":6.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":1,"pos":1,"voice":"vo_char_4029_00_02","textHome":"\"France will be destroyed by a woman,@but shall be saved by a girl.\""}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":100,"textHome":"This is the prophecy of a certain sage."}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp3.json","id":402900,"textHome":"My name is Perenelle."}]},{"autoTurnFirst":4.5,"chara":[{"id":402900,"motion":0,"textHome":"And I am here to witness its truth."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":1,"pos":1,"voice":"vo_char_4029_00_27","textHome":"I'll cook dinner."}]},{"autoTurnFirst":3.6,"chara":[{"id":402900,"motion":300,"textHome":"I don't have any particular@strengths or weaknesses,"}]},{"autoTurnFirst":4.8,"chara":[{"id":402900,"motion":100,"textHome":"but I do miss cooking@with honey and figs."}]},{"autoTurnFirst":3.0,"chara":[{"id":402900,"motion":0,"textHome":"Perhaps their taste reminds me of home..."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":6.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":402900,"motion":100,"pos":1,"voice":"vo_char_4029_00_28","textHome":"No matter how long I live,@I never get my old memories mixed up."}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402900,"textHome":"But not in dreams."}]},{"autoTurnFirst":5.0,"chara":[{"id":402900,"motion":300,"textHome":"People from different time periods,@hundreds of years apart,@can appear together..."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":402900,"motion":400,"pos":1,"voice":"vo_char_4029_00_29","textHome":"Have you seen any books on mysticism?"}]},{"autoTurnFirst":4.4,"chara":[{"id":402900,"motion":1,"textHome":"I rely on my husband, Nicolas,@to organize my library,@and often books get lost in my room."}]},{"autoTurnFirst":5.1,"chara":[{"id":402900,"motion":300}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":402900,"motion":400,"pos":1,"voice":"vo_char_4029_00_30","textHome":"I sense the presence of a Witch nearby."}]},{"autoTurnFirst":7.0,"chara":[{"id":402900,"motion":0,"textHome":"I don't feel comfortable fighting them@myself, but I am not afraid of any Witch."}]},{"autoTurnFirst":1.3,"chara":[{"id":402900,"motion":200,"textHome":"I am better at defensive magic@than anyone else."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402900}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp3.json","id":402900,"motion":0,"pos":1,"voice":"vo_char_4029_00_31","textHome":"A mansion of mirrors spreading@across the wall of time."}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":300,"textHome":"It's an intriguing subject for study,"}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp3.json","id":402900,"textHome":"but it's going to become an undesirable@presence in the world sooner or later."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":8.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp3.json","id":402900,"motion":200,"pos":1,"voice":"vo_char_4029_00_32","textHome":"The sight of Magical Girls quarreling is@by no means unusual throughout history."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402900,"motion":0,"textHome":"Unless there's a compelling reason,@I want to avoid intervening@as much as possible."}]},{"autoTurnFirst":3.3,"chara":[{"id":402900,"motion":400}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_26":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":100,"pos":1,"voice":"vo_char_4029_00_33","textHome":"If you'd like, I can be@your conversation partner."}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402900,"textHome":"However, I'm not good at@talking about problems."}]},{"autoTurnFirst":6.8,"chara":[{"id":402900,"motion":300,"textHome":"Maybe it's because I've lived too long,@but I've lost touch with people's feelings."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":0,"pos":1,"voice":"vo_char_4029_00_34","textHome":"Sometimes, when I don't have@anything handy to write on,"}]},{"autoTurnFirst":4.1,"chara":[{"id":402900,"motion":200,"textHome":"I end up scribbling@impromptu ideas on the walls."}]},{"autoTurnFirst":2.5,"chara":[{"id":402900,"motion":1,"textHome":"Thanks to that, the walls of my home are@filled with magical symbols and codes."}]},{"autoTurnFirst":4.4,"chara":[{"id":402900,"motion":100}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":0,"pos":1,"voice":"vo_char_4029_00_35","textHome":"Hmmm...@Oh, where am I?"}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402900}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"id":402900,"motion":400}]},{"autoTurnFirst":5.8,"chara":[{"id":402900,"motion":1,"textHome":"No, well, I was thinking about@improving a new technique,@and I forgot why I came here."}]},{"autoTurnFirst":3.5,"chara":[{"id":402900}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":402900,"motion":300,"pos":1,"voice":"vo_char_4029_00_36","textHome":"People who want to know the secret@of the Philosopher's Stone@occasionally come to visit us."}]},{"autoTurnFirst":6.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":100,"textHome":"I wonder if there have been rumors@spreading too much about that stone."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":402900,"motion":100,"pos":1,"voice":"vo_char_4029_00_03"}]}],"group_30":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":0,"pos":1,"voice":"vo_char_4029_00_37","textHome":"As a seeker of the world's truth,@I strive to maintain neutrality."}]},{"autoTurnFirst":4.5,"chara":[{"id":402900,"motion":200,"textHome":"I wish to be an observer of existence,@without distinguishing between@good or evil, light or darkness."}]},{"autoTurnFirst":4.5,"chara":[{"id":402900,"motion":400}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":402900,"motion":200,"pos":1,"voice":"vo_char_4029_00_38","textHome":"Melissa, who admires her father@as a seasoned hero."}]},{"autoTurnFirst":5.1,"chara":[{"id":402900,"motion":400,"textHome":"Liz, who was ashamed of her grandfather,@known as the betrayer hero."}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp3.json","id":402900,"motion":0,"textHome":"Both inherited the immense@causality of their ancestors."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_001.exp3.json","id":402900,"motion":400,"pos":1,"voice":"vo_char_4029_00_39","textHome":"Miss Elisa's strong-willed eyes remind me@of Miss Audfreda, who supported the@founding of the Frankish Kingdom long ago."}]},{"autoTurnFirst":6.0,"chara":[{"id":402900,"motion":100}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402900,"motion":300,"textHome":"Miss Elisa used to be affectionate@towards me when she was young..."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":402900,"motion":1,"pos":1,"voice":"vo_char_4029_00_40","textHome":"La Pucelle, who realized@her own limitations..."}]},{"autoTurnFirst":4.0,"chara":[{"id":402900,"motion":200,"textHome":"Tart willingly became a prisoner@to save her comrades."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402900}]},{"autoTurnFirst":4.5,"chara":[{"id":402900,"motion":0,"textHome":"She lived for others until the very end."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":3.2,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":402900,"motion":100,"pos":1,"voice":"vo_char_4029_00_41","textHome":"Ahh, I just want to go back home!"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":1,"face":"mtn_ex_011.exp3.json","id":402900,"motion":200,"textHome":"I want to see my own angel's smile@when I return! Wait for me, Nico—..."}]},{"autoTurnFirst":1.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp3.json","id":402900,"textHome":"Ahem!"}]},{"autoTurnFirst":2.3,"chara":[{"id":402900,"motion":400}]},{"autoTurnFirst":4.7,"chara":[{"cheek":1,"face":"mtn_ex_010.exp3.json","id":402900,"motion":0,"textHome":"...Um, is there something you need?"}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":100,"pos":1,"voice":"vo_char_4029_00_42","textHome":"My name is Perenelle Flamel,@and I am an alchemist."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":400,"pos":1,"voice":"vo_char_4029_00_43","textHome":"It seems my protection wasn't@able to destroy the enemy."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_041.exp3.json","id":402900,"motion":300,"pos":1,"voice":"vo_char_4029_00_44","textHome":"Aha... I suppose a slight@adjustment is necessary?"}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":200,"pos":1,"voice":"vo_char_4029_00_45","textHome":"For this... I wonder if I didn't@need to use a catalyst?"}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_041.exp3.json","id":402900,"motion":0,"pos":1,"voice":"vo_char_4029_00_46","textHome":"Have you become obedient?@It's a good attitude to have."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":100}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":100,"pos":1,"voice":"vo_char_4029_00_04"}]},{"autoTurnFirst":4.2,"chara":[{"id":402900,"motion":200}]}],"group_5":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":402900,"motion":400,"pos":1,"voice":"vo_char_4029_00_05"}]}],"group_6":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":400,"pos":1,"voice":"vo_char_4029_00_13","textHome":"I have come to know@another truth of the world."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":200,"pos":1,"voice":"vo_char_4029_00_14","textHome":"It seems that@I have reached a new height."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":300,"pos":1,"voice":"vo_char_4029_00_15","textHome":"This is how people are@bound together by causality."}]},{"autoTurnFirst":3.5,"chara":[{"id":402900}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":402900,"motion":1,"pos":1,"voice":"vo_char_4029_00_16","textHome":"Until one can control magic properly,"}]},{"autoTurnFirst":4.4,"chara":[{"id":402900,"motion":200,"textHome":"it is more efficient to use weapons@metallurgized with magical power."}]},{"autoTurnFirst":3.3,"chara":[{"id":402900,"motion":100,"textHome":"La Pucelle and Miss Elisa@understood this."}]},{"chara":[{"id":402900,"textHomeStatus":"Clear"}]}]},"version":3}

0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":400,"pos":0}],"nameLeft":"Kagome","textLeft":"Eeeeh?"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

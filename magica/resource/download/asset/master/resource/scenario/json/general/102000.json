{"story":{"group_1":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_101.exp3.json","id":102000,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1020_00_01","textHome":"I'm Kagome Satori."}]},{"autoTurnFirst":7.5,"chara":[{"cheek":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":400,"textHome":"I've been conducting interviews so@I can inform as many people as possible@about the Magical Girl status quo."}]},{"autoTurnFirst":6.9,"chara":[{"id":102000,"motion":1,"textHome":"By the way, this little one is Aru.@She's my best friend in the world."}]},{"autoTurnFirst":8.7,"chara":[{"cheek":1,"face":"mtn_ex_140.exp3.json","id":102000,"motion":200,"textHome":"U-um, I'm not very good@at talking to people,@so I might cause you some trouble,"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":400,"textHome":"but I hope we can get along."}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1020_00_17","textHome":"Nobody taught me ventriloquism;@I just figured it out on my own."}]},{"autoTurnFirst":3.5,"chara":[{"id":102000,"motion":300}]},{"autoTurnFirst":1.9,"chara":[{"id":102000,"motion":100,"textHome":"When I showed my grandma,@she was surprised but delighted."}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_511.exp3.json","id":102000}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_111.exp3.json","id":102000}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1020_00_18","textHome":"My grandma is the reason@why I love plants so much."}]},{"autoTurnFirst":4.6,"chara":[{"eyeClose":1,"id":102000,"motion":300,"textHome":"Her garden, with its many flowers,@is like a paradise that shows me@a new face every season."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":102000}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":400}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_200.exp3.json","id":102000,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1020_00_19","textHome":"Connecting with everyone gave me@this power, and now I'm going to@use it to protect other people."}]},{"autoTurnFirst":3.3,"chara":[{"id":102000,"motion":100}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_300.exp3.json","id":102000,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1020_00_20","textHome":"It's time to say goodbye to the me@who's scared all the time...!"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":102000}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_200.exp3.json","id":102000,"motion":400}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":1.9,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_110.exp3.json","id":102000,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1020_00_21","textHome":"Becoming a Magical Girl and being@able to talk with Aru for real@is like a dream come true!"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":102000}]},{"autoTurnFirst":4.6,"chara":[{"id":102000,"motion":400}]},{"autoTurnFirst":3.6,"chara":[{"cheek":1,"face":"mtn_ex_111.exp3.json","id":102000,"motion":100,"textHome":"Let's keep doing our best together, okay?"}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_300.exp3.json","id":102000,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1020_00_22","textHome":"I want as many people as possible@to know about Magical Girls,@which is why I keep writing."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":102000}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_200.exp3.json","id":102000,"motion":100}]},{"autoTurnFirst":5.4,"chara":[{"id":102000,"motion":300,"textHome":"Even after becoming a Magical Girl myself,@that hasn't changed."}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_100.exp3.json","id":102000,"motion":1,"textHome":"I'm positive that hope@still lies ahead of us."}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_110.exp3.json","id":102000}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":6.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_330.exp3.json","id":102000,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1020_00_23"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":102000}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":300}]},{"autoTurnFirst":1.2,"chara":[{"id":102000,"motion":0}]},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_111.exp3.json","id":102000}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":100}]}],"group_17":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1020_00_24","textHome":"I'm so glad you came!"}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_111.exp3.json","id":102000,"motion":100}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"face":"mtn_ex_550.exp3.json","id":102000,"textHome":"Ah, but, um, my room is kind of@a mess of papers at the moment."}]},{"autoTurnFirst":2.2,"chara":[{"id":102000,"motion":200,"textHome":"I'll clean it up right away."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_340.exp3.json","id":102000,"textHome":"Could you give me a minute?"}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_150.exp3.json","id":102000,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1020_00_25","textHome":"Oh, it's sprouting!"}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_111.exp3.json","id":102000,"motion":100,"textHome":"Thank goodness~."}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":300,"textHome":"Honestly, I was worried for it@since it was growing slower@than it was supposed to."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_111.exp3.json","id":102000,"motion":1,"textHome":"I hope it'll continue to grow and@produce some beautiful flowers."}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1020_00_26","textHome":"If we're going out for lunch,@can we stop by the florist?"}]},{"autoTurnFirst":6.0,"chara":[{"id":102000,"motion":100,"textHome":"I was actually just thinking about@picking up some new flower seeds."}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1020_00_02","textHome":"My name is Kagome Satori."}]},{"autoTurnFirst":5.4,"chara":[{"id":102000,"motion":200,"textHome":"I'm interviewing@all kinds of Magical Girls@in order to write a memoir."}]},{"autoTurnFirst":0.8,"chara":[{"cheek":1,"face":"mtn_ex_340.exp3.json","id":102000,"textHome":"...Am I doing this right...?"}]},{"autoTurnFirst":3.0,"chara":[{"id":102000,"motion":300}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1020_00_27","textHome":"I've got after-school stuff to do,@so it's okay if you want@to head home without me."}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_310.exp3.json","id":102000,"motion":300,"textHome":"There are some flowerbeds that the clean-up@committee members have been neglecting,@and I want to take care of them."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":200}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1020_00_28","textHome":"Now that I've had my bath,@I should update my diary,@right, Aru?"}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_111.exp3.json","id":102000}]},{"autoTurnFirst":1.9,"chara":[{"id":102000,"motion":200}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":1,"textHome":"I need to summarize everything@I saw and heard today."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":102000,"motion":300}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1020_00_29","textHome":"After meeting some Magical Girls,@talking to them, and watching them fight,"}]},{"autoTurnFirst":1.6,"chara":[{"eyeClose":1,"id":102000}]},{"autoTurnFirst":2.3,"chara":[{"id":102000,"motion":200}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":102000}]},{"autoTurnFirst":4.4,"chara":[{"id":102000,"motion":100,"textHome":"I think I've gained@a bit of courage myself."}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_550.exp3.json","id":102000,"motion":400,"textHome":"...Uwaaagh!@Oh, it was just a little birdie.@It startled me..."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_340.exp3.json","id":102000}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_100.exp3.json","id":102000,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1020_00_30","textHome":"If the Automatic Purification System absorbs@impurities to let Doppels be summoned,"}]},{"autoTurnFirst":2.3,"chara":[{"id":102000,"motion":0,"textHome":"do you think the Witches we defeat from@now on will be absorbed into the sky, too?"}]},{"autoTurnLast":5.0,"chara":[{"cheek":0,"face":"mtn_ex_340.exp3.json","id":102000,"motion":200}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_550.exp3.json","id":102000,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1020_00_31","textHome":"Huh?@Over there, is that...a copy of me?!"}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_330.exp3.json","id":102000,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"id":102000,"motion":200,"textHome":"Wait, even Aru has a doppelganger?!"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_220.exp3.json","id":102000,"motion":100,"textHome":"I didn't know that was possible...!"}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_550.exp3.json","id":102000,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1020_00_32"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_340.exp3.json","id":102000,"motion":300}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_200.exp3.json","id":102000}]},{"autoTurnFirst":3.0,"chara":[{"id":102000,"motion":400}]}],"group_26":[{"autoTurnFirst":5.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1020_00_33","textHome":"Aru's name comes from the name \"Alraune\"."}]},{"autoTurnFirst":4.1,"chara":[{"id":102000,"motion":1,"textHome":"Most people call those plants \"mandragoras\",@but this name is cuter, don't you think?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_111.exp3.json","id":102000,"motion":100}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1020_00_34","textHome":"Reading is enriching, isn't it?"}]},{"autoTurnFirst":6.9,"chara":[{"id":102000,"motion":200,"textHome":"Technical books grant you knowledge,@and stories fill you with emotions."}]},{"autoTurnFirst":1.9,"chara":[{"id":102000,"motion":1,"textHome":"That's why it's my favorite way@to spend my time."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_111.exp3.json","id":102000,"motion":400}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":4.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_550.exp3.json","id":102000,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1020_00_35","textHome":"Ah, sorry, I was focused on my book."}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_110.exp3.json","id":102000,"motion":1,"textHome":"This one is a novel about@a lonely girl who grows up."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":102000}]},{"autoTurnFirst":2.5,"chara":[{"id":102000,"motion":200,"textHome":"I can't count how many times@I've read it."}]},{"autoTurnFirst":2.6,"chara":[{"id":102000,"motion":400,"textHome":"I can lend it to you, if you want."}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_150.exp3.json","id":102000,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1020_00_36","textHome":"No, I don't grow mandragoras...!"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_340.exp3.json","id":102000,"motion":300,"textHome":"I only grow regular ordinary plants,"}]},{"autoTurnFirst":1.7,"chara":[{"id":102000,"motion":0,"textHome":"and I don't have a garden at home, which@means I'd have nowhere to plant one..."}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":102000}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1020_00_03"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_111.exp3.json","id":102000,"motion":100}]}],"group_30":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1020_00_37","textHome":"When I explained the origin of@Aru's name to Shizuka, she looked@as lost as I thought she would."}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_340.exp3.json","id":102000,"motion":300}]},{"autoTurnFirst":5.0,"chara":[{"id":102000,"motion":200,"textHome":"I wonder if it'd be possible to break@it down in an easy-to-understand way..."}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1020_00_38","textHome":"My best friend, Hibari,@is a plushie collector."}]},{"autoTurnFirst":4.0,"chara":[{"id":102000,"motion":1,"textHome":"When I visited her house for the@first time, I was amazed by the@sheer number of plushies she had."}]},{"autoTurnFirst":4.0,"chara":[{"id":102000,"motion":400}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":6.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_340.exp3.json","id":102000,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1020_00_39","textHome":"I thought that copying Himena@would help me speak more fearlessly,"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":102000}]},{"autoTurnFirst":4.0,"chara":[{"id":102000,"motion":200,"textHome":"but it just...felt weird instead..."}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1020_00_40","textHome":"When Hibari called me for the@first time, I was so surprised@that my heart skipped a beat."}]},{"autoTurnFirst":4.7,"chara":[{"id":102000,"motion":1}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_111.exp3.json","id":102000,"motion":200,"textHome":"It made me really happy, though."}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_110.exp3.json","id":102000,"motion":100,"textHome":"That's still one of@my most treasured memories."}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1020_00_41","textHome":"Thank you for allowing me@to take things at my own pace."}]},{"autoTurnFirst":3.8,"chara":[{"eyeClose":1,"id":102000,"motion":0,"textHome":"I feel so much safer@when you're here with me."}]},{"autoTurnFirst":0.4,"chara":[{"eyeClose":0,"id":102000}]},{"autoTurnFirst":3.5,"chara":[{"cheek":1,"id":102000,"motion":200,"textHome":"I always appreciate it, you know?"}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_200.exp3.json","id":102000,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1020_00_42","textHome":"We need to spread the word,@for everyone's sake...!"}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_220.exp3.json","id":102000,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1020_00_43","textHome":"D-did we work a little harder...?!"}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_111.exp3.json","id":102000,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1020_00_44","textHome":"We did it, Aru!@We really won!"}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_200.exp3.json","id":102000,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1020_00_45","textHome":"I have to catalogue this, too...@Lest it go unnoticed..."}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1020_00_46","textHome":"Good encounters, bad encounters–@both have made me stronger."}]},{"autoTurnFirst":3.0,"chara":[{"id":102000,"motion":0}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_200.exp3.json","id":102000,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1020_00_04"}]},{"autoTurnFirst":3.0,"chara":[{"id":102000,"motion":400}]}],"group_5":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1020_00_05"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_111.exp3.json","id":102000,"motion":100}]}],"group_6":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_111.exp3.json","id":102000,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1020_00_13","textHome":"Sprouting like a weed!"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":1,"textHome":"Aru and I are going@to grow up together!"}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_150.exp3.json","id":102000,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1020_00_14","textHome":"Are we in full bloom yet?"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_340.exp3.json","id":102000,"motion":300,"textHome":"I think we're about@80% of the way there."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_111.exp3.json","id":102000,"motion":100,"textHome":"We'll have to work harder."}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":5.1,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_140.exp3.json","id":102000,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1020_00_15","textHome":"I'm not much of a talker, so you@might have a hard time hearing me,@but if that's okay, then..."}]},{"autoTurnFirst":3.0,"chara":[{"id":102000,"motion":300}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_110.exp3.json","id":102000,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1020_00_16","textHome":"I made a special spot in my room@just for Aru's comfort."}]},{"autoTurnFirst":3.8,"chara":[{"id":102000,"motion":100}]},{"autoTurnFirst":2.2,"chara":[{"id":102000,"motion":200,"tear":0,"textHome":"It's full of houseplants and@looks really cozy, doesn't it?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_111.exp3.json","id":102000,"motion":1}]},{"chara":[{"id":102000,"textHomeStatus":"Clear"}]}]},"version":3}

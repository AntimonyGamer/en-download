ith Sayaka..."},{"chara":[{"id":200101,"motion":0,"voiceFullAuto":"fullvoice/section_104211/vo_full_912122-010-27"}],"nameAvRight":"Madoka","textAvColor":"textMadoka","textAvRight":"[fontSize:20]Huh?"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

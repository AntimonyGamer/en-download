":200904},{"effect":"fadeout","id":260102}],"surround":"stop","textAvClear":1,"turnEffect":"stop"},{"chara":[{"cheek":0,"face":"mtn_ex_015.exp3.json","id":833500,"motion":0,"pos":1,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-13"}],"nameAvCenter":"Sakie","textAvCenter":"[fontSize:20]Hey Kyoko, could you come here for a sec?","textAvColorRGB":"255255255"},{"autoTurnLast":0.2,"chara":[{"id":833500,"pos":0}],"textAvClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp3.json","id":260102,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-14"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]Huh...?@What's up?"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":833500,"motion":200,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-15"}],"nameAvLeft":"Sakie","textAvColorRGB":"255255255","textAvLeft":"[fontSize:20][chara:833500:effect_emotion_joy_0][se:7222_happy]Ta-dah!@It's our newest item, an apricot tart."},{"chara":[{"id":260102,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-16"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]Ohh...whoa..."},{"chara":[{"cheek":0,"face":"mtn_ex_015.exp3.json","id":833500,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-17"}],"nameAvLeft":"Sakie","textAvColorRGB":"255255255","textAvLeft":"[fontSize:20]Feel free to try one out."},{"chara":[{"id":260102,"motion":300,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-18"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]C...can I?"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":833500,"motion":100,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-19"}],"nameAvLeft":"Sakie","textAvColorRGB":"255255255","textAvLeft":"[fontSize:20]Of course!@It was inspired by you, after all!"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":260102,"motion":0,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-20"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]Well...@If you're offerin', I guess..."},{"autoTurnFirst":1.8,"autoTurnNoDelay":1,"chara":[{"eyeClose":1,"id":260102,"voiceFull":"fullvoice/section_104212/vo_full_913107-010-21"}],"nameAvRight":"Kyoko","textAvRight":"[fontSize:20]Omn...hm..."},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp3.json","id":260102,"lipSynch":0}]},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":833500,"motion":1,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-22","voiceFullStop":"fullvoice/section_104212/vo_full_913107-010-21"}],"nameAvLeft":"Sakie","textAvColorRGB":"255255255","textAvLeft":"[fontSize:20]Well? How do you like it?"},{"autoTurnFirst":1.0,"autoTurnNoDelay":1,"chara":[{"cheek":1,"id":260102,"voiceFull":"fullvoice/section_104212/vo_full_913107-010-24"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]Whoa...it's..."},{"chara":[{"cheek":1,"face":"mtn_ex_011.exp3.json","id":260102}]},{"chara":[{"id":260102,"motion":200,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-25","voiceFullStop":"fullvoice/section_104212/vo_full_913107-010-24"}],"nameAvRight":"Kyoko","textAvRight":"[fontSize:20][chara:260102:effect_emotion_joy_0][se:7222_happy]...delicious."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":833500,"motion":400,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-26"}],"nameAvLeft":"Sakie","textAvColorRGB":"255255255","textAvLeft":"[fontSize:20]Good to hear!@I knew you'd like it, Kyoko."},{"chara":[{"id":833500,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-27"}],"nameAvLeft":"Sakie","textAvLeft":"[fontSize:20]I made a lot of them, so feel free@to take some home with you."},{"autoTurnFirst":1.0,"autoTurnNoDelay":1,"chara":[{"cheek":0,"face":"mtn_ex_051.exp3.json","id":260102,"motion":0,"voiceFull":"fullvoice/section_104212/vo_full_913107-010-28"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]Um... Yeah, thanks."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":260102}]},{"autoTurnLast":0.5,"chara":[{"effect":"fadeout","id":833500,"voiceFullStop":"fullvoice/section_104212/vo_full_913107-010-28"}],"textAvClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":200904,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-29"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]...Heh heh heh."},{"chara":[{"id":200904,"motion":100,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-30"}],"nameAvLeft":"Mabayu","surround":"7202_telepathy","textAvLeft":"[fontSize:20]Looks like you've warmed up@to Aunt Sakie, huh?","turnEffect":"ef_adv_02"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":260102,"motion":100,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-31"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]Wha?@It's...not like that."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":200904,"motion":1,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-32"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]You know, I want to protect everyone's@daily lives."},{"chara":[{"id":200904,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-33"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Even if we defeat Walpurgisnacht, there's@no point if the town gets destroyed."},{"chara":[{"id":200904,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-34"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]I try to keep living as normally as possible..."},{"chara":[{"eyeClose":1,"id":200904,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-35"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]...so that everyone can go about@their usual, normal lives."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":260102,"motion":0,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-36"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]Everyone, huh...?"},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":200904,"motion":0,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-37"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Yes. That's why I invited you to work here."},{"chara":[{"id":200904,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-38"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Defeating Walpurgisnacht, and@drumming up business for this place..."},{"chara":[{"id":200904,"motion":400,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-39"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Both of those things are important@to me!"},{"bgm":"stop","chara":[{"id":260102,"motion":300,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-40"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]...What a joke."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200904,"motion":0,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-41"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Huh?"},{"bgm":"bgm01_anime19","chara":[{"id":260102,"motion":1,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-42"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]Do you really think Walpurgisnacht@is goin' down in one go?"},{"chara":[{"id":260102,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-43"}],"nameAvRight":"Kyoko","textAvRight":"[fontSize:20]Even if Homura can stop time, stealin'@military equipment ain't that easy."},{"chara":[{"id":260102,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-44"}],"nameAvRight":"Kyoko","textAvRight":"[fontSize:20]Honestly, aren't you already plannin'@on abandoning this world?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200904,"motion":300,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-45"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]No, I wouldn't—"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":260102,"motion":100,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-46"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]That's what I'd do."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200904,"motion":0,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-47"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Huh...?"},{"chara":[{"eyeClose":0,"id":260102,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-48"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]As long as Homura doesn't give up,@you basically have infinite do-overs, yeah?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":260102,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-49"}],"nameAvRight":"Kyoko","textAvRight":"[fontSize:20]Then isn't it better to just have@as much fun as you can?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200904,"motion":400,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-50"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]No, I...!"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":260102,"motion":0,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-51"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]You seemed to be havin' fun@moments ago."},{"chara":[{"id":200904,"motion":0,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-52"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]Ngh..."},{"chara":[{"id":260102,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-53"}],"nameAvRight":"Kyoko","textAvColor":"textKyoko","textAvRight":"[fontSize:20]You're already used to it,@aren't you? Or..."},{"chara":[{"id":260102,"motion":200,"voiceFullAuto":"fullvoice/section_104212/vo_full_913107-010-54"}],"nameAvRight":"Kyoko","textAvRight":"[fontSize:20]Do you seriously want these days@to end?"},{"autoTurnLast":2.0,"surround":"stop","turnChangeIn":"fadeIn","turnEffect":"stop"}]},"version":3}

{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21723.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":101601,"motion":0,"pos":1}],"surround":"7008_station","turnChangeIn":"fadeIn"},{"chara":[{"id":101601,"lipSynch":0,"pos":1}],"nameCenter":"Kanagi","textCenter":"...","turnChangeOut":"fadeOut"},{"nameNarration":"","narration":"*Phone ringing*","narrationBg":"","narrationEffect":"in","surround":"7105_telphone"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101601,"pos":1}],"nameCenter":"Kanagi","narrationEffect":"out","textCenter":"Hm...?"},{"autoTurnLast":0.2,"bg":"bg_adv_narration.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":101601,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":800900,"motion":0,"pos":2}],"surround":"stop","turnChangeIn":"rollInFast","turnEffect":"thinking"},{"chara":[{"id":101601}],"nameLeft":"Kanagi","textLeft":"What is it, Dad?","turnChangeOut":"rollOutFast"},{"bgm":"bgm03_story10","chara":[{"id":800900}],"nameRight":"Kanagi's Father","textBg":"shout","textRight":"KANAGI! IT'S AN EMERGENCY!"},{"chara":[{"id":800900}],"nameRight":"Kanagi's Father","textBg":"shout","textRight":"WHERE ARE YOU RIGHT NOW?!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101601,"motion":400,"pos":0}],"nameLeft":"Kanagi","textLeft":"Wh-what the...?!@I'm in Shinsei Ward...!"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800900,"pos":2}],"nameRight":"Kanagi's Father","textRight":"Okay...!@Th-thank God you're close."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":800900,"pos":2}],"nameRight":"Kanagi's Father","textRight":"Hurry over to the hospital!"},{"autoTurnLast":2.0,"bg":"bg_adv_21801.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":832400,"motion":0,"pos":2},{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":101601,"motion":0,"pos":0}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm03_story06","chara":[{"id":832400,"lipSynch":0}],"nameRight":"Kanagi's Brother","textRight":"...","turnChangeOut":"fadeOut"},{"chara":[{"id":101601}],"nameLeft":"Kanagi","textLeft":"...Mom and Dad are on their way right now..."},{"chara":[{"effect":"shake","eyeClose":1,"id":832400}],"nameRight":"Kanagi's Brother","textRight":"Ugh..."},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":101601,"motion":200,"pos":0}],"nameLeft":"Kanagi","textLeft":"What the hell happened...?!"},{"chara":[{"id":101601}],"nameLeft":"Kanagi","textLeft":"Are those broken bones...?!@Were you hit by a car?!"},{"chara":[{"eyeClose":0,"id":832400}],"nameRight":"Kanagi's Brother","textRight":"...You and Dad were right all along..."},{"chara":[{"id":832400}],"nameRight":"Kanagi's Brother","textRight":"I should've kept my hands to myself,@no matter what..."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":101601,"motion":0}],"nameLeft":"Kanagi","textLeft":"What do you mean...?"},{"chara":[{"id":832400}],"nameRight":"Kanagi's Brother","textRight":"You know how I told you I got in a fight with@a Western dude a while back...?"},{"chara":[{"id":832400}],"nameRight":"Kanagi's Brother","textRight":"He got his revenge."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101601,"motion":400,"pos":0}],"nameLeft":"Kanagi","textLeft":"Y-your injuries...@A person did this to you?! "},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":832400,"motion":1,"pos":2}],"nameRight":"Kanagi's Brother","textRight":"It wasn't just one guy.@I was surrounded..."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":101601,"motion":100,"pos":0}],"nameLeft":"Kanagi","textLeft":"That doesn't matter!"},{"chara":[{"id":101601,"motion":1}],"nameLeft":"Kanagi","textLeft":"The police―@we have to go to the police...!"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":832400,"motion":300,"pos":2}],"nameRight":"Kanagi's Brother","textRight":"I talked to them earlier, but it was weird."},{"chara":[{"id":832400}],"nameRight":"Kanagi's Brother","textRight":"They didn't seem to wanna take me seriously..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101601,"lipSynch":0}],"nameLeft":"Kanagi","textLeft":"[chara:101601:effect_emotion_surprise_0][se:7226_shock]...?!"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":101601,"motion":400,"pos":0}],"nameLeft":"Kanagi","textBg":"shout","textLeft":"Why not?!"},{"chara":[{"id":832400,"motion":200}],"nameRight":"Kanagi's Brother","textRight":"Beats me..."},{"chara":[{"id":832400}],"nameRight":"Kanagi's Brother","textRight":"The first cop I spoke to listened carefully..."},{"chara":[{"id":832400}],"nameRight":"Kanagi's Brother","textRight":"Then a detective in a suit showed up, and suddenly@he got all lax and lost interest...!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101601,"lipSynch":0,"motion":0}],"nameLeft":"Kanagi","textLeft":"...!"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":101601,"lipSynch":0,"pos":0}],"nameLeft":"Kanagi","textLeft":"..."},{"chara":[{"id":832400,"motion":0}],"nameRight":"Kanagi's Brother","textRight":"I dunno if this is relevant, but..."},{"chara":[{"id":832400}],"nameRight":"Kanagi's Brother","textRight":"...I think the guy I fought with...had some backdoor@connections..."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":101601,"pos":0}],"nameLeft":"Kanagi","textLeft":"Like what?"},{"chara":[{"id":832400}],"nameRight":"Kanagi's Brother","textRight":"One of the bastards who surrounded me was@someone I'd seen before."},{"chara":[{"id":101601,"motion":200,"pos":0}],"nameLeft":"Kanagi","textLeft":"Who?"},{"autoTurnLast":0.01,"bg":"bg_adv_13042.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":801100,"motion":0,"pos":1}],"turnChangeIn":"fadeIn","turnEffect":"sepiaFrame"},{"autoTurnLast":2.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bg":"bg_adv_21801.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":832400,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101601,"motion":0,"pos":0}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"bgm":"bgm03_story08","chara":[{"id":832400}],"nameRight":"Kanagi's Brother","textRight":"...From whatever that group's called...","turnChangeOut":"fadeOut"},{"chara":[{"id":101601,"lipSynch":0,"pos":0}],"nameLeft":"Kanagi","textLeft":"...!"},{"chara":[{"id":101601,"pos":0}],"nameLeft":"Kanagi","textLeft":"Are you positive...?"},{"chara":[{"id":832400}],"nameRight":"Kanagi's Brother","textRight":"Yeah, a hundred percent..."},{"chara":[{"cheek":0,"id":101601,"lipSynch":0,"motion":300,"pos":0}],"nameLeft":"Kanagi","textLeft":"(Yakumo told me the name of that organization...)"},{"chara":[{"id":101601,"lipSynch":0}],"nameLeft":"Kanagi","textLeft":"(They're the ones who sabotaged the West@in the previous election...)"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":101601,"lipSynch":0,"pos":0}],"nameLeft":"Kanagi","textLeft":"(And threw a stone at the director of the hospital...)"},{"chara":[{"id":101601,"lipSynch":0}],"nameLeft":"Kanagi","textLeft":"(Both of these were staged attacks by the West...)"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":101601,"lipSynch":0,"motion":0}],"nameLeft":"Kanagi","textLeft":"(They're chumming the waters with us@to undermine the East...)"},{"chara":[{"id":101601}],"nameLeft":"Kanagi","textLeft":"...Tell me where that group is based out of."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":832400,"pos":2}],"nameRight":"Kanagi's Brother","textRight":"Eh...?"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":832400,"motion":200}],"nameRight":"Kanagi's Brother","textRight":"S-Sis, stop...!@What are you doing...?!"},{"chara":[{"id":101601}],"nameLeft":"Kanagi","textLeft":"Next time something happens,@I'll be here to take the bait."},{"bgm":"stop","chara":[{"id":101601,"motion":100}],"nameLeft":"Kanagi","textLeft":"If you won't tell me, I'll take a peek for myself."},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"black","bgm":"stop","turnChangeIn":"fadeIn"},{"nameNarration":"","narration":"Chapter 6@\"Encounter and Resolve\"","narrationBg":"black","narrationEffect":"in","narrationFontSize":37.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":2.0,"bg":"bg_adv_31031.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831300,"live2dName":"live2d_0","motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831300,"live2dName":"live2d_1","motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":100,"pos":1}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"autoTurnLast":2.5,"bgm":"bgm24_story03","chara":[{"id":412200}],"turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831300,"live2dName":"live2d_0"},{"effect":"fadeout","id":831300,"live2dName":"live2d_1"},{"effect":"fadeout","id":412200}],"textClear":1},{"autoTurnLast":0.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402601,"motion":0,"pos":1}],"textClear":1},{"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_020.exp3.json","id":402600,"motion":0,"pos":1}],"nameCenter":"Elisa","se":"7205_magic_girl","textCenter":"Isabeau de Baviere...!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402600}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":0,"pos":1}],"nameCenter":"Isabeau","textCenter":"Hehe..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":412200}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":830200,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":0,"soulGem":0}],"nameRight":"Charles VII","textRight":"M-Mother...?!"},{"chara":[{"id":831303,"motion":400}],"nameLeft":"Torte","textLeft":"Was Lord Charles dragged into this too?!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":830200},{"effect":"fadeout","id":831303}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402901,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50}],"textClear":1},{"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_020.exp3.json","id":402900,"motion":100,"pos":0}],"nameLeft":"Perenelle","se":"7205_magic_girl","textLeft":"Qube, this space that appeared a moment ago,@what is it?"},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"The distortion in spacetime has reached its@limit..."},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"It seems that spacetime has been shattered by a@time paradox."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":1,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"A time paradox...?!"},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"Yes, your actions have resurrected the original@world."},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"The balance between the world where Tart is born,"},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"and the world where she isn't, is now in a state of@conflict."},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"In other words, contradictory events started@coexisting at the same time."},{"chara":[{"id":102001,"motion":300,"pos":0}],"nameLeft":"Kagome","textLeft":"Distortion of spacetime...? Time paradox...?"},{"autoTurnLast":0.5,"bg":"bg_adv_21184.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":1,"soulGem":0}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"autoTurnLast":1.0,"se":"7208_wander_into"},{"chara":[{"cheek":0,"id":102001,"lipSynch":0,"motion":400,"pos":1}],"nameCenter":"Kagome","textCenter":"[chara:102001:effect_emotion_surprise_0][se:7226_shock]...?!","turnChangeOut":"fadeOut"},{"chara":[{"id":102001}],"nameCenter":"Kagome","textCenter":"This place...!"},{"autoTurnLast":1.0,"bg":"bg_adv_31031.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831303,"motion":0,"pos":2,"soulGem":0}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":102001}],"nameLeft":"Kagome","textLeft":"Could the cause be...an offshot Mirrors...?","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"pos":2}],"nameRight":"Torte","textRight":"Huh?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50}],"nameRight":"Qube","textRight":"...What do you mean?"},{"chara":[{"id":102001,"motion":300}],"nameLeft":"Kagome","textLeft":"Earlier, did you see a place with lots of mirrors?"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"pos":0}],"nameLeft":"Kagome","textLeft":"There's something like a time tunnel"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":400,"pos":0}],"nameLeft":"Kagome","textLeft":"connecting the past and the future there!"},{"chara":[{"id":102001}],"nameLeft":"Kagome","textLeft":"I think that's how my time period and the 1400s@got connected!"},{"bg":"bg_adv_31031.jpg","nameNarration":"","narration":"*Flip*","narrationBg":"bg_adv_31031.jpg","narrationEffect":"in"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"lipSynch":0,"motion":200}],"nameLeft":"Kagome","narrationEffect":"out","textLeft":"(Touka's speech...)"},{"chara":[{"id":102001,"lipSynch":0}],"nameLeft":"Kagome","textLeft":"(I must have...written it down somewhere...@[wait:1.0][chara:102001:motion_000][chara:102001:cheek_0][chara:102001:face_mtn_ex_050.exp3.json]Oh, here it is!)"},{"chara":[{"id":102001,"motion":1}],"nameLeft":"Kagome","textLeft":"If the past changes...and the world splits into@multiple branches,"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"pos":0}],"nameLeft":"Kagome","textLeft":"history could gradually be changed...!"},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"I see...Isabeau, through that, saw the future,"},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"and the world diverged into two branches..."},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"The two worlds balanced out, causing a paradox."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402601,"motion":0,"pos":2}],"nameRight":"Elisa","textRight":"So, what do we must do in the end?"},{"chara":[{"id":102001,"motion":400}],"nameLeft":"Kagome","textLeft":"We should go to the place we saw earlier and@break the mirror..."},{"chara":[{"id":402601,"motion":1}],"nameRight":"Elisa","textRight":"How do we get there?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50},{"id":102001,"motion":0}],"nameRight":"Qube","textRight":"If we recreate the same situation as earlier,@it will be possible."},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"Dive into the mind of the remaining individual,"},{"chara":[{"id":810000}],"nameRight":"Qube","textRight":"and pull the balance of the world towards us."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":1,"pos":0,"soulGem":0}],"nameLeft":"Torte","textLeft":"Where could the last book be...?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402300,"motion":1,"pos":2}],"nameRight":"Melissa","textRight":"I can't see any books, but if we find the entrance to@their heart..."},{"chara":[{"id":831303,"motion":100}],"nameLeft":"Torte","textLeft":"...What's that?"},{"autoTurnLast":0.2,"bg":"bg_adv_31032.jpg","turnChangeIn":"rollInFast"},{"autoTurnLast":3.0,"turnChangeOut":"rollOutFast"},{"autoTurnLast":0.2,"bg":"bg_adv_31031.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":1}],"turnChangeIn":"rollInFast"},{"chara":[{"cheek":0,"id":831303,"lipSynch":0,"motion":101,"pos":1}],"nameCenter":"Torte","textCenter":"[se:7222_happy]...!","turnChangeOut":"rollOutFast"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":831303,"motion":100,"pos":1}],"nameCenter":"Torte","textCenter":"No doubt about it, it's there!"},{"bgm":"stop","nameLeft":"Isabeau's voice","textLeft":"...Is that what you're after?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_31031.jpg","bgChangeEffect":"cameraPan"},{"bgm":"bgm05_event04","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":200,"pos":1}],"nameCenter":"Isabeau","textCenter":"Heh."},{"autoTurnLast":2.0,"flashEffect":"explosion","item":[{"path":"resource/scenario/img/51158_tower_tart2/51158_isabeau_magic_circle.png","posX":0,"posY":0,"visible":"appear","zOrder":"charaFront"}],"se":"3210_curse","textClear":1},{"bg":"bg_adv_31031.jpg","chara":[{"id":412200,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402900,"motion":200,"pos":2}],"item":[{"path":"resource/scenario/img/51158_tower_tart2/51158_isabeau_magic_circle.png","visible":"hide"}],"nameNarration":"","narration":"[se:3103_enemy_cast]*Boom*","narrationBg":"bg_adv_31031.jpg","narrationEffect":"in"},{"autoTurnLast":1.0,"flashEffect":"explosion","narrationEffect":"out"},{"chara":[{"id":402900,"lipSynch":0}],"nameRight":"Perenelle","textRight":"..."},{"chara":[{"id":412200,"motion":0}],"nameLeft":"Isabeau","textLeft":"It was an interesting story, so I got caught up in@listening to it."},{"chara":[{"id":412200}],"nameLeft":"Isabeau","textLeft":"For me, you are the ones who live in the future."},{"chara":[{"id":412200}],"nameLeft":"Isabeau","textLeft":"You are trying to restore the changed history that I@learned of through that mirror Labyrinth..."},{"chara":[{"id":412200}],"nameLeft":"Isabeau","textLeft":"And now you've found a way to pull it off."},{"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":412200,"motion":100}],"nameLeft":"Isabeau","textLeft":"I'm right, aren't I, Qube?"},{"chara":[{"cheek":0,"id":810000,"lipSynch":0,"pos":2,"posX":50}],"nameRight":"Qube","textRight":"...@..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":1}],"nameLeft":"Isabeau","textLeft":"Oh? ...The silent treatment? How cold."},{"chara":[{"id":412200}],"nameLeft":"Isabeau","textLeft":"Well, there's no need to listen anymore, I suppose."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":0,"pos":0}],"nameLeft":"Isabeau","textLeft":"All that's left is to annihilate you all..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":810000},{"effect":"fadeout","id":412200}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_31031.jpg","bgChangeEffect":"cameraPan"},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831300,"live2dName":"live2d_0","motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831300,"live2dName":"live2d_1","motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831301,"motion":0,"pos":1}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831300,"live2dName":"live2d_0"},{"effect":"fadeout","id":831300,"live2dName":"live2d_1"},{"effect":"fadeout","id":831301}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_31031.jpg","bgChangeEffect":"cameraPan"},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831301,"live2dName":"live2d_0","motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831301,"live2dName":"live2d_1","motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831300,"motion":0,"pos":1}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831301,"live2dName":"live2d_0"},{"effect":"fadeout","id":831301,"live2dName":"live2d_1"},{"effect":"fadeout","id":831300}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402300,"motion":300,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":0,"soulGem":0}],"nameRight":"Melissa","textRight":"...Both of you, please jump into that entrance."},{"chara":[{"id":402300}],"nameRight":"Melissa","textRight":"Elisa and I will distract Isabeau and the others."},{"chara":[{"id":831303,"motion":1}],"nameLeft":"Torte","textLeft":"Okay..."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":102001,"motion":400,"pos":0,"soulGem":0}],"nameLeft":"Kagome","textLeft":"Understood."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402300},{"effect":"fadeout","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402601,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":830200,"motion":0,"pos":0}],"nameRight":"Elisa","textRight":"Everyone else, stay behind Perenelle...@King Charles, you too."},{"chara":[{"id":830200}],"nameLeft":"Charles VII","textLeft":"Y-yes."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":830200,"pos":0}],"nameLeft":"Charles VII","textLeft":"If you meet him... Please, I beg of you,@take care of Louis."},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":830200}],"nameLeft":"Charles VII","textLeft":"If I return alive,"},{"chara":[{"id":830200}],"nameLeft":"Charles VII","textLeft":"I will definitely fulfill my promise to restore the@honor of La Pucelle."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402601},{"effect":"fadeout","id":830200}],"textClear":1},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":831303,"motion":0,"pos":2,"soulGem":0}],"nameLeft":"Kagome","textLeft":"Yes...!"},{"bgm":"bgm24_story02","chara":[{"id":831303,"motion":200}],"nameRight":"Torte","textRight":"Alright, let's go!"},{"autoTurnLast":0.2,"chara":[{"effect":"slideOutLeftFast","id":831303},{"effect":"slideOutRightFast","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":412200,"motion":200,"pos":1}],"nameCenter":"Isabeau","textCenter":"I won't let you do that!"},{"autoTurnLast":1.5,"chara":[{"cheek":0,"effect":"slideInRightFast","face":"mtn_ex_020.exp3.json","id":402300,"motion":400,"pos":0}],"nameLeft":"Melissa","textLeft":"[flashEffect:flashRed2][bgEffect:shakeLarge][chara:412200:effect_shake][se:3001_chara_damage]That is..."},{"chara":[{"cheek":0,"effect":"slideInLeftFast","face":"mtn_ex_020.exp3.json","id":402600,"motion":200,"pos":2}],"nameRight":"Elisa","textRight":"[flashEffect:flashRed2][bgEffect:shakeLarge][chara:412200:effect_shake][se:3001_chara_damage]OUR line!"},{"chara":[{"eyeClose":1,"id":412200}],"nameCenter":"Isabeau","textCenter":"Ugh...!!"},{"chara":[{"cheek":0,"eyeClose":0,"id":412200,"motion":400,"pos":1}],"nameCenter":"Isabeau","textBg":"shout","textCenter":"Drown these wretches...in a sea of blood!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402600},{"effect":"fadeout","id":402300},{"effect":"fadeout","id":412200}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_31031.jpg","bgChangeEffect":"cameraPan"},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831300,"live2dName":"live2d_0","motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831300,"live2dName":"live2d_1","motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831301,"motion":0,"pos":1}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831300,"live2dName":"live2d_0"},{"effect":"fadeout","id":831300,"live2dName":"live2d_1"},{"effect":"fadeout","id":831301}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_31031.jpg","bgChangeEffect":"cameraPan"},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831301,"live2dName":"live2d_0","motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831301,"live2dName":"live2d_1","motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":831300,"motion":0,"pos":1}],"textClear":1},{"autoTurnLast":0.4,"item":[{"path":"resource/scenario/img/51158_tower_tart2/memoria_1739.jpg","posX":0,"posY":125,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"autoTurnFirst":0.1,"item":[{"action":{"spawn":[{"moveTo":{"duration":18.0,"posX":0,"posY":-125}}]},"path":"resource/scenario/img/51158_tower_tart2/memoria_1739.jpg"}],"turnChangeOut":"fadeOut"},{"autoTurnLast":1.0},{"nameNarration":"Elisa","narration":"―Elisa―@That was a really reckless move, using ourselves as bait...@And against THE Isabeau?","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":10.0,"narrationLineSpace":20.0},{"nameNarration":"Melissa","narration":"―Melissa―@Just as planned!@As long as this lets us send the two of them on their way..."},{"narration":"―Melissa―@Besides, we aren't the same people we used to be."},{"autoTurnLast":0.5},{"narration":"―Melissa―@After all, we've spent nearly ten years@protecting Europe since back then...!"},{"autoTurnLast":0.5},{"nameNarration":"Elisa","narration":"―Elisa―@Heh... That's right.@Let's demonstrate just how much we've grown."},{"autoTurnLast":1.0,"narrationEffect":"out"},{"autoTurnLast":1.0,"bg":"bg_adv_31032.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":102001,"motion":0,"pos":2,"soulGem":0}],"turnChangeIn":"fadeIn"},{"chara":[{"id":831303,"motion":101}],"nameLeft":"Torte","textLeft":"[se:7222_happy]Here it is!","turnChangeOut":"fadeOut"},{"chara":[{"id":102001}],"nameRight":"Kagome","textRight":"Take my hand so we won't get separated!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102001},{"effect":"fadeout","id":831303}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":0,"mouthOpen":1,"pos":0,"posX":100,"soulGem":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":102001,"motion":0,"mouthOpen":1,"pos":2,"posX":-100,"soulGem":0}],"nameCenter":"Torte & Kagome","textCenter":"...Ready, go!"},{"autoTurnLast":0.2,"textClear":1},{"autoTurnLast":0.4,"bg":"black","item":[{"path":"resource/scenario/img/51158_tower_tart2/memoria_1737.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"whiteIn","turnChangeInTime":1.3},{"nameNarration":"Torte","narration":"[se:7222_happy]―Torte―@My hair is reacting!@This way, Kagome!","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":10.0,"narrationLineSpace":20.0,"turnChangeOut":"whiteOut","turnChangeOutTime":1.0},{"nameNarration":"Kagome","narration":"―Kagome―@Eh, ah...@Hey, wait a second!"},{"nameNarration":"Torte","narration":"―Torte―@Hehe, I won't wait!@I won't wait, and I won't let go of your hand!"},{"nameNarration":"Kagome","narration":"―Kagome―@Then...I'm gonna fall...!"},{"nameNarration":"Torte","narration":"―Torte―@Just run faster!"},{"narration":"―Torte―@The trick to running fast is...don't hesitate!@Keep facing forward and run straight ahead!"},{"autoTurnLast":2.2,"bg":"bg_adv_20081.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":200,"mouthOpen":0,"pos":0,"posX":100,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":1,"mouthOpen":0,"pos":2,"posX":-100,"soulGem":0}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"chara":[{"id":102001,"lipSynch":0}],"nameRight":"Kagome","textRight":"(Don't hesitate...)","turnChangeOut":"fadeOut"},{"chara":[{"id":102001,"lipSynch":0}],"nameRight":"Kagome","textRight":"(Keep facing forward and run straight ahead...)"},{"chara":[{"id":102001,"lipSynch":0,"pos":2}],"nameRight":"Kagome","textRight":"(I've made up my mind to become involved as a@participant.)"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":102001,"lipSynch":0,"motion":400}],"nameRight":"Kagome","textRight":"(I...won't lose either!)"},{"autoTurnLast":0.2,"textClear":1},{"autoTurnLast":1.0,"bg":"bg_adv_31031.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402300,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402600,"motion":1,"pos":2}],"turnChangeIn":"fadeIn","turnChangeInTime":1.0},{"bg":"bg_adv_31031.jpg","nameNarration":"","narration":"[se:3002_chara_dead]*Thud*","narrationBg":"bg_adv_31031.jpg","narrationEffect":"in","turnChangeOut":"fadeOut","turnChangeOutTime":1.0},{"bgm":"bgm22_battle17","chara":[{"id":402300}],"nameLeft":"Melissa","narrationEffect":"out","textLeft":"Haa...haa..."},{"chara":[{"id":402600},{"id":402300}],"nameRight":"Elisa","textRight":"Those dolls really gave us a hard time."},{"chara":[{"id":402600,"motion":0}],"nameRight":"Elisa","textRight":"[flashEffect:flashRed2][bgEffect:shakeLarge][chara:402600:effect_shake][chara:402600:eyeClose_1][se:3001_chara_damage]Kuh...!"},{"autoTurnLast":1.0,"bg":"black","item":[{"path":"resource/scenario/img/51158_tower_tart2/memoria_1735.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"nameNarration":"Isabeau","narration":"Oh, are you already out of breath?","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":60.0,"narrationLineSpace":20.0,"turnChangeOut":"fadeOut"},{"narration":"Don't you know that the real fun@is just getting started?"},{"narration":"Heheheh."},{"narration":"Now, come.@I'll shower you with affection."},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

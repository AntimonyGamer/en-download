{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_20103.jpg","bgm":"bgm03_story10","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402301,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":830000,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":402301,"motion":400}],"nameLeft":"Melissa","textBg":"shout","textLeft":"Father, why don't you understand?","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402301}],"nameLeft":"Melissa","textLeft":"You can gather authority under Charles's name,"},{"chara":[{"id":402301}],"nameLeft":"Melissal","textLeft":"restore peace and drive England out of France...!"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402301,"motion":200}],"nameLeft":"Melissa","textLeft":"If everyone cooperates with Marshal Richemont,"},{"chara":[{"id":402301}],"nameLeft":"Melissa","textBg":"shout","textLeft":"it will be a shortcut to peace in France!"},{"chara":[{"id":830000}],"nameRight":"La Hire","textBg":"shout","textRight":"I don't trust Charles...!"},{"chara":[{"id":830000}],"nameRight":"La Hire","textRight":"Because of his stinginess with the ransom,"},{"chara":[{"id":830000,"pos":2}],"nameRight":"La Hire","textBg":"shout","textRight":"Saint-Rémy and I were almost left to die!"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402301,"motion":1}],"nameLeft":"Melissa","textLeft":"But even so, if we start a civil war among the@French..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":830000},{"effect":"fadeout","id":402301}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_20103.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":400,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":2,"soulGem":0}],"nameLeft":"Kagome","textLeft":"[chara:102001:effect_emotion_surprise_0][se:7226_shock]What?!"},{"chara":[{"id":831303,"motion":400}],"nameRight":"Torte","textRight":"They're having a huge fight!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":810000,"pos":2,"posX":50}],"nameRight":"Qube","textRight":"Neither side seems willing to back down."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402901,"motion":300,"pos":0}],"nameLeft":"Perenelle","textLeft":"Like father, like daughter, I suppose."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831700,"motion":0,"pos":2}],"nameRight":"Nicolas","textRight":"W-what should we do...?"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402601,"motion":0,"pos":0}],"nameLeft":"Elisa","textLeft":"It will be over soon."},{"bg":"bg_adv_20103.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402301,"motion":200,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":830000,"motion":0,"pos":2}],"nameNarration":"","narration":"Bang!","narrationBg":"bg_adv_20103.jpg","narrationEffect":"in"},{"chara":[{"effect":"shake","id":830000,"lipSynch":0}],"nameRight":"La Hire","narrationEffect":"out","textRight":"..."},{"autoTurnLast":1.0,"chara":[{"effect":"fadeout","id":830000}],"se":"3002_chara_dead","textClear":1},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402301}],"textClear":1},{"bgm":"bgm03_story02","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":2,"soulGem":0}],"nameCenter":"Kagome & Torte","textCenter":"..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102001},{"effect":"fadeout","id":831303}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831700,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402901,"motion":0,"pos":0}],"nameRight":"Nicolas","textRight":"...They solved it through violence."},{"chara":[{"id":402901,"motion":300}],"nameLeft":"Perenelle","textLeft":"Was it worth talking at all...?"},{"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":402301,"motion":0,"pos":2}],"nameRight":"Melissa","textRight":"I apologize for showing you such an embarrassing@sight..."},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":830000,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"chara":[{"id":830000,"lipSynch":0}],"nameCenter":"La Hire","textCenter":"...","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":830000}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402301,"motion":300,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"nameRight":"Melissa","textRight":"...Father has forgotten about Tart."},{"chara":[{"id":402301}],"nameRight":"Melissa","textRight":"He and Sir Saint-Rémy"},{"chara":[{"id":402301}],"nameRight":"Melissa","textRight":"attacked Rouen multiple times to rescue Tart,"},{"chara":[{"id":402301}],"nameRight":"Melissa","textRight":"and it was because of that they became captives..."},{"chara":[{"id":102001,"motion":1}],"nameLeft":"Kagome","textLeft":"They truly cherished Jeanne La Pucelle,@didn't they?"},{"chara":[{"id":402301,"motion":1}],"nameRight":"Melissa","textRight":"Yes..."},{"chara":[{"id":402301}],"nameRight":"Melissa","textRight":"When Father wakes up,"},{"chara":[{"id":402301}],"nameRight":"Melissa","textRight":"Please look into his eyes, Torte."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":1,"pos":0,"soulGem":0}],"nameLeft":"Torte","textLeft":"O-okay..."},{"chara":[{"eyeClose":1,"id":402301}],"nameRight":"Melissa","textRight":"I believe he will remember then."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":402301}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_20103.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"effect":"shake","face":"mtn_ex_050.exp3.json","id":830000,"motion":0,"pos":1}],"nameCenter":"La Hire","textCenter":"...Ugh...uuuh..."},{"autoTurnLast":0.2,"chara":[{"id":830000,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":0}],"nameLeft":"Torte","textLeft":"Ah!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402301,"motion":400,"pos":0}],"nameLeft":"Melissa","textLeft":"Please..."},{"autoTurnLast":0.2,"textClear":1},{"autoTurnLast":1.3,"bg":"black","bgm":"stop","item":[{"path":"resource/scenario/img/51015_singleraid_tart/memoria_1175.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"whiteIn","turnChangeInTime":1.0,"turnEffect":"sepiaFrame"},{"bgm":"bgm03_story07","nameNarration":"La Hire","narration":"―La Hire―@...?@What is this memory?","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":10.0,"narrationLineSpace":20.0,"turnChangeOut":"whiteOut","turnChangeOutTime":1.0},{"narration":"―La Hire―@That girl...@I remember..."},{"narration":"―La Hire―@La Pucelle ...!"},{"narration":"―La Hire―@That's right...@She saved me and Melissa when we almost died..."},{"narration":"―La Hire―@And because of that,@she almost lost her life..."},{"narration":"―La Hire―@...Yes, when we last met in Rouen..."},{"narration":"―La Hire―@She sacrificed her own life for our safety."},{"autoTurnLast":1.0,"bg":"bg_adv_20091.jpg","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402100,"motion":0,"pos":1},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":831200,"live2dName":"live2d_0","motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":831200,"live2dName":"live2d_1","motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn"},{"bg":"bg_adv_20091.jpg","nameNarration":"","narration":"*Clank, clank*","narrationBg":"bg_adv_20091.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"chara":[{"id":402100,"motion":1}],"nameCenter":"Tart","narrationEffect":"out","textCenter":"I offer myself as a prisoner. "},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":831200,"live2dName":"live2d_0"},{"effect":"fadeout","id":831200,"live2dName":"live2d_1"},{"effect":"fadeout","id":402100}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402401,"motion":400,"mouthOpen":1,"pos":1}],"nameCenter":"Minou","textCenter":"Wha—?!"},{"autoTurnLast":0.25,"chara":[{"effect":"fadeout","id":402401}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":402100,"motion":100,"pos":1}],"nameCenter":"Tart","textCenter":"I am the one you hate the most, right?"},{"chara":[{"id":402100}],"nameCenter":"Tart","textCenter":"Well, I don't care what happens to me."},{"chara":[{"id":402100}],"nameCenter":"Tart","textCenter":"But in exchange..."},{"chara":[{"id":402100,"motion":200}],"nameCenter":"Tart","textCenter":"You are not to take any aggressive action against@these people."},{"autoTurnLast":2.0,"bg":"bg_adv_20103.jpg","chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":830000,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":402301,"motion":0,"pos":0}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":830000}],"nameRight":"La Hire","textRight":"...Melissa.","turnChangeOut":"fadeOut","turnChangeOutTime":0.5},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402301,"motion":400,"pos":0}],"nameLeft":"Melissa","textLeft":"...Do you remember now?"},{"chara":[{"id":830000}],"nameRight":"La Hire","textRight":"Yeah...everything."},{"chara":[{"id":830000},{"id":402301,"motion":0}],"nameRight":"La Hire","textRight":"Why did I forget about her...?"},{"chara":[{"id":830000}],"nameRight":"La Hire","textRight":"She who sacrificed herself for us, her comrades,@countless times."},{"chara":[{"id":830000}],"nameRight":"La Hire","textRight":"To the very end, she only thought about others."},{"chara":[{"id":830000}],"nameRight":"La Hire","textRight":"I was determined to rescue La Pucelle."},{"chara":[{"id":830000}],"nameRight":"La Hire","textRight":"Together with Saint-Rémy, we attacked Rouen..."},{"chara":[{"id":830000}],"nameRight":"La Hire","textRight":"But in the end, we couldn't save her..."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":830000,"lipSynch":0}],"nameRight":"La Hire","textRight":"...@..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":402301},{"effect":"fadeout","id":830000}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":831303,"motion":0,"pos":2,"soulGem":0}],"nameCenter":"Kagome & Torte","textCenter":"..."},{"chara":[{"id":102001,"lipSynch":0,"motion":300}],"nameLeft":"Kagome","textLeft":"(Everyone left behind is also grieving...)"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":830000,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402301,"motion":0,"pos":0}],"nameRight":"La Hire","textRight":"I thought I resented Charles..."},{"chara":[{"id":830000}],"nameRight":"La Hire","textRight":"Because I believed he left us to die...@But in reality..."},{"chara":[{"id":830000}],"nameRight":"La Hire","textRight":"I couldn't forgive that La Pucelle was left to die..."},{"chara":[{"id":402301,"motion":300}],"nameLeft":"Melissa","textLeft":"...Father, please listen."},{"chara":[{"id":402301}],"nameLeft":"Melissa","textLeft":"Tart stood up for the sake of France"},{"chara":[{"id":402301}],"nameLeft":"Melissa","textLeft":"because she lost her sister before her eyes."},{"autoTurnLast":1.0,"bg":"black","item":[{"path":"resource/scenario/img/51015_singleraid_tart/memoria_1171.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn","turnEffect":"sepiaFrame"},{"nameNarration":"Tart","narration":"―Tart―@I won't allow this cruelty to happen again,@to anyone.","narrationAnchor":"bottom","narrationCoverOpacity":110.0,"narrationEffect":"in","narrationFontSize":30.0,"narrationLineMargin":10.0,"narrationLineSpace":20.0,"turnChangeOut":"fadeOut"},{"narration":"―Tart―@I will become...@a Magical Girl."},{"nameNarration":"Qube","narration":"―Qube―@Okay, Tart...@What will you wish for?"},{"nameNarration":"Tart","narration":"―Tart―@The power to bring light to all of France!"},{"autoTurnLast":2.0,"bg":"bg_adv_20103.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":402301,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":830000,"motion":0,"pos":2}],"narrationEffect":"out","turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":402301,"motion":300}],"nameLeft":"Melissa","textLeft":"At that time, there was no official king,@and the country was in chaos.","turnChangeOut":"fadeOut"},{"chara":[{"id":402301}],"nameLeft":"Melissa","textLeft":"But now, Marshal Richemont supports Charles,"},{"chara":[{"id":402301}],"nameLeft":"Melissa","textLeft":"trying to restore peaceful days to France."},{"chara":[{"id":402301}],"nameLeft":"Melissa","textLeft":"That person is also trying to carry on Tart's will."},{"bgm":"stop","chara":[{"id":402301}],"nameLeft":"Melissa","textLeft":"So now, let's all work together for France..."},{"bgm":"bgm03_story05","chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":830000}],"nameRight":"La Hire","textRight":"...You've grown up, Melissa."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":402301,"motion":0,"pos":0}],"nameLeft":"Melissa","textLeft":"Huh...?"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":830000}],"nameRight":"La Hire","textRight":"Just putting away my sword won't solve everything@so easily."},{"chara":[{"id":830000}],"nameRight":"La Hire","textRight":"People are driven by emotions, you know."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":830000,"pos":2}],"nameRight":"La Hire","textRight":"But I won't forget about La Pucelle anymore..."},{"chara":[{"id":830000}],"nameRight":"La Hire","textRight":"That's right, never!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402301,"motion":400,"pos":0}],"nameLeft":"Melissa","textLeft":"Father...!"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":402601,"motion":1,"pos":2}],"nameRight":"Elisa","textRight":"Hmph..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":831303,"motion":100,"pos":0,"soulGem":0}],"nameLeft":"Torte","textLeft":"Thank goodness...!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":830000,"motion":0,"pos":2}],"nameRight":"La Hire","textRight":"By the way, little girl, you truly resemble@La Pucelle..."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":831303,"pos":0}],"nameLeft":"Torte","textLeft":"Hehe... I get told that a lot."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":830000}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":402901,"motion":100,"pos":2},{"cheek":0,"face":"mtn_ex_001.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"item":[{"path":"resource/scenario/img/51158_tower_tart2/51158_kagome_magical_pencil.png","posX":0,"posY":0,"visible":"appear","zOrder":"charaBack"}],"nameRight":"Perenelle","textRight":"...Did you manage to record it all safely, Kagome?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102001,"motion":400}],"nameLeft":"Kagome","textLeft":"Yes...!"},{"autoTurnLast":3.0,"chara":[{"effect":"fadeout","id":402901},{"effect":"fadeout","id":102001}],"flashEffect":"explosion","item":[{"path":"resource/scenario/img/51158_tower_tart2/51158_kagome_magical_pencil.png","visible":"hide"}],"se":"3205_charm","textClear":1},{"autoTurnLast":0.4,"bg":"black","bgm":"stop","item":[{"path":"resource/scenario/img/51158_tower_tart2/memoria_1733.jpg","posX":0,"posY":0,"visible":"appear"}],"turnChangeIn":"fadeIn"},{"autoTurnLast":1.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":2.0,"surround":"7023_camera"},{"autoTurnLast":1.0,"bg":"bg_adv_31031.jpg","turnChangeIn":"fadeIn"},{"autoTurnLast":1.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":3.0,"chara":[{"cheek":0,"face":"mtn_ex_02
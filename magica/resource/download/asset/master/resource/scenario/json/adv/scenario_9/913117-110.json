_104217/vo_full_913117-110-7"}],"nameAvLeft":"Homura","textAvColor":"textHomura","textAvLeft":"[fontSize:20]*Sigh*"},{"chara":[{"eyeClose":0,"id":200200,"motion":0,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-8"}],"nameAvLeft":"Homura","textAvLeft":"[fontSize:20]I knew you lied about the vision@from the start."},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":200900,"motion":0,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-9"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]Huh...?"},{"chara":[{"id":200200,"motion":200,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-10"}],"nameAvLeft":"Homura","textAvColor":"textHomura","textAvLeft":"[fontSize:20]It was either Madoka making a contract,@or you turning into a Witch..."},{"chara":[{"id":200200,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-11"}],"nameAvLeft":"Homura","textAvLeft":"[fontSize:20]Or perhaps both."},{"chara":[{"eyeClose":1,"id":200200,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-12"}],"nameAvLeft":"Homura","textAvLeft":"[fontSize:20]I already suspected as much."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200900,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-13"},{"eyeClose":0,"id":200200,"motion":0}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]Neither me or Miss Tomoe will be@turning into Witches."},{"chara":[{"id":200900,"motion":200,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-14"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]Because...Miss Kaname made@a contract to prevent that."},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_031.exp3.json","id":200900,"motion":100,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-15"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]I'm so sorry that I couldn't stop her!"},{"chara":[{"eyeClose":1,"id":200200,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-16"}],"nameAvLeft":"Homura","textAvColor":"textHomura","textAvLeft":"[fontSize:20]*Sigh*"},{"chara":[{"eyeClose":1,"id":200200,"motion":101,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-17"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":200900,"motion":0}],"nameAvLeft":"Homura","textAvLeft":"[fontSize:20]It can't be helped.@That's just how Madoka is."},{"chara":[{"eyeClose":0,"id":200200,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-18"}],"nameAvLeft":"Homura","textAvLeft":"[fontSize:20]I can't chastise her kindness."},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":200200,"motion":0,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-19"}],"nameAvLeft":"Homura","textAvLeft":"[fontSize:20]So, at the very least..."},{"chara":[{"id":200200,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-20"}],"nameAvLeft":"Homura","textAvLeft":"[fontSize:20]Let's save Mami Tomoe from@becoming a Witch."},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":200900,"pos":1}],"textAvClear":1},{"chara":[{"id":200900,"motion":400,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-21_mabayu"},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":200100,"motion":201,"pos":2,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-21_madoka"}],"nameAvCenter":"Mabayu & Madoka","textAvCenter":"[fontSize:20]Yes ma'am!","textAvColorRGB":"255255255"},{"autoTurnLast":0.3,"chara":[{"effect":"fadeout","id":200200},{"effect":"fadeout","id":200100},{"effect":"fadeout","id":200900}],"textAvClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200600,"motion":1,"pos":1,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-22"}],"nameAvCenter":"Kyoko","textAvCenter":"[fontSize:20]Still...this is a pretty bothersome situation.","textAvColor":"textKyoko"},{"autoTurnLast":0.2,"chara":[{"id":200600,"pos":0}],"textAvClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200900,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-23"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]Oh, Miss Sakura!"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":200200,"motion":0,"pos":0,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-24"}],"nameAvLeft":"Homura","textAvColor":"textHomura","textAvLeft":"[fontSize:20]She's the one that found Mami."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200900,"motion":300,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-25"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]So, um...I'm sorry."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":200600,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-26"}],"nameAvLeft":"Kyoko","textAvColor":"textKyoko","textAvLeft":"[fontSize:20]I should be the one apologizin'."},{"chara":[{"id":200600,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-27"}],"nameAvLeft":"Kyoko","textAvLeft":"[fontSize:20]Homura filled me in on the gist of it."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200600,"motion":300,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-27b"}],"nameAvLeft":"Kyoko","textAvLeft":"[fontSize:20]Sorry for accusing you of cutting out@her memory."},{"chara":[{"id":200900,"motion":0,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-28"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]No, it was only natural for you@to get angry."},{"chara":[{"id":200900,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-29"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]Manipulating people's memories@is unforgivable."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":200600,"motion":1,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-30"}],"nameAvLeft":"Kyoko","textAvColor":"textKyoko","textAvLeft":"[fontSize:20]So...does that mean you're never@doing it again?"},{"chara":[{"eyeClose":1,"id":200900,"lipSynch":0,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-31"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]......"},{"chara":[{"eyeClose":1,"id":200900,"lipSynch":1,"motion":100,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-32"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]I honestly don't know."},{"chara":[{"eyeClose":0,"id":200900,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-33"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]Maybe, if there's really no other choice..."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":200900,"motion":0,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-34"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]I think it would be my responsibility@to do it."},{"bgmFadeOut":5000,"chara":[{"id":200600,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-35"}],"nameAvLeft":"Kyoko","textAvColor":"textKyoko","textAvLeft":"[fontSize:20]...I see."},{"chara":[{"eyeClose":1,"id":200600,"motion":300,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-36"}],"nameAvLeft":"Kyoko","textAvLeft":"[fontSize:20]I guess Mami did have a proper friend@in you, huh?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200900,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-37"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]I feel really bad for forgetting@about all of it until now, though..."},{"bgm":"bgm02_anime07","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":200200,"motion":200,"pos":0,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-38"}],"nameAvLeft":"Homura","textAvColor":"textHomura","textAvLeft":"[fontSize:20]Now, let's hurry."},{"chara":[{"id":200200,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-39"}],"nameAvLeft":"Homura","textAvLeft":"[fontSize:20]Her Soul Gem won't last much longer."},{"chara":[{"id":200200,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-40"}],"nameAvLeft":"Homura","textAvLeft":"[fontSize:20]There's a chance she'll use up what remains@of her magic to prove my words wrong..."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200100,"motion":0,"pos":2,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-41"}],"nameAvRight":"Madoka","textAvColor":"textMadoka","textAvRight":"[fontSize:20]If we all try to talk to her,@I'm sure she'll..."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":200600,"motion":100,"pos":0,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-42"}],"nameAvLeft":"Kyoko","textAvColor":"textKyoko","textAvLeft":"[fontSize:20]Well, I dunno if things'll work out@that easily."},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp3.json","id":200100,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-43"}],"nameAvRight":"Madoka","textAvColor":"textMadoka","textAvRight":"[fontSize:20]Huh...?"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":200600,"voiceFullAuto":"fullvoice/section_104217/vo_full_913117-110-44"}],"nameAvLeft":"Kyoko","textAvColor":"textKyoko","textAvLeft":"[fontSize:20]Why do you think Mami is waiting@at the school?"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

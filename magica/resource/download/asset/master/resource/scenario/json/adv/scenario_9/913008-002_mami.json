,"id":200501,"motion":300,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-7"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Yet...why does my heart still feel@so heavy...?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200906,"motion":400,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-8"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]Come on, you did all you can!"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":200906,"motion":1,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-9"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]You've taught every Magical Girl@the skills they need..."},{"chara":[{"id":200906,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-10"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]Plus, with my foresight, you've beaten@all those Witches..."},{"chara":[{"eyeClose":1,"id":200501,"motion":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-11"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]...And in the end, I still get dumped."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200906,"motion":400,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-12"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]Mami?!"},{"chara":[{"eyeClose":0,"id":200501,"motion":1,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-13"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]It's not just one or two of them, either."},{"chara":[{"id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-14"},{"id":200906,"motion":0}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]I've reached out to so many girls,@and nudged them towards contracting..."},{"chara":[{"id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-15"}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]Yet, now they're all gone."},{"chara":[{"eyeClose":1,"id":200501,"motion":200,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-16"}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]Am I doing something wrong...?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200906,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-17"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]It's just a matter of compatibility."},{"chara":[{"id":200906,"motion":100,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-18"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]You know, since Magical Girls have@to accept risking their lives?"},{"chara":[{"id":200906,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-19"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]The girls that wish for the sake of other@people end up breaking down in the end."},{"chara":[{"eyeClose":0,"id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-20"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Wishing for other people..."},{"chara":[{"id":200501,"motion":100,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-21"}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]Almost all of them wished for@someone else's sake."},{"chara":[{"id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-22"},{"id":200906,"motion":1}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]Yet, I...@I only made a contract to survive."},{"chara":[{"id":200501,"motion":300,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-23"}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]Maybe I shouldn't have used my wish@on myself...?"},{"chara":[{"eyeClose":1,"id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-24"}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]The pure-hearted Magical Girls@who used their wish for others..."},{"chara":[{"eyeClose":1,"id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-25"}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]Do they not want to be around@someone selfish like me?"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200906,"motion":200,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-26"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]Aww, come on! Mami!@You know that's not it!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200906,"motion":400,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-27"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]Look! Me! I'm here!@I made a wish for myself too, y'know!"},{"chara":[{"cheek":1,"eyeClose":0,"id":200501,"motion":400,"tear":1,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-28"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Mabayu...@Thank you...!"},{"chara":[{"id":200501,"motion":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-29"}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]You're the only one who stays by my side...!"},{"bgmFadeOut":4000,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200906,"motion":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-30"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]W-whoa?! Come on Mami.@I'm the designated loner here!"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200906,"motion":100,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-31"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]...Actually, are you a little tipsy?!"},{"autoTurnFirst":1.8,"autoTurnNoDelay":1,"chara":[{"cheek":1,"face":"mtn_ex_040.exp3.json","id":200501,"motion":1,"tear":1,"voiceFull":"fullvoice/section_104213/vo_full_913008-002-32"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]I'm not tipsyyy...@*Munch Munch*"},{"chara":[{"eyeClose":1,"id":200501,"lipSynch":0}]},{"bgm":"bgm03_story01","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200906,"motion":200,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-33","voiceFullStop":"fullvoice/section_104213/vo_full_913008-002-32"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]Wait... Oh, no!@This cake...it has liqueur in it!"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200906,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-34"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]Did Aunt Sakie put too much in...?"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":200906,"motion":400,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-35"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]Okaaay, stop that fork!@That's enough cake for you today, missy!"},{"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":200501,"lipSynch":1,"motion":300,"tear":1,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-36"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]But, why...? It's so yummy...@Am I not even allowed to eat cake?"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200906,"motion":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-37"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]If you overeat from stress,@you're going to regret it later."},{"chara":[{"cheek":1,"id":200501,"motion":0,"tear":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-38"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Ah...@That's...certainly true."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":200906,"motion":100,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-39"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]I think what you need is some@kind of outlet for stress relief."},{"chara":[{"id":200906,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-40"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]Like, for me, that's watching movies."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200501,"motion":100,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-41"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Watching movies...?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200906,"motion":200,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-42"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]Oh, right. I actually happen to have@a good book that might fit the bill."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":200906,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-43"},{"id":200501,"motion":0}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]It's perfect for stress relief!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200906,"motion":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913008-002-44"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]Read it, and blow up all your worries!"},{"autoTurnLast":2.0,"deleteArmatureList":[1],"turnChangeIn":"fadeIn"}]},"version":3}

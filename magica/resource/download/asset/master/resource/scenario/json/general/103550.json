500,"motion":100}]}],"group_14":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103500,"motion":1,"pos":1,"voice":"vo_char_1035_00_21"}]},{"autoTurnFirst":4.7,"chara":[{"id":103500,"motion":0}]},{"autoTurnFirst":5.5,"chara":[{"eyeClose":1,"id":103500}]}],"group_15":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103500,"motion":300,"pos":1,"voice":"vo_char_1035_00_22"}]},{"autoTurnFirst":2.9,"chara":[{"id":103500,"motion":1}]},{"autoTurnFirst":3.6,"chara":[{"eyeClose":1,"id":103500}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":103500}]},{"autoTurnFirst":6.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":103500,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":103500,"motion":0}]}],"group_16":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103500,"motion":0,"pos":1,"voice":"vo_char_1035_00_23"}]},{"autoTurnFirst":3.6,"chara":[{"eyeClose":1,"id":103500,"motion":300}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":103500}]},{"autoTurnFirst":4.6,"chara":[{"id":103500,"motion":1}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":103500,"motion":0}]},{"autoTurnFirst":2.3,"chara":[{"id":103500,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":103500}]}],"group_17":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103550,"motion":300,"pos":1,"voice":"vo_char_1035_50_24","textHome":"Whew..."}]},{"autoTurnFirst":3.2,"chara":[{"eyeClose":0,"id":103550,"textHome":"Seems like it's going@to be hot again today."}]},{"autoTurnFirst":2.8,"chara":[{"id":103550,"motion":100,"textHome":"Let's make sure to keep hydrated,"}]},{"autoTurnFirst":4.6,"chara":[{"id":103550,"motion":1,"textHome":"sit under the shade of a tree@once in a while, and sing a song@or two while we relax."}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103550,"textHome":"Ehehe♪"}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103550,"motion":200,"pos":1,"voice":"vo_char_1035_50_25","textHome":"Hmm, still no reply..."}]},{"autoTurnFirst":4.4,"chara":[{"id":103550,"motion":1,"textHome":"Hime was so excited to get up early@and go to the beach today,"}]},{"autoTurnFirst":2.4,"chara":[{"id":103550,"motion":300,"textHome":"but she's really not@a morning person..."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103550,"textHome":"Maybe I should give her a call."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":103550,"motion":100,"pos":1,"voice":"vo_char_1035_50_26","textHome":"It's lunchtime, isn't it?"}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103550,"textHome":"I actually made sandwiches@for everyone to eat:"}]},{"autoTurnFirst":4.8,"chara":[{"id":103550,"motion":400}]},{"autoTurnFirst":3.3,"chara":[{"id":103550,"motion":200,"textHome":"some for a meal@and some for dessert."}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103550,"textHome":"Now then, would you like one?"}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":103500,"motion":100,"pos":1,"voice":"vo_char_1035_00_02"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103500,"motion":300}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103500,"motion":0}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103500,"motion":200}]}],"group_20":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":103550,"motion":300,"pos":1,"voice":"vo_char_1035_50_27","textHome":"Wow~!@How gorgeous...!"}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103550,"motion":100,"textHome":"No matter how many times I see it,@the view of the sun setting@over the ocean always moves me."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103550,"motion":1,"textHome":"I hope I never lose my ability@to appreciate the beauty of nature."}]},{"autoTurnFirst":2.8,"chara":[{"eyeClose":1,"id":103550}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103550,"motion":400,"pos":1,"voice":"vo_char_1035_50_28","textHome":"It's finally starting to cool off,@but I don't think I'll be able@to sleep just yet,"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103550,"motion":1,"textHome":"so let's have a little chat."}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103550,"motion":300,"textHome":"Would you like to hear@a fairy tale about pirates@that my sailor Papa told me?"}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":103550,"motion":200,"pos":1,"voice":"vo_char_1035_50_29","textHome":"I brought my harp so I could@play it on the beach for a bit."}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103550,"motion":300,"textHome":"Back home, I used to regularly@play outdoors to find a sound@that would harmonize with nature."}]},{"autoTurnFirst":2.5,"chara":[{"id":103550,"motion":100}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103550,"motion":400,"pos":1,"voice":"vo_char_1035_50_30","textHome":"It seems like a Witch has shown up."}]},{"autoTurnFirst":3.6,"chara":[{"id":103550,"motion":1,"textHome":"There are a lot of people on the beach,@so let's take it down quickly@before anyone gets hurt."}]},{"autoTurnFirst":2.0,"chara":[{"id":103550,"motion":200}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103550,"motion":1,"pos":1,"voice":"vo_char_1035_50_31","textHome":"I was looking in the mirror,@and my hairstyle and clothes@don't feel quite right anymore..."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":103550}]},{"autoTurnFirst":6.3,"chara":[{"id":103550,"motion":400,"textHome":"Maybe it's because I just saw a copy@of myself in the Mirrors Labyrinth@that was decidedly more stylish..."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103550,"motion":100,"pos":1,"voice":"vo_char_1035_50_32"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103550,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":103550,"motion":200}]}],"group_26":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103550,"motion":300,"pos":1,"voice":"vo_char_1035_50_33","textHome":"Urara used to busk on the beach@every day during summer vacation."}]},{"autoTurnFirst":3.9,"chara":[{"id":103550,"motion":200}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103550,"motion":1,"textHome":"Spending hours@outside in the hot sun..."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":103550}]},{"autoTurnFirst":3.0,"chara":[{"id":103550,"motion":400,"textHome":"Why, I would have collapsed..."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":7.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103550,"motion":300,"pos":1,"voice":"vo_char_1035_50_34","textHome":"Oh dear, Hagumu forgot her wallet@when she left to go shopping."}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103550,"motion":0,"textHome":"Well, Shigure went with her,@so it's alright..."}]},{"autoTurnFirst":0.9,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":103550,"motion":100,"textHome":"Wait, Shigure left@her wallet here too...?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103550}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":7.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103550,"motion":1,"pos":1,"voice":"vo_char_1035_50_35","textHome":"The Instructor and I were discussing the idea@of wearing skirts or pants when we take@a Neo-Magius group trip to the beach."}]},{"autoTurnFirst":3.2,"chara":[{"eyeClose":1,"id":103550,"motion":200,"textHome":"That way, Miyu will be able@to keep herself together."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":103550,"motion":100,"pos":1,"voice":"vo_char_1035_50_36","textHome":"Gelato, shaved ice,@and tropical juices...!"}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":103550,"motion":300,"textHome":"The summertime seaside@is full of temptations!"}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103550,"motion":0,"textHome":"Let's not waste time fretting over what@to choose and just order everything@that interests us, shall we?"}]},{"autoTurnFirst":2.7,"chara":[{"id":103550,"motion":200}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":103500,"motion":1,"pos":1,"voice":"vo_char_1035_00_03"}]}],"group_30":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103550,"motion":1,"pos":1,"voice":"vo_char_1035_50_37","textHome":"Asahi heard from one of the Tokime girls@that there's a spot by the river@that's perfect for little kids to play in."}]},{"autoTurnFirst":3.3,"chara":[{"id":103550,"motion":100,"textHome":"Perhaps I should tell@Nagisa about it next time."}]},{"autoTurnFirst":1.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103550,"textHome":"Ehehe♪"}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":3.3,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":103550,"motion":400,"pos":1,"voice":"vo_char_1035_50_38","textHome":"Mmmm! Delicious~!"}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103550,"motion":300,"textHome":"The watermelons that@Rabi's family grows are so sweet."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103550,"motion":200,"textHome":"I'm afraid I won't be able to eat@any other watermelons from now on~...!"}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103550,"motion":1,"pos":1,"voice":"vo_char_1035_50_39","textHome":"Look, those lovers on the beach must@have only recently started dating."}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103550,"motion":100,"textHome":"Every now and then, you can feel@that they're new to all of this."}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103550,"motion":300,"textHome":"...*Giggle*.@It's somewhat dazzling to me."}]},{"autoTurnFirst":1.5,"chara":[{"eyeClose":1,"id":103550}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103550,"motion":100,"pos":1,"voice":"vo_char_1035_50_40","textHome":"I can't really imagine the four of us@in Folklore of Zero playing together,"}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103550}]},{"autoTurnFirst":3.5,"chara":[{"id":103550,"motion":1,"textHome":"but it would be nice to take@a trip around the aquarium where@we used to meet up all the time."}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103550}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103550,"motion":300,"pos":1,"voice":"vo_char_1035_50_41","textHome":"La~lalala~♪"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":103550}]},{"autoTurnFirst":2.3,"chara":[{"cheek":1,"face":"mtn_ex_050.exp3.json","id":103550,"motion":400,"textHome":"...Ah!@I'm sorry;"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":103550,"motion":100,"textHome":"I just get the urge to sing@as soon as I feel free..."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103550,"motion":1,"textHome":"But since we're here,@would you like to listen to a song?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103550}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":103500,"motion":200,"pos":1,"voice":"vo_char_1035_00_42"}]},{"autoTurnFirst":2.0,"chara":[{"id":103500,"motion":200}]}],"group_36":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103500,"motion":300,"pos":1,"voice":"vo_char_1035_00_43"}]}],"group_37":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103500,"motion":200,"pos":1,"voice":"vo_char_1035_00_44"}]}],"group_38":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103500,"motion":100,"pos":1,"voice":"vo_char_1035_00_45"}]}],"group_39":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":103500,"motion":1,"pos":1,"voice":"vo_char_1035_00_46"}]}],"group_4":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103500,"motion":300,"pos":1,"voice":"vo_char_1035_00_04"}]}],"group_5":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103500,"motion":0,"pos":1,"voice":"vo_char_1035_00_05"}]},{"autoTurnFirst":2.7,"chara":[{"id":103500,"motion":200}]}],"group_6":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103500,"motion":100,"pos":1,"voice":"vo_char_1035_00_13"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103500}]}],"group_7":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103500,"motion":400,"pos":1,"voice":"vo_char_1035_00_14"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103500}]}],"group_8":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103500,"motion":1,"pos":1,"voice":"vo_char_1035_00_15"}]}],"group_9":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":103500,"motion":200,"pos":1,"voice":"vo_char_1035_00_16"}]},{"autoTurnFirst":7.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103500,"motion":1}]},{"autoTurnFirst":2.3,"chara":[{"id":103500,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103500,"motion":400}]}]},"version":3}

"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390101,"motion":100}]}],"group_13":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_014.exp3.json","id":390101,"motion":300,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_20"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390101}]},{"autoTurnFirst":4.5,"chara":[{"id":390101}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101,"motion":1}]}],"group_14":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390101,"motion":200,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_21"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":390101}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390101,"motion":300}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101,"motion":100}]}],"group_15":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390101,"motion":400,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_22"}]},{"autoTurnFirst":2.2,"chara":[{"id":390101,"motion":1}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390101}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390101}]}],"group_16":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":390101,"motion":1,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_23"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390101}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"id":390101}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390101}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390101,"motion":400}]}],"group_17":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390101,"motion":0,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_24","textHome":"We're together today too~."}]},{"autoTurnFirst":1.4,"chara":[{"cheek":1,"face":"mtn_ex_050.exp3.json","id":390101,"motion":200,"textHome":"Was it the same as yesterday?@Will it be the same tomorrow?!"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390101}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":390101,"motion":1,"textHome":"Maybe the day before yesterday too?"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390101,"textHome":"Maybe after tomorrow as well..."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101,"motion":400,"textHome":"Wait, so even today too?!"}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":390101,"motion":100,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_25","textHome":"Did you just say good morning~?"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390101,"motion":1,"textHome":"Oh, is it morning now?@I see."}]},{"autoTurnLast":0.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101,"textHome":"Wait...did I sleep?"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390101,"textHome":"What a pain."}]},{"autoTurnFirst":1.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390101,"motion":200,"textHome":"No, it isn't!@Aha! Morning!"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390101}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":390101,"motion":100,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_26","textHome":"I'm getting hungry..."}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101,"motion":400,"textHome":"Wait?! Maybe I'm full?!@Which was it?"}]},{"autoTurnLast":1.3,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390101}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101,"motion":0,"textHome":"It sucks not to know what's@inside of your tummy, doesn't it?"}]},{"autoTurnFirst":2.6,"chara":[{"eyeClose":1,"id":390101}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390101,"motion":1,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_02"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390101}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101,"motion":0}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101,"motion":200}]}],"group_20":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":390101,"motion":100,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_27","textHome":"Darkness is seeping in more and more."}]},{"autoTurnFirst":2.3,"chara":[{"id":390101,"motion":1,"textHome":"When I'm alone, it feels like@I'm melting away. You know?"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390101}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390101,"motion":300,"textHome":"So I'm getting rid of bad guys."}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":390101,"motion":400,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_28","textHome":"Did you just say good evening...?"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101,"textHome":"Isn't good evening a signal@of the end of the day?!"}]},{"autoTurnFirst":4.3,"chara":[{"eyeClose":1,"id":390101,"motion":1,"textHome":"If we keep saying good evening,@can we stop tomorrow from coming...?"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390101}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101,"motion":100}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":390101,"motion":200,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_29","textHome":"Sorry! I..."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":390101,"textHome":"What was I thinking about?"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101,"motion":0,"textHome":"Do you know?@Can you tell me?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390101,"textHome":"What a pain, what a pain."}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101,"motion":400,"textHome":"Oh?@What was bothering me?"}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390101,"motion":0,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_30","textHome":"Do I really need magic@to get rid of Witches?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390101,"motion":100,"textHome":"I can just stab them."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390101,"motion":1,"textHome":"Let's do it together!"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101,"textHome":"It'll be okay, probably."}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390101,"motion":400,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_31","textHome":"If I go to the Endless Mirrors,@will I be able to meet myself?"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101,"motion":200,"textHome":"I am not me!@I can meet me!@Where...am I?"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390101,"motion":100,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_32","textHome":"Wow!@So many nice smells!"}]},{"autoTurnFirst":0.9,"chara":[{"id":390101,"motion":1,"textHome":"They're coming from here and there!"}]},{"autoTurnFirst":1.4,"chara":[{"eyeClose":1,"id":390101}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390101}]},{"autoTurnFirst":1.7,"chara":[{"id":390101}]},{"autoTurnFirst":3.3,"chara":[{"id":390101,"motion":400,"textHome":"I want to take them all for myself!"}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_26":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390101,"motion":300,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_33","textHome":"When I see a lovely neck,@I get all shivery and tingly..."}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":1,"id":390101}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390101}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101,"textHome":"It reminds me that I am Yuu."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":390101,"motion":0,"textHome":"But I can't go anywhere as Yuu."}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390101,"motion":1,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_34","textHome":"There's a smell I like.@I can't remember it,@but I'm sure it's my favorite smell..."}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390101}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":390101,"motion":100,"textHome":"I love it.@I want to have it all for myself."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390101}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":390101,"motion":200,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_35","textHome":"Magical Girls have to@get rid of bad things, right?"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101,"motion":1,"textHome":"And since I get rid of the bad guys@on my list, I'm a Magical Girl!"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390101}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390101,"motion":0,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_36","textHome":"Legs, arms...@Why not just rip them off@if they get worn out?"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":390101}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":390101,"textHome":"New ones will grow back,@so it's okay!"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390101}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_014.exp3.json","id":390101,"motion":100,"textHome":"Want me to help?"}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":390101,"motion":300,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_03"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390101}]},{"autoTurnFirst":3.4,"chara":[{"id":390101}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390101,"motion":400}]}],"group_30":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":390101,"motion":300,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_37","textHome":"Nagisa helps with my job."}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":390101,"textHome":"She's really kind..."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390101}]},{"autoTurnFirst":5.0,"chara":[{"id":390101,"motion":100,"textHome":"I want to help her too..."}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":390101,"motion":200,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_38","textHome":"Once the bad guys are gone,@Shii will feel relieved."}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390101,"motion":1,"textHome":"So I have to get rid of bad guys."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390101,"textHome":"Hehe!@I'll keep doing it more and more."}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":390101,"motion":400,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_39","textHome":"I got this from Shii."}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390101,"textHome":"It's my list!"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":390101,"textHome":"It has a meaning."}]},{"autoTurnFirst":3.0,"chara":[{"id":390101,"motion":0,"textHome":"That's why I decided to follow it."}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390101,"motion":100,"textHome":"I want to give her what she wants."}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":390101,"motion":1,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_40","textHome":"No matter how many times time rewinds,@I'll do the same things!"}]},{"autoTurnFirst":2.2,"chara":[{"eyeClose":1,"id":390101,"textHome":"I don't want to pretend that@any failure or sadness was a lie!"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390101}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":390101,"motion":200}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":390101,"motion":0,"mouthOpen":0,"pos":1,"tear":0,"voice":"vo_char_3901_01_41","textHome":"No matter how many times I'm reborn,"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":390101}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":390101,"textHome":"once I meet you,@my life...ends..."}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":390101}]},{"chara":[{"id":390101,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":390101,"motion":0,"mouthOpen":0,"pos":1,"tear":0,"
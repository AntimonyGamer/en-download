:[{"eyeClose":1,"id":104301,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"..."},{"chara":[{"eyeClose":1,"id":104301,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"(I'm scared...)"},{"chara":[{"eyeClose":0,"id":104301,"lipSynch":0,"motion":0}],"nameCenter":"Kuroe","textCenter":"(But... Tamaki-san wouldn't run away,@would she...?)"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp3.json","id":104301,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"..."},{"chara":[{"eyeClose":0,"id":104301,"lipSynch":1,"motion":400}],"nameCenter":"Kuroe","textCenter":"...I-I'll go after him...!"},{"autoTurnLast":0.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":104301,"motion":0,"pos":1}],"turnChangeIn":"rollInFast","turnEffect":"stop"},{"autoTurnLast":0.1,"turnChangeOut":"rollOutFast"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":104301,"lipSynch":0}],"nameCenter":"Kuroe","textCenter":"[se:7201_detect_magic][chara:104301:effect_ef_adv_01]*Gasp*?!"},{"autoTurnLast":0.2,"chara":[{"id":104301,"pos":2}],"textClear":1},{"autoTurnLast":1.5,"item":[{"path":"resource/scenario/img/6103_zenobia_emblem.png","posX":0,"posY":120,"visible":"appear"}],"turnEffect":"ef_adv_06"},{"chara":[{"id":104301,"lipSynch":0}],"nameRight":"Kuroe","textRight":"(A Witch...! So there really was one around!)"},{"chara":[{"id":104301,"lipSynch":0,"motion":100}],"nameRight":"Kuroe","textRight":"(...I wonder if that's what that guy was running@from?)"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":104301,"lipSynch":0}],"nameRight":"Kuroe","textRight":"(I don't want to think about it, but maybe@it's responsible for that smell, too?)"},{"autoTurnLast":1.5,"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_020.exp3.json","id":104300,"motion":0,"pos":2}],"se":"7205_magic_girl","textClear":1},{"chara":[{"id":104300,"lipSynch":0,"motion":200}],"nameRight":"Kuroe","textRight":"(I've got to take it down before it causes any@more casualties...!)"},{"autoTurnLast":0.2,"bgm":"sto
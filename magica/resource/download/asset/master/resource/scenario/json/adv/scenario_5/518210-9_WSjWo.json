","id":831303,"motion":400,"pos":2,"soulGem":0}],"nameCenter":"Kagome & Torte","textCenter":"[chara:102001:effect_emotion_surprise_0][chara:831303:effect_emotion_surprise_0][se:7226_shock]...?!"},{"chara":[{"id":102001,"motion":300}],"nameLeft":"Kagome","textLeft":"Does he think...you are Miss Jeanne?"},{"chara":[{"id":831303,"motion":1}],"nameRight":"Torte","textRight":"But that means...he remembers La Pucelle, right?"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":1,"pos":0}],"nameLeft":"Kagome","textLeft":"Even though he hasn't seen Torte's eyes yet...?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":831303},{"effect":"fadeout","id":102001}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":830100,"motion":0,"pos":1}],"nameCenter":"Gilles de Rais","textCenter":"My Saint and her companion."},{"chara":[{"id":830100}],"nameCenter":"Gilles de Rais","textCenter":"Please accept my hospitality...!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":830100}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":400,"pos":2,"soulGem":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"nameRight":"Torte","textRight":"Eh, Sir Gilles de Rais...?"},{"chara":[{"id":102001,"motion":300}],"nameLeft":"Kagome","textLeft":"Ah...I think I heard the name earlier."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":831303,"motion":100,"pos":2}],"nameRight":"Torte","textRight":"Yeah, he fought alongside La Pucelle to liberate@Orleans."},{"chara":[{"id":831303}],"nameRight":"Torte","textRight":"He's a nobleman from France!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102001},{"effect":"fadeout","id":831303}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":830100,"motion":0,"pos":1}],"nameCenter":"Gilles de Rais","textCenter":"The Battle of Orleans...@Oh, how nostalgic."},{"chara":[{"id":830100}],"nameCenter":"Gilles de Rais","textCenter":"It has been 10 years...no, even more than that..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":830100}],"textClear":1},{"autoTurnLast":0.01,"bg":"bg_adv_20091.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":831303,"motion":0,"pos":2,"soulGem":0},{"cheek":0,"face":"mtn_ex_040.exp3.json","id":102001,"motion":0,"pos":0,"soulGem":0}],"nameRight":"Torte","textRight":"Oh... This feels, a bit weird?"},{"chara":[{"id":102001,"motion":300}],"nameLeft":"Kagome","textLeft":"Yeah... It doesn't feel like we can have a proper@conversation with him... Perhaps..."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":830100,"motion":0,"pos":0}],"nameLeft":"Gilles de Rais","textLeft":"I have longed for this moment, my Saint.@Come, to my mansion..."},{"autoTurnLast":1.0,"bgm":"stop","turnChangeIn":"fadeIn"},{"bg":"bg_adv_20091.jpg","nameNarration":"","narration":"[se:7107_arrivalone]*Swoosh*","narrationBg":"bg_adv_20091.jpg","narrationEffect":"in","turnChangeOut":"fadeOut"},{"nameCenter":"???'s Voice","narrationEffect":"out","textCenter":"Did you see that just now?"},{"nameCenter":"???'s Voice","textCenter":"...Yes."},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

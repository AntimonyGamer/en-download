{"story":{"group_1":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_01"}]},{"autoTurnFirst":5.7,"chara":[{"id":103300,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"id":103300,"motion":300}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":2.2,"chara":[{"id":103300}]},{"autoTurnFirst":3.7,"chara":[{"id":103300,"motion":1}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":0}]},{"autoTurnFirst":4.0,"chara":[{"id":103300,"motion":400}]}],"group_10":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103300,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1033_00_17"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":7.0,"chara":[{"id":103300,"motion":1}]},{"autoTurnFirst":6.5,"chara":[{"cheek":1,"face":"mtn_ex_031.exp3.json","id":103300,"motion":300}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103300}]}],"group_11":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1033_00_18"}]},{"autoTurnFirst":1.2,"chara":[{"eyeClose":1,"id":103300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":300}]},{"autoTurnFirst":5.2,"chara":[{"eyeClose":1,"id":103300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":4.0,"chara":[{"id":103300,"motion":0}]}],"group_12":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_032.exp3.json","id":103300,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1033_00_19"}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_031.exp3.json","id":103300}]}],"group_13":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_033.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_20"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":4.0,"chara":[{"id":103300,"motion":200}]}],"group_14":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_032.exp3.json","id":103300,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_00_21"}]},{"autoTurnFirst":5.3,"chara":[{"id":103300,"motion":300}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":1}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":103300,"motion":400}]}],"group_15":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_033.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_22"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":5.0,"chara":[{"id":103300}]},{"autoTurnFirst":6.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":0}]},{"autoTurnFirst":7.7,"chara":[{"cheek":0,"face":"mtn_ex_031.exp3.json","id":103300,"motion":300}]}],"group_16":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_00_23"}]},{"autoTurnFirst":4.2,"chara":[{"id":103300,"motion":200}]},{"autoTurnFirst":4.8,"chara":[{"eyeClose":1,"id":103300,"motion":1}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"id":103300,"motion":100}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_031.exp3.json","id":103300,"motion":300}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_033.exp3.json","id":103300,"motion":0}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":3.5,"chara":[{"id":103300}]}],"group_17":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103350,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1033_50_24","textHome":"Trick or treat."}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103350,"motion":1,"textHome":"I thought I could join@this side occasionally."}]},{"autoTurnFirst":2.8,"chara":[{"id":103350,"motion":300,"textHome":"And for tricks...@I'm not planning anything."}]},{"autoTurnFirst":3.0,"chara":[{"id":103350,"motion":0,"textHome":"Do you have any wishes?"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":103350,"textHome":"Not that I'm asking."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":7.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103350,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_50_25","textHome":"I had some leftovers from what@I bought, so I made pumpkin miso soup@for breakfast... Do you want some?"}]},{"autoTurnFirst":3.6,"chara":[{"id":103350,"motion":300,"textHome":"It's nutritious, so it should be@suitable for breakfast."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103350,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1033_50_26","textHome":"For lunch...@Halloween candies might be fine."}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103350,"motion":400,"textHome":"No, they might lead to@a nutritional imbalance..."}]},{"autoTurnFirst":2.5,"chara":[{"id":103350,"motion":0,"textHome":"I can't afford to be careless@with my meals when I'm by myself."}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":103350}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_00_02"}]},{"autoTurnFirst":3.1,"chara":[{"id":103300,"motion":100}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":300}]},{"autoTurnFirst":4.3,"chara":[{"eyeClose":1,"id":103300}]}],"group_20":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103350,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_50_27","textHome":"They say that ghosts come out@on Halloween, so it's better@to go home before it gets dark..."}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103350,"textHome":"Well, that's what I told Mikage@to get her to leave."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103350,"motion":300,"textHome":"But it was Nayuta@who got scared and left."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103350,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1033_50_28","textHome":"As winter approaches,@the stars become more visible."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103350,"motion":0,"textHome":"They say that autumn nights are long,"}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103350,"motion":100,"textHome":"but when I gaze at the quiet@starry sky, it feels like@this moment could last forever."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103350,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1033_50_29","textHome":"Dressing up and eating sweets@is a departure from the@original Halloween tradition."}]},{"autoTurnFirst":4.2,"chara":[{"id":103350,"motion":1,"textHome":"That's why I avoided doing it."}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103350,"textHome":"But it might also be a nice and@lively way to spend Halloween."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103350,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_50_30","textHome":"Just because the dead return@during Halloween doesn't mean@we can let Witches go free."}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103350,"motion":200,"textHome":"As long as they harm the living,@we must defeat them."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103350,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1033_50_31","textHome":"During this time,@there are many overly excited@Magical Girls in Endless Mirrors."}]},{"autoTurnFirst":2.3,"chara":[{"id":103350,"motion":0,"textHome":"That is fine and all,"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103350,"motion":300,"textHome":"but things like costumes that make@them look injured can be confusing."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp3.json","id":103350,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1033_50_32","textHome":"A costume contest..."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103350,"motion":0,"textHome":"In that case, I'll have@Nayuta and Mikage participate."}]},{"autoTurnFirst":3.5,"chara":[{"id":103350,"motion":200,"textHome":"They should win."}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":103350,"motion":1,"textHome":"However...if Urara will@also be participating,@it might be a close call."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_26":[{"autoTurnFirst":5.7,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103350,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_50_33","textHome":"I'm not dressing up@just to collect rewards."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":103350,"motion":300,"textHome":"So, I'd appreciate it if you@didn't stare at me too much."}]},{"autoTurnFirst":4.5,"chara":[{"eyeClose":1,"id":103350,"textHome":"I'm not used to this outfit...@Ugh..."}]},{"autoTurnFirst":1.8,"chara":[{"id":103350,"motion":200,"textHome":"It's embarrassing."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103350,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_50_34","textHome":"*Sigh*"}]},{"autoTurnFirst":5.8,"chara":[{"eyeClose":0,"id":103350,"textHome":"Whether it's making or distributing candy,@Halloween is a busy time."}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103350,"motion":400,"textHome":"Those who enjoy eating them@scream with joy."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103350,"motion":300,"textHome":"It's very exhausting."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103350,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1033_50_35","textHome":"Do you like candies?@I don't have a lot left, but..."}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103350}]},{"autoTurnFirst":6.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103350,"motion":1,"textHome":"I am very proud of them,@so I'd like you to try them."}]},{"autoTurnFirst":3.0,"chara":[{"id":103350,"motion":200,"textHome":"What do you think?"}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103350,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_50_36","textHome":"If you can't give me treats,@I'll play a trick on you... "}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":103350,"textHome":"Now then..."}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":103350,"textHome":"Coochy-coo..."}]},{"autoTurnFirst":2.2,"chara":[{"id":103350,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_051.exp3.json","id":103350,"motion":400,"textHome":"Oh?@I asked Mikage how to do it,@so why isn't it...?"}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103350,"motion":0,"textHome":"I must not be doing this right."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103300,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_00_03"}]},{"autoTurnFirst":3.0,"chara":[{"id":103300,"motion":200}]}],"group_30":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp3.json","id":103350,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_50_37","textHome":"Huh?@Miss Ooba is eating..."}]},{"autoTurnFirst":3.4,"chara":[{"id":103350,"motion":400,"textHome":"...the candies I made for Nayuta?"}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103350,"motion":300,"textHome":"*Sigh*..."}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":0,"id":103350,"textHome":"Maybe these bad habits@are one of the reasons why@Miss Kureha gets angry with her."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103350,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1033_50_38","textHome":"When I gave candy to Urara,"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103350,"textHome":"I was scolded by Asahi and@the others for spoiling her."}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":103350,"motion":300,"textHome":"It's true that I'm sweet@to younger kids,"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":0,"id":103350,"textHome":"but it's not to the extent@of being pointed out..."}]},{"autoTurnFirst":1.3,"chara":[{"id":103350,"motion":0,"textHome":"What do you think?"}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103350,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1033_50_39","textHome":"For the next Halloween, I'll have@Nayuta, Mikage, and even Sasha dress up."}]},{"autoTurnFirst":4.3,"chara":[{"id":103350,"motion":100}]},{"autoTurnFirst":3.2,"chara":[{"id":103350,"motion":300,"textHome":"I have changed so much that now@I am making plans for next year..."}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":1,"id":103350}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103350,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_50_40","textHome":"Supposing there is@a world of the dead,"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":103350,"textHome":"if I were to meet her@beneath the stars and@talk about my current daily life..."}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":103350}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103350,"motion":100,"textHome":"Hehe, she'd probably be surprised."}]},{"autoTurnFirst":3.8,"chara":[{"eyeClose":0,"id":103350}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":1.5,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_051.exp3.json","id":103350,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1033_50_41","textHome":"Ah!"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103350,"motion":300,"textHome":"Oh, you startled me.@I just heard a ghost story,"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":103350,"textHome":"and you suddenly approached me@from behind."}]},{"autoTurnFirst":3.3,"chara":[{"id":103350,"motion":0,"textHome":"I don't usually get this surprised,"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103350,"textHome":"but the atmosphere@made it quite effective."}]},{"chara":[{"id":103350,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103300,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1033_00_42"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103300,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1033_00_43"}]}],"group_37":[{"autoTurnFirst":1.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_44"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103300}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1033_00_45"}]}],"group_39":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_033.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_46"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":2.5,"chara":[{"id":103300}]}],"group_4":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_04"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103300}]}],"group_5":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103300,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1033_00_05"}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":103300}]}],"group_6":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_033.exp3.json","id":103300,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1033_00_13"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_032.exp3.json","id":103300}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_023.exp3.json","id":103300,"motion":200}]}],"group_7":[{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1033_00_14"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":103300,"motion":300}]}],"group_8":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_033.exp3.json","id":103300,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1033_00_15"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_032.exp3.json","id":103300}]}],"group_9":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103300,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1033_00_16"}]},{"autoTurnFirst":1.8,"chara":[{"eyeClose":1,"id":103300}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103300}]},{"autoTurnFirst":4.5,"chara":[{"id":103300,"motion":100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103300,"motion":200}]},{"autoTurnFirst":3.1,"chara":[{"id":103300,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103300}]}]},"version":3}

0,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1201_00_21"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":120100}]}],"group_15":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":120100,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1201_00_22"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":120100,"motion":100}]},{"autoTurnFirst":6.9,"chara":[{"id":120100,"motion":1}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":0}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":120100}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":120100,"motion":401}]}],"group_16":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1201_00_23"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":120100,"motion":100}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":120100,"motion":200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":1}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":120100}]}],"group_17":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":120100,"motion":300,"pos":1,"tear":0,"voice":"vo_char_1201_50_24","textHome":"Why am I an idol..."}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":120100,"motion":400,"textHome":"*Gasp*!@I'm sorry, I didn't notice you!"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":1,"textHome":"Err, I'm Iroha Tamaki!"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":120100,"motion":100,"textHome":"I know I'm a newbie,@but I'd appreciate your support!"}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":120100,"motion":401,"pos":1,"tear":0,"voice":"vo_char_1201_50_25","textHome":"Good morning!"}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":120100,"textHome":"Madoka-senpai..."}]},{"autoTurnFirst":2.6,"chara":[{"id":120100,"motion":1,"textHome":"Er, the producer has called for me..."}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":120100,"motion":300,"textHome":"I wonder what she's going to@make me do at this hour..."}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1201_50_26","textHome":"Look at this!"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":120100,"motion":201,"textHome":"They provided me with lunch!"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":1,"textHome":"It's just a regular bento,@but it gives the feeling@of being in the industry..."}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":120100,"motion":100,"textHome":"Hehehe♪"}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1201_00_02"}]},{"autoTurnFirst":2.1,"chara":[{"id":120100,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":120100}]}],"group_20":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1201_50_27","textHome":"If you aim to be an idol,@you can't rest!"}]},{"autoTurnFirst":6.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":120100,"motion":300,"textHome":"They say being the top idol is harder@than defeating Walpurgisnacht."}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1201_50_28","textHome":"I heard there's a law that junior high@school students can't work at this time,"}]},{"autoTurnFirst":5.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":120100,"motion":0,"textHome":"b-but the producer said it's ok,@so there should be no problem!"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":120100,"motion":300,"textHome":"...Right?"}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1201_50_29","textHome":"Practicing is hard work,@but it's fun to work together@to put on a show on stage!"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":120100,"motion":101}]},{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":120100,"motion":300,"textHome":"I haven't had much experience@working together like this before."}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":201,"pos":1,"tear":0,"voice":"vo_char_1201_50_30","textHome":"It's an idol's job to make everyone smile!"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":120100,"motion":200,"textHome":"Defeat Witches and everyone will smile!"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":120100,"motion":101,"textHome":"In other words,@it's an idol's job to defeat Witches!"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":120100,"textHome":"Let's go!"}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":120100,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1201_50_31","textHome":"We don't have an idol version@of the paper sumo ready."}]},{"autoTurnFirst":3.4,"chara":[{"id":120100,"motion":300,"textHome":"Madoka-senpai said@there wasn't enough budget."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":120100,"textHome":"What a cruel world..."}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":120100,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1201_50_32","textHome":"So many Magical Girls..."}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":120100,"motion":201,"textHome":"This is our chance to spread@the name of Kamiha☆Magica!"}]},{"autoTurnFirst":3.2,"chara":[{"id":120100,"motion":101,"textHome":"Let's charge in with@the Entertainment Cavalry!"}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_26":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":120100,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1201_50_33","textHome":"I'll do some gacha pulls with@the money I got from everyone..."}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":120100,"motion":400,"textHome":"*Gasp*!@Just kidding!@I wasn't actually considering it..."}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":120100,"motion":200,"textHome":"Okay, maybe just a little!"}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":120100,"motion":101,"pos":1,"tear":0,"voice":"vo_char_1201_50_34","textHome":"Ehehe♪@I'm Iroha Tamaki!"}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":120100,"textHome":"...Ah.@Did you see that?"}]},{"autoTurnFirst":2.0,"chara":[{"id":120100,"motion":201}]},{"autoTurnFirst":5.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":120100,"textHome":"I heard that idols always@have a beautiful smile, so..."}]},{"autoTurnFirst":2.0,"chara":[{"id":120100,"motion":200,"textHome":"I've been practicing mine...!"}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":120100,"motion":100,"pos":1,"tear":1,"voice":"vo_char_1201_50_35","textHome":"Please help me!"}]},{"autoTurnFirst":5.6,"chara":[{"id":120100,"motion":0,"textHome":"I heard that you can watch@Kamiha☆Magica videos@on your smartphone..."}]},{"autoTurnFirst":3.3,"chara":[{"id":120100,"motion":300,"textHome":"But I don't know how..."}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1201_50_36","textHome":"No matter how hard I work,@I only get support points..."}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_023.exp.json","id":120100,"motion":1,"textHome":"That's weird.@Someone must be..."}]},{"autoTurnFirst":0.8,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":120100,"motion":400,"textHome":"No, no matter how greedy she is,@I can't suspect Madoka-senpai..!"}]},{"autoTurnFirst":5.4,"chara":[{"id":120100,"motion":100}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1201_00_03"}]}],"group_30":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1201_50_37","textHome":"Rena-chan is amazing,@she puts all her energy@into her idol activities!"}]},{"autoTurnFirst":2.8,"chara":[{"eyeClose":1,"id":120100}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":120100}]},{"autoTurnFirst":7.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":120100,"motion":300,"textHome":"But I can't imitate her throwing up,@doing bridges, or fighting crocodiles..."}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":120100,"motion":201,"pos":1,"tear":0,"voice":"vo_char_1201_50_38","textHome":"I'm not Eroha-chan!@I'm Iroha!"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":120100,"motion":200,"textHome":"I'm a wholesome idol who's moved on@from weird variety nonsense!"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_023.exp.json","id":120100,"textHome":"And I'm not letting anyone say otherwise!"}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":201,"pos":1,"tear":0,"voice":"vo_char_1201_50_39","textHome":"I know it's a long shot,@but I still want to aim for@the top of the idol world."}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":120100,"motion":300,"textHome":"Hm, if I can get the Kamihama Magia Union@to help out, I might just be able to win@through sheer numbers..."}]},{"autoTurnFirst":2.1,"chara":[{"eyeClose":1,"id":120100}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":120100,"motion":201,"pos":1,"tear":0,"voice":"vo_char_1201_50_40","textHome":"Idols are amazing.@They can make everyone smile."}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":0,"textHome":"I was surprised when Madoka-senpai@said she would be our producer,"}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":1,"id":120100,"motion":300,"textHome":"but now I'm glad she did."}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":101,"pos":1,"tear":0,"voice":"vo_char_1201_50_41","textHome":"I'm Iroha Tamaki, the pink one of@Kamihama's idol unit, Kamiha☆Magica!"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":120100}]},{"autoTurnFirst":3.0,"chara":[{"id":120100,"motion":0,"textHome":"I may not know much about idols,@but I'll be in your care!"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":120100,"motion":401}]},{"chara":[{"id":120150,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":120100,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1201_00_42"}]},{"autoTurnFirst":2.0,"chara":[{"id":120100,"motion":401}]}],"group_36":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1201_00_43"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":120100}]}],"group_37":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":120100,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1201_00_44"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":100}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1201_00_45"}]}],"group_39":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":120100,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1201_00_46"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":120100,"motion":300}]}],"group_4":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":120100,"motion":200,"pos":1,"tear":0,"voice":"vo_char_1201_00_04"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":401}]}],"group_40":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":120100,"motion":401,"pos":1,"tear":0,"voice":"vo_char_1201_00_63"}]}],"group_41":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":120100,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1201_00_64"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":120100}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":120100}]}],"group_42":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":120100,"motion":400,"pos":1,"tear":0,"voice":"vo_char_1201_00_65"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":120100,"motion":300}]}],"group_43":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":120100,"motion":401,"pos":1,"tear":0,"voice":"vo_char_1201_00_66"}]}],"group_5":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":120100,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1201_00_05"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":120100,"motion":201}]}],"group_6":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1201_00_13"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":120100,"motion":200}]}],"group_7":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":120100,"motion":100,"pos":1,"tear":0,"voice":"vo_char_1201_00_14"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":120100,"motion":400}]}],"group_8":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":120100,"motion":0,"pos":1,"tear":0,"voice":"vo_char_1201_00_15"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":100}]}],"group_9":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":120100,"motion":1,"pos":1,"tear":0,"voice":"vo_char_1201_00_16"}]},{"autoTurnFirst":2.1,"chara":[{"id":120100,"motion":200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":120100,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":120100,"motion":300}]}]},"version":3}

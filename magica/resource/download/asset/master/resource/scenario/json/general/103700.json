{"story":{"group_1":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":1,"pos":1,"voice":"vo_char_1037_00_01","textHome":"I've just moved to Kamihama recently.@The name is Nayuta Satomi."}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103700}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":0,"textHome":"My father told me to come here,"}]},{"autoTurnFirst":4.7,"chara":[{"id":103700,"motion":300,"textHome":"but more importantly,@he is currently missing."}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103700,"motion":100,"textHome":"Oh, if you know anything about him,@please do tell!"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":103700}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":200,"textHome":"He's Tasuke Satomi, a folklorist who@is doing research about Magical Girls."}]},{"autoTurnFirst":5.0,"chara":[{"id":103700,"motion":1}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":5.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103700,"motion":400,"pos":1,"voice":"vo_char_1037_00_17","textHome":"The problems regarding Magical Girls@have to be taken care of@as soon as possible."}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103700,"textHome":"Otherwise, Papa won't even@have time for romance."}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":103700,"motion":200}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":100,"textHome":"That's why I am doing my best."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":1,"pos":1,"voice":"vo_char_1037_00_18","textHome":"Sometimes, Mama and Papa@appear in my dreams,"}]},{"autoTurnFirst":4.6,"chara":[{"eyeClose":1,"id":103700,"textHome":"along with memories of my childhood."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103700}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":103700,"motion":300,"textHome":"I can't go back@to that time again, though."}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":103700,"textHome":"It's for the best@for the three of us."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103700,"motion":200,"pos":1,"voice":"vo_char_1037_00_19","textHome":"A world inside a spinning fan@is a deadly place for all enemies."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103700,"motion":100,"pos":1,"voice":"vo_char_1037_00_20","textHome":"Is being strong and happy@a good thing...?"}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103700,"motion":0,"pos":1,"voice":"vo_char_1037_00_21","textHome":"I feel like I can sense@my magic more easily now,@as if the surroundings are clearer."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":103700,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":103700,"textHome":"If so, this will be@a piece of cake for Papa..."}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103700,"motion":300,"textHome":"But wait,@he isn't a Magical Girl...!"}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":103700,"motion":1,"pos":1,"voice":"vo_char_1037_00_22","textHome":"Magical Girls can definitely be saved,@they will be."}]},{"autoTurnFirst":3.2,"chara":[{"eyeClose":0,"id":103700}]},{"autoTurnFirst":1.3,"chara":[{"id":103700,"motion":200,"textHome":"I'm working as hard as I can with@Papa in order to achieve that goal."}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103700}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":103700,"motion":400,"textHome":"It's never been wrong for us to hope."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103700}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":100,"textHome":"I'm sure there'll be a way@to save every one of them!"}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":100,"pos":1,"voice":"vo_char_1037_00_23"}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":103700}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103700}]},{"autoTurnFirst":6.8,"chara":[{"id":103700,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":300}]}],"group_17":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":103700,"motion":100,"pos":1,"voice":"vo_char_1037_00_24","textHome":"Ah!@Rabi, you've come back already?"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":103700,"motion":0,"textHome":"Oh, sorry, I was mistaken..."}]},{"autoTurnFirst":3.4,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":103700,"motion":1,"textHome":"It's just, I heard that she'd@make my favorite dish today,@so I got too excited..."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103700}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103700}]},{"autoTurnFirst":4.0,"chara":[{"id":103700,"motion":300,"textHome":"I do apologize for that..."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":5.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":300,"pos":1,"voice":"vo_char_1037_00_25","textHome":"Ugh...@My hair is always frizzing,@even after applying hairspray..."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":103700,"motion":0}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":200,"textHome":"Mmmgh...@It's no good..."}]},{"autoTurnFirst":1.4,"chara":[{"eyeClose":1,"id":103700}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103700}]},{"autoTurnFirst":5.0,"chara":[{"id":103700,"motion":0,"textHome":"I don't have much time,@so I'll just go out with this."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":1,"pos":1,"voice":"vo_char_1037_00_26","textHome":"Rabi makes lunch for me every day."}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103700,"textHome":"Today's side dish is..."}]},{"autoTurnFirst":3.4,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":103700,"motion":100,"textHome":"Ah, it's leftovers from last night!"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":103700,"textHome":"I've been wanting@to have them again~!"}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":100,"pos":1,"voice":"vo_char_1037_00_02","textHome":"I'm Nayuta Satomi.@Yes,"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":1,"textHome":"as you can see@from my last name Satomi,"}]},{"autoTurnFirst":2.8,"chara":[{"eyeClose":1,"id":103700,"textHome":"I'm...a relative of Touka."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103700}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":400,"textHome":"I'm also the daughter of the author of@\"Magical Girls: Their Hope and Despair\",@Tasuke Satomi."}]},{"autoTurnFirst":5.0,"chara":[{"id":103700,"motion":200}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103700,"motion":100,"pos":1,"voice":"vo_char_1037_00_27","textHome":"It's dinnertime before I know it."}]},{"autoTurnFirst":4.8,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":103700,"motion":1,"textHome":"Whenever I study,@I lose track of time."}]},{"autoTurnFirst":8.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":103700,"motion":200,"textHome":"Hehe, seems like@it runs in the family."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":3.4,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103700,"motion":400,"pos":1,"voice":"vo_char_1037_00_28","textHome":"Allow me to say this@before you laugh at me."}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":103700,"motion":1,"textHome":"According to folklore, gods dwell in@mundane objects, so sleeping with@a stuffed animal is considered sacred!"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103700}]},{"autoTurnFirst":4.0,"chara":[{"id":103700,"motion":200}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":5.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103700,"motion":1,"pos":1,"voice":"vo_char_1037_00_29","textHome":"Rabi doesn't seem to mind@if I'm bored or not."}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":100,"textHome":"I'll help her with the chores,@I just hope she's alright with@spending time with me once in a while."}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":103700}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103700,"motion":0,"pos":1,"voice":"vo_char_1037_00_30","textHome":"Don't underestimate me@just because I only do research."}]},{"autoTurnFirst":2.8,"chara":[{"id":103700,"motion":400}]},{"autoTurnFirst":4.4,"chara":[{"eyeClose":1,"id":103700,"motion":200,"textHome":"I've been researching@Magical Girls for years..."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103700}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103700,"textHome":"and I'm perfectly@capable of fighting."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":5.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103700,"motion":100,"pos":1,"voice":"vo_char_1037_00_31","textHome":"Are there fake Magical Girls@in Endless Mirrors?"}]},{"autoTurnFirst":3.9,"chara":[{"id":103700,"motion":0,"textHome":"If so...will there be@a fake Touka as well?"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":103700,"motion":200,"textHome":"That's..."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103700}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103700,"textHome":"...quite exciting.@I won't hold back..."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103700,"textHome":"Hehe♪"}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":5.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":1,"pos":1,"voice":"vo_char_1037_00_32"}]},{"autoTurnFirst":4.4,"chara":[{"id":103700,"motion":300}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":103700,"motion":400}]}],"group_26":[{"autoTurnFirst":6.8,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":1,"pos":1,"voice":"vo_char_1037_00_33","textHome":"Um, I'd like you to have this@stuffed animal, if you don't mind."}]},{"autoTurnFirst":5.2,"chara":[{"eyeClose":1,"id":103700,"motion":400,"textHome":"I bought it on impulse, and it's@the same one I've had before."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103700}]},{"autoTurnFirst":0.8,"chara":[{"id":103700,"motion":100,"textHome":"We'll have matching ones@if you'd like."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":103700}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":3.1,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103700,"motion":0,"pos":1,"voice":"vo_char_1037_00_34","textHome":"Me, having a father complex?!"}]},{"autoTurnFirst":2.1,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":103700,"motion":200,"textHome":"There is no such thing."}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":1,"textHome":"Papa and I are simply partners@in a shared mission,"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_020.exp.json","id":103700,"motion":400,"textHome":"and saying that was rather rude."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":1,"pos":1,"voice":"vo_char_1037_00_35","textHome":"Truth is, Mama and Touka's mother@are sisters,"}]},{"autoTurnFirst":3.9,"chara":[{"id":103700,"motion":400,"textHome":"so they're quite close@with each other."}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":100,"textHome":"But Touka's mother@is a rather gentle person..."}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":103700,"textHome":"It's hard to understand bloodlines."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":103700,"motion":100,"pos":1,"voice":"vo_char_1037_00_36","textHome":"Phew...@That was indeed interesting."}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":1,"textHome":"Oh, this is a book about@Tokime Village that Papa wrote."}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":0,"textHome":"It didn't sell well, though..."}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":200,"textHome":"Perhaps the readers@didn't see it the same way I do."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103700,"motion":400,"pos":1,"voice":"vo_char_1037_00_03"}]}],"group_30":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":400,"pos":1,"voice":"vo_char_1037_00_37","textHome":"I have a lot of friends@who are Magical Girls."}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103700,"textHome":"It's mostly to@gather information, though..."}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103700,"motion":100,"textHome":"But still,@they were all very nice people."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":300,"pos":1,"voice":"vo_char_1037_00_38","textHome":"When I met Touka again,@I slapped her without warning."}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":103700,"textHome":"Naturally,@I regretted it a little bit."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103700}]},{"autoTurnFirst":8.0,"chara":[{"cheek":1,"id":103700,"motion":400,"textHome":"But considering what she had said,@I have no remorse at all."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":100,"pos":1,"voice":"vo_char_1037_00_39","textHome":"Mikage is coming today,@so I've prepared quite a lot@of treats for her."}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":103700}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":1,"textHome":"I anticipated that@she might beg for more,"}]},{"autoTurnFirst":5.0,"chara":[{"id":103700,"motion":200,"textHome":"so I have to prepare in advance."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":1,"pos":1,"voice":"vo_char_1037_00_40","textHome":"Sometimes, when Rabi is alone,@she says to herself@something about a clock."}]},{"autoTurnFirst":2.8,"chara":[{"eyeClose":1,"id":103700,"motion":400,"textHome":"It's a little scary."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103700}]},{"autoTurnFirst":8.0,"chara":[{"id":103700,"motion":300,"textHome":"I don't know if I should talk@to her when she does that."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103700,"motion":0,"pos":1,"voice":"vo_char_1037_00_41","textHome":"Eh, are you interested@in folkloristics?"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":103700}]},{"autoTurnFirst":2.9,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":103700,"motion":100,"textHome":"Then you've piqued my attention!"}]},{"autoTurnFirst":5.6,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":103700,"motion":1,"textHome":"Folkloristics elucidates current@lifestyles through its studies,"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":103700,"motion":200,"textHome":"it's the strongest knowledge of all!"}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103700,"motion":0,"pos":1,"voice":"vo_char_1037_00_42","textHome":"Combat is also part of research."}]},{"autoTurnFirst":3.0,"chara":[{"id":103700,"motion":400,"textHome":"Here I go!"}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":103700,"motion":200,"pos":1,"voice":"vo_char_1037_00_43","textHome":"See, I actually can fight!"}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":300,"pos":1,"voice":"vo_char_1037_00_44","textHome":"That was dangerous...@I barely made it...!"}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103700,"motion":100,"pos":1,"voice":"vo_char_1037_00_45","textHome":"I'll save Papa along with everyone!"}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103700,"motion":0,"pos":1,"voice":"vo_char_1037_00_46","textHome":"For the sake of the future,@I won't give up!"}]},{"autoTurnFirst":3.0,"chara":[{"id":103700,"motion":200}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":103700,"motion":1,"pos":1,"voice":"vo_char_1037_00_04"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":103700}]}],"group_5":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":103700,"motion":100,"pos":1,"voice":"vo_char_1037_00_05"}]}],"group_6":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":103700,"motion":100,"pos":1,"voice":"vo_char_1037_00_13","textHome":"I've taken one step closer@to the truth of Magical Girls."}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":103700,"motion":200,"pos":1,"voice":"vo_char_1037_00_14","textHome":"Since I've been doing so well,@I believe I deserve to be praised!"}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":103700,"motion":300,"pos":1,"voice":"vo_char_1037_00_15","textHome":"Looking back, a lot has happened@since I came to Kamihama."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":103700}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":100,"pos":1,"voice":"vo_char_1037_00_16","textHome":"I used to ask Papa@to give me piggyback rides."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":103700,"textHome":"I can't do that now, though."}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":103700,"motion":400,"textHome":"When I see young children@doing the same,@it makes me a little jealous."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103700}]},{"chara":[{"id":103700,"textHomeStatus":"Clear"}]}]},"version":3}

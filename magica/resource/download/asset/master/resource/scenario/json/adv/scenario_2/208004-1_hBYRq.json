{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21503.jpg","bgm":"stop","turnChangeIn":"fadeIn"},{"autoTurnLast":0.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800400,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800200,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800700,"motion":0,"pos":1}],"textClear":1},{"nameNarration":"Everyone","narration":"\"...\"","narrationBg":"","narrationEffect":"in","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"narrationEffect":"out"},{"autoTurnLast":0.01,"bg":"bg_adv_21503.jpg","chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":302300,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":301200,"motion":0,"pos":0}],"narrationEffect":"out","turnChangeIn":"whiteIn","turnChangeInTime":1.0},{"autoTurnLast":0.5,"se":"3102_enemy_dead"},{"autoTurnLast":2.0,"se":"7209_gate_close"},{"bgm":"bgm01_anime02","chara":[{"id":302300,"motion":400}],"nameRight":"Aimi","textRight":"We beat iiiit!@Haven't seen a Witch that huge in a long time!","turnChangeOut":"whiteOut","turnChangeOutTime":1.0},{"chara":[{"id":301200,"motion":100}],"nameLeft":"Meiyui","textLeft":"Hah, some time, indeed..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":302300},{"effect":"fadeout","id":301200}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_21503.jpg","bgChangeEffect":"cameraPan"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":800700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101300,"motion":0,"pos":2}],"nameLeft":"","textLeft":"...Huh? What the heck am I doing...?"},{"chara":[{"id":101300,"lipSynch":0}],"nameRight":"Asuka","textRight":"..."},{"autoTurnLast":0.2,"chara":[{"id":101300,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":302300,"motion":200,"pos":2}],"nameRight":"Aimi","textRight":"Guys! Is everything okay?!"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":302300,"pos":2}],"nameRight":"Aimi","textRight":"Or rather...what? The heck is going on now...?"},{"chara":[{"id":101300,"motion":200}],"nameLeft":"Asuka","textLeft":"Ahh― We're okay! That was perfect timing!"},{"autoTurnLast":1.0,"bg":"bg_adv_21503.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":101300,"motion":0,"pos":2}],"turnChangeIn":"fadeIn"},{"chara":[{"id":800700}],"nameLeft":"","surround":"7003_wind","textLeft":"Is that so... We were apologizing by drowning@ourselves...","turnChangeOut":"fadeOut"},{"chara":[{"id":800700}],"nameLeft":"","textLeft":"While it is selfish, I've always felt guilty about it..."},{"chara":[{"id":800700}],"nameLeft":"","textLeft":"I've always regretted. That's the truth..."},{"chara":[{"id":800700}],"nameLeft":"","textLeft":"I can't commit suicide... But I also want@to make amends somehow..."},{"chara":[{"id":800700}],"nameLeft":"","textLeft":"But now I can't just flip my life around."},{"chara":[{"id":800700}],"nameLeft":"","textLeft":"I don't have the courage to speak up alone...!"},{"chara":[{"id":101300,"lipSynch":0}],"nameRight":"Asuka","textRight":"..."},{"nameCenter":"","surround":"stop","textCenter":"...You're not alone."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":101300},{"effect":"fadeout","id":800700}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_21503.jpg","bgChangeEffect":"cameraPan"},{"bgm":"bgm03_story05","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800400,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800200,"motion":0,"pos":2}],"nameLeft":"","textLeft":"If there's anyone who has the same regrets,@it's us right here."},{"chara":[{"id":800200}],"nameRight":"","textRight":"Let's raise our voices together..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800200},{"effect":"fadeout","id":800400}],"textClear":1},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":801500,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":801100,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800300,"motion":0,"pos":1}],"nameNarration":"","narration":"\"We're all together.\"","narrationBg":"","narrationEffect":"in"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":801500},{"effect":"fadeout","id":801100},{"effect":"fadeout","id":800300}],"textClear":1},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800800,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800100,"motion":0,"pos":1}]},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800101},{"effect":"fadeout","id":800800},{"effect":"fadeout","id":800100}],"textClear":1},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800201,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":801500,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800500,"motion":0,"pos":1}]},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800201},{"effect":"fadeout","id":801500},{"effect":"fadeout","id":800500}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800700,"motion":0,"pos":1}],"nameCenter":"","narrationEffect":"out","textCenter":"All of you...thank you..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800700}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":101300,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":300400,"motion":1,"pos":2}],"nameLeft":"Asuka","textLeft":"There is hope after all...!"},{"chara":[{"id":300400}],"nameRight":"Sasara","textRight":"If you're aware of your own mistakes, then instead@of taking the easy way out with suicide,"},{"chara":[{"id":300400}],"nameRight":"Sasara","textRight":"it may be better to prepare for a little backlash"},{"chara":[{"id":300400}],"nameRight":"Sasara","textRight":"and go down the right path instead."},{"chara":[{"id":101300,"motion":200}],"nameLeft":"Asuka","textLeft":"That is precisely right!"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800700,"motion":0,"pos":0}],"nameLeft":"","textLeft":"I don't know if it's okay for me to live so carefree,"},{"chara":[{"id":800700}],"nameLeft":"","textLeft":"but, little by little, I will make up for it..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800700},{"effect":"fadeout","id":300400}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":301200,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":302300,"motion":0,"pos":2}],"nameLeft":"Meiyui","textLeft":"...I do not understand the situation,"},{"chara":[{"id":301200}],"nameLeft":"Meiyui","textLeft":"but is this not what the petition is for?"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":301200,"motion":200,"pos":0}],"nameLeft":"Meiyui","textLeft":"Then here― All of you be quick and sign this."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":302300,"motion":100,"pos":2}],"nameRight":"Aimi","textRight":"Uwaah~ Good thinking, Meiyui."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":302300},{"effect":"fadeout","id":301200}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800700,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800200,"motion":0,"pos":2}],"nameLeft":"","textLeft":"You're right. I'll sign it right away."},{"chara":[{"id":800200}],"nameRight":"","textRight":"I felt so hopeless looking at this petition,@but now it's saved me..."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800200},{"effect":"fadeout","id":800700}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":303300,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"Sayuki","textCenter":"..."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":303300,"pos":1}],"nameCenter":"Sayuki","textCenter":"Heheh, looks like some joy is spreading."},{"autoTurnLast":0.2,"chara":[{"id":303300,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800400,"pos":0}],"nameLeft":"","textLeft":"Are...[chara:800400:lipSynch_0][wait:1.0][chara:800400:cheek_0][chara:800400:face_mtn_ex_050.exp3.json][chara:800400:lipSynch_1] Are you by chance...SayuSayu...?"},{"chara":[{"id":800400}],"nameLeft":"","textLeft":"And that costume...I've seen that before..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":303300,"lipSynch":0,"motion":400}],"nameRight":"Sayuki","textRight":"[chara:303300:effect_emotion_surprise_0][se:7226_shock]...?!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101300,"motion":400,"pos":0}],"nameLeft":"Asuka","textBg":"shout","textLeft":"B...B-B-B-BIG PROBLEM!"},{"chara":[{"id":101300}],"nameLeft":"Asuka","textBg":"shout","textLeft":"THEY FOUND OUT WE HAVE THE IDOL SAYUSAYU!"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":304200,"motion":1,"pos":0}],"nameLeft":"Meguru","textLeft":"Everyone returned to their senses so quickly"},{"chara":[{"id":304200}],"nameLeft":"Meguru","textLeft":"that we didn't even get a chance to transform@back...!"},{"chara":[{"cheek":0,"id":303300,"lipSynch":0,"motion":0,"pos":2}],"nameRight":"Sayuki","textRight":"..."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":300400,"motion":1,"pos":0}],"nameLeft":"Sasara","textLeft":"W-what do we do...? Lie to them...?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":303600,"motion":1,"pos":0}],"nameLeft":"Maria","textLeft":"Let's avoid panicking now..."},{"chara":[{"id":303600}],"nameLeft":"Maria","textLeft":"Besides, if the office saw you at such a scene,"},{"chara":[{"id":303600}],"nameLeft":"Maria","textLeft":"they would be furious..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":303300,"motion":300,"pos":2}],"nameRight":"Sayuki","textRight":"Auu... Y-you're riiight~..."},{"chara":[{"id":303300,"motion":1},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":800400,"motion":0,"pos":0}],"nameRight":"Sayuki","textRight":"U-um, excuse me...@I'm actually...not Sayuki..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800400,"pos":0}],"nameLeft":"","textLeft":"[chara:800400:effect_emotion_sad_0][se:7224_fall_into]Did I get the wrong person...@Pardon me, sorry to bother you..."},{"chara":[{"id":800400}],"nameLeft":"","textLeft":"[chara:800400:effect_emotion_sad_0][se:7224_fall_into]Haa..."},{"chara":[{"id":303300,"lipSynch":0}],"nameRight":"Sayuki","textRight":"...[chara:303300:lipSynch_0][wait:1.0][chara:303300:motion_000][chara:303300:cheek_0][chara:303300:face_mtn_ex_050.exp3.json][chara:303300:lipSynch_1]Ah, my mistake."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":303300,"pos":2}],"nameRight":"Sayuki","textRight":"I aaam Sayuki Fumino.@[chara:303300:lipSynch_0][wait:1.0][chara:303300:motion_100][chara:303300:cheek_0][chara:303300:face_mtn_ex_011.exp3.json][chara:303300:lipSynch_1]I'm SayuSayu!"},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":300400,"motion":400,"pos":0}],"nameLeft":"Sasara","textLeft":"[chara:300400:effect_emotion_surprise_0][se:7226_shock]Wait― Ehh―?!"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":800400,"motion":0,"pos":0}],"nameLeft":"","textLeft":"N-no way...?!@You're actually SayuSayu?!"},{"chara":[{"id":800400}],"nameLeft":"","textLeft":"W-what're you doing in a place like this...?!"},{"chara":[{"id":303300,"motion":400}],"nameRight":"Sayuki","textRight":"Yes! I'm really SayuSayu!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":303300,"motion":200,"pos":2}],"nameRight":"Sayuki","textRight":"Here for a guerrilla live performance."},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

{"story":{"group_1":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":412200,"motion":0,"pos":1,"voice":"vo_char_4122_00_01","textHome":"At court, desires swirl in a vortex."}]},{"autoTurnFirst":8.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":1,"textHome":"With the war against England in the@background, the French are consumed@by ugly court conflicts..."}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":400,"textHome":"Yes, fight more."}]},{"autoTurnFirst":6.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":201,"textHome":"Both France and England@will eventually belong to me."}]},{"autoTurnFirst":4.7,"chara":[{"id":412200,"motion":100,"textHome":"I am the Queen of France,@Isabeau de Bavière."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":200,"textHome":"The one who will become@the Queen of the World."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":412200,"motion":1,"pos":1,"voice":"vo_char_4122_00_17","textHome":"I heard some children regret@making a contract with Qube."}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":412200,"textHome":"They sell their souls without@properly listening, and then@they curse their ignorance."}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":412200}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":100}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp3.json","id":412200,"motion":201,"pos":1,"voice":"vo_char_4122_00_18","textHome":"The next child I bear should be a girl."}]},{"autoTurnFirst":3.2,"chara":[{"eyeClose":0,"id":412200}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":0,"textHome":"Since she will inherit my fate@as the Queen of France,"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":400,"textHome":"I'm looking forward to see what kind@of Magical Girl she will become."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":412200}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":1.1,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_014.exp3.json","id":412200,"motion":0,"pos":1,"voice":"vo_char_4122_00_19","textHome":"Ah!@My magic is filling up.@This will be simple enough for me."}]},{"autoTurnFirst":0.4,"chara":[{"eyeClose":0,"id":412200}]},{"autoTurnFirst":6.0,"chara":[{"id":412200,"motion":200}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":200,"pos":1,"voice":"vo_char_4122_00_20","textHome":"Too bad.@I'm going to get even stronger."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":400,"pos":1,"voice":"vo_char_4122_00_21","textHome":"I have glimpsed the forbidden@knowledge Qube holds."}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":412200,"motion":0,"textHome":"I can't understand it all,"}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":412200}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200,"textHome":"but as my power grows,@so does my understanding."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":100}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":10.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":1,"pos":1,"voice":"vo_char_4122_00_22","textHome":"Qube once told me that a Magical Girl's@potential is determined by@the amount of karma she carries."}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":412200,"motion":100,"textHome":"Now that I have Qube's knowledge,@I understand what that means."}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":200,"textHome":"I also know how to weave@even greater karma to gain power."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":6.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":100,"pos":1,"voice":"vo_char_4122_00_23","textHome":"Hehehehe, I can see all the steps@to take over the world."}]},{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":412200,"motion":0,"textHome":"Now I just need to follow my plan and@bring the administration under my control."}]},{"autoTurnFirst":5.4,"chara":[{"eyeClose":0,"id":412200,"textHome":"Of course, there will be obstacles."}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":201,"textHome":"But isn't that what makes@ambition interesting?"}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_17":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_015.exp3.json","id":412200,"motion":1,"pos":1,"voice":"vo_char_4122_00_24","textHome":"Hehehe!@I'm happy to see you today too."}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200}]},{"autoTurnFirst":3.3,"chara":[{"id":412200,"motion":201,"textHome":"Oh, I wouldn't lie to you."}]},{"autoTurnFirst":6.5,"chara":[{"id":412200,"motion":100,"textHome":"Why should I flatter you@when I can have anything I want?"}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":4.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":1,"pos":1,"voice":"vo_char_4122_00_25","textHome":"I don't dislike mornings.@They make me feel like@I'm one step closer to my ambitions."}]},{"autoTurnFirst":4.2,"chara":[{"eyeClose":1,"id":412200}]},{"autoTurnFirst":0.4,"chara":[{"eyeClose":0,"id":412200}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":412200,"motion":0,"textHome":"I just don't like too much bright light."}]},{"autoTurnFirst":6.0,"chara":[{"id":412200,"motion":201}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":100,"pos":1,"voice":"vo_char_4122_00_26","textHome":"How about having lunch in my room today?"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_015.exp3.json","id":412200,"motion":0,"textHome":"Tell me whatever you like,@and I'll have it brought@from the kitchen right away."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":412200,"motion":0,"pos":1,"voice":"vo_char_4122_00_02","textHome":"Oh, is it nice to meet you?"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_015.exp3.json","id":412200,"motion":1,"textHome":"Hehehe.@You don't need to be afraid."}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200,"textHome":"I am Isabeau de Bavière."}]},{"autoTurnFirst":3.5,"chara":[{"id":412200,"motion":100,"textHome":"For now, I'll just say@I am the Queen of France."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":8.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":200,"pos":1,"voice":"vo_char_4122_00_27","textHome":"As the sun sets, creatures more terrifying@than Witches begin to stir in the darkness."}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":0,"textHome":"They are the desires of people,@the monsters that dwell in the court."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":412200,"motion":0,"pos":1,"voice":"vo_char_4122_00_28","textHome":"Oh, are you not coming with me?"}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_015.exp3.json","id":412200,"motion":1,"textHome":"Ahaha, no need to hesitate."}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":100,"textHome":"After all, the night is just beginning,@is it not?"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":412200,"motion":1,"pos":1,"voice":"vo_char_4122_00_29","textHome":"Oh, my apologies."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":412200,"textHome":"I was tired, so I was resting."}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":100,"textHome":"The King is not in good condition,@so I have many duties to attend to."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":412200,"motion":0,"pos":1,"voice":"vo_char_4122_00_30","textHome":"Do I really need to fight Witches myself?"}]},{"autoTurnFirst":6.1,"chara":[{"id":412200,"motion":200,"textHome":"Prove your loyalty by hunting Witches@and offering me their Grief Seeds."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":412200}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":412200,"motion":1,"pos":1,"voice":"vo_char_4122_00_31","textHome":"The master of the barrier@that nests in the Mirror Labyrinth..."}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":0,"textHome":"Hmph! A strange Witch has appeared,@hasn't it?"}]},{"autoTurnFirst":6.5,"chara":[{"id":412200,"motion":100,"textHome":"I will conquer even the dimensions@beyond that Labyrinth."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":6.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":200,"pos":1,"voice":"vo_char_4122_00_32","textHome":"Magical Girls, both enemies and allies,@fighting each other."}]},{"autoTurnFirst":2.0,"chara":[{"eyeClose":1,"id":412200,"motion":0,"textHome":"Hehehehe!"}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":412200}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":412200,"textHome":"What an exhilarating sight."}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":201,"textHome":"I shall save my subordinates@until the system collapses."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_26":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_015.exp3.json","id":412200,"motion":1,"pos":1,"voice":"vo_char_4122_00_33","textHome":"Yes. Maybe I should put it this way."}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":0,"textHome":"Oh, I was writing a letter to a teacher@who helped me before."}]},{"autoTurnFirst":4.5,"chara":[{"id":412200,"motion":100,"textHome":"Living in the court requires@some consideration."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":412200,"motion":0,"pos":1,"voice":"vo_char_4122_00_34","textHome":"Hmm..."}]},{"autoTurnFirst":4.3,"chara":[{"eyeClose":0,"id":412200,"textHome":"I wonder when will@I be able to travel next..."}]},{"autoTurnFirst":7.5,"chara":[{"id":412200,"motion":100,"textHome":"I look forward taking a tour@through the mountains and being@healed by the animals and birds."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":200,"pos":1,"voice":"vo_char_4122_00_35","textHome":"What do you desire?@Don't be afraid to tell me."}]},{"autoTurnFirst":5.8,"chara":[{"id":412200,"motion":1,"textHome":"An exotic rose from a foreign land?@My beloved leopard?"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":412200,"motion":0,"textHome":"Or perhaps..."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":400,"textHome":"Do you want to make a contract with me?"}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":6.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":100,"pos":1,"voice":"vo_char_4122_00_36","textHome":"The maids serving the French royal family@are daughters from distinguished families."}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":0,"textHome":"Naturally, many of them have@the qualities of becoming Magical Girls."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_015.exp3.json","id":412200,"motion":1,"pos":1,"voice":"vo_char_4122_00_03"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":412200}]}],"group_30":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":100,"pos":1,"voice":"vo_char_4122_00_37","textHome":"History isn't just for men."}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp3.json","id":412200,"motion":1,"textHome":"One day, powerful,@scheming women will emerge."}]},{"autoTurnFirst":0.4,"chara":[{"eyeClose":0,"id":412200}]},{"autoTurnFirst":7.2,"chara":[{"id":412200,"motion":400,"textHome":"Hehehe!@I'm looking forward to playing@this game of strategy with them."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":8.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":1,"pos":1,"voice":"vo_char_4122_00_38","textHome":"I heard there's a minstrel named@Wolkenstein who has traveled the@world and mastered many languages."}]},{"autoTurnFirst":5.0,"chara":[{"id":412200,"motion":201,"textHome":"I'd like to invite him to my court@and listen to his songs someday."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":10.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":0,"pos":1,"voice":"vo_char_4122_00_39","textHome":"There's a rumor in Paris about an alchemist@who succeeded in forging the Philosopher's@Stone, a magical stone of great power."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":412200,"motion":100,"textHome":"It's an intriguing rumor..."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":7.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":412200,"motion":1,"pos":1,"voice":"vo_char_4122_00_40","textHome":"What I wished for from Qube was,@\"I want everything you possess.\""}]},{"autoTurnFirst":3.1,"chara":[{"id":412200,"motion":200}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":412200,"textHome":"And I got it."}]},{"autoTurnFirst":5.5,"chara":[{"id":412200,"motion":400,"textHome":"As a Magical Girl, now I have Qube's@knowledge and the power to grant wishes!"}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_015.exp3.json","id":412200,"motion":100,"pos":1,"voice":"vo_char_4122_00_41","textHome":"Oh, how cute!@Come here, I'll give you something tasty."}]},{"autoTurnFirst":4.0,"chara":[{"id":412200,"motion":1,"textHome":"Hehe, you chirp so happily..."}]},{"autoTurnFirst":1.4,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":412200,"motion":0,"textHome":"...W-what do you want?"}]},{"autoTurnFirst":1.8,"chara":[{"cheek":2,"face":"mtn_ex_020.exp3.json","id":412200}]},{"autoTurnFirst":3.5,"chara":[{"id":412200,"motion":201,"textHome":"I was just admiring the little birds."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":412200,"motion":201,"pos":1,"voice":"vo_char_4122_00_42","textHome":"I'll show you your end!"}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":400,"pos":1,"voice":"vo_char_4122_00_43","textHome":"...Oh?@Over already, is it?"}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":412200,"motion":1,"pos":1,"voice":"vo_char_4122_00_44","textHome":"I suppose that was enough@to keep my interest."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":412200,"motion":100,"pos":1,"voice":"vo_char_4122_00_45","textHome":"Hehehe, you were a good child."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":201,"pos":1,"voice":"vo_char_4122_00_46","textHome":"It seems you've lost the will to resist."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":412200,"motion":200,"pos":1,"voice":"vo_char_4122_00_04"}]}],"group_5":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_014.exp3.json","id":412200,"motion":0,"pos":1,"voice":"vo_char_4122_00_05"}]},{"autoTurnFirst":2.3,"chara":[{"id":412200,"motion":400}]}],"group_6":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":200,"pos":1,"voice":"vo_char_4122_00_13","textHome":"I've taken another step closer to power."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":412200,"motion":201,"pos":1,"voice":"vo_char_4122_00_14","textHome":"Good.@Satisfy me next time as well."}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":0,"pos":1,"voice":"vo_char_4122_00_15","textHome":"Someday, I hope to look down@on the world from the same heights."}]},{"autoTurnFirst":3.5,"chara":[{"id":412200,"motion":100}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":412200,"motion":0,"pos":1,"voice":"vo_char_4122_00_16","textHome":"You should always treat@your maid of honor with care."}]},{"autoTurnFirst":3.0,"chara":[{"id":412200,"motion":201,"textHome":"It's easy to control them with force."}]},{"autoTurnFirst":0.7,"chara":[{"eyeClose":1,"id":412200,"textHome":"However, using force without reason@is something only fools do."}]},{"autoTurnFirst":0.4,"chara":[{"eyeClose":0,"id":412200}]},{"autoTurnFirst":5.0,"chara":[{"id":412200,"motion":100}]},{"chara":[{"id":412200,"textHomeStatus":"Clear"}]}]},"version":3}

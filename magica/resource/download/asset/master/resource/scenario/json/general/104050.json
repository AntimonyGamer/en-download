{"story":{"group_1":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_01"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1}]},{"autoTurnFirst":8.5,"chara":[{"id":104000,"motion":0}]},{"autoTurnFirst":3.4,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":100}]}],"group_10":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_00_17"}]},{"autoTurnFirst":4.5,"chara":[{"id":104000,"motion":0}]},{"autoTurnFirst":2.7,"chara":[{"id":104000,"motion":100}]}],"group_11":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_00_18"}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":0}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":104000,"motion":100}]}],"group_12":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_19"}]}],"group_13":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":200,"pos":1,"voice":"vo_char_1040_00_20"}]}],"group_14":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":0,"pos":1,"voice":"vo_char_1040_00_21"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000}]},{"autoTurnFirst":2.7,"chara":[{"id":104000,"motion":100}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":104000}]}],"group_15":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_00_22"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":300}]},{"autoTurnFirst":5.8,"chara":[{"id":104000,"motion":100}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":104000,"motion":0}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":1}]}],"group_16":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_00_23"}]},{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":104000}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":100}]}],"group_17":[{"autoTurnFirst":2.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":0,"pos":1,"voice":"vo_char_1040_50_24","textHome":"It was hot today too, wasn't it."}]},{"autoTurnFirst":2.8,"chara":[{"id":104000,"motion":400,"textHome":"Now, this way please, there is proper@air conditioning inside this room."}]},{"autoTurnFirst":3.3,"chara":[{"id":104000,"motion":100}]},{"autoTurnFirst":4.9,"chara":[{"id":104000,"motion":1,"textHome":"I'll deliver us some cold drinks,@so please wait a moment."}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_50_25","textHome":"One would likely lose their@appetite in such hot weather,"}]},{"autoTurnFirst":3.4,"chara":[{"id":104000,"motion":200,"textHome":"so have you properly@eaten your breakfast?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":0,"textHome":"There are light meals@such as fruits arranged as well,"}]},{"autoTurnFirst":2.3,"chara":[{"id":104000,"motion":100,"textHome":"so if you feel like it,@please help yourself."}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":2.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_50_26","textHome":"The sunlight is very strong@right now, isn't it..."}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":100,"textHome":"There is sunscreen made ready for us,@so do not hesitate to request it."}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":300,"textHome":"Or perhaps...@Would you prefer some tan lotion?"}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_02"}]},{"autoTurnFirst":3.3,"chara":[{"id":104000,"motion":1}]},{"autoTurnFirst":5.5,"chara":[{"id":104000,"motion":300}]}],"group_20":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":0,"pos":1,"voice":"vo_char_1040_50_27","textHome":"I learned about this the other day,"}]},{"autoTurnFirst":5.7,"chara":[{"id":104000,"motion":400,"textHome":"but apparently there is a place where@you can see a wonderful view of the@setting sun being reflected by the sea."}]},{"autoTurnFirst":3.6,"chara":[{"id":104000,"motion":100,"textHome":"If you do not mind, would you@like to go see it together?"}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":4.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_50_28","textHome":"If you're going to sleep already,@allow me to apply some@baby powder on you."}]},{"autoTurnFirst":3.1,"chara":[{"id":104000,"motion":300,"textHome":"After all it would be very unfortunate@if you developed heat rashes."}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1,"textHome":"Please stand still..."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":0,"textHome":"There you go."}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_50_29","textHome":"We Coordinators continue to business@as always through the summer period."}]},{"autoTurnFirst":5.2,"chara":[{"id":104000,"motion":300,"textHome":"However, even we are not immune@to the summer's heat fatigue,"}]},{"autoTurnFirst":2.7,"chara":[{"eyeClose":1,"id":104000,"motion":100,"textHome":"so I humbly ask@for your comprehension."}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":104000,"motion":200,"pos":1,"voice":"vo_char_1040_50_30","textHome":"It seems that a Witch has appeared."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1,"textHome":"We're having a summer limited@service with cold beverages@and towels among other things,"}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":100,"textHome":"so feel free to come visit@for an adjustment anytime."}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":0,"pos":1,"voice":"vo_char_1040_50_31","textHome":"When I briefly toured around@the Endless Mirrors,"}]},{"autoTurnFirst":4.6,"chara":[{"id":104000,"motion":200,"textHome":"I happened to lay my eyes on@a handful of copies wearing swimsuits."}]},{"autoTurnFirst":5.0,"chara":[{"id":104000,"motion":300,"textHome":"Curiously, it appears that@our customers often enter the@Labyrinth while in their swimwear."}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_50_32"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":104000,"motion":1}]},{"autoTurnFirst":3.4,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":2.0,"chara":[{"id":104000,"motion":100}]}],"group_26":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":200,"pos":1,"voice":"vo_char_1040_50_33","textHome":"A-aahh!"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":100,"textHome":"I-I'm sorry for losing my composure!"}]},{"autoTurnFirst":3.2,"chara":[{"id":104000,"motion":300,"textHome":"Uhh...@My favorite notepad got@soaked in sea water,"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":104000,"textHome":"and the letters have@gotten all blurry...!"}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":1.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":104000,"motion":0,"pos":1,"voice":"vo_char_1040_50_34","textHome":"Stay back!"}]},{"autoTurnFirst":4.1,"chara":[{"id":104000,"motion":400,"textHome":"I will not let you@suck anyone's blood...!"}]},{"autoTurnFirst":5.3,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":0,"textHome":"Pardon me, there are awfully too@many mosquitoes during this season."}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":1,"textHome":"I'll light up the@mosquito incense now."}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_50_35","textHome":"I was told that complimenting one's@attire is also one form of kindness,"}]},{"autoTurnFirst":4.3,"chara":[{"id":104000,"motion":300,"textHome":"so I tried praising the people@around wearing swimsuits."}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":0,"textHome":"However, I ended up@being mistaken for a seducer."}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_50_36","textHome":"I'm only speaking for myself,"}]},{"autoTurnFirst":4.0,"chara":[{"id":104000,"motion":400,"textHome":"but my swimming technique@is quite exceptional."}]},{"autoTurnFirst":2.0,"chara":[{"id":104000,"motion":0,"textHome":"If you're not particularly@good at swimming,"}]},{"autoTurnFirst":3.5,"chara":[{"id":104000,"motion":200,"textHome":"I could instruct you some other time@if that's alright with you."}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_03"}]},{"autoTurnFirst":3.0,"chara":[{"id":104000,"motion":400}]}],"group_30":[{"autoTurnFirst":4.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_051.exp.json","id":104000,"motion":400,"pos":1,"voice":"vo_char_1040_50_37","textHome":"Wearing a swimsuit@makes it easy to adjust?"}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":200,"textHome":"This rumor...where on Earth@did you hear it from?"}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":0,"textHome":"No, I can tell even if@you don't answer me."}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":104000,"motion":300,"textHome":"For goodness' sake, Mitama..."}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":6.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_50_38","textHome":"Lately, when there are no customers,@Teacher has been displaying@a much more brazen appearance..."}]},{"autoTurnFirst":2.4,"chara":[{"id":104000,"motion":300,"textHome":"I understand that her@chest area must be stifled,"}]},{"autoTurnFirst":4.0,"chara":[{"id":104000,"motion":200,"textHome":"but at the very least, I wish that@she would wear some more clothes."}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_50_39","textHome":"I wonder if Sudachi@doesn't feel hot in that attire."}]},{"autoTurnFirst":2.1,"chara":[{"id":104000,"motion":0,"textHome":"It wouldn't be good@if she had a heatstroke,"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":400,"textHome":"so I better make sure@I have a chilled towel@and some ice packs ready."}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":104000,"motion":0,"pos":1,"voice":"vo_char_1040_50_40","textHome":"When I relax my muscles and let@myself drift about in the water,"}]},{"autoTurnFirst":4.0,"chara":[{"id":104000,"motion":1,"textHome":"it feels like my body@is being gently embraced..."}]},{"autoTurnFirst":1.4,"chara":[{"eyeClose":0,"id":104000,"textHome":"\"Just like a motherly love\",@though uncharacteristic of me,@it's what I end up thinking."}]},{"autoTurnFirst":1.7,"chara":[{"id":104000,"motion":100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":0,"pos":1,"voice":"vo_char_1040_50_41","textHome":"I do not have any@memories of the summer,"}]},{"autoTurnFirst":5.1,"chara":[{"eyeClose":1,"id":104000,"motion":300,"textHome":"or to be more precise, all of@my fun memories have faded away."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":5.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":100,"textHome":"If possible, could you perhaps@teach me how to enjoy the summer?"}]},{"chara":[{"id":104050,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":104000,"motion":400,"pos":1,"voice":"vo_char_1040_00_42"}]}],"group_36":[{"autoTurnFirst":3.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_43"}]}],"group_37":[{"autoTurnFirst":3.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_00_44"}]}],"group_38":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":200,"pos":1,"voice":"vo_char_1040_00_45"}]}],"group_39":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":104000,"motion":200,"pos":1,"voice":"vo_char_1040_00_46"}]}],"group_4":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_00_04"}]}],"group_5":[{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_05"}]},{"autoTurnFirst":3.3,"chara":[{"eyeClose":0,"id":104000}]}],"group_6":[{"autoTurnFirst":4.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_040.exp.json","id":104000,"motion":300,"pos":1,"voice":"vo_char_1040_00_13"}]}],"group_7":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_14"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp.json","id":104000}]}],"group_8":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":104000,"motion":1,"pos":1,"voice":"vo_char_1040_00_15"}]}],"group_9":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp.json","id":104000,"motion":100,"pos":1,"voice":"vo_char_1040_00_16"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":104000}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":104000}]},{"autoTurnFirst":5.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":104000,"motion":400}]}]},"version":3}

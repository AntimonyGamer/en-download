{"story":{"group_1":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":0,"pos":1,"voice":"vo_char_4028_00_01","textHome":"I am known as Jeanne d'Arc."}]},{"autoTurnFirst":5.6,"chara":[{"id":402800,"motion":100,"textHome":"Guided by the angels, I devoted@myself to the battle to save France."}]},{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402800,"motion":300,"textHome":"I am here now@because of everyone's support."}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":402800,"textHome":"Therefore, no matter what happens,@I will never give up.@Until I bring light to France!"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402800}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402800,"motion":0}]},{"autoTurnFirst":3.0,"chara":[{"id":402800,"motion":201}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402800,"motion":0,"pos":1,"voice":"vo_char_4028_00_17","textHome":"When I left my hometown@guided by the angels' revelation,"}]},{"autoTurnFirst":3.8,"chara":[{"id":402800,"motion":201,"textHome":"I embarked on a journey@without my family's knowledge."}]},{"autoTurnFirst":4.0,"chara":[{"id":402800,"motion":300,"textHome":"When I think of my parents and brothers,@I feel a little...regretful."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":402800}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":5.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":1,"pos":1,"voice":"vo_char_4028_00_18","textHome":"It seems that my younger sister,@Catherine, had more talent with swords."}]},{"autoTurnFirst":4.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402800,"motion":300,"textHome":"Whenever I held a sword,@I unintentionally exerted too much force,"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":201,"textHome":"and Liz always corrected my grip."}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":402800,"motion":0,"pos":1,"voice":"vo_char_4028_00_19","textHome":"To save the people of this country...!"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402800}]},{"autoTurnFirst":2.5,"chara":[{"id":402800,"motion":201}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":402800,"motion":1,"pos":1,"voice":"vo_char_4028_00_20","textHome":"I can feel power.@Power that is not my own...!"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":0,"id":402800}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402800,"motion":300,"pos":1,"voice":"vo_char_4028_00_21","textHome":"I don't even know what I am now,@whether I am a Magical Girl or not."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":402800}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402800}]},{"autoTurnFirst":5.0,"chara":[{"id":402800,"motion":0,"textHome":"Nevertheless, for the sake of those@who believed in me, I will resist@and continue to fight...!"}]},{"autoTurnFirst":0.9,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":402800}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402800}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402800,"motion":100}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402800,"motion":0,"pos":1,"voice":"vo_char_4028_00_22","textHome":"Monsieur Angel said..."}]},{"autoTurnFirst":6.5,"chara":[{"id":402800,"motion":1,"textHome":"...that the strong hopes of each and@every person in this country became@a strong causality and gave me power."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402800,"motion":0,"textHome":"And without the wishes of@Liz and Melissa, I would have@ended up unable to do anything."}]},{"autoTurnFirst":5.3,"chara":[{"eyeClose":1,"id":402800,"motion":300}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402800,"motion":201,"pos":1,"voice":"vo_char_4028_00_23","textHome":"I can see a light."}]},{"autoTurnFirst":5.0,"chara":[{"id":402800,"motion":0,"textHome":"A powerful light that will dispel@the darkness that covers this country."}]},{"autoTurnFirst":3.6,"chara":[{"id":402800,"motion":100,"textHome":"Let's create a miracle together."}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":402800,"motion":1,"textHome":"To turn the prayers and wishes@I made on that day in front@of Monsieur Angel into reality."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402800}]},{"autoTurnFirst":3.0,"chara":[{"id":402800,"motion":200}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_17":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402800,"motion":201,"pos":1,"voice":"vo_char_4028_00_24","textHome":"I'm grateful for a new day."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402800}]},{"autoTurnFirst":5.1,"chara":[{"id":402800,"motion":0,"textHome":"Even if my remaining time is short,@I will continue to do what I can@to bring light to this country."}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":402800,"motion":300}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402800}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":100}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":5.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":100,"pos":1,"voice":"vo_char_4028_00_25","textHome":"In my hometown, I always began@my day with morning prayers."}]},{"autoTurnFirst":1.5,"chara":[{"id":402800,"motion":1,"textHome":"Afterward, Catherine would go@somewhere chasing after the sheeps,@causing quite a commotion."}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402800}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":201}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":1,"pos":1,"voice":"vo_char_4028_00_26","textHome":"Near the village of Domrémy,@there is a tree called the Fairy Tree."}]},{"autoTurnFirst":2.0,"chara":[{"id":402800,"motion":100,"textHome":"I used to have lunch under@that tree with Catherine."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402800}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":0.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402800,"motion":1,"pos":1,"voice":"vo_char_4028_00_02"}]},{"autoTurnFirst":9.0,"chara":[{"eyeClose":1,"id":402800,"textHome":"Elisa... Melissa... Perenelle...@Everyone is fighting for my sake..."}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":0,"id":402800,"textHome":"That's why, Liz, I will go.@To bring light to this country...@to this world...!"}]},{"autoTurnFirst":4.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402800,"motion":201}]},{"autoTurnFirst":3.0,"chara":[{"id":402800,"motion":100}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402800,"motion":201,"pos":1,"voice":"vo_char_4028_00_27","textHome":"Elisa loves meat."}]},{"autoTurnFirst":5.6,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402800,"motion":0,"textHome":"Since I don't eat meat, I would give it@to her when I was served it for dinner."}]},{"autoTurnFirst":1.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":100}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402800,"textHome":"Oh, but I really love fish."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":1}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":0,"pos":1,"voice":"vo_char_4028_00_28","textHome":"Sometimes, I have dreams."}]},{"autoTurnFirst":10.2,"chara":[{"eyeClose":1,"id":402800,"motion":1,"textHome":"Dreams where I pray at the church, tend to@the sheeps, complete the daily tasks of@spinning and sewing, and quietly go to sleep..."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402800}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402800,"motion":300,"textHome":"The peacefulness of my hometown."}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":0.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402800,"motion":400,"pos":1,"voice":"vo_char_4028_00_29","textHome":"Ah, I was thinking a little."}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402800,"motion":1,"textHome":"I wonder what kind of future the people@hundreds of years from now are living in."}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800}]},{"autoTurnFirst":3.4,"chara":[{"id":402800,"motion":201,"textHome":"I hope that it is a wonderful future."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":402800}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402800,"motion":300,"pos":1,"voice":"vo_char_4028_00_30","textHome":"I don't have much time left@to fight in this form."}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402800,"motion":200,"textHome":"Let's vanquish the darkness together."}]},{"autoTurnFirst":3.3,"chara":[{"id":402800,"motion":201,"textHome":"Before the miracle comes to an end."}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402800,"motion":1,"pos":1,"voice":"vo_char_4028_00_31","textHome":"I'm not good at sparring with others..."}]},{"autoTurnFirst":2.9,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402800,"textHome":"When I sparred with Elisa before,@she took away my weapon. I couldn't@do anything and ended up losing..."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402800,"motion":300}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402800,"motion":201,"pos":1,"voice":"vo_char_4028_00_32","textHome":"When I fought,@I've always had someone with me."}]},{"autoTurnFirst":3.1,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":1,"textHome":"Thanks to having companions by my side,@I've been able to keep fighting all this time."}]},{"autoTurnFirst":3.7,"chara":[{"eyeClose":1,"id":402800}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_26":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":100,"pos":1,"voice":"vo_char_4028_00_33","textHome":"Liz seems to like sweets."}]},{"autoTurnFirst":0.1,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402800}]},{"autoTurnFirst":2.8,"chara":[{"id":402800,"motion":1,"textHome":"When we ran out of honey during our journey,@she was so sad that she couldn't even speak."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":402800}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":6.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402800,"motion":1,"pos":1,"voice":"vo_char_4028_00_34","textHome":"\"Why Monsieur Angel?\" you ask?"}]},{"autoTurnFirst":4.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":100,"textHome":"They convey the divine word,@turn souls into gems,@and possess radiant rings."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":402800}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402800,"motion":201,"textHome":"That's what an angel is, right?"}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402800,"motion":400,"pos":1,"voice":"vo_char_4028_00_35","textHome":"Oh? Are you curious about this weapon?"}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":0,"textHome":"Indeed, scythes and hatchets@are Liz's specialty weapons."}]},{"autoTurnFirst":5.0,"chara":[{"id":402800,"motion":1,"textHome":"I always use a sword or a spear."}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":5.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402800,"motion":300,"pos":1,"voice":"vo_char_4028_00_36","textHome":"I am not the only one who@fought to save this country."}]},{"autoTurnFirst":1.7,"chara":[{"eyeClose":1,"id":402800,"textHome":"It is because everyone...shed blood@and fought for the sake of France@that we have what we have now!"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402800}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":402800,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"id":402800,"motion":201}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":0,"pos":1,"voice":"vo_char_4028_00_03"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402800,"motion":100}]}],"group_30":[{"autoTurnFirst":4.9,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":1,"pos":1,"voice":"vo_char_4028_00_37","textHome":"Perenelle always helps us with protective@and healing magic, as well as alchemy."}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402800,"motion":201}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402800,"motion":300,"textHome":"How long has she been watching over us...?"}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":3.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":0,"pos":1,"voice":"vo_char_4028_00_38","textHome":"Noble-heartedness and@strong determination..."}]},{"autoTurnFirst":4.9,"chara":[{"eyeClose":1,"id":402800,"motion":201,"textHome":"When I go down the wrong path,@she admonishes me strongly..."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402800}]},{"autoTurnFirst":1.7,"chara":[{"id":402800,"motion":0,"textHome":"Because of Elisa,@I was able to stand up again."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":100}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":8.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402800,"motion":1,"pos":1,"voice":"vo_char_4028_00_39","textHome":"Come to think of it, only Melissa@and I call the angel \"Monsier Angel\"."}]},{"autoTurnFirst":3.0,"chara":[{"id":402800,"motion":300,"textHome":"I wonder why that is?"}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":5.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":402800,"motion":300,"pos":1,"voice":"vo_char_4028_00_40","textHome":"If I hadn't met Liz,@what kind of future awaited me?"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402800,"textHome":"...No, this is the guidance@of the angels, the will of God,"}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402800}]},{"autoTurnFirst":2.6,"chara":[{"id":402800,"motion":0}]},{"autoTurnFirst":2.4,"chara":[{"id":402800,"motion":201}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":402800,"textHome":"so it's meaningless to imagine."}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":6.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":402800,"motion":0,"pos":1,"voice":"vo_char_4028_00_41","textHome":"Mmmh~...@Big Sis Liz..."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402800}]},{"autoTurnFirst":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402800,"motion":400,"textHome":"...Oh!@S-Sorry.@I...dozed off for a moment."}]},{"autoTurnFirst":1.8,"chara":[{"cheek":2,"face":"mtn_ex_030.exp.json","id":402800}]},{"autoTurnFirst":3.2,"chara":[{"id":402800,"motion":300}]},{"autoTurnFirst":2.8,"chara":[{"cheek":1,"id":402800,"motion":1,"textHome":"It seems like...@I was having a pleasant dream."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":1,"face":"mtn_ex_050.exp.json","id":402800}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402800,"motion":201,"pos":1,"voice":"vo_char_4028_00_42","textHome":"Let's go, to bring light to the world!"}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402800,"motion":100,"pos":1,"voice":"vo_char_4028_00_43","textHome":"Was anyone injured?"}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":1.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":402800,"motion":0,"pos":1,"voice":"vo_char_4028_00_44","textHome":"I've decided...@I won't give up here..."}]},{"autoTurnFirst":0.1,"chara":[{"eyeClose":0,"id":402800}]},{"autoTurnFirst":2.0,"chara":[{"id":402800,"motion":200}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":402800,"motion":0,"pos":1,"voice":"vo_char_4028_00_45","textHome":"I will...keep moving forward.@Because that's all I can do."}]},{"autoTurnFirst":4.0,"chara":[{"id":402800,"motion":400}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":0,"pos":1,"voice":"vo_char_4028_00_46","textHome":"It's thanks to everyone...@and thanks to Liz."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":402800,"motion":201}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402800,"motion":0,"pos":1,"voice":"vo_char_4028_00_04"}]},{"autoTurnFirst":2.5,"chara":[{"id":402800,"motion":400}]}],"group_5":[{"autoTurnFirst":5.0,"chara":[{"cheek":-1,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":0,"pos":1,"voice":"vo_char_4028_00_05"}]}],"group_6":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":402800,"motion":0,"pos":1,"tear":0,"voice":"vo_char_4028_00_13","textHome":"Everyone's prayers give me strength...!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":100}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":1.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":402800,"motion":100,"pos":1,"voice":"vo_char_4028_00_14","textHome":"Thank you.@With this, I can fight against any enemy!"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":402800}]},{"autoTurnFirst":2.0,"chara":[{"id":402800,"motion":201}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":1.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":1,"pos":1,"voice":"vo_char_4028_00_15","textHome":"Please, call me Tart!"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402800}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":402800,"motion":1,"pos":1,"voice":"vo_char_4028_00_16","textHome":"Melissa's father is a fierce commander@whom people call La Hire."}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":402800,"motion":300,"textHome":"It seems that when both of them get angry,@their ears turn bright red,"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":402800,"motion":100,"textHome":"so they figured out they were father@and daughter at their first meeting."}]},{"chara":[{"id":402800,"textHomeStatus":"Clear"}]}]},"version":3}

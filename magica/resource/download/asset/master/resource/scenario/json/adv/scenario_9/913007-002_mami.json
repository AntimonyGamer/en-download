{"story":{"group_1":[{"armatureList":[{"animation":["action"],"armatureId":1,"filePath":"resource/image_native/effect/story/general/3507_film_frame.ExportJson","zOrder":"messageBack"}],"autoTurnLast":0.2,"bg":"bg_adv_20171.jpg","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200906,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200501,"motion":0,"pos":0}],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/mt_calender_day-xx.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"turnChangeIn":"fadeIn"},{"bgm":"bgm01_anime04","chara":[{"id":200906,"motion":100,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-1"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]B-but...","turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200501,"motion":200,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-2"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Mabayu, are you running away?@After you've come this far?"},{"chara":[{"id":200906,"motion":200,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-3"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]Uhhh no, it's nothing like that..."},{"chara":[{"id":200906,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-4"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]But you can never be too cautious,@so I was thinking about looking into..."},{"autoTurnLast":0.01,"textAvClear":1},{"autoTurnLast":1.0,"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_030.exp3.json","id":200900,"motion":0,"pos":2}],"se":"7205_magic_girl"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200501,"motion":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-5"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]You're going to waste your magic@on something like this?"},{"chara":[{"id":200900,"motion":400,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-6"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]You don't understand,@this is a MAJOR issue for me."},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_040.exp3.json","id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-7"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]*Sigh* I suppose it can't be helped."},{"chara":[{"id":200900,"motion":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-8"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_001.exp3.json","id":200501}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]Yep, sorry. Now, let me just borrow@those eyes for a moment..."},{"autoTurnLast":0.2,"bg":"black","bgm":"stop","item":[{"anchor":"skip","path":"resource/scenario/img/scene0/mt_calender_day-xx.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"},{"path":"resource/scenario/img/scene0/film13_mami_seriously.jpg","posX":0,"posY":0,"visible":"appear","zOrder":"charaFront"}],"textAvClear":1,"turnChangeIn":"fadeIn"},{"autoTurnLast":1.0,"turnChangeOut":"fadeOut"},{"autoTurnLast":0.01,"bg":"white","deleteArmatureList":[1],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/mt_calender_day-xx.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"turnChangeIn":"whiteIn"},{"autoTurnLast":0.01,"turnChangeOut":"whiteOut","turnChangeOutTime":0.1},{"armatureList":[{"animation":["action"],"armatureId":1,"filePath":"resource/image_native/effect/story/general/3507_film_frame.ExportJson","zOrder":"messageBack"}],"autoTurnLast":0.01,"surround":"8005_heartbeat"},{"armatureList":[{"animation":["action"],"armatureId":2,"filePath":"resource/image_native/effect/story/general/1509_prophecy_active.ExportJson","zOrder":"charaFront"}],"autoTurnLast":0.01},{"autoTurnLast":0.5,"bg":"bg_adv_20171.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200900,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_001.exp3.json","id":200501,"motion":0,"pos":0}],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/mt_calender_day-xx.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"turnChangeIn":"whiteIn","turnChangeInTime":0.2},{"chara":[{"id":200900,"lipSynch":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-9"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]......","turnChangeOut":"whiteOut"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200501,"motion":200,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-10"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]How was it, Mabayu?"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":200900,"motion":100,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-11"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]Umm, so...@I have a tiny request..."},{"autoTurnLast":1.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800102,"motion":0,"pos":1}],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/mt_calender_day-xx.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"textAvClear":1,"turnChangeIn":"fadeIn"},{"bgm":"bgm01_anime19","chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-12"}],"nameAvCenter":"","textAvCenter":"[fontSize:20]Excuse me.","textAvColorRGB":"255255255","turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"id":800102,"pos":2}],"textAvClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200501,"motion":1,"pos":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-13"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Hi, welcome."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-14"}],"nameAvRight":"","textAvColorRGB":"255255255","textAvRight":"[fontSize:20]I just want to hurry up and get@today's Witch hunt over with..."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-15"}],"nameAvRight":"","textAvRight":"[fontSize:20]What did you want to talk to me about?"},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200501,"motion":100,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-16"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Sorry, it won't take long."},{"chara":[{"id":200501,"motion":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-17"}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]You've been curious about how my@predictions are always accurate, right?"},{"chara":[{"id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-18"}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]I wanted to explain the reason for it."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-19"}],"nameAvRight":"","textAvColorRGB":"255255255","textAvRight":"[fontSize:20]The reason...?"},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":200501,"motion":200,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-20"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]The truth is, I've always had advance@knowledge of what's going to happen."},{"chara":[{"id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-21"}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]I've known where Witches would appear,@as well as their attacks and weaknesses@before even fighting them."},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":200501,"motion":300,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-22"}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]I'm sorry for keeping this from you.@So..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-23"}],"nameAvRight":"","textAvColorRGB":"255255255","textAvRight":"[fontSize:20]Hold on!"},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-24"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":200501,"motion":0}],"nameAvRight":"","textAvRight":"[fontSize:20]So...you've been manipulating me?"},{"chara":[{"id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-25"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]No, that wasn't my intent..."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-26"}],"nameAvRight":"","textAvColorRGB":"255255255","textAvRight":"[fontSize:20]I wasn't really sure if I wanted to be@a Magical Girl..."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-27"}],"nameAvRight":"","textAvRight":"[fontSize:20]But, on that day, you took the time@to talk to me about a lot of things..."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-28"}],"nameAvRight":"","textAvRight":"[fontSize:20]You convinced me to go ahead@with the contract..."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-29"}],"nameAvRight":"","textAvRight":"[fontSize:20]Was all of that because you could@see the future?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200501,"motion":300,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-30"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Well..."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-31"}],"nameAvRight":"","textAvColorRGB":"255255255","textAvRight":"[fontSize:20]I see...@That makes sense."},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-32"}],"nameAvRight":"","textAvRight":"[fontSize:20]No wonder. I thought you were oddly@pushy that day."},{"chara":[{"id":200501,"motion":200,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-33"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]But, I believed that making a contract@would help you out."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-34"}],"nameAvRight":"","textAvColorRGB":"255255255","textAvRight":"[fontSize:20]Since you recommended that I go forward@with it..."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-35"}],"nameAvRight":"","textAvRight":"[fontSize:20]I became a Magical Girl, and I got rich."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-36"}],"nameAvRight":"","textAvRight":"[fontSize:20]I was able to clear my father's debt,@and he started being nicer to us..."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-37"}],"nameAvRight":"","textAvRight":"[fontSize:20]We could be a happy family..."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-38"}],"nameAvRight":"","textAvRight":"[fontSize:20]At least, that's what I thought."},{"chara":[{"id":200501,"motion":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-39"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Even though your wish was for@your family's sake..."},{"chara":[{"cheek":1,"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-40"}],"nameAvRight":"","textAvColorRGB":"255255255","textAvRight":"[fontSize:20]The result was disastrous."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-41"}],"nameAvRight":"","textAvRight":"[fontSize:20]Once we had wealth, everyone in my family@began indulging their own selfish desires..."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-42"}],"nameAvRight":"","textAvRight":"[fontSize:20]Now, my parents have divorced, and@they're arguing over alimony and what not..."},{"chara":[{"eyeClose":1,"id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-43"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]I'm so sorry.@I had no idea that would happen..."},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-44"}],"nameAvRight":"","textAvColorRGB":"255255255","textAvRight":"[fontSize:20]But why didn't you?"},{"chara":[{"cheek":1,"face":"mtn_ex_020.exp3.json","id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-45"},{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":200501}],"nameAvRight":"","textAvRight":"[fontSize:20]You can see the future, can't you?"},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-46"}],"nameAvRight":"","textAvRight":"[fontSize:20]You're the one that changed my future,@right?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200501,"motion":300,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-47"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Um, that's..."},{"chara":[{"cheek":1,"face":"mtn_ex_030.exp3.json","id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-48"}],"nameAvRight":"","textAvColorRGB":"255255255","textAvRight":"[fontSize:20]I didn't mind staying poor...if it meant@my family could get along and stay together."},{"chara":[{"cheek":2,"face":"mtn_ex_020.exp3.json","id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-49"}],"nameAvRight":"","textAvRight":"[fontSize:20]But all because you pressured me@into this...!"},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-50"}],"nameAvRight":"","textAvRight":"[fontSize:20]Because you gave me hope that, if I become@a Magical Girl, my wish would come true...!"},{"autoTurnLast":0.01,"textAvClear":1},{"autoTurnLast":1.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":250313,"motion":0,"pos":1}],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/mt_calender_day-xx.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"se":"7205_magic_girl","turnChangeIn":"whiteIn"},{"chara":[{"cheek":0,"face":"mtn_ex_052.exp3.json","id":250313,"motion":400,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-51"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Wait, no...!@Stop...!","turnChangeOut":"whiteOut"},{"autoTurnLast":3.5,"nameAvRight":"","textAvColorRGB":"255255255","textAvRight":"[fontSize:20][flashEffect:flashWhiteSlow2]All because of that, I...!@I...!","voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-52"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":250313}],"textAvClear":1},{"autoTurnLast":1.0,"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":200910,"motion":0,"pos":1}],"flashEffect":"explosion"},{"nameAvRight":"","textAvColorRGB":"255255255","textAvRight":"[fontSize:20]...?!","voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-53"},{"chara":[{"id":200910,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-54"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]Those memories...","textAvColor":"textMabayu"},{"chara":[{"id":200910,"motion":400,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-55"}],"nameAvCenter":"Mabayu","textAvCenter":"[fontSize:20]I'll cut them out for you.","turnEffect":"promist"},{"autoTurnLast":0.01,"bgm":"stop","textAvClear":1},{"autoTurnLast":0.2,"bg":"white","deleteArmatureList":[1],"turnChangeIn":"whiteIn","turnEffect":"stop"},{"autoTurnLast":1.5,"flashEffect":"flashWhite2","surround":"8098_filmcut_cutting"},{"autoTurnLast":0.01,"turnChangeOut":"whiteOut"},{"armatureList":[{"animation":["action"],"armatureId":2,"filePath":"resource/image_native/effect/story/general/3507_film_frame.ExportJson","zOrder":"messageBack"}],"autoTurnLast":1.0,"bg":"bg_adv_20171.jpg","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":800102,"motion":0,"pos":1}],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/mt_calender_day-xx.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"se":"7205_magic_girl","turnChangeIn":"fadeIn"},{"chara":[{"id":800102,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-56"}],"nameAvCenter":"","textAvCenter":"[fontSize:20]Ah...","textAvColorRGB":"255255255","turnChangeOut":"fadeOut"},{"autoTurnLast":1.0,"chara":[{"effect":"fadeout","id":800102}],"se":"3002_chara_dead","textAvClear":1},{"bgm":"bgm02_anime07","chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200501,"motion":200,"pos":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-57"},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":200900,"motion":0,"pos":2}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Mabayu?!@What did you do just now...?"},{"autoTurnLast":0.01,"textAvClear":1},{"chara":[{"id":200900,"motion":200,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-58"}],"item":[{"path":"resource/scenario/img/scene0/film04_mabayu_scissors.png","posX":0,"posY":0,"visible":"appear","zOrder":"messageFront"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]I cut her memories with these scissors."},{"chara":[{"id":200900,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-59"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]Once she wakes up, she won't remember@that you convinced her."},{"chara":[{"id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-60"},{"id":200900,"motion":0}],"item":[{"path":"resource/scenario/img/scene0/film04_mabayu_scissors.png","visible":"hide"}],"nameAvLeft":"Mami","textAvColor":"textMami","textAvLeft":"[fontSize:20]Cut...her memories...?"},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200501,"motion":300,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-61"}],"nameAvLeft":"Mami","textAvLeft":"[fontSize:20]When did you get a skill like that...?"},{"chara":[{"id":200900,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-62"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]I saw it in a vision."},{"chara":[{"eyeClose":1,"id":200900,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-63"},{"id":200501,"motion":0}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]Turning someone's life into a film,@and snipping it with my scissors..."},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":200900,"motion":300,"voiceFullAuto":"fullvoice/section_104213/vo_full_913007-002-64"}],"nameAvRight":"Mabayu","textAvRight":"[fontSize:20]Apparently, that's my real ability."},{"autoTurnLast":2.0,"deleteArmatureList":[2],"turnChangeIn":"fadeIn"}]},"version":3}

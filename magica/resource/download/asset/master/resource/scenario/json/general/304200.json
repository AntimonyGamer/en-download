{"story":{"group_1":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":304200,"motion":100,"pos":1,"voice":"vo_char_3042_00_01","textHome":"First-magnitude stars of all kinds,@shining across the globe!"}]},{"autoTurnFirst":3.2,"chara":[{"id":304200,"motion":300,"textHome":"Meguru Hibiki here exists to watch 'em,@listen to their stories,@and spread their splendor far and wide!"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":304200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":0}]},{"autoTurnFirst":3.3,"chara":[{"id":304200,"motion":1}]},{"autoTurnFirst":2.1,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":0,"textHome":"And today, I've locked onto YOU!"}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":304200,"motion":100,"textHome":"I'm feelin' the glow of the brightest star@in the sky, right down to the sparkle!"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":200,"pos":1,"voice":"vo_char_3042_00_17","textHome":"Okay, okay!@It's fine to run away@if the going gets tough."}]},{"autoTurnFirst":1.9,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":0,"textHome":"Meguru here runs away all the time."}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":1,"textHome":"Challenges and perseverance are important,@but so is knowing when to quit, right?"}]},{"autoTurnFirst":3.0,"chara":[{"id":304200,"motion":100}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":2.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":1,"pos":1,"voice":"vo_char_3042_00_18","textHome":"Even among those of us@who had wishes granted,"}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304200,"textHome":"there are still some who doubt@their dreams will come true."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":100,"textHome":"Not Meguru, though!@If it's within reach,@I'll grab hold for sure!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":400}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":304200,"motion":0,"pos":1,"voice":"vo_char_3042_00_19","textHome":"After the umpteenth award ceremony, what's@the gold trophy gonna look like this time?!"}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":304200}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":400}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":3.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304200,"motion":0,"pos":1,"voice":"vo_char_3042_00_20","textHome":"A voice just came down from the heavens...!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":100,"textHome":"Did something awaken in me?!"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304200,"motion":1,"pos":1,"voice":"vo_char_3042_00_21","textHome":"Honestly, I don't even@need to puzzle about it.@The words come flowing right out!"}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":304200,"motion":100,"textHome":"Is this what it means to be@\"in the zone\"?"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":200,"pos":1,"voice":"vo_char_3042_00_22"}]},{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp.json","id":304200,"motion":300}]},{"autoTurnFirst":0.3,"chara":[{"eyeClose":0,"id":304200}]},{"autoTurnFirst":3.8,"chara":[{"id":304200,"motion":1}]},{"autoTurnFirst":1.9,"chara":[{"id":304200,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":100}]}],"group_16":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304200,"motion":400,"pos":1,"voice":"vo_char_3042_00_23"}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":304200,"motion":100}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":304200}]},{"autoTurnFirst":2.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":0}]},{"autoTurnFirst":2.8,"chara":[{"id":304200,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200}]}],"group_17":[{"autoTurnFirst":2.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304200,"motion":200,"pos":1,"voice":"vo_char_3042_00_24","textHome":"Here comes the runner Meguru!"}]},{"autoTurnFirst":4.0,"chara":[{"id":304200,"motion":0,"textHome":"Just in time for her meeting!"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":304200,"motion":400,"textHome":"AND SHE'S CROSSED THE FINISH LIIIINE!"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":304200,"motion":300,"textHome":"*Pant*... *Pant*..."}]},{"autoTurnFirst":2.0,"chara":[{"cheek":1,"face":"mtn_ex_011.exp.json","id":304200,"motion":0,"textHome":"Sorry to keep you waiting~."}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":1.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304200,"motion":0,"pos":1,"voice":"vo_char_3042_00_25","textHome":"Eggs, cracked and dropped!"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304200,"motion":400}]},{"autoTurnFirst":5.0,"chara":[{"id":304200,"motion":100,"textHome":"Whaddaya get when you add the@smell of bacon to the harmony@of the eggs in the frying pan?!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":1,"textHome":"...Iiit's BREAKFAST!"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304200,"motion":0,"pos":1,"voice":"vo_char_3042_00_26","textHome":"Mm?@I'm just watchin'."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"textHome":"It's hard to eat when@someone's calling a play-by-play,"}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304200,"motion":300,"textHome":"and I've really cheesed people off@with that before..."}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":304200,"motion":1,"textHome":"But that means I don't have@anything to talk about."}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":1.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":400,"pos":1,"voice":"vo_char_3042_00_02","textHome":"Lookie here! Now YOU are one up-and-coming@big shot Magical Girl, am I right?!"}]},{"autoTurnFirst":4.1,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":1}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":200,"textHome":"Your pro announcer, Meguru Hibiki, is gonna@give you the broadcast of a lifetime!"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":100}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":200,"pos":1,"voice":"vo_char_3042_00_27","textHome":"Alright!@School's out,"}]},{"autoTurnFirst":5.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":1,"textHome":"and I'm bringing you a basketball showdown@between the bitterest of rivals:@the soccer and baseball teams!"}]},{"autoTurnFirst":1.6,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304200,"motion":0,"textHome":"Are they trying@to even the playing field...?"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304200,"motion":300,"textHome":"What in the heck is this...?"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":200,"pos":1,"voice":"vo_char_3042_00_28","textHome":"Are you tuned in, sports fans?!"}]},{"autoTurnFirst":3.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":1,"textHome":"Nighttime serves up battles@between Magical Girls and Witches."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_050.exp.json","id":304200,"motion":400,"textHome":"Woah!@If you come over here, I'm not gonna@be able to dish out the commentary!"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":300,"pos":1,"voice":"vo_char_3042_00_29","textHome":"Ehehe..."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304200,"textHome":"I'm a chatterbox@who's always causing trouble,"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":304200,"motion":200,"textHome":"but you know, I'm actually still@in demand from all sorts of areas~."}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":5.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304200,"motion":400,"pos":1,"voice":"vo_char_3042_00_30","textHome":"Ack, th-th-this can't be...!@How can a Witch show up when@my friends aren't around...?!"}]},{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":304200,"motion":100,"textHome":"It's so hard to give@a play-by-play while I'm fighting!"}]},{"autoTurnFirst":0.4,"chara":[{"eyeClose":0,"id":304200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":304200,"motion":200,"textHome":"Wait, I don't even have@an audience to begin with!"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304200,"motion":400,"pos":1,"voice":"vo_char_3042_00_31","textHome":"No way—@is it about to start?"}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":100,"textHome":"It's the main event in Endless Mirrors!"}]},{"autoTurnFirst":1.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":200,"textHome":"Meguru here is stepping up to bat!"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":1,"textHome":"Once again, I'm coming at you LIVE@to bring you everyone's heroics!"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304200,"motion":400,"pos":1,"voice":"vo_char_3042_00_32"}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":304200,"motion":1}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":304200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":304200,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200}]}],"group_26":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":100,"pos":1,"voice":"vo_char_3042_00_33","textHome":"This notepad is where I compile phrases@that catch my attention on the TV or radio."}]},{"autoTurnFirst":2.5,"chara":[{"id":304200,"motion":1,"textHome":"By the way,@a few of them are from students."}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":304200,"motion":300,"textHome":"Sometimes they've got some real zingers."}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":0,"pos":1,"voice":"vo_char_3042_00_34","textHome":"I'm just on my way to the arcade."}]},{"autoTurnFirst":3.3,"chara":[{"id":304200,"motion":1,"textHome":"Of course, I'm a commentator,@not a player."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":200,"textHome":"If you're gonna participate,@look forward to it!"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":2.4,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304200,"motion":400,"pos":1,"voice":"vo_char_3042_00_35","textHome":"Okaaay! Quiet!"}]},{"autoTurnFirst":2.1,"chara":[{"id":304200,"motion":0,"textHome":"Talking about tests is now BANNED!"}]},{"autoTurnFirst":2.8,"chara":[{"eyeClose":1,"id":304200,"motion":1,"textHome":"Especially in front of me!"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":304200,"motion":300,"textHome":"Now I've gotta forget it again!@Hrmm..."}]},{"autoTurnFirst":0.5,"chara":[{"eyeClose":0,"id":304200}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":400,"textHome":"Alright, it's gone!"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":2.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304200,"motion":100,"pos":1,"voice":"vo_char_3042_00_36","textHome":"While I'm thinking of it, I'm gonna@be with the broadcasting club today."}]},{"autoTurnFirst":2.6,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"textHome":"Do you have any song requests?"}]},{"autoTurnFirst":4.0,"chara":[{"id":304200,"motion":1,"textHome":"Since we're buddies,@I can squeeze something in for ya."}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp.json","id":304200,"motion":300,"pos":1,"voice":"vo_char_3042_00_03"}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":304200}]}],"group_30":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":304200,"motion":100,"pos":1,"voice":"vo_char_3042_00_37","textHome":"Hmmm..."}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":0,"id":304200,"textHome":"You know how I'm always@wandering from place to place?"}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":200,"textHome":"I guess that's given me@a lot of connections,"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304200,"textHome":"but honestly, I don't feel like@there's anyone I'm really close with."}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":0.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304200,"motion":400,"pos":1,"voice":"vo_char_3042_00_38","textHome":"Ooh, that look!@That has to be THE number-one@facial expression of the day!"}]},{"autoTurnFirst":1.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":200}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":1,"textHome":"Time to roll out the questions!"}]},{"autoTurnFirst":5.0,"chara":[{"id":304200,"motion":100,"textHome":"How are ya feeling at the moment?"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":1,"pos":1,"voice":"vo_char_3042_00_39","textHome":"Even if you don't have any@special skills, talents, or dreams,@everyone has the seed of something."}]},{"autoTurnFirst":3.3,"chara":[{"id":304200,"motion":100}]},{"autoTurnFirst":1.4,"chara":[{"id":304200,"motion":200,"textHome":"So you've gotta believe in your future."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":3.7,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":300,"pos":1,"voice":"vo_char_3042_00_40","textHome":"I'm giving you a title@for always following me around,@even though I heckle you nonstop!"}]},{"autoTurnFirst":1.7,"chara":[{"cheek":0,"face":"mtn_ex_020.exp.json","id":304200,"motion":0}]},{"autoTurnFirst":0.8,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":200,"textHome":"It's...@Meguru's Best Friend!"}]},{"autoTurnFirst":2.4,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200}]},{"autoTurnFirst":5.0,"chara":[{"id":304200,"motion":1,"textHome":"I hope you cherish it from now on♪"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":1.3,"chara":[{"cheek":1,"eyeClose":1,"face":"mtn_ex_030.exp.json","id":304200,"motion":0,"pos":1,"voice":"vo_char_3042_00_41","textHome":"Ehehe..."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":304200}]},{"autoTurnFirst":3.5,"chara":[{"id":304200,"motion":1,"textHome":"I sure am quiet@when I'm not broadcasting, eh?"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":1,"face":"mtn_ex_010.exp.json","id":304200,"motion":200,"textHome":"When my switch is flicked on,@I go full throttle..."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":1,"face":"mtn_ex_030.exp.json","id":304200,"motion":300,"textHome":"but I'm usually pretty mellow otherwise..."}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":400,"pos":1,"voice":"vo_char_3042_00_42","textHome":"I'll bring you another clincher today!"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":200,"pos":1,"voice":"vo_char_3042_00_43","textHome":"That was a good fight!@Magnifique!"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":1,"pos":1,"voice":"vo_char_3042_00_44","textHome":"Time to decide the MVP!!"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":100,"pos":1,"voice":"vo_char_3042_00_45","textHome":"Now THAT'S a victory@to get talkin' about!"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":4.0,"chara":[{"cheek":1,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304200,"motion":400,"pos":1,"voice":"vo_char_3042_00_46","textHome":"Your MC's blood is boiling,@and it's NEEEEVER getting cold!"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp.json","id":304200,"motion":400,"pos":1,"voice":"vo_char_3042_00_04"}]}],"group_5":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":200,"pos":1,"voice":"vo_char_3042_00_05"}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200}]}],"group_6":[{"autoTurnFirst":4.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":100,"pos":1,"voice":"vo_char_3042_00_13","textHome":"I guess my commentating skills@have improved a bit, eh?"}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":304200,"motion":1,"pos":1,"voice":"vo_char_3042_00_14","textHome":"This is it! We're rolling@Meguru's \"Best Of\" reel right now!"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":304200}]},{"autoTurnFirst":3.0,"chara":[{"id":304200,"motion":200}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp.json","id":304200,"motion":1,"pos":1,"voice":"vo_char_3042_00_15","textHome":"Aw jeez, the situation@I'm in now is the result of having@zero redeeming features, isn't it..."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":304200}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp.json","id":304200,"motion":300}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp.json","id":304200,"motion":0,"pos":1,"voice":"vo_char_3042_00_16","textHome":"No talents, no skills, no nothin'?"}]},{"autoTurnFirst":2.55,"chara":[{"cheek":0,"face":"mtn_ex_011.exp.json","id":304200,"motion":300,"textHome":"Well, hey, I say c'est la vie!"}]},{"autoTurnFirst":2.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp.json","id":304200,"motion":200,"textHome":"I was the same way, but every flower@blossoms when the time's right. Mm-hm."}]},{"autoTurnFirst":3.4,"chara":[{"id":304200,"motion":1}]},{"autoTurnFirst":1.0,"chara":[{"eyeClose":1,"id":304200}]},{"chara":[{"id":304200,"textHomeStatus":"Clear"}]}]},"version":3}

oice/section_104213/vo_full_913003-001-35"}],"nameAvRight":"Mami","textAvColor":"textMami","textAvRight":"[fontSize:20]I'm looking forward to it, Mabayu."},{"chara":[{"id":200906,"motion":0,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-36"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]S-sure..."},{"chara":[{"id":200906,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-37"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]M-me too, I think..."},{"chara":[{"cheek":1,"id":200906,"motion":300,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-38"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]Miss...Mami?"},{"autoTurnLast":2.0,"deleteArmatureList":[1],"turnChangeIn":"fadeIn"}]},"version":3}

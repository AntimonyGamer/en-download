ize:20]Go buy some for your friend, too."},{"chara":[{"id":200906,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-14"}],"nameAvRight":"Mabayu","textAvColor":"textMabayu","textAvRight":"[fontSize:20]Sure thing."},{"autoTurnLast":1.8,"chara":[{"effect":"fadeout","id":200906}],"surround":"8017_1footsteps","textAvClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200501,"motion":100,"pos":2,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-15"},{"id":833400}],"nameAvRight":"Mami","surround":"stop","textAvColor":"textMami","textAvRight":"[fontSize:20]Sorry to be a bother."},{"chara":[{"id":833400,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-16"}],"nameAvLeft":"Mabayu's Mother","textAvColorRGB":"255255255","textAvLeft":"[fontSize:20]No, it's fine."},{"chara":[{"id":833400,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-16b"}],"nameAvLeft":"Mabayu's Mother","textAvLeft":"[fontSize:20]Thank you for coming along with@Mabayu for the visit."},{"chara":[{"id":833400,"motion":300,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-17"},{"id":200501,"motion":0}],"nameAvLeft":"Mabayu's Mother","textAvLeft":"[fontSize:20]She's always been shy and reserved,@so she's had trouble making friends..."},{"chara":[{"eyeClose":1,"id":833400,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-18"}],"nameAvLeft":"Mabayu's Mother","textAvLeft":"[fontSize:20]I was actually a little surprised@to see you with her."},{"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_011.exp3.json","id":833400,"motion":1,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-19"}],"nameAvLeft":"Mabayu's Mother","textAvLeft":"[fontSize:20]Thank you for keeping her company."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-20"}],"nameAvRight":"Mami","textAvColor":"textMami","textAvRight":"[fontSize:20]Oh no, it's no big deal..."},{"chara":[{"cheek":0,"face":"mtn_ex_014.exp3.json","id":833400,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-21"}],"nameAvLeft":"Mabayu's Mother","textAvColorRGB":"255255255","textAvLeft":"[fontSize:20]I hope you'll continue to spend time@together."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200501,"motion":100,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-22"}],"nameAvRight":"Mami","textAvColor":"textMami","textAvRight":"[fontSize:20]Of course."},{"autoTurnLast":1.5,"bg":"bg_adv_21013.jpg","bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":200501,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_000.exp3.json","id":200906,"motion":0,"pos":0}],"item":[{"anchor":"skip","path":"resource/scenario/img/scene0/mt_calender_day-xx.png","posX":-4,"posY":-50,"visible":"appear","zOrder":"messageFront"}],"textAvClear":1,"turnChangeIn":"fadeIn"},{"chara":[{"id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-23"}],"nameAvRight":"Mami","textAvColor":"textMami","textAvRight":"[fontSize:20]Your mother...seemed quite calm.","turnChangeOut":"fadeOut"},{"bgm":"bgm02_anime02","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":200906,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-24"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]It's thanks to my wish."},{"chara":[{"cheek":0,"face":"mtn_ex_040.exp3.json","id":200501,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-25"}],"nameAvRight":"Mami","textAvColor":"textMami","textAvRight":"[fontSize:20]So, in the end your wish was...?"},{"chara":[{"id":200906,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-26"}],"nameAvLeft":"Mabayu","textAvColor":"textMabayu","textAvLeft":"[fontSize:20]To erase my mom's memories@of seeing the future."},{"chara":[{"id":200906,"motion":100,"voiceFullAuto":"fullvoice/section_104213/vo_full_913003-001-27"}],"nameAvLeft":"Mabayu","textAvLeft":"[fontSize:20]She was sweet, wasn't she? That's 
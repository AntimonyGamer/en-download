":1,"pos":0}],"nameLeft":"Sasara","textLeft":"Are you heading to the riverside@in Kosho as well, Sayuki?"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":303300,"motion":100,"pos":2}],"nameRight":"Sayuki","textRight":"Yes―!"},{"autoTurnLast":1.0,"bg":"bg_adv_narration.jpg","chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":303301,"motion":300,"pos":2},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":101301,"motion":400,"pos":0}],"turnChangeIn":"fadeIn","turnEffect":"blackFrame"},{"chara":[{"id":101301}],"nameLeft":"Asuka","textLeft":"If I may, have you decided on your new song's title?","turnChangeOut":"fadeOut"},{"chara":[{"id":303301,"motion":0}],"nameRight":"Sayuki","textRight":"Unfortunately, in the end we couldn't decide...@So we gave up for the day."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":303301,"motion":100,"pos":2}],"nameRight":"Sayuki","textRight":"I'm leaving it all to the Sayuki@of tomorrow mornii~iing."},{"autoTurnLast":0.01,"bg":"bg_adv_21563.jpg","chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":101300,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":303300,"motion":0,"pos":2}],"turnChangeIn":"fadeIn","turnEffect":"stop"},{"chara":[{"id":101300,"motion":200}],"nameLeft":"Asuka","textLeft":"I see, after that you even took time@to take care of this matter.","turnChangeOut":"fadeOut"},{"chara":[{"id":303300,"motion":200}],"nameRight":"Sayuki","textRight":"I got a telephone call from Rui,"},{"chara":[{"id":303300}],"nameRight":"Sayuki","textRight":"saying \"people are gathering at the river,@it's serious,\" and I rushed out right away!"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":300600,"motion":200,"pos":0}],"nameLeft":"Emiri","textLeft":"Same as us!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":303300,"motion":1,"pos":2}],"nameRight":"Sayuki","textRight":"I checked the group chat log to make sure,"},{"chara":[{"id":303300}],"nameRight":"Sayuki","textRight":"so I got most of the picture~"},{"autoTurnLast":1.5,"bg":"bg_adv_21503.jpg","bgm":"stop","turnChangeIn":"fadeIn"},{"autoTurnLast":1.0,"turnChangeOut":"fadeOut"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":300600,"motion":1,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101300,"motion":1,"pos":0}],"nameRight":"Emiri","textRight":"...Hum, isn't this around where RuiRui was talking@about?"},{"chara":[{"id":101300}],"nameLeft":"Asuka","textLeft":"But where is Rui...?"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":300400,"motion":400,"pos":2}],"nameRight":"Sasara","textRight":"[chara:300400:effect_emotion_surprise_0][se:7226_shock]Wah― What's that―?!"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":101300},{"effect":"fadeout","id":300400}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_21503.jpg","bgChangeEffect":"cameraPan"},{"autoTurnLast":2.0,"bgm":"bgm03_story08","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":801500,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":801100,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800300,"motion":0,"pos":1}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":801500},{"effect":"fadeout","id":801100},{"effect":"fadeout","id":800300}],"textClear":1},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800101,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800800,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800100,"motion":0,"pos":1}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":800101},{"effect":"fadeout","id":800800},{"effect":"fadeout","id":800100}],"textClear":1},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800201,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":801500,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_030.exp3.json","id":800500,"motion":0,"pos":1}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"effec
ht":"Who were invading Daito Ward@while carrying heavy bags..."},{"chara":[{"id":101300,"motion":300}],"nameRight":"Asuka","textRight":"W-what's happening here...?!"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

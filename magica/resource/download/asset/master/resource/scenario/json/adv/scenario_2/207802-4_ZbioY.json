{"story":{"group_1":[{"autoTurnLast":0.01,"bg":"bg_adv_21221.jpg","bgm":"bgm03_story10","chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":102801,"motion":0,"pos":1}],"turnChangeIn":"fadeIn"},{"autoTurnLast":2.5,"chara":[{"id":102801,"motion":200}],"turnChangeOut":"fadeOut"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102801}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp3.json","id":101701,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_051.exp3.json","id":102301,"motion":0,"pos":1}],"nameRight":"Mitama","textRight":"...Himena...Aika..."},{"chara":[{"id":102501,"motion":200}],"nameLeft":"Shizuka","textLeft":"How is this possible...? I...could have sworn that@we'd killed her a while ago..."},{"chara":[{"id":102301,"motion":300}],"nameCenter":"Ao","textCenter":"She's...not a ghost, right...?"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":101701},{"effect":"fadeout","id":102301},{"effect":"fadeout","id":102501}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":102801,"motion":1,"pos":1}],"nameCenter":"Himena","textCenter":"Omigosh, your reactions are PRICELESS!"},{"chara":[{"id":102801,"motion":100}],"nameCenter":"Himena","textCenter":"It's the cutie herself, in the flesh★"},{"autoTurnLast":0.2,"chara":[{"id":102801,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101601,"motion":400,"pos":2}],"nameRight":"Kanagi","textRight":"What is the meaning of this...?!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102801,"motion":200,"pos":0}],"nameLeft":"Himena","textLeft":"Aha, you look like you're gonna pop something!"},{"chara":[{"id":102801}],"nameLeft":"Himena","textLeft":"I'll fill you in on that in a sec..."},{"chara":[{"id":102801,"motion":400}],"nameLeft":"Himena","textLeft":"And I'll explain my plans, too."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":102801,"pos":0}],"nameLeft":"Himena","textLeft":"I get the feeling Nagirin has some doubts about@this cutie's capability.★"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":101601,"lipSynch":0,"motion":0}],"nameRight":"Kanagi","textRight":"..."},{"autoTurnLast":0.2,"textClear":1},{"autoTurnLast":2.0,"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_051.exp3.json","id":101701,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102501,"motion":0,"pos":0},{"cheek":0,"face":"mtn_ex_051.exp3.json","id":102301,"motion":1,"pos":1}],"turnChangeIn":"fadeIn","turnChangeInTime":1.5},{"chara":[{"id":101701},{"id":102301,"lipSynch":0}],"nameCenter":"Everyone","textCenter":"...","turnChangeOut":"fadeOut","turnChangeOutTime":1.5},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102301},{"effect":"fadeout","id":101701}],"textClear":1},{"autoTurnLast":0.2,"chara":[{"id":102501,"pos":2}],"textClear":1},{"bgm":"bgm05_event08","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102501,"motion":300},{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102801,"motion":0,"pos":0}],"nameRight":"Shizuka","textRight":"Y-you can't be serious..."},{"chara":[{"id":102801,"motion":200}],"nameLeft":"Himena","textLeft":"Whatcha mean?"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":101601,"motion":300,"pos":2}],"nameRight":"Kanagi","textRight":"Hmph...!@That's downright heinous...!"},{"chara":[{"id":101601}],"nameRight":"Kanagi","textRight":"But...this plan could certainly drive people,@hold them down..."},{"chara":[{"id":101601}],"nameRight":"Kanagi","textRight":"Maybe even force them to listen and obey...!"},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":102801,"motion":100,"pos":0}],"nameLeft":"Himena","textLeft":"Right?!@You dig me, Nagirin!"},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102301,"motion":200,"pos":2}],"nameRight":"Ao","textRight":"That sounds amazing...!@I'm definitely in, too...!"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":101601,"lipSynch":0,"motion":0,"pos":2}],"nameRight":"Kanagi","textRight":"(Carrying out this plan could destroy Kamihama...)"},{"chara":[{"id":101601,"lipSynch":0}],"nameRight":"Kanagi","textRight":"(Which would turn the eyes of the masses on me...)"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":101601,"lipSynch":0,"pos":2}],"nameRight":"Kanagi","textRight":"(However...)"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102801,"motion":0,"pos":0}],"nameLeft":"Himena","textLeft":"Mm...? What's up?"},{"chara":[{"cheek":0,"id":101601,"lipSynch":0,"pos":2}],"nameRight":"Kanagi","textRight":"(First, I must find out what's in this@woman's heart...!)"},{"autoTurnLast":1.0,"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_020.exp.json","id":101600,"motion":0,"pos":2}],"se":"7205_magic_girl","textClear":1},{"chara":[{"id":101600,"lipSynch":0,"motion":100}],"nameRight":"Kanagi","textRight":"(Right here, right now...@I need to...!)"},{"autoTurnLast":2.0,"flashEffect":"flashWhiteSlow2","textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":101600,"lipSynch":0,"motion":400}],"nameRight":"Kanagi","textRight":"[chara:101600:effect_emotion_surprise_0][se:7226_shock]...?!"},{"chara":[{"id":101600,"lipSynch":0}],"nameRight":"Kanagi","textRight":"(You fool...!)"},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102801,"motion":400,"pos":0}],"nameLeft":"Himena","textLeft":"[chara:102801:effect_emotion_surprise_0][se:7226_shock]Hang on, are you legit gonna transform indoors?! "},{"bgm":"stop","chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":102801,"pos":0}],"nameLeft":"Himena","textLeft":"...Did you, like,@[chara:102801:lipSynch_0][wait:2.0][chara:102801:motion_000][chara:102801:cheek_0][chara:102801:face_mtn_ex_011.exp.json][chara:102801:lipSynch_1]try to do something to me...?"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp3.json","id":101600,"lipSynch":0,"motion":300}],"nameRight":"Kanagi","textRight":"..."},{"autoTurnLast":1.0,"chara":[{"cheek":0,"effect":"ef_adv_05","face":"mtn_ex_000.exp.json","id":101601,"motion":0,"pos":2}],"se":"7205_magic_girl","textClear":1},{"bgm":"bgm05_event07","chara":[{"id":101601}],"nameRight":"Kanagi","textRight":"...I attempted to read your mind@with my personal magic."},{"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":102801,"motion":400,"pos":0}],"nameLeft":"Himena","textLeft":"Huh?! No way!@How am I supposed to go on after that?"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":102301,"lipSynch":0,"motion":0,"pos":2}],"nameRight":"Ao","textRight":"..."},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":101601,"motion":1,"pos":2},{"id":102801,"motion":0}],"nameRight":"Kanagi","textRight":"Alas, I could not..."},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":101701,"motion":0,"pos":2}],"nameRight":"Mitama","textRight":"You failed...?"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":101601,"motion":300,"pos":2}],"nameRight":"Kanagi","textRight":"Something in her head prevented me...@I believe it was a man."},{"chara":[{"cheek":0,"id":102801,"pos":0}],"nameLeft":"Himena","textLeft":"Eh?"},{"chara":[{"id":101601}],"nameRight":"Kanagi","textRight":"It was only a split-second of a shadow that@interrupted me, so I'm not positive..."},{"chara":[{"id":102801,"lipSynch":0,"motion":300}],"nameLeft":"Himena","textLeft":"..."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":102801,"pos":0},{"id":101601,"motion":0}],"nameLeft":"Himena","textLeft":"Whaaat~? Was that you, Hiko?"},{"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":102801,"motion":1}],"nameLeft":"Himena","textLeft":"Uh-huh, okay..."},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":102801,"motion":100,"pos":0}],"nameLeft":"Himena","textLeft":"Kyaha!★"},{"chara":[{"id":102801}],"nameLeft":"Himena","textLeft":"You can really show your cool side sometimes,@Hiko~."},{"chara":[{"cheek":0,"face":"mtn_ex_051.exp3.json","id":102301,"motion":1,"pos":2}],"nameRight":"Ao","textRight":"She has a man inside her...?@W-what does that mean...?"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103101,"motion":1,"pos":0}],"nameLeft":"San","textLeft":"What Her Highness wants by achieving Magical Girl@supremacy is a free love life."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103201,"motion":400,"pos":0}],"nameLeft":"Miyuri","textLeft":"And her partner exists in her head at the moment."},{"chara":[{"id":103201}],"nameLeft":"Miyuri","textLeft":"The two of them make plans together all the time."},{"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":102501,"motion":200,"pos":2}],"nameRight":"Shizuka","textRight":"That's a strange setup, isn't it?"},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":101601,"motion":0,"pos":2}],"nameRight":"Kanagi","textRight":"...There's no other way to look at it."},{"chara":[{"id":101601,"motion":200},{"cheek":0,"face":"mtn_ex_011.exp3.json","id":102801,"motion":1,"pos":0}],"nameRight":"Kanagi","textRight":"The brief glimpse I caught was not an illusion...@nor was it a delusion of any kind..."},{"chara":[{"id":101601,"lipSynch":0}],"nameRight":"Kanagi","textRight":"(I'd heard for some time that she would speak@to someone in her brain...)"},{"chara":[{"id":101601,"lipSynch":0}],"nameRight":"Kanagi","textRight":"(But she's not insane...)"},{"chara":[{"cheek":0,"id":101601,"lipSynch":0,"motion":300,"pos":2}],"nameRight":"Kanagi","textRight":"(Which means that every plan she's ever made,@every action she'll ever take—)"},{"chara":[{"id":101601,"lipSynch":0}],"nameRight":"Kanagi","textRight":"(Each one of them was carefully thought out...)"},{"chara":[{"cheek":0,"id":101601,"lipSynch":0,"motion":0,"pos":2}],"nameRight":"Kanagi","textRight":"..."},{"chara":[{"cheek":0,"eyeClose":1,"id":101601,"lipSynch":0,"pos":2}],"nameRight":"Kanagi","textRight":"(Murderous and calculating...)"},{"autoTurnLast":0.2,"chara":[{"id":101601,"pos":0}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":101701,"motion":300,"pos":2}],"nameRight":"Mitama","textRight":"Kanagi...?"},{"chara":[{"cheek":0,"eyeClose":0,"id":101601,"motion":200,"pos":0}],"nameLeft":"Kanagi","textLeft":"It would seem that I underestimated@the Neo-Magius a fair bit."},{"chara":[{"id":101601},{"id":101701,"motion":0}],"nameLeft":"Kanagi","textLeft":"You're not merely a ragtag band of strays."},{"autoTurnLast":0.2,"chara":[{"id":101601,"pos":2}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":102801,"motion":200,"pos":0}],"nameLeft":"Himena","textLeft":"That's kinda rude.@I get what you mean, though."},{"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":102801,"motion":100}],"nameLeft":"Himena","textLeft":"'Cause we're besties sharing the same destiny."},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":102801},{"effect":"fadeout","id":101701}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":101601,"lipSynch":0,"motion":300,"pos":1}],"nameCenter":"Kanagi","textCenter":"(The last point of contention...@[wait:1.0]is me...)"},{"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":101601,"lipSynch":0}],"nameCenter":"Kanagi","textCenter":"(I still lack integrity compared to the others...!)"},{"chara":[{"id":101601,"lipSynch":0,"motion":0}],"nameCenter":"Kanagi","textCenter":"(Probably because...)"},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":101601}],"textClear":1},{"autoTurnLast":0.1,"bg":"bg_adv_21221.jpg","bgChangeEffect":"cameraPan"},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_001.exp3.json","id":101701,"motion":0,"pos":2},{"cheek":0,"face":"mtn_ex_001.exp3.json","id":102501,"motion":1,"pos":0},{"cheek":0,"face":"mtn_ex_020.exp3.json","id":102301,"motion":200,"pos":1}]},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":101701},{"effect":"fadeout","id":102501},{"effect":"fadeout","id":102301}],"textClear":1},{"autoTurnLast":2.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103101,"motion":100,"pos":2},{"cheek":0,"face":"mtn_ex_014.exp3.json","id":103201,"motion":400,"pos":0},{"cheek":0,"face":"mtn_ex_011.exp3.json","id":102801,"motion":200,"pos":1}]},{"autoTurnLast":0.2,"chara":[{"effect":"fadeout","id":103101},{"effect":"fadeout","id":103201},{"effect":"fadeout","id":102801}],"textClear":1},{"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":101601,"lipSynch":0,"motion":0,"pos":1}],"nameCenter":"Kanagi","textCenter":"(Compared to them, I am still myself...)"},{"autoTurnLast":2.0,"turnChangeIn":"fadeIn"}]},"version":3}

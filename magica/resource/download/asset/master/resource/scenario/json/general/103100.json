{"story":{"group_1":[{"autoTurnFirst":2.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":0,"pos":1,"voice":"vo_char_1031_00_01","textHome":"My name is San Kagura."}]},{"autoTurnFirst":5.3,"chara":[{"id":103100,"motion":200,"textHome":"In the Neo-Magius,@I'm responsible for the supervision@and education of the Feathers."}]},{"autoTurnFirst":6.0,"chara":[{"id":103100,"motion":1,"textHome":"In the past when I was working@in the Wings of the Magius,@my role was also that of an instructor,"}]},{"autoTurnFirst":2.8,"chara":[{"id":103100,"textHome":"so perhaps I'm simply cut out for it."}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_050.exp3.json","id":103100,"motion":0,"textHome":"By the way, have you ever heard@of the Hikarizuka Fire Festival?"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":100,"textHome":"It's an annual festival@held in my hometown,"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103100,"textHome":"and I'd be happy@if you could come and see it."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_10":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_17","textHome":"Ever since I was a little girl,@I've been following the footsteps of@the people of the Youth Association,"}]},{"autoTurnFirst":2.0,"chara":[{"id":103100,"motion":301,"textHome":"so perhaps in their eyes,@I might as well be their@little sister or daughter."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_11":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103100,"motion":300,"pos":1,"voice":"vo_char_1031_00_18","textHome":"Because Miyu keeps praising me@in weird ways, even those@of the Youth Association..."}]},{"autoTurnFirst":3.5,"chara":[{"eyeClose":1,"id":103100,"textHome":"...have been flattering me@strangely lately."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":7.0,"chara":[{"id":103100,"motion":0,"textHome":"Well, I guess it's just natural@if I'm going to be held sacred@as a god sooner or later."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_12":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":200,"pos":1,"voice":"vo_char_1031_00_19","textHome":"Merely having a large number@of bullets will not cut it."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103100,"textHome":"You have to fire with the@intention of hitting everything."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_13":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_20","textHome":"I will not become a Witch,"}]},{"autoTurnFirst":2.5,"chara":[{"eyeClose":1,"id":103100,"textHome":"nor will I be killed@by a Magical Girl;"}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp3.json","id":103100,"motion":200,"textHome":"I WILL survive."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_14":[{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":100,"pos":1,"voice":"vo_char_1031_00_21","textHome":"Even if you're granted@a wish for your own sake,"}]},{"autoTurnFirst":5.6,"chara":[{"eyeClose":1,"id":103100,"textHome":"you still won't be able to enjoy@the delight of being a human being@if you end up becoming a Witch."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":6.0,"chara":[{"id":103100,"motion":1,"textHome":"That was why I joined@the Wings of the Magius."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_15":[{"autoTurnFirst":3.1,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":0,"pos":1,"voice":"vo_char_1031_00_22","textHome":"If the Hikarizuka Fire Festival@dies out because of the belief@that there is no god in this world,"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":301}]},{"autoTurnFirst":2.8,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_021.exp3.json","id":103100,"textHome":"then I shall become@a god in its place."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":200,"textHome":"That way, to the people,@I will be a god@they can see with their eyes."}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":1,"textHome":"The festival will survive for my sake,@and for my sake will the flames burn on."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_16":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":103100,"motion":300,"pos":1,"voice":"vo_char_1031_00_23","textHome":"My obsession with the festival,@my attachment to the city,"}]},{"autoTurnFirst":5.7,"chara":[{"eyeClose":0,"id":103100,"textHome":"are both feelings I have@because I cannot grow up..."}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103100,"motion":0,"textHome":"In truth, I should be grateful@to the city and the festival@for helping me grow up,"}]},{"autoTurnFirst":3.4,"chara":[{"id":103100,"motion":100,"textHome":"and step into a new@stage of life, and yet..."}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":103100,"textHome":"I was afraid to take that one step."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_17":[{"autoTurnFirst":5.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_24","textHome":"Knowing how strict I would be,@you still came to me for guidance?"}]},{"autoTurnFirst":4.9,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":100,"textHome":"Very well. If you've steeled yourself@for this, then I shall accompany you."}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103100,"textHome":"Note, however, that I can't@go easy on you, alright?"}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_18":[{"autoTurnFirst":4.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":0,"pos":1,"voice":"vo_char_1031_00_25","textHome":"Miyu and I have been going to school@together for quite a long time now."}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_042.exp3.json","id":103100,"motion":301,"textHome":"From the day after I found out that@we lived near each other, I would@stand waiting on the way to school."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":1,"textHome":"Soon enough,@she began following me around."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_19":[{"autoTurnFirst":4.8,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103100,"motion":400,"pos":1,"voice":"vo_char_1031_00_26","textHome":"Well now, you need to eat well@for lunch too, otherwise@you won't have any strength."}]},{"autoTurnFirst":3.8,"chara":[{"cheek":0,"face":"mtn_ex_042.exp3.json","id":103100,"motion":0,"textHome":"I'm not telling you@to be all stuffed and macho@like the men around here,"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":100,"textHome":"but at least@see to your nutrition, okay?"}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_2":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":200,"pos":1,"voice":"vo_char_1031_00_02","textHome":"If you don't mind it@being rather spartan,"}]},{"autoTurnFirst":3.5,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100,"textHome":"I can accompany you@to your combat training."}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103100,"motion":1,"textHome":"Seeing as I, San Kagura, will be@instructing you in person,@you ought to look forward to it."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_20":[{"autoTurnFirst":4.4,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_011.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_27","textHome":"From the smell of cooking dinner,@to the smell of boiling bathwater..."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":100,"textHome":"I love the scent of dusk in my town,@for it makes me feel as though@the town itself is alive."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103100}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_21":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":100,"pos":1,"voice":"vo_char_1031_00_28","textHome":"I'm proud to say, I think@I'm pretty good at winning@people's hearts through their stomachs."}]},{"autoTurnFirst":4.2,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103100}]},{"autoTurnFirst":2.3,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":0,"textHome":"All in all, the women in the@Youth Association taught me@how to cook very well, you know?"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103100,"motion":200}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_22":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp3.json","id":103100,"motion":300,"pos":1,"voice":"vo_char_1031_00_29","textHome":"The more new people@move into Hikarizuka,"}]},{"autoTurnFirst":3.4,"chara":[{"eyeClose":1,"id":103100,"textHome":"the more they want to@get rid of the Fire Festival..."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103100,"motion":0,"textHome":"Still, these people are also part@of the town I want to protect."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_23":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_042.exp3.json","id":103100,"motion":0,"pos":1,"voice":"vo_char_1031_00_30","textHome":"I've known the truth about@Witches for a long time."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp3.json","id":103100,"motion":1,"textHome":"Even so, I won't go easy on those@who harm people, and will make sure@they are taken care of."}]},{"autoTurnFirst":2.0,"chara":[{"id":103100,"motion":200}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103100,"textHome":"After all,@I've already made up my mind."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_24":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103100,"motion":301,"pos":1,"voice":"vo_char_1031_00_31","textHome":"The Endless Mirrors@is a rather unsettling place..."}]},{"autoTurnFirst":4.3,"chara":[{"id":103100,"motion":100,"textHome":"I can tell when Miyu is a fake@by the way she reacts@when I show her my legs,"}]},{"autoTurnFirst":6.0,"chara":[{"eyeClose":1,"id":103100,"textHome":"but figuring out the others@is something that I'm still@getting used to..."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_25":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_042.exp3.json","id":103100,"motion":301,"pos":1,"voice":"vo_char_1031_00_32","textHome":"Some say I'm@cold-hearted and cruel,"}]},{"autoTurnFirst":2.7,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":0,"textHome":"but don't you think@that's natural?"}]},{"autoTurnFirst":8.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":1,"textHome":"After all, we're trying to win@the right to live whilst@fighting for our lives."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_26":[{"autoTurnFirst":7.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_030.exp3.json","id":103100,"motion":300,"pos":1,"voice":"vo_char_1031_00_33","textHome":"Hmm...still no luck.@This time again, I'll have no@choice but to rely on my memory."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_021.exp3.json","id":103100,"motion":0,"textHome":"For some reason, English is the@only subject I can't quite master,@so I end up memorizing the textbook."}]},{"autoTurnFirst":4.0,"chara":[{"eyeClose":1,"id":103100,"motion":400,"textHome":"So frustrating..."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_27":[{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":0,"face":"mtn_ex_050.exp3.json","id":103100,"motion":400,"pos":1,"voice":"vo_char_1031_00_34","textHome":"Wha—?! N-no way, I've never@had anyone confess to me@in the Youth Association...!"}]},{"autoTurnFirst":2.5,"chara":[{"cheek":2,"face":"mtn_ex_030.exp3.json","id":103100,"motion":200,"textHome":"It's not like I have to@answer that at all to begin with,"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":2,"eyeClose":1,"face":"mtn_ex_020.exp3.json","id":103100,"motion":301,"textHome":"and besides, I don't have any@romantic interests anywhere@whatsoever in the first place...!"}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_28":[{"autoTurnFirst":3.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_042.exp3.json","id":103100,"motion":200,"pos":1,"voice":"vo_char_1031_00_35","textHome":"Wait a minute,@your collar's crooked."}]},{"autoTurnFirst":5.1,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":0,"textHome":"I don't like this sort of@slovenliness, you know.@Here;"}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":100,"textHome":"it's much better@to be neat and tidy, see?"}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_29":[{"autoTurnFirst":4.3,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":100,"pos":1,"voice":"vo_char_1031_00_36","textHome":"That's right. Maybe it's precisely@because of having a cool-headed@personality myself..."}]},{"autoTurnFirst":3.6,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103100,"textHome":"...that I, ironically,@seek out things that burn."}]},{"autoTurnFirst":6.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":1,"textHome":"Perhaps that's why I like summer@and the Fire Festival so much."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_3":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":300,"pos":1,"voice":"vo_char_1031_00_03"}]}],"group_30":[{"autoTurnFirst":4.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_37","textHome":"As a matter of fact, I was one of the@people who invented the fighting style of@the Black Feathers and the White Feathers."}]},{"autoTurnFirst":3.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100}]},{"autoTurnFirst":3.3,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":301,"textHome":"Back then, we used to have discussions@about how to unify our fighting styles."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103100}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_31":[{"autoTurnFirst":3.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":100,"pos":1,"voice":"vo_char_1031_00_38","textHome":"By self-confidence,@I mean that I believe in myself,"}]},{"autoTurnFirst":2.9,"chara":[{"eyeClose":1,"id":103100,"textHome":"so whether I grow or not@is also up to myself."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":2.0,"chara":[{"id":103100,"motion":0,"textHome":"The reason I'm so hard on others@is because I've been@whipping myself to change, too."}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":200}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_32":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":100,"pos":1,"voice":"vo_char_1031_00_39","textHome":"Yes, I'm in the Neo-Magius@in order to stand above humans and@have them recognize me as a god."}]},{"autoTurnFirst":3.0,"chara":[{"eyeClose":1,"id":103100}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":7.0,"chara":[{"id":103100,"motion":0,"textHome":"For the sake of@fulfilling my objective,@I'm going to become a living god."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_33":[{"autoTurnFirst":2.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_030.exp3.json","id":103100,"motion":300,"pos":1,"voice":"vo_char_1031_00_40","textHome":"\"Waaah, waaah\"...@I never grew up, still always@whining and whining..."}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103100}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_010.exp3.json","id":103100,"textHome":"But, that's all right."}]},{"autoTurnFirst":0.2,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":0,"textHome":"I'd still like to be a kid,@pampered by someone."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_34":[{"autoTurnFirst":1.5,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_000.exp3.json","id":103100,"motion":400,"pos":1,"voice":"vo_char_1031_00_41","textHome":"Phew..."}]},{"autoTurnFirst":0.4,"chara":[{"eyeClose":0,"id":103100}]},{"autoTurnFirst":3.4,"chara":[{"id":103100,"motion":0,"textHome":"If you can fight me@up to this point,@you're good to go."}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":1,"textHome":"You're on your own now,@and there's nothing more to say."}]},{"autoTurnFirst":7.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103100,"motion":100,"textHome":"Hence, you no longer have to@follow from behind from now on;@walk side-by-side with me."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_35":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_42","textHome":"Here we go, to the summit@Her Highness aims for!"}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_36":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":200,"pos":1,"voice":"vo_char_1031_00_43","textHome":"It's only natural@to remove the hindrances."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_37":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp3.json","id":103100,"motion":0,"pos":1,"voice":"vo_char_1031_00_44","textHome":"Whoever still dares to resist,@step forward."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_38":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":1,"face":"mtn_ex_020.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_45","textHome":"With this, I've moved another@step towards our ideal."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_39":[{"autoTurnFirst":5.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":100,"pos":1,"voice":"vo_char_1031_00_46","textHome":"Now, the summit is near!"}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_4":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_020.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_04"}]},{"autoTurnFirst":5.0,"chara":[{"eyeClose":1,"id":103100}]}],"group_5":[{"autoTurnFirst":3.2,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_021.exp3.json","id":103100,"motion":0,"pos":1,"voice":"vo_char_1031_00_05"}]},{"autoTurnFirst":4.0,"chara":[{"id":103100,"motion":200}]}],"group_6":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_13","textHome":"The results have been superb.@It feels like I am@in control of my powers."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_7":[{"autoTurnFirst":2.5,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":100,"pos":1,"voice":"vo_char_1031_00_14","textHome":"With an endless storm of bullets,"}]},{"autoTurnFirst":4.0,"chara":[{"cheek":0,"face":"mtn_ex_011.exp3.json","id":103100,"textHome":"this shall be a most@magnificent fireworks display."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_8":[{"autoTurnFirst":6.0,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_010.exp3.json","id":103100,"motion":1,"pos":1,"voice":"vo_char_1031_00_15","textHome":"When it comes to the topic of@my hometown, there's so much to@talk about that I could go on and on."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}],"group_9":[{"autoTurnFirst":2.6,"chara":[{"cheek":0,"eyeClose":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":301,"pos":1,"voice":"vo_char_1031_00_16","textHome":"The truth is, I'm an only child;"}]},{"autoTurnFirst":4.5,"chara":[{"cheek":0,"face":"mtn_ex_030.exp3.json","id":103100,"textHome":"one who was, in the past,@once a pampered kid@very shy of people."}]},{"autoTurnFirst":3.2,"chara":[{"cheek":0,"face":"mtn_ex_000.exp3.json","id":103100,"motion":100,"textHome":"When I encountered@the Fire Festival, however,"}]},{"autoTurnFirst":5.0,"chara":[{"cheek":0,"face":"mtn_ex_010.exp3.json","id":103100,"textHome":"I began changing little by little."}]},{"chara":[{"id":103100,"textHomeStatus":"Clear"}]}]},"version":3}
